// FORMATTING FOUNDATION (design 0011/0013 text surface + 0009 interfaces) — the
// language's first value-rendering convention, as a self-contained single-file
// corelib IMAGE (the `corelib_flat.cnr` pattern). It cannot live in the
// backend-swept `corelib/` module tree: it uses the design-0013 `String`
// (a compiler-known CollectionOp) which is MIR-interpreter-only, and the corelib
// tree is compiled by the AOT/LLVM/Stage-D native gates, which exclude
// CollectionOp. The `String` std is therefore single-file, exactly like
// `tests/text.rs`/`vec.rs`/`map.rs`. Runtime observation lives in `tests/fmt.rs`,
// which appends a `main` to these definitions.
//
// This file carries the WHOLE convention, including the generic
// `impl[T: Show] Show for Opt[T]` and `show_it[T: Show]` — those check and RUN
// here (single-file) but do NOT resolve under the module-tree checker (E1002 on
// a bound-method call inside a generic impl, parallel to the corelib `?` finding
// F2), which is the other reason this is a single-file image rather than a tree.

// core/opt (design 0008 §5), inlined: `Opt[T]` with `Some` the `ok`-marked arm.
enum Opt[T] { ok Some(T), None }

// std/alloc + std/bump (design 0008 §5), inlined: a bump allocator over a
// caller-provided window, producing the `copy` `Alloc` handle (design 0001 §6.1).
// The two `unsafe` valves are the standard bump-arena promises (see std/bump.cnr).
struct AllocVtable {
    alloc: fn(ctx: rawptr u8, size: usize, align: usize) alloc -> rawptr u8,
    free: fn(ctx: rawptr u8, ptr: rawptr u8, size: usize, align: usize) alloc -> unit,
    realloc: fn(ctx: rawptr u8, ptr: rawptr u8, old_size: usize, new_size: usize, align: usize) alloc -> rawptr u8,
}
copy struct Alloc { ctx: rawptr u8, vt: rawptr AllocVtable }
struct Bump { next: usize, end: usize }
fn with_window(base: usize, size: usize) -> Bump {
    return Bump { next: base, end: base + size };
}
fn bump_alloc(ctx: rawptr u8, size: usize, align: usize) -> rawptr u8 {
    unsafe "ctx points at the live Bump whose [next, end) window is reserved to this arena alone; the carved block stays inside [next, end)" {
        let b: Bump = ptr_read(cast_ptr[Bump](ctx));
        let aligned: usize = (b.next + align - 1) / align * align;
        if aligned + size > b.end {
            return ptr_null[u8]();
        }
        ptr_write(cast_ptr[Bump](ctx), Bump { next: aligned + size, end: b.end });
        return addr_to_ptr[u8](aligned);
    }
}
fn bump_free(ctx: rawptr u8, ptr: rawptr u8, size: usize, align: usize) -> unit {}
fn bump_realloc(ctx: rawptr u8, ptr: rawptr u8, old_size: usize, new_size: usize, align: usize) -> rawptr u8 {
    unsafe "bump cannot reclaim, so it cannot grow in place: carve a fresh block, copy old_size bytes into it, and release the old block through bump_free (a no-op for a real bump, so the old space is leaked as bump semantics require)" {
        let newp: rawptr u8 = bump_alloc(ctx, new_size, align);
        if is_null(newp) {
            return newp;
        }
        let a: usize = ptr_to_addr(ptr);
        let base: usize = ptr_to_addr(newp);
        let mut i: usize = 0usize;
        while i < old_size {
            let s: rawptr u8 = addr_to_ptr[u8](a + i);
            let d: rawptr u8 = addr_to_ptr[u8](base + i);
            let v: u8 = ptr_read(s);
            ptr_write(d, v);
            i = i + 1usize;
        }
        bump_free(ctx, ptr, old_size, align);
        return newp;
    }
}

static BUMP_VT: AllocVtable = AllocVtable { alloc: bump_alloc, free: bump_free, realloc: bump_realloc };
fn mk_alloc(state: write Bump) -> Alloc {
    unsafe "ctx (the caller's Bump local) and vt (the static BUMP_VT) outlive every copy of this handle and every String it serves" {
        return Alloc { ctx: cast_ptr[u8](addr_of_mut(state.*)), vt: addr_of(BUMP_VT) };
    }
}

// ---- the formatting foundation ---------------------------------------------

// Render a signed 64-bit integer to its decimal `String`. Total over the whole
// range, INCLUDING `i64::MIN`: the digits are produced in the NEGATIVE domain,
// so the whole value is never negated. `i64::MIN` has no positive counterpart
// (negating it overflows, a Candor arithmetic fault), but a non-negative `n` is
// reflected to `0 - n` (safe, since `n >= 0`) and a negative `n` passes through
// unchanged, so the overflow-prone `-i64::MIN` is never formed. For `m <= 0`,
// `m % 10` is in `-9..=0` (division truncates toward zero), so `48 - (m % 10)`
// is the ASCII code of the low digit and `m / 10` carries the rest. Digits are
// emitted low-first into a fixed buffer (an i64 is at most 19 digits), then
// pushed high-to-low, so the built String reads left-to-right with no reversal.
// A fixed buffer, not a `write String` helper: the String primitives operate on
// this function's own owned local `s` (a String reached through a borrow is not
// recognized by the intrinsic dispatch).
fn fmt_i64(a: read Alloc, n: i64) alloc -> String {
    let mut s: String = string_new(a);
    if n < 0 {
        push(write s, 45);
    }
    let mut m: i64 = n;
    if n >= 0 {
        m = 0 - n;
    }
    let mut digits: [20]i64 = [0i64; 20];
    let mut count: usize = 0;
    let mut more: bool = true;
    while more {
        digits[count] = 48 - (m % 10);
        count = count + 1;
        m = m / 10;
        more = m != 0;
    }
    let mut i: usize = count;
    while i > 0 {
        i = i - 1;
        push(write s, digits[i]);
    }
    return s;
}


// Build the powers of ten 10^0 .. 10^40 by repeated multiplication. Each product
// is a single IEEE `f64` multiply, so the table is bit-identical on every engine
// (design 0016) and matches the correctly-rounded decimal literals through 10^22
// (staying within ~1 ULP beyond, which the covered range below tolerates).
fn pow10_table() -> [41]f64 {
    let mut t: [41]f64 = [1.0; 41];
    let mut i: usize = 1;
    while i < 41 { t[i] = t[i - 1] * 10.0; i = i + 1; }
    return t;
}

// Render an `f64` to a decimal `String` — the float analog of `fmt_i64`.
//
// FORMAT (a defined, documented format — NOT shortest-round-trip / Ryū, which
// is deferred):
//   - `NaN` -> "NaN"; `+inf` -> "inf"; `-inf` -> "-inf"; `0.0` and `-0.0` -> "0"
//     (the sign of zero is dropped); finite negatives carry a leading '-'.
//   - Finite non-zero values render in FIXED-POINT decimal (never scientific) with
//     up to 15 significant digits and trailing zeros stripped: `1.5` -> "1.5",
//     `10.0` -> "10", `0.1` -> "0.1", `6.022e23` -> "602200000000000000000000".
//
// ROUND-TRIP GUARANTEE: for every `f64` that is the nearest value to a decimal of
// at most 15 significant digits with magnitude in [1e-15, 1e39), the produced
// string parses back (Rust `f64::from_str`) to the identical `f64` bits. Values
// that need 16–17 significant digits (an unrounded `sqrt(2)`, `0.1 + 0.2`, ...) do
// NOT round-trip: a 17th correct digit requires an integer past `f64`'s exact
// 2^53 range, unreachable with `f64`-only arithmetic (no bitcast / bignum in this
// slice). Magnitudes outside the covered range are best-effort (a scientific-
// notation extension is deferred), never a fault.
//
// ALGORITHM: normalize |x| to a decimal exponent `e` (10^e <= |x| < 10^(e+1)) by
// comparison against the power table, then form the 15-digit significand `m` with
// ONE scaled multiply-or-divide (`|x| * 10^(14-e)` or `|x| / 10^(e-14)`), whose
// result is < 10^15 < 2^53 and so an exact integer after rounding. A digit-by-digit
// float loop is avoided: its repeated `*10` accumulates rounding error, whereas the
// single scaled op holds the error near one ULP — enough for the 15-digit guarantee.
fn fmt_f64(a: read Alloc, x: f64) alloc -> String {
    let mut s: String = string_new(a);
    if x != x { append(write s, "NaN"); return s; }
    let neg: bool = x < 0.0;
    let mut av: f64 = x;
    if neg { av = -x; }
    if av == 0.0 { push(write s, 48); return s; }
    let inf: f64 = 1.0 / 0.0;
    if av == inf {
        if neg { push(write s, 45); }
        append(write s, "inf");
        return s;
    }
    let p: [41]f64 = pow10_table();
    let mut e: i32 = 0;
    if av >= 1.0 {
        let mut hi: i32 = e + 1;
        while e < 38 && p[conv usize (hi)] <= av { e = e + 1; hi = e + 1; }
    } else {
        let mut j: i32 = 0;
        while j < 15 && av * p[conv usize (j)] < 1.0 { j = j + 1; }
        e = 0 - j;
    }
    let mut m0: f64 = 0.0;
    if e >= 14 {
        let lo: i32 = e - 14;
        m0 = av / p[conv usize (lo)];
    } else {
        let hi: i32 = 14 - e;
        m0 = av * p[conv usize (hi)];
    }
    let mut m: i64 = conv i64 (m0 + 0.5);
    if m >= 1000000000000000 { m = m / 10; e = e + 1; }
    while m % 10 == 0 && m != 0 { m = m / 10; }
    // Emit `m`'s decimal digits low-first into a fixed buffer, then place them with
    // the point according to `e` (leading-digit power): trailing integer zeros for
    // e >= k-1, an embedded point for 0 <= e < k-1, else a leading "0.00..".
    let mut digits: [20]i64 = [0i64; 20];
    let mut count: i32 = 0;
    let mut mm: i64 = m;
    let mut more: bool = true;
    while more {
        digits[conv usize (count)] = 48 + mm % 10;
        count = count + 1;
        mm = mm / 10;
        more = mm != 0;
    }
    if neg { push(write s, 45); }
    let k: i32 = count;
    if e >= k - 1 {
        let mut idx: i32 = k;
        while idx > 0 { idx = idx - 1; push(write s, digits[conv usize (idx)]); }
        let mut z: i32 = e - (k - 1);
        while z > 0 { push(write s, 48); z = z - 1; }
    } else {
        if e >= 0 {
            let mut ll: i32 = 0;
            while ll < k {
                if ll == e + 1 { push(write s, 46); }
                let di: i32 = k - 1 - ll;
                push(write s, digits[conv usize (di)]);
                ll = ll + 1;
            }
        } else {
            push(write s, 48); push(write s, 46);
            let mut z: i32 = 0 - e - 1;
            while z > 0 { push(write s, 48); z = z - 1; }
            let mut ll: i32 = 0;
            while ll < k {
                let di: i32 = k - 1 - ll;
                push(write s, digits[conv usize (di)]);
                ll = ll + 1;
            }
        }
    }
    return s;
}

// `Show` is Candor's value-rendering convention — the Display analog. An ordinary
// design-0009 interface: one method rendering the receiver into a freshly-built
// owning `String`. It is `alloc` (building a String allocates) and threads the
// `Alloc` BY VALUE — `Alloc` is a `copy` handle meant to be passed by value,
// which also sidesteps the checker's double-borrow of a `read`-mode interface-
// method parameter. A `T: Show` bound composes it through generics.
interface Show {
    fn to_string(read self, a: Alloc) alloc -> String;
}

// A minimal `Show` witness over an `i64`, delegating to `fmt_i64`.
struct ShowInt { val: i64 }
impl Show for ShowInt {
    fn to_string(read self, a: Alloc) alloc -> String {
        return fmt_i64(read a, self.val);
    }
}


// A `Show` witness over an `f64`, delegating to `fmt_f64` (parallels `ShowInt`).
struct ShowFloat { val: f64 }
impl Show for ShowFloat {
    fn to_string(read self, a: Alloc) alloc -> String {
        return fmt_f64(read a, self.val);
    }
}

// `Show` over `String` itself: render the string's own text into a fresh owning
// String. The built target `s` is this function's own directly-owned local (the
// owned-String build constraint). `self` arrives as a `read` borrow, so the string
// intrinsic needs the underlying String named directly: `self.*` derefs the borrow
// to the `String` place (static type `String`, which `as_str` dispatch recognizes),
// then `read self.*` takes the read view whose bytes are appended.
impl Show for String {
    fn to_string(read self, a: Alloc) alloc -> String {
        let mut s: String = string_new(read a);
        append(write s, as_str(read self.*));
        return s;
    }
}

// `Show` composing THROUGH a generic bound: `Opt[T]` is renderable exactly when
// its payload is (`T: Show`), rendering "Some(<inner>)" / "None". The `Some` arm
// calls `T`'s own `to_string`, proving the convention threads through the bound.
impl[T: Show] Show for Opt[T] {
    fn to_string(read self, a: Alloc) alloc -> String {
        match self {
            Opt::Some(v) => {
                let mut s: String = string_new(read a);
                append(write s, "Some(");
                let inner: String = v.to_string(a);
                append(write s, as_str(read inner));
                append(write s, ")");
                return s;
            },
            Opt::None => {
                let mut s: String = string_new(read a);
                append(write s, "None");
                return s;
            },
        }
    }
}

// A def-site `T: Show` bound: `show_it` renders an opaque `T` through the bound
// (§2.1) — the convention composing at a generic call site, not just an impl.
fn show_it[T: Show](x: read T, a: Alloc) alloc -> String {
    return x.to_string(a);
}
