// Parity fixture (real syntax). Identical run result to point.cn: the only
// difference is the read auto-deref (`p.x` vs `(deref p).x`).
struct Point {
    x: i64,
    y: i64,
}

fn add(p: read Point) -> i64 {
    return p.x + p.y;
}

fn main() -> i64 {
    let pt: Point = Point { x: 40, y: 2 };
    return add(read pt);
}
