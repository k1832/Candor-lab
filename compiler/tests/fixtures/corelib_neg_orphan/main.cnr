// An impl placed in NEITHER the interface's module (`from`) NOR the target's
// module (`errs`) violates the orphan rule at module granularity (E1013).
use core::from::{From};
use core::errs::{IoErr, AppErr};
impl From[IoErr] for AppErr {
    fn from(e: IoErr) -> Self {
        return AppErr::FromIo(e);
    }
}
fn main() -> i64 {
    return 0;
}
