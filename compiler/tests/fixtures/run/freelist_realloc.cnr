// Focused `realloc` gate (ABI 0001 §6.1, realloc landed 2026-07-16): drives the
// free-list `realloc` slot DIRECTLY (no collection) so both physical paths run
// deterministically on every engine — the tree-walking oracle, the MIR
// interpreter, the Cranelift no-opt/opt backends, and (via the tests/fixtures/run
// corpus) the LLVM engine. Path A: a block at the frontier is grown IN PLACE
// (same pointer, bytes preserved). Path B: with the following block occupied,
// realloc MOVES to a fresh block and copies the bytes. Returns 100 iff both
// paths preserve the payload byte-for-byte and pick the expected in-place/move
// pointer; any divergence yields a different sentinel.
// Native `String` (design 0013): `string_new` over a reclaiming free-list
// allocator, `append` byte-views that force `string_reserve` growth across the
// initial capacity, then read back through `as_str` + byte `len`/index. Every
// engine — the tree-walking oracle, the MIR interpreter, and the Cranelift /
// LLVM native backends — must agree byte-for-byte on the traced content and the
// returned byte length (the New / StringAppend / StringAsStr intrinsics lowered
// inline in the backends, mirroring `mir::interp::collection_op`).
struct AllocVtable {
    alloc: fn(ctx: rawptr u8, size: usize, align: usize) alloc -> rawptr u8,
    free: fn(ctx: rawptr u8, ptr: rawptr u8, size: usize, align: usize) alloc -> unit,
    realloc: fn(ctx: rawptr u8, ptr: rawptr u8, old_size: usize, new_size: usize, align: usize) alloc -> rawptr u8,
}
copy struct Alloc { ctx: rawptr u8, vt: rawptr AllocVtable }

struct FreeList { next: usize, end: usize, head: rawptr u8 }
struct FreeBlock { next: rawptr u8, size: usize }

fn with_window(base: usize, size: usize) -> FreeList {
    unsafe "the empty free list starts with a null head; no block is threaded yet" {
        return FreeList { next: base, end: base + size, head: ptr_null[u8]() };
    }
}

fn block_span(size: usize, align: usize) -> usize {
    let mut need: usize = size;
    if need < 16usize {
        need = 16usize;
    }
    return (need + align - 1usize) / align * align;
}

fn freelist_alloc(ctx: rawptr u8, size: usize, align: usize) -> rawptr u8 {
    unsafe "ctx points at the live FreeList whose [next, end) window and address-ordered free chain are reserved to this arena alone; every carved block stays inside [next, end) and is >= header-sized, and a split remainder (kept only when >= MIN_SPLIT) is written into the block's own tail" {
        let st: FreeList = ptr_read(cast_ptr[FreeList](ctx));
        let need: usize = block_span(size, align);
        let mut prev: rawptr u8 = ptr_null[u8]();
        let mut cur: rawptr u8 = st.head;
        while !is_null(cur) {
            let blk: FreeBlock = ptr_read(cast_ptr[FreeBlock](cur));
            if blk.size >= need {
                if blk.size - need >= 32usize {
                    let rem: rawptr u8 = addr_to_ptr[u8](ptr_to_addr(cur) + need);
                    ptr_write(cast_ptr[FreeBlock](rem), FreeBlock { next: blk.next, size: blk.size - need });
                    if is_null(prev) {
                        ptr_write(cast_ptr[FreeList](ctx), FreeList { next: st.next, end: st.end, head: rem });
                    } else {
                        let pblk: FreeBlock = ptr_read(cast_ptr[FreeBlock](prev));
                        ptr_write(cast_ptr[FreeBlock](prev), FreeBlock { next: rem, size: pblk.size });
                    }
                } else {
                    if is_null(prev) {
                        ptr_write(cast_ptr[FreeList](ctx), FreeList { next: st.next, end: st.end, head: blk.next });
                    } else {
                        let pblk: FreeBlock = ptr_read(cast_ptr[FreeBlock](prev));
                        ptr_write(cast_ptr[FreeBlock](prev), FreeBlock { next: blk.next, size: pblk.size });
                    }
                }
                return cur;
            }
            prev = cur;
            cur = blk.next;
        }
        let aligned: usize = (st.next + align - 1usize) / align * align;
        if aligned + need > st.end {
            return ptr_null[u8]();
        }
        ptr_write(cast_ptr[FreeList](ctx), FreeList { next: aligned + need, end: st.end, head: st.head });
        return addr_to_ptr[u8](aligned);
    }
}

fn freelist_free(ctx: rawptr u8, ptr: rawptr u8, size: usize, align: usize) -> unit {
    unsafe "the free list is kept ADDRESS-ORDERED; the freed block's own storage (>= header-sized, guaranteed by block_span in alloc) holds its FreeBlock header {next, size}, and a merge joins two blocks ONLY when their byte spans are exactly adjacent (addr + size == neighbour addr), so a merge can never overlap live memory nor bridge a gap" {
        let st: FreeList = ptr_read(cast_ptr[FreeList](ctx));
        let mut cap: usize = block_span(size, align);
        let a: usize = ptr_to_addr(ptr);
        let mut prev: rawptr u8 = ptr_null[u8]();
        let mut cur: rawptr u8 = st.head;
        while !is_null(cur) && ptr_to_addr(cur) < a {
            let cblk: FreeBlock = ptr_read(cast_ptr[FreeBlock](cur));
            prev = cur;
            cur = cblk.next;
        }
        let mut link: rawptr u8 = cur;
        if !is_null(cur) {
            let nblk: FreeBlock = ptr_read(cast_ptr[FreeBlock](cur));
            if a + cap == ptr_to_addr(cur) {
                cap = cap + nblk.size;
                link = nblk.next;
            }
        }
        if !is_null(prev) {
            let pblk: FreeBlock = ptr_read(cast_ptr[FreeBlock](prev));
            if ptr_to_addr(prev) + pblk.size == a {
                ptr_write(cast_ptr[FreeBlock](prev), FreeBlock { next: link, size: pblk.size + cap });
                return;
            }
        }
        ptr_write(cast_ptr[FreeBlock](ptr), FreeBlock { next: link, size: cap });
        if is_null(prev) {
            ptr_write(cast_ptr[FreeList](ctx), FreeList { next: st.next, end: st.end, head: ptr });
        } else {
            let pblk: FreeBlock = ptr_read(cast_ptr[FreeBlock](prev));
            ptr_write(cast_ptr[FreeBlock](prev), FreeBlock { next: ptr, size: pblk.size });
        }
    }
}

fn freelist_realloc(ctx: rawptr u8, ptr: rawptr u8, old_size: usize, new_size: usize, align: usize) -> rawptr u8 {
    unsafe "ctx points at the live FreeList; [ptr, ptr+old_span) is the block carved for old_size (block_span rounds identically on alloc/free). Growing in place either extends the bump frontier inside [next, end) or absorbs the physically-adjacent free block beginning exactly at ptr+old_span (splitting its tail when the remainder is >= MIN_SPLIT); the fallback carves a fresh block, copies old_size bytes into it, and frees the old block" {
        let old_span: usize = block_span(old_size, align);
        let new_span: usize = block_span(new_size, align);
        if new_span <= old_span {
            return ptr;
        }
        let a: usize = ptr_to_addr(ptr);
        let tail: usize = a + old_span;
        let extra: usize = new_span - old_span;
        let st: FreeList = ptr_read(cast_ptr[FreeList](ctx));
        if tail == st.next {
            if tail + extra <= st.end {
                ptr_write(cast_ptr[FreeList](ctx), FreeList { next: tail + extra, end: st.end, head: st.head });
                return ptr;
            }
        } else {
            let mut prev: rawptr u8 = ptr_null[u8]();
            let mut cur: rawptr u8 = st.head;
            while !is_null(cur) && ptr_to_addr(cur) < tail {
                let cblk: FreeBlock = ptr_read(cast_ptr[FreeBlock](cur));
                prev = cur;
                cur = cblk.next;
            }
            if !is_null(cur) && ptr_to_addr(cur) == tail {
                let fblk: FreeBlock = ptr_read(cast_ptr[FreeBlock](cur));
                if fblk.size >= extra {
                    let mut link: rawptr u8 = fblk.next;
                    if fblk.size - extra >= 32usize {
                        let rem: rawptr u8 = addr_to_ptr[u8](tail + extra);
                        ptr_write(cast_ptr[FreeBlock](rem), FreeBlock { next: fblk.next, size: fblk.size - extra });
                        link = rem;
                    }
                    if is_null(prev) {
                        ptr_write(cast_ptr[FreeList](ctx), FreeList { next: st.next, end: st.end, head: link });
                    } else {
                        let pblk: FreeBlock = ptr_read(cast_ptr[FreeBlock](prev));
                        ptr_write(cast_ptr[FreeBlock](prev), FreeBlock { next: link, size: pblk.size });
                    }
                    return ptr;
                }
            }
        }
        let newp: rawptr u8 = freelist_alloc(ctx, new_size, align);
        if is_null(newp) {
            return newp;
        }
        let mut i: usize = 0usize;
        while i < old_size {
            let s: rawptr u8 = addr_to_ptr[u8](a + i);
            let d: rawptr u8 = addr_to_ptr[u8](ptr_to_addr(newp) + i);
            let v: u8 = ptr_read(s);
            ptr_write(d, v);
            i = i + 1usize;
        }
        freelist_free(ctx, ptr, old_size, align);
        return newp;
    }
}

static FREELIST_VT: AllocVtable = AllocVtable { alloc: freelist_alloc, free: freelist_free, realloc: freelist_realloc };

fn mk_alloc(state: write FreeList) -> Alloc {
    unsafe "ctx (the caller's FreeList local) and vt (the static FREELIST_VT) outlive every String this handle serves; the caller keeps the window and FREELIST_VT alive for the whole run and drops every String before the window dies" {
        return Alloc { ctx: cast_ptr[u8](addr_of_mut(state.*)), vt: addr_of(FREELIST_VT) };
    }
}

fn freelist_ctx(state: write FreeList) -> rawptr u8 {
    unsafe "ctx aliases the live FreeList local for the whole run" {
        return cast_ptr[u8](addr_of_mut(state.*));
    }
}

fn write_pattern(p: rawptr u8, n: usize) -> unit {
    unsafe "p points at a live block of at least n bytes carved from this arena" {
        let mut i: usize = 0usize;
        while i < n {
            let b: rawptr u8 = addr_to_ptr[u8](ptr_to_addr(p) + i);
            ptr_write(b, conv u8 (i % 251usize));
            i = i + 1usize;
        }
    }
}

fn check_pattern(p: rawptr u8, n: usize) -> bool {
    unsafe "p points at a live block of at least n bytes carved from this arena" {
        let mut i: usize = 0usize;
        while i < n {
            let b: rawptr u8 = addr_to_ptr[u8](ptr_to_addr(p) + i);
            let v: u8 = ptr_read(b);
            if conv usize v != i % 251usize {
                return false;
            }
            i = i + 1usize;
        }
        return true;
    }
}

fn same_ptr(a: rawptr u8, b: rawptr u8) -> bool {
    unsafe "comparing two rawptr addresses carved from this arena is a read-only check" {
        return ptr_to_addr(a) == ptr_to_addr(b);
    }
}

fn main() alloc -> i64 {
    let mut st: FreeList = with_window(16777216usize, 1048576usize);
    let ctx: rawptr u8 = freelist_ctx(write st);

    // Path A: p1 sits at the bump frontier, so growing it extends in place.
    let p1: rawptr u8 = freelist_alloc(ctx, 64usize, 1usize);
    write_pattern(p1, 64usize);
    let g1: rawptr u8 = freelist_realloc(ctx, p1, 64usize, 128usize, 1usize);
    let a_in_place: bool = same_ptr(g1, p1);
    let a_kept: bool = check_pattern(g1, 64usize);

    // Fill the whole extended block so the move below copies only written bytes.
    write_pattern(g1, 128usize);

    // Occupy the block physically following g1, then grow again: must MOVE + copy.
    let q: rawptr u8 = freelist_alloc(ctx, 64usize, 1usize);
    let g2: rawptr u8 = freelist_realloc(ctx, g1, 128usize, 256usize, 1usize);
    let b_moved: bool = !same_ptr(g2, g1);
    let b_kept: bool = check_pattern(g2, 128usize);
    let q_here: bool = !same_ptr(q, g2);

    if a_in_place {
        if a_kept {
            if b_moved {
                if b_kept {
                    if q_here {
                        return 100;
                    }
                }
            }
        }
    }
    return 1;
}
