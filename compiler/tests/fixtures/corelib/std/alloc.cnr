// std layer (design 0008 §5): allocator-explicit. This module defines the
// allocator *handle* — a `copy` vtable value (design 0001 §6.1). DEFINING the
// handle carries no `alloc` effect; only *using* `box`/`free` through it does,
// which is why the handle types live in `std`, not `core`.
pub struct AllocVtable {
    alloc: fn(ctx: rawptr u8, size: usize, align: usize) alloc -> rawptr u8,
    free: fn(ctx: rawptr u8, ptr: rawptr u8, size: usize, align: usize) alloc -> unit,
    realloc: fn(ctx: rawptr u8, ptr: rawptr u8, old_size: usize, new_size: usize, align: usize) alloc -> rawptr u8,
}
// `copy`: an `Alloc` is a handle — freely passed by value, stored in a `Box`,
// and copied without a valve; its `rawptr` fields are inert in safe code (§4.2).
pub copy struct Alloc {
    ctx: rawptr u8,
    vt: rawptr AllocVtable,
}
