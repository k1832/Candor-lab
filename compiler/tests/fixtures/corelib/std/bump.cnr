// std layer: a bump allocator over a caller-provided address window, producing
// the `std::alloc` handle. Ported from the Bet-5 parser infrastructure (design
// 0001 §11.4 shape) to real syntax + modules. Its two `unsafe` valves are the
// ONLY valves in the seed; everything above them is value + borrow gear, and
// each valve's justification is a true liveness/aliasing promise the checker
// cannot verify (design 0001 §6.1).
use std::alloc::{Alloc, AllocVtable};

pub struct Bump {
    next: usize,
    end: usize,
}

// the caller reserves the backing window `[base, base + size)` — a region of the
// flat address space handed to this arena alone.
pub fn with_window(base: usize, size: usize) -> Bump {
    return Bump { next: base, end: base + size };
}

fn bump_alloc(ctx: rawptr u8, size: usize, align: usize) -> rawptr u8 {
    unsafe "ctx points at the live Bump whose [next, end) window is reserved to this arena alone (no other code hands out addresses from it); the carved block stays inside [next, end)" {
        let b: Bump = ptr_read(cast_ptr[Bump](ctx));
        let aligned: usize = (b.next + align - 1) / align * align;
        if aligned + size > b.end {
            return ptr_null[u8]();
        }
        ptr_write(cast_ptr[Bump](ctx), Bump { next: aligned + size, end: b.end });
        return addr_to_ptr[u8](aligned);
    }
}

// a bump arena never frees an individual block; it dies with its window.
fn bump_free(ctx: rawptr u8, ptr: rawptr u8, size: usize, align: usize) -> unit {}

fn bump_realloc(ctx: rawptr u8, ptr: rawptr u8, old_size: usize, new_size: usize, align: usize) -> rawptr u8 {
    unsafe "bump cannot reclaim, so it cannot grow in place: carve a fresh block, copy old_size bytes into it, and release the old block through bump_free (a no-op for a real bump, so the old space is leaked as bump semantics require)" {
        let newp: rawptr u8 = bump_alloc(ctx, new_size, align);
        if is_null(newp) {
            return newp;
        }
        let a: usize = ptr_to_addr(ptr);
        let base: usize = ptr_to_addr(newp);
        let mut i: usize = 0usize;
        while i < old_size {
            let s: rawptr u8 = addr_to_ptr[u8](a + i);
            let d: rawptr u8 = addr_to_ptr[u8](base + i);
            let v: u8 = ptr_read(s);
            ptr_write(d, v);
            i = i + 1usize;
        }
        bump_free(ctx, ptr, old_size, align);
        return newp;
    }
}

static BUMP_VT: AllocVtable = AllocVtable { alloc: bump_alloc, free: bump_free, realloc: bump_realloc };

pub fn mk_alloc(state: write Bump) -> Alloc {
    unsafe "ctx (the caller's Bump local) and vt (the static BUMP_VT) outlive every copy of this handle and every Box it serves: the caller guarantees the window and BUMP_VT live for the whole run, and every Box is dropped before the window dies" {
        return Alloc { ctx: cast_ptr[u8](addr_of_mut(state.*)), vt: addr_of(BUMP_VT) };
    }
}
