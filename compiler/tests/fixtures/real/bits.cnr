// Golden (real syntax): bitwise ops, shifts, `~`, the negative-literal fold
// (i64::MIN), and constant `conv` (design 0006 §2.4; spec 01/02).
fn main() -> i64 {
    let a: i64 = 240;
    let b: i64 = 15;
    let orv: i64 = a | b;
    let andv: i64 = a & b;
    let xorv: i64 = a ^ b;
    let shl: i64 = 1 << 8;
    let shr: i64 = shl >> 4;
    let notv: i64 = ~0i64;
    let mn: i64 = -9223372036854775808i64;
    let recovered: i64 = mn + 9223372036854775807i64 + 1;
    let byte: u8 = conv u8 andv;
    let back: i64 = conv i64 byte;
    return orv + andv + xorv + shl + shr + notv + recovered + back;
}
