// The FIRST Candor native code generator (N1): a Candor program that walks the
// parser's AST arena and EMITS x86-64 assembly TEXT (AT&T syntax) for the scalar
// subset, so the system assembler+linker (`cc`) turns it into a real ELF process
// that reproduces the tree-walking oracle byte-exact (θ + exit byte + fault JSON).
// Gated in tests/selfhost_codegen.rs.
//
// It ports the same scalar subset as selfhost/lower/lower.cnr (integer/bool
// scalars; let/assign; if/else; while; loop + break/continue; return; arithmetic
// + - * / % with the Checked/Wrapping regimes and the Overflow/DivByZero fault
// edges; comparisons; && / || short-circuit; bitwise/shift; unary neg/not/bitnot;
// trace(x); assert/panic; direct non-generic scalar fn calls + recursion; conv
// with the ConvLoss edge) but lowers directly to machine instructions rather than
// MIR. It mirrors lower.cnr's AST walk and its fault-span/`cur` threading exactly,
// so the delivered (kind, span) matches the oracle.
//
// MODEL: all-on-stack, NO register allocator. Every local and every temp gets an
// 8-byte stack slot holding the CANONICAL i64 value (sign/zero-extended per the
// scalar type, as load_scalar produces). Values evaluate into %rax, spilling to /
// reloading from slots. SysV frame per fn (push rbp; mov rsp,rbp; sub frame,rsp);
// rsp never moves after the prologue, so every `call` sees a 16-byte-aligned rsp.
// The frame size is known only after the body is walked, so the body is buffered
// in a byte pool and flushed after the prologue is streamed.
//
// This module is composed with the `lexer` and `parser` modules. Like lower.cnr it
// is NOT self-checked in this slice, so it uses the full language.

use lexer::{Buf, span_eq, decoded_len};
use parser::{Node, P, nnew, parse_program, T_FN, T_PARAM, T_LET, T_ASSIGN, T_INT, T_NEGINT, T_BOOL, T_ID, T_UNARY, T_BIN, T_CALL, T_BLOCK, T_IF, T_LOOP, T_WHILE, T_RETURN, T_BREAK, T_CONTINUE, T_ASSERT, T_PANIC, T_PAREN, T_CONV, T_UNSAFE, T_WRAPPING, T_SATURATING, T_NAMED, T_SC, OP_ADD, OP_SUB, OP_MUL, OP_DIV, OP_REM, OP_EQ, OP_NE, OP_LT, OP_LE, OP_GT, OP_GE, OP_AND, OP_OR, OP_BITAND, OP_BITOR, OP_BITXOR, OP_SHL, OP_SHR, UN_NEG, UN_NOT, UN_BITNOT, T_FIELD, T_INDEX, T_STRUCTLIT, T_ARRAYLIT, T_ARRAYREP, T_FINIT, T_STRUCT, T_ENUMCTOR, T_MATCH, T_PVARIANT, T_WILD, T_BIND, T_STATIC, T_RAWPTR, T_FNPTR, T_FPPARAM, T_BOX, T_BOXRESULT, T_PREFIX, PF_DEREF, PF_READ, PF_WRITE, T_OFFSETOF, T_CASTPTR, T_ADDRTOPTR, T_PTRNULL, T_ENUM, T_VARIANT, T_BORROW, T_BORROWMUT, T_SLICE, T_SLICEMUT, T_BYTES, T_ARRAY, T_STR, T_IMPL, T_GENERICVAL, T_TRY};
use layout::{ty_size, ty_align, struct_size, struct_align, field_off, field_off_lit, field_ty, struct_of_ty, array_len_of, needs_drop, is_copy, enum_size, enum_of_ty, variant_by_index, variant_index_by_name, variant_payload_off, variant_payload_ty};
use mono::{mono_program};

// rt_fault kind codes (src/backend/lower.rs kind_code / aot_runtime.c kind_name).
static FK_OVERFLOW: i32 = 0;
static FK_DIVZERO: i32 = 1;
static FK_CONVLOSS: i32 = 3;
static FK_ASSERT: i32 = 4;
static FK_PANIC: i32 = 7;
static W_BOOL: i32 = 11;
static W_AGG: i32 = 30;
static W_USIZE: i32 = 10;
static FK_BOUNDS: i32 = 2;
static MEM_BASE: u64 = 35184372088832u64;

struct C {
    head: u32,
    bbuf: [1048576]u8,
    bbuf_n: usize,
    bnd_p0: [1024]usize,
    bnd_p1: [1024]usize,
    bnd_slot: [1024]i32,
    bnd_w: [1024]i32,
    bnd_ty: [1024]u32,
    bnd_n: usize,
    slot_next: usize,
    slot_max: usize,
    loop_cont: [64]i32,
    loop_brk: [64]i32,
    loop_n: usize,
    lbl: i32,
    ret_w: i32,
    ret_ty: u32,
    regime: i32,
    cur_p0: usize,
    cur_p1: usize,
    cur_agg_ty: u32,
    luk_slot: i32,
    luk_w: i32,
    luk_ty: u32,
    luk_locid: i32,
    dloc_slot: [256]i32,
    dloc_ty: [256]u32,
    dloc_n: usize,
    sco_local: [256]i32,
    sco_mark: [64]usize,
    sco_depth: usize,
    sco_n: usize,
    mv_local: [256]i32,
    mv_seg_start: [256]usize,
    mv_seg_count: [256]usize,
    mv_seg_p0: [512]usize,
    mv_seg_p1: [512]usize,
    mv_seg_syn: [512]i32,
    mv_seg_n: usize,
    mv_n: usize,
    loop_depth: [64]usize,
    bnd_locid: [1024]i32,
    st_p0: [64]usize,
    st_p1: [64]usize,
    st_ty: [64]u32,
    st_val: [64]u32,
    st_n: usize,
    alloc_sid: u32,
    alloc_vt_sid: u32,
    at_p0: [64]usize,
    at_p1: [64]usize,
    at_n: usize,
    bnd_flat: [1024]i32,
    luk_flat: i32,
    mat_scrut: [64]u32,
    mat_tn: [64]u32,
    mat_hold: [64]i32,
    mat_n: usize,
    glue_eid: [128]u32,
    glue_n: usize,
    disp_sid: [128]u32,
    disp_p0: [128]usize,
    disp_p1: [128]usize,
    disp_fn: [128]u32,
    disp_n: usize,
    err: i32,
}

// ---- byte-pool emit (function body) -----------------------------------------
fn bc(c: write C, x: i32) -> unit {
    c.*.bbuf[c.bbuf_n] = conv u8 x;
    c.*.bbuf_n = c.bbuf_n + 1usize;
    return;
}
fn bs(c: write C, s: [u8]) -> unit {
    let mut i: usize = 0usize;
    while i < len(s) {
        bc(c, conv i32 s[i]);
        i = i + 1usize;
    }
    return;
}
fn bn(c: write C, v: u64) -> unit {
    if v == 0u64 { bc(c, 48); return; }
    let mut b: [24]u8 = [0u8; 24];
    let mut cnt: usize = 0usize;
    let mut x: u64 = v;
    while x > 0u64 {
        b[cnt] = conv u8 (48u64 + x % 10u64);
        x = x / 10u64;
        cnt = cnt + 1usize;
    }
    let mut i: usize = cnt;
    while i > 0usize {
        i = i - 1usize;
        bc(c, conv i32 b[i]);
    }
    return;
}
// A whole instruction line: tab + text + newline.
fn bi(c: write C, s: [u8]) -> unit {
    bc(c, 9);
    bs(c, s);
    bc(c, 10);
    return;
}
// The `-off(%rbp)` operand for slot `s` (slot 0 at -8, slot 1 at -16, ...).
fn bslot(c: write C, s: i32) -> unit {
    let off: usize = 8usize * (conv usize s + 1usize);
    bc(c, 45);
    bn(c, conv u64 off);
    bs(c, b"(%rbp)");
    return;
}
// A generated `.Lc<n>` label reference (no leading tab).
fn blabel_ref(c: write C, n: i32) -> unit {
    bs(c, b".Lc");
    bn(c, conv u64 n);
    return;
}
fn blabel_def(c: write C, n: i32) -> unit {
    blabel_ref(c, n);
    bc(c, 58);
    bc(c, 10);
    return;
}
fn newlbl(c: write C) -> i32 {
    let n: i32 = c.lbl;
    c.*.lbl = n + 1;
    return n;
}
fn newslot(c: write C) -> i32 {
    let s: usize = c.slot_next;
    c.*.slot_next = s + 1usize;
    if c.slot_next > c.slot_max { c.*.slot_max = c.slot_next; }
    return conv i32 s;
}
// Spill %rax into a fresh temp slot; return the slot.
fn spill(c: write C) -> i32 {
    let s: i32 = newslot(c);
    bc(c, 9);
    bs(c, b"movq %rax, ");
    bslot(c, s);
    bc(c, 10);
    return s;
}
fn reload_rax(c: write C, s: i32) -> unit {
    bc(c, 9);
    bs(c, b"movq ");
    bslot(c, s);
    bs(c, b", %rax");
    bc(c, 10);
    return;
}
fn store_slot(c: write C, s: i32) -> unit {
    bc(c, 9);
    bs(c, b"movq %rax, ");
    bslot(c, s);
    bc(c, 10);
    return;
}

// ---- widths (mirror lower.cnr) ----------------------------------------------
fn sc_width(src: [u8], s: usize, en: usize) -> i32 {
    if span_eq(src, s, en, b"i8") { return 1; }
    if span_eq(src, s, en, b"i16") { return 2; }
    if span_eq(src, s, en, b"i32") { return 3; }
    if span_eq(src, s, en, b"i64") { return 4; }
    if span_eq(src, s, en, b"isize") { return 5; }
    if span_eq(src, s, en, b"u8") { return 6; }
    if span_eq(src, s, en, b"u16") { return 7; }
    if span_eq(src, s, en, b"u32") { return 8; }
    if span_eq(src, s, en, b"u64") { return 9; }
    if span_eq(src, s, en, b"usize") { return 10; }
    if span_eq(src, s, en, b"bool") { return W_BOOL; }
    if span_eq(src, s, en, b"unit") { return 12; }
    return 0;
}
fn scalar_width(pp: read P, src: [u8], tn: u32) -> i32 {
    if tn == 0u32 { return 0; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_NAMED || nd.tag == T_SC { return sc_width(src, nd.p0, nd.p1); }
    if nd.tag == T_RAWPTR || nd.tag == T_FNPTR { return W_USIZE; }
    if nd.tag == T_BORROW || nd.tag == T_BORROWMUT { return W_USIZE; }
    return 0;
}
fn lit_width(suf: i32, exp_w: i32) -> i32 {
    if suf != 0 { return suf; }
    if exp_w >= 1 && exp_w <= 10 { return exp_w; }
    return 4;
}
fn concretize(w: i32) -> i32 {
    if w >= 1 && w <= 10 { return w; }
    if w == W_BOOL { return W_BOOL; }
    return 4;
}
fn signedw(w: i32) -> i32 {
    if w >= 1 && w <= 5 { return 1; }
    return 0;
}
fn bits_of(w: i32) -> i32 {
    if w == 1 || w == 6 || w == W_BOOL { return 8; }
    if w == 2 || w == 7 { return 16; }
    if w == 3 || w == 8 { return 32; }
    return 64;
}
// The unsigned max of a non-64-bit width (as a u64 movabs immediate).
fn umax_of(w: i32) -> u64 {
    let b: i32 = bits_of(w);
    if b == 8 { return 255u64; }
    if b == 16 { return 65535u64; }
    return 4294967295u64;
}
// The signed [min,max] of a non-64-bit width fit in imm32.
fn smax_of(w: i32) -> i64 {
    let b: i32 = bits_of(w);
    if b == 8 { return 127i64; }
    if b == 16 { return 32767i64; }
    return 2147483647i64;
}
fn smin_of(w: i32) -> i64 {
    let b: i32 = bits_of(w);
    if b == 8 { return 0i64 - 128i64; }
    if b == 16 { return 0i64 - 32768i64; }
    return 0i64 - 2147483648i64;
}

// ---- bindings (innermost-first, block-scoped by bnd_n save/restore) ----------
fn bind(c: write C, p0: usize, p1: usize, s: i32, w: i32, ty: u32, locid: i32, flat: i32) -> unit {
    let k: usize = c.bnd_n;
    c.*.bnd_p0[k] = p0;
    c.*.bnd_p1[k] = p1;
    c.*.bnd_slot[k] = s;
    c.*.bnd_w[k] = w;
    c.*.bnd_ty[k] = ty;
    c.*.bnd_locid[k] = locid;
    c.*.bnd_flat[k] = flat;
    c.*.bnd_n = k + 1usize;
    return;
}
fn name_eq(src: [u8], a0: usize, a1: usize, b0: usize, b1: usize) -> bool {
    if a1 - a0 != b1 - b0 { return false; }
    let n: usize = a1 - a0;
    let mut i: usize = 0usize;
    while i < n {
        if src[a0 + i] != src[b0 + i] { return false; }
        i = i + 1usize;
    }
    return true;
}
// Returns the slot or -1; sets luk_w.
fn lookup(c: write C, src: [u8], p0: usize, p1: usize) -> i32 {
    let mut i: usize = c.bnd_n;
    while i > 0usize {
        i = i - 1usize;
        if name_eq(src, p0, p1, c.bnd_p0[i], c.bnd_p1[i]) {
            c.*.luk_w = c.bnd_w[i];
            c.*.luk_slot = c.bnd_slot[i];
            c.*.luk_ty = c.bnd_ty[i];
            c.*.luk_locid = c.bnd_locid[i];
            c.*.luk_flat = c.bnd_flat[i];
            return c.bnd_slot[i];
        }
    }
    return 0i32 - 1i32;
}
fn find_fn(pp: read P, src: [u8], head: u32, p0: usize, p1: usize) -> u32 {
    let mut cur: u32 = head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_FN && name_eq(src, p0, p1, nd.p0, nd.p1) { return cur; }
        cur = nd.nx;
    }
    return 0u32;
}


// ---- drop schedule: scopes, move mask, drop emission (mirrors lower.cnr L3) ----
// Drop-scopes record the owned needs-drop locals bound in them (declaration order);
// scope exit / return / loop-exit drop them in REVERSE, pruned by the move mask.
fn scope_push(c: write C) -> unit {
    c.*.sco_mark[c.sco_depth] = c.sco_n;
    c.*.sco_depth = c.sco_depth + 1usize;
    return;
}
fn scope_add(c: write C, id: i32) -> unit {
    c.*.sco_local[c.sco_n] = id;
    c.*.sco_n = c.sco_n + 1usize;
    return;
}
// Register an owned drop-local (its slot holds the value's flat offset) and add it
// to the current scope; returns its id (also stored in the binding for move lookup).
fn reg_dloc(c: write C, slot: i32, ty: u32) -> i32 {
    let id: i32 = conv i32 c.dloc_n;
    c.*.dloc_slot[c.dloc_n] = slot;
    c.*.dloc_ty[c.dloc_n] = ty;
    c.*.dloc_n = c.dloc_n + 1usize;
    scope_add(c, id);
    return id;
}
fn whole_moved(c: write C, id: i32) -> bool {
    let mut k: usize = 0usize;
    while k < c.mv_n {
        if c.mv_local[k] == id && c.mv_seg_count[k] == 0usize { return true; }
        k = k + 1usize;
    }
    return false;
}
fn field_moved(c: write C, src: [u8], id: i32, fp0: usize, fp1: usize) -> bool {
    let mut k: usize = 0usize;
    while k < c.mv_n {
        if c.mv_local[k] == id && c.mv_seg_count[k] == 1usize {
            let sg: usize = c.mv_seg_start[k];
            if c.mv_seg_syn[sg] < 0 && name_eq(src, c.mv_seg_p0[sg], c.mv_seg_p1[sg], fp0, fp1) { return true; }
        }
        k = k + 1usize;
    }
    return false;
}
// Whether a one-level enum-payload sub-path (`<local>._idx`) is marked moved. The
// dual of field_moved for the index-named payload segments a consuming match records.
fn payload_moved(c: write C, id: i32, idx: i32) -> bool {
    let mut k: usize = 0usize;
    while k < c.mv_n {
        if c.mv_local[k] == id && c.mv_seg_count[k] == 1usize {
            let sg: usize = c.mv_seg_start[k];
            if c.mv_seg_syn[sg] == idx { return true; }
        }
        k = k + 1usize;
    }
    return false;
}
// Record the scrutinee's payload sub-path `<scrut>._idx` moved (an owned-match move-
// bind), so the scrutinee's tag-directed enum drop prunes that field (mirrors
// lower.cnr mark_moved_payload).
fn mark_moved_payload(c: write C, pp: read P, src: [u8], scrut: u32, idx: i32) -> unit {
    let seg_start: usize = c.mv_seg_n;
    let root: i32 = collect_path(c, pp, src, scrut);
    if root < 0 { c.*.mv_seg_n = seg_start; return; }
    let sg: usize = c.mv_seg_n;
    c.*.mv_seg_p0[sg] = 0usize;
    c.*.mv_seg_p1[sg] = 0usize;
    c.*.mv_seg_syn[sg] = idx;
    c.*.mv_seg_n = sg + 1usize;
    let k: usize = c.mv_n;
    c.*.mv_local[k] = root;
    c.*.mv_seg_start[k] = seg_start;
    c.*.mv_seg_count[k] = c.mv_seg_n - seg_start;
    c.*.mv_n = k + 1usize;
    return;
}
// The (owned-local id, one-level field path) a place names, appending segments to
// the seg pool; -1 for a non-trackable operand (temp, literal, index, call result).
fn collect_path(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_PAREN { return collect_path(c, pp, src, nd.a); }
    if nd.tag == T_ID {
        let sl: i32 = lookup(c, src, nd.p0, nd.p1);
        if sl < 0 { return 0i32 - 1i32; }
        return c.luk_locid;
    }
    if nd.tag == T_FIELD {
        let root: i32 = collect_path(c, pp, src, nd.a);
        if root < 0 { return 0i32 - 1i32; }
        let sg: usize = c.mv_seg_n;
        c.*.mv_seg_p0[sg] = nd.p0;
        c.*.mv_seg_p1[sg] = nd.p1;
        c.*.mv_seg_syn[sg] = 0i32 - 1i32;
        c.*.mv_seg_n = sg + 1usize;
        return root;
    }
    return 0i32 - 1i32;
}
// Record `i` as moved out (a non-copy by-value consume) so its drop is pruned.
fn mark_moved(c: write C, pp: read P, src: [u8], i: u32) -> unit {
    let seg_start: usize = c.mv_seg_n;
    let root: i32 = collect_path(c, pp, src, i);
    if root < 0 { c.*.mv_seg_n = seg_start; return; }
    let k: usize = c.mv_n;
    c.*.mv_local[k] = root;
    c.*.mv_seg_start[k] = seg_start;
    c.*.mv_seg_count[k] = c.mv_seg_n - seg_start;
    c.*.mv_n = k + 1usize;
    return;
}
// Call a struct's drop hook `cnr_drophk_<Name>[.<sid>]` with the value's flat offset
// (its self address) in %rdi. A generic struct instance (ival != 0) gets a `.sid`
// suffix so distinct instances of one generic struct do not collide on one symbol.
fn drop_hook_call(c: write C, pp: read P, src: [u8], sid: u32, off_slot: i32) -> unit {
    bc(c, 9); bs(c, b"movq "); bslot(c, off_slot); bs(c, b", %rdi"); bc(c, 10);
    bc(c, 9); bs(c, b"call cnr_drophk_");
    let snode: Node = pp.nodes[conv usize sid];
    let mut j: usize = snode.p0;
    while j < snode.p1 { bc(c, conv i32 src[j]); j = j + 1usize; }
    if snode.ival != 0u64 { bc(c, 46); bn(c, conv u64 sid); }
    bc(c, 10);
    return;
}
// Drop the value at flat offset `off_slot` of type `ty`: run its struct drop hook
// first (whole value), then drop its needs-drop fields in REVERSE. `locid` (>=0 only
// at the root value) enables the one-level partial-move field skip.
fn emit_drop_at(c: write C, pp: read P, src: [u8], off_slot: i32, ty: u32, locid: i32) -> unit {
    let tnode0: Node = pp.nodes[conv usize ty];
    if tnode0.tag == T_BOX { drop_box(c, pp, src, off_slot, tnode0.a); return; }
    let sid: u32 = struct_of_ty(pp, src, c.head, ty);
    if sid == 0u32 {
        let eid: u32 = enum_of_ty(pp, src, c.head, ty);
        if eid != 0u32 {
            // A root value carries partial-move info -> inline its tag-directed drop; a
            // nested value (locid < 0, incl. Box pointees) routes through a per-enum drop-
            // glue fn, so a self-referential enum (e.g. `Box Expr` inside `Expr`) recurses
            // at RUNTIME via a `call` rather than expanding forever at codegen time.
            if locid >= 0 {
                emit_enum_drop(c, pp, src, off_slot, eid, locid);
            } else {
                emit_enum_drop_call(c, off_slot, eid);
            }
        }
        return;
    }
    let snode: Node = pp.nodes[conv usize sid];
    if snode.c != 0u32 {
        drop_hook_call(c, pp, src, sid, off_slot);
    }
    let mut fp0s: [32]usize = [0usize; 32];
    let mut fp1s: [32]usize = [0usize; 32];
    let mut ftys: [32]u32 = [0u32; 32];
    let mut nf: usize = 0usize;
    let mut fcur: u32 = snode.b;
    while fcur != 0u32 {
        let fd: Node = pp.nodes[conv usize fcur];
        fp0s[nf] = fd.p0;
        fp1s[nf] = fd.p1;
        ftys[nf] = fd.a;
        nf = nf + 1usize;
        fcur = fd.nx;
    }
    let mut idx: usize = nf;
    while idx > 0usize {
        idx = idx - 1usize;
        let fty: u32 = ftys[idx];
        let mut skip: bool = false;
        if locid >= 0 && field_moved(c, src, locid, fp0s[idx], fp1s[idx]) { skip = true; }
        if !skip && needs_drop(pp, src, c.head, fty) {
            let off: usize = field_off(pp, src, c.head, sid, fp0s[idx], fp1s[idx]);
            reload_rax(c, off_slot);
            if off != 0usize {
                bc(c, 9); bs(c, b"addq $"); bn(c, conv u64 off); bs(c, b", %rax"); bc(c, 10);
            }
            let fslot: i32 = spill(c);
            emit_drop_at(c, pp, src, fslot, fty, 0i32 - 1i32);
        }
    }
    return;
}
// Register (dedup) `eid` for drop-glue emission, and emit a call to its glue fn with the
// value's flat offset in %rdi.
fn emit_enum_drop_call(c: write C, off_slot: i32, eid: u32) -> unit {
    let mut k: usize = 0usize;
    let mut found: bool = false;
    while k < c.glue_n {
        if c.glue_eid[k] == eid { found = true; }
        k = k + 1usize;
    }
    if !found {
        let g: usize = c.glue_n;
        c.*.glue_eid[g] = eid;
        c.*.glue_n = g + 1usize;
    }
    bc(c, 9); bs(c, b"movq "); bslot(c, off_slot); bs(c, b", %rdi"); bc(c, 10);
    bc(c, 9); bs(c, b"call cnr_dropenum_"); bn(c, conv u64 eid); bc(c, 10);
    return;
}
// Tag-directed enum drop: read the tag@0, then a runtime switch that, for the active
// variant, drops its needs-drop payload fields in REVERSE, skipping any field a
// consuming match marked moved. Enums carry no drop hook (mirrors interp drop_variant_rev).
fn emit_enum_drop(c: write C, pp: read P, src: [u8], off_slot: i32, eid: u32, locid: i32) -> unit {
    reload_rax(c, off_slot);
    emit_load_flat(c, 9);
    let tag_slot: i32 = spill(c);
    let done: i32 = newlbl(c);
    let enode: Node = pp.nodes[conv usize eid];
    let mut vc: u32 = enode.b;
    let mut vidx: i32 = 0;
    while vc != 0u32 {
        let vd: Node = pp.nodes[conv usize vc];
        let mut nf: i32 = 0;
        let mut fcur: u32 = vd.a;
        while fcur != 0u32 { nf = nf + 1i32; fcur = pp.nodes[conv usize fcur].nx; }
        let mut anydrop: bool = false;
        let mut ck: i32 = 0;
        while ck < nf {
            let fty: u32 = variant_payload_ty(pp, vc, ck);
            let mut skip: bool = false;
            if locid >= 0 && payload_moved(c, locid, ck) { skip = true; }
            if !skip && needs_drop(pp, src, c.head, fty) { anydrop = true; }
            ck = ck + 1i32;
        }
        if anydrop {
            let nextl: i32 = newlbl(c);
            reload_rax(c, tag_slot);
            bc(c, 9); bs(c, b"cmpq $"); bn(c, conv u64 vidx); bs(c, b", %rax"); bc(c, 10);
            bc(c, 9); bs(c, b"jne "); blabel_ref(c, nextl); bc(c, 10);
            let mut idx: i32 = nf;
            while idx > 0i32 {
                idx = idx - 1i32;
                let fty2: u32 = variant_payload_ty(pp, vc, idx);
                let mut skip2: bool = false;
                if locid >= 0 && payload_moved(c, locid, idx) { skip2 = true; }
                if !skip2 && needs_drop(pp, src, c.head, fty2) {
                    let off: usize = variant_payload_off(pp, src, c.head, vc, idx);
                    reload_rax(c, off_slot);
                    if off != 0usize {
                        bc(c, 9); bs(c, b"addq $"); bn(c, conv u64 off); bs(c, b", %rax"); bc(c, 10);
                    }
                    let fslot: i32 = spill(c);
                    emit_drop_at(c, pp, src, fslot, fty2, 0i32 - 1i32);
                }
            }
            bc(c, 9); bs(c, b"jmp "); blabel_ref(c, done); bc(c, 10);
            blabel_def(c, nextl);
        }
        vidx = vidx + 1i32;
        vc = vd.nx;
    }
    blabel_def(c, done);
    return;
}
fn emit_drop_local(c: write C, pp: read P, src: [u8], id: i32) -> unit {
    if whole_moved(c, id) { return; }
    let slot: i32 = c.dloc_slot[conv usize id];
    let ty: u32 = c.dloc_ty[conv usize id];
    emit_drop_at(c, pp, src, slot, ty, id);
    return;
}
// Scope exit: drop this scope's owned locals in reverse declaration order.
fn scope_pop_drops(c: write C, pp: read P, src: [u8]) -> unit {
    c.*.sco_depth = c.sco_depth - 1usize;
    let start: usize = c.sco_mark[c.sco_depth];
    let mut i: usize = c.sco_n;
    while i > start {
        i = i - 1usize;
        emit_drop_local(c, pp, src, c.sco_local[i]);
    }
    c.*.sco_n = start;
    return;
}
// return: drop every live scope's locals innermost-first (no scope pop).
fn emit_return_drops(c: write C, pp: read P, src: [u8]) -> unit {
    let mut i: usize = c.sco_n;
    while i > 0usize {
        i = i - 1usize;
        emit_drop_local(c, pp, src, c.sco_local[i]);
    }
    return;
}
// break/continue: drop the locals in scopes opened inside the innermost loop body.
fn emit_loop_exit_drops(c: write C, pp: read P, src: [u8], keep: usize) -> unit {
    let start: usize = c.sco_mark[keep];
    let mut i: usize = c.sco_n;
    while i > start {
        i = i - 1usize;
        emit_drop_local(c, pp, src, c.sco_local[i]);
    }
    return;
}
// The byte span of `self` in the source (the hook binds `self` by these bytes, so
// the hook body's `self` place resolves). Same trick as lower.cnr set_self_span.
fn find_self(src: [u8]) -> usize {
    let n: usize = len(src);
    let mut i: usize = 0usize;
    while i + 4usize <= n {
        if src[i] == 115u8 && src[i + 1usize] == 101u8 && src[i + 2usize] == 108u8 && src[i + 3usize] == 102u8 { return i; }
        i = i + 1usize;
    }
    return 0usize;
}

// ---- fault edges ------------------------------------------------------------
fn emit_fault(c: write C, kind: i32, s: usize, e: usize) -> unit {
    bc(c, 9);
    bs(c, b"movl $");
    bn(c, conv u64 kind);
    bs(c, b", %edi");
    bc(c, 10);
    bc(c, 9);
    bs(c, b"movl $");
    bn(c, conv u64 s);
    bs(c, b", %esi");
    bc(c, 10);
    bc(c, 9);
    bs(c, b"movl $");
    bn(c, conv u64 e);
    bs(c, b", %edx");
    bc(c, 10);
    bi(c, b"call rt_fault");
    return;
}
// Emit `<jgood> skip; <fault>; skip:` — the fault fires unless the good branch is
// taken. `jgood` is a jump mnemonic (e.g. "jno", "jbe", "jne").
fn fault_unless(c: write C, jgood: [u8], kind: i32, s: usize, e: usize) -> unit {
    let sk: i32 = newlbl(c);
    bc(c, 9);
    bs(c, jgood);
    bc(c, 32);
    blabel_ref(c, sk);
    bc(c, 10);
    emit_fault(c, kind, s, e);
    blabel_def(c, sk);
    return;
}

// ---- canonicalize %rax to width `w` (sign/zero-extend, matching load_scalar) --
fn emit_canon(c: write C, w: i32) -> unit {
    let b: i32 = bits_of(w);
    if b == 64 { return; }
    if signedw(w) != 0 {
        if b == 8 { bi(c, b"movsbq %al, %rax"); return; }
        if b == 16 { bi(c, b"movswq %ax, %rax"); return; }
        bi(c, b"movslq %eax, %rax");
        return;
    }
    if b == 8 { bi(c, b"movzbq %al, %rax"); return; }
    if b == 16 { bi(c, b"movzwq %ax, %rax"); return; }
    bi(c, b"movl %eax, %eax");
    return;
}

// ---- constants --------------------------------------------------------------
// Load the canonical bit pattern of a scalar const into %rax.
fn emit_const(c: write C, ival: u64, neg: i32) -> unit {
    let mut pat: u64 = ival;
    if neg != 0 { pat = 0u64 - ival; }
    bc(c, 9);
    bs(c, b"movabsq $");
    bn(c, pat);
    bs(c, b", %rax");
    bc(c, 10);
    return;
}

// ---- signed/unsigned range check of %rax against width `w` (Checked) --------
fn emit_range_check(c: write C, w: i32, kind: i32, s: usize, e: usize) -> unit {
    if bits_of(w) == 64 { return; }
    if signedw(w) != 0 {
        bc(c, 9);
        bs(c, b"cmpq $");
        bn(c, conv u64 smax_of(w));
        bs(c, b", %rax");
        bc(c, 10);
        fault_unless(c, b"jle", kind, s, e);
        bc(c, 9);
        bs(c, b"cmpq $");
        if smin_of(w) < 0i64 {
            bc(c, 45);
            bn(c, conv u64 (0i64 - smin_of(w)));
        } else {
            bn(c, conv u64 smin_of(w));
        }
        bs(c, b", %rax");
        bc(c, 10);
        fault_unless(c, b"jge", kind, s, e);
        return;
    }
    bc(c, 9);
    bs(c, b"movabsq $");
    bn(c, umax_of(w));
    bs(c, b", %rcx");
    bc(c, 10);
    bi(c, b"cmpq %rcx, %rax");
    fault_unless(c, b"jbe", kind, s, e);
    return;
}

// ---- flat-memory aggregates (structs/arrays): live in the FLAT MEMORY region
// (rt_stack_alloc'd; addresses are MEM_BASE + candor_offset, mirroring lower.rs).
// A scalar VALUE flows through %rax as N1; an aggregate VALUE flows through %rax as
// its flat OFFSET (Candor address). Field/index resolve to a flat offset; a scalar
// leaf is loaded/stored at MEM_BASE + offset. -------------------------------------
fn is_agg_ty(pp: read P, src: [u8], head: u32, tn: u32) -> bool {
    if tn == 0u32 { return false; }
    if scalar_width(pp, src, tn) != 0 { return false; }
    return ty_size(pp, src, head, tn) > 0usize;
}
// Padded element stride of `[N]T` = size / N (reuses layout's ty_size + array_len;
// layout.cnr exposes no stride_of, so it is derived here from exported sizes).
fn arr_stride(pp: read P, src: [u8], head: u32, arr_ty: u32) -> usize {
    let arrnd: Node = pp.nodes[conv usize arr_ty];
    let n: usize = array_len_of(pp, arrnd.a);
    if n == 0usize { return 0usize; }
    return ty_size(pp, src, head, arr_ty) / n;
}
fn find_finit_cg(pp: read P, src: [u8], flist: u32, fs: usize, fen: usize) -> u32 {
    let mut cur: u32 = flist;
    while cur != 0u32 {
        let fi: Node = pp.nodes[conv usize cur];
        if name_eq(src, fs, fen, fi.p0, fi.p1) { return cur; }
        cur = fi.nx;
    }
    return 0u32;
}
// rt_stack_alloc(size, align) -> %rax = the fresh flat offset.
fn emit_alloc(c: write C, size: usize, align: usize) -> unit {
    bc(c, 9); bs(c, b"movl $"); bn(c, conv u64 size); bs(c, b", %edi"); bc(c, 10);
    bc(c, 9); bs(c, b"movl $"); bn(c, conv u64 align); bs(c, b", %esi"); bc(c, 10);
    bi(c, b"call rt_stack_alloc");
    return;
}
// Load the scalar at flat offset (%rax) into %rax, extended per width (load_scalar).
fn emit_load_flat(c: write C, w: i32) -> unit {
    bc(c, 9); bs(c, b"movabsq $"); bn(c, MEM_BASE); bs(c, b", %rcx"); bc(c, 10);
    bi(c, b"addq %rcx, %rax");
    let b: i32 = bits_of(w);
    let sg: i32 = signedw(w);
    bc(c, 9);
    if b == 64 { bs(c, b"movq (%rax), %rax"); }
    else if b == 8 { if sg != 0 { bs(c, b"movsbq (%rax), %rax"); } else { bs(c, b"movzbq (%rax), %rax"); } }
    else if b == 16 { if sg != 0 { bs(c, b"movswq (%rax), %rax"); } else { bs(c, b"movzwq (%rax), %rax"); } }
    else { if sg != 0 { bs(c, b"movslq (%rax), %rax"); } else { bs(c, b"movl (%rax), %eax"); } }
    bc(c, 10);
    return;
}
// Store %rax (canonical value) at MEM_BASE + [off_slot] + disp, low `w` bytes.
fn emit_store_flat(c: write C, w: i32, off_slot: i32, disp: usize) -> unit {
    bc(c, 9); bs(c, b"movq "); bslot(c, off_slot); bs(c, b", %rcx"); bc(c, 10);
    bc(c, 9); bs(c, b"movabsq $"); bn(c, MEM_BASE); bs(c, b", %rdx"); bc(c, 10);
    bi(c, b"addq %rdx, %rcx");
    let b: i32 = bits_of(w);
    bc(c, 9);
    if b == 8 { bs(c, b"movb %al, "); }
    else if b == 16 { bs(c, b"movw %ax, "); }
    else if b == 32 { bs(c, b"movl %eax, "); }
    else { bs(c, b"movq %rax, "); }
    if disp != 0usize { bn(c, conv u64 disp); }
    bs(c, b"(%rcx)");
    bc(c, 10);
    return;
}
// rt_copy(dst = [base_slot] + disp, src = %rax, size).
fn emit_copy_to(c: write C, base_slot: i32, disp: usize, size: usize) -> unit {
    bi(c, b"movq %rax, %rsi");
    bc(c, 9); bs(c, b"movq "); bslot(c, base_slot); bs(c, b", %rdi"); bc(c, 10);
    if disp != 0usize { bc(c, 9); bs(c, b"addq $"); bn(c, conv u64 disp); bs(c, b", %rdi"); bc(c, 10); }
    bc(c, 9); bs(c, b"movl $"); bn(c, conv u64 size); bs(c, b", %edx"); bc(c, 10);
    bi(c, b"call rt_copy");
    return;
}
// rt_copy(dst = [dst_slot], src = [src_slot], size).
fn emit_copy_from(c: write C, dst_slot: i32, src_slot: i32, size: usize) -> unit {
    bc(c, 9); bs(c, b"movq "); bslot(c, dst_slot); bs(c, b", %rdi"); bc(c, 10);
    bc(c, 9); bs(c, b"movq "); bslot(c, src_slot); bs(c, b", %rsi"); bc(c, 10);
    bc(c, 9); bs(c, b"movl $"); bn(c, conv u64 size); bs(c, b", %edx"); bc(c, 10);
    bi(c, b"call rt_copy");
    return;
}
// Resolve a place to its flat OFFSET in %rax; return the place's type node. Mirrors
// interp.cnr eval_place: index evaluates its index THEN its base, and the Bounds
// fault reports the base root's span (cur_p0/cur_p1 left by the base resolution).
fn gen_place_addr(c: write C, pp: read P, src: [u8], i: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize i];
    c.*.cur_p0 = nd.p0;
    c.*.cur_p1 = nd.p1;
    if nd.tag == T_PAREN { return gen_place_addr(c, pp, src, nd.a); }
    if nd.tag == T_ID {
        let s: i32 = lookup(c, src, nd.p0, nd.p1);
        if s >= 0 {
            reload_rax(c, s);
            return c.luk_ty;
        }
        let si: i32 = find_static_idx(c, src, nd.p0, nd.p1);
        if si >= 0 {
            emit_static_load(c, si);
            return c.st_ty[conv usize si];
        }
        c.*.err = 1; return 0u32;
    }
    if nd.tag == T_PREFIX {
        if nd.op == PF_DEREF {
            let bt: u32 = gen_place_addr(c, pp, src, nd.a);
            let btn: Node = pp.nodes[conv usize bt];
            // A Box deref loads ptr@0; a borrow/rawptr value already IS the pointee address.
            if btn.tag == T_BOX {
                emit_load_flat(c, W_USIZE);
            }
            return btn.a;
        }
    }
    if nd.tag == T_FIELD {
        let mut bt: u32 = gen_place_addr(c, pp, src, nd.a);
        bt = peel_box_addr(c, pp, src, bt);
        let sid: u32 = struct_of_ty(pp, src, c.head, bt);
        let off: usize = field_off(pp, src, c.head, sid, nd.p0, nd.p1);
        let fty: u32 = field_ty(pp, src, sid, nd.p0, nd.p1);
        if off > 0usize {
            bc(c, 9); bs(c, b"addq $"); bn(c, conv u64 off); bs(c, b", %rax"); bc(c, 10);
        }
        return fty;
    }
    if nd.tag == T_INDEX {
        let _iw: i32 = gen_value(c, pp, src, nd.b, W_USIZE);
        let idxslot: i32 = spill(c);
        let mut bt: u32 = gen_place_addr(c, pp, src, nd.a);
        // A Box/borrow base auto-derefs to its pointee (an array or slice) before index.
        bt = peel_box_addr(c, pp, src, bt);
        let arrnd: Node = pp.nodes[conv usize bt];
        if arrnd.tag == T_SLICE || arrnd.tag == T_SLICEMUT {
            // A slice is a {ptr@0, len@8} fat pointer: bounds-check idx < len, then load
            // the data ptr and offset by idx*stride (element size).
            let hdr_slot: i32 = spill(c);
            let elem: u32 = arrnd.a;
            let stride: usize = ty_size(pp, src, c.head, elem);
            reload_rax(c, hdr_slot);
            bi(c, b"addq $8, %rax");
            emit_load_flat(c, W_USIZE);
            let len_slot: i32 = spill(c);
            reload_rax(c, idxslot);
            bc(c, 9); bs(c, b"movq "); bslot(c, len_slot); bs(c, b", %rcx"); bc(c, 10);
            bi(c, b"cmpq %rcx, %rax");
            fault_unless(c, b"jb", FK_BOUNDS, c.cur_p0, c.cur_p1);
            reload_rax(c, hdr_slot);
            emit_load_flat(c, W_USIZE);
            let ptr_slot: i32 = spill(c);
            reload_rax(c, idxslot);
            bc(c, 9); bs(c, b"imulq $"); bn(c, conv u64 stride); bs(c, b", %rax, %rax"); bc(c, 10);
            bc(c, 9); bs(c, b"movq "); bslot(c, ptr_slot); bs(c, b", %rcx"); bc(c, 10);
            bi(c, b"addq %rcx, %rax");
            return elem;
        }
        let baseslot: i32 = spill(c);
        let n: usize = array_len_of(pp, arrnd.a);
        let stride: usize = arr_stride(pp, src, c.head, bt);
        reload_rax(c, idxslot);
        bc(c, 9); bs(c, b"cmpq $"); bn(c, conv u64 n); bs(c, b", %rax"); bc(c, 10);
        fault_unless(c, b"jb", FK_BOUNDS, c.cur_p0, c.cur_p1);
        bc(c, 9); bs(c, b"imulq $"); bn(c, conv u64 stride); bs(c, b", %rax, %rax"); bc(c, 10);
        bc(c, 9); bs(c, b"movq "); bslot(c, baseslot); bs(c, b", %rcx"); bc(c, 10);
        bi(c, b"addq %rcx, %rax");
        return arrnd.b;
    }
    c.*.err = 1;
    return 0u32;
}
// Evaluate an AGGREGATE-valued expression: leave its flat offset in %rax, set
// cur_agg_ty, and return its type node. `exp_ty` supplies the type for literals.
fn gen_agg(c: write C, pp: read P, src: [u8], i: u32, exp_ty: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize i];
    c.*.cur_p0 = nd.p0;
    c.*.cur_p1 = nd.p1;
    if nd.tag == T_PAREN { return gen_agg(c, pp, src, nd.a, exp_ty); }
    if nd.tag == T_ENUMCTOR { return gen_enum_ctor(c, pp, src, i, exp_ty); }
    if nd.tag == T_STRUCTLIT { return gen_struct_lit(c, pp, src, i, exp_ty); }
    if nd.tag == T_ARRAYLIT { return gen_array_lit(c, pp, src, i, exp_ty); }
    if nd.tag == T_ARRAYREP { return gen_array_rep(c, pp, src, i, exp_ty); }
    if nd.tag == T_BYTES { return gen_bytes(c, pp, src, i, exp_ty); }
    if nd.tag == T_MATCH { return gen_match_value(c, pp, src, i, exp_ty); }
    if nd.tag == T_ID || nd.tag == T_FIELD || nd.tag == T_INDEX {
        return gen_place_addr(c, pp, src, i);
    }
    if nd.tag == T_PREFIX && nd.op == PF_DEREF {
        return gen_place_addr(c, pp, src, i);
    }
    // `read x`/`write x` as an aggregate value yields the borrowed place's address (its
    // flat offset); the borrow's pointee lives there (e.g. box's Alloc handle argument).
    if nd.tag == T_PREFIX && (nd.op == PF_READ || nd.op == PF_WRITE) {
        return gen_place_addr(c, pp, src, nd.a);
    }
    if nd.tag == T_CALL {
        let callee: Node = pp.nodes[conv usize nd.a];
        if callee.tag == T_ID && span_eq(src, callee.p0, callee.p1, b"box") {
            return gen_box(c, pp, src, i, exp_ty);
        }
        let _w: i32 = gen_call(c, pp, src, i);
        return c.cur_agg_ty;
    }
    c.*.err = 1;
    return 0u32;
}
// T_ENUMCTOR: rt_stack_alloc the enum, write the u64 tag@0 (the variant's declared
// index), then store/copy each payload argument at its variant_payload_off. Leaves the
// enum's flat offset in %rax (aggregate convention); mirrors lower.cnr lower_enum_ctor.
fn gen_enum_ctor(c: write C, pp: read P, src: [u8], i: u32, exp_ty: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize i];
    let eid: u32 = enum_of_ty(pp, src, c.head, exp_ty);
    if eid == 0u32 { c.*.err = 1; return 0u32; }
    let vname: Node = pp.nodes[conv usize nd.a];
    let idx: i32 = variant_index_by_name(pp, src, eid, vname.p0, vname.p1);
    if idx < 0 { c.*.err = 1; return 0u32; }
    let vid: u32 = variant_by_index(pp, eid, idx);
    let size: usize = enum_size(pp, src, c.head, eid);
    let align: usize = ty_align(pp, src, c.head, exp_ty);
    emit_alloc(c, size, align);
    let baseslot: i32 = spill(c);
    emit_const(c, conv u64 idx, 0);
    emit_store_flat(c, 9, baseslot, 0usize);
    let mut argc: u32 = nd.b;
    let mut k: i32 = 0;
    while argc != 0u32 {
        let pty: u32 = variant_payload_ty(pp, vid, k);
        let off: usize = variant_payload_off(pp, src, c.head, vid, k);
        let pw: i32 = scalar_width(pp, src, pty);
        if pw != 0 {
            let _v: i32 = gen_value(c, pp, src, argc, pw);
            emit_canon(c, pw);
            emit_store_flat(c, pw, baseslot, off);
        } else {
            let _t: u32 = gen_agg(c, pp, src, argc, pty);
            emit_copy_to(c, baseslot, off, ty_size(pp, src, c.head, pty));
            if !is_copy(pp, src, c.head, pty) { mark_moved(c, pp, src, argc); }
        }
        k = k + 1i32;
        argc = pp.nodes[conv usize argc].nx;
    }
    reload_rax(c, baseslot);
    c.*.cur_agg_ty = exp_ty;
    return exp_ty;
}
fn gen_struct_lit(c: write C, pp: read P, src: [u8], i: u32, exp_ty: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize i];
    let sid: u32 = struct_of_ty(pp, src, c.head, exp_ty);
    let size: usize = struct_size(pp, src, c.head, sid);
    let align: usize = struct_align(pp, src, c.head, sid);
    emit_alloc(c, size, align);
    let baseslot: i32 = spill(c);
    let snode: Node = pp.nodes[conv usize sid];
    let mut fcur: u32 = snode.b;
    while fcur != 0u32 {
        let fdef: Node = pp.nodes[conv usize fcur];
        let fty: u32 = fdef.a;
        let off: usize = field_off(pp, src, c.head, sid, fdef.p0, fdef.p1);
        let finit: u32 = find_finit_cg(pp, src, nd.a, fdef.p0, fdef.p1);
        if finit != 0u32 {
            let fin: Node = pp.nodes[conv usize finit];
            let fw: i32 = scalar_width(pp, src, fty);
            if fw != 0 {
                let _v: i32 = gen_value(c, pp, src, fin.a, fw);
                emit_canon(c, fw);
                emit_store_flat(c, fw, baseslot, off);
            } else {
                let _t: u32 = gen_agg(c, pp, src, fin.a, fty);
                emit_copy_to(c, baseslot, off, ty_size(pp, src, c.head, fty));
                if !is_copy(pp, src, c.head, fty) { mark_moved(c, pp, src, fin.a); }
            }
        }
        fcur = fdef.nx;
    }
    reload_rax(c, baseslot);
    c.*.cur_agg_ty = exp_ty;
    return exp_ty;
}
fn gen_array_lit(c: write C, pp: read P, src: [u8], i: u32, exp_ty: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize i];
    let arrnd: Node = pp.nodes[conv usize exp_ty];
    let elem: u32 = arrnd.b;
    let esz: usize = ty_size(pp, src, c.head, elem);
    let stride: usize = arr_stride(pp, src, c.head, exp_ty);
    let ew: i32 = scalar_width(pp, src, elem);
    let size: usize = ty_size(pp, src, c.head, exp_ty);
    let align: usize = ty_align(pp, src, c.head, exp_ty);
    emit_alloc(c, size, align);
    let baseslot: i32 = spill(c);
    let mut k: usize = 0usize;
    let mut cur: u32 = nd.a;
    while cur != 0u32 {
        let cn: Node = pp.nodes[conv usize cur];
        if ew != 0 {
            let _v: i32 = gen_value(c, pp, src, cur, ew);
            emit_canon(c, ew);
            emit_store_flat(c, ew, baseslot, k * stride);
        } else {
            let _t: u32 = gen_agg(c, pp, src, cur, elem);
            emit_copy_to(c, baseslot, k * stride, esz);
            if !is_copy(pp, src, c.head, elem) { mark_moved(c, pp, src, cur); }
        }
        k = k + 1usize;
        cur = cn.nx;
    }
    reload_rax(c, baseslot);
    c.*.cur_agg_ty = exp_ty;
    return exp_ty;
}
fn gen_array_rep(c: write C, pp: read P, src: [u8], i: u32, exp_ty: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize i];
    let arrnd: Node = pp.nodes[conv usize exp_ty];
    let elem: u32 = arrnd.b;
    let esz: usize = ty_size(pp, src, c.head, elem);
    let stride: usize = arr_stride(pp, src, c.head, exp_ty);
    let ew: i32 = scalar_width(pp, src, elem);
    let n: usize = array_len_of(pp, arrnd.a);
    let size: usize = ty_size(pp, src, c.head, exp_ty);
    let align: usize = ty_align(pp, src, c.head, exp_ty);
    emit_alloc(c, size, align);
    let baseslot: i32 = spill(c);
    if ew != 0 {
        let _v: i32 = gen_value(c, pp, src, nd.a, ew);
        emit_canon(c, ew);
        let valslot: i32 = spill(c);
        let mut k: usize = 0usize;
        while k < n {
            reload_rax(c, valslot);
            emit_store_flat(c, ew, baseslot, k * stride);
            k = k + 1usize;
        }
    } else {
        let _t: u32 = gen_agg(c, pp, src, nd.a, elem);
        let valslot: i32 = spill(c);
        let mut k: usize = 0usize;
        while k < n {
            reload_rax(c, valslot);
            emit_copy_to(c, baseslot, k * stride, esz);
            k = k + 1usize;
        }
    }
    reload_rax(c, baseslot);
    c.*.cur_agg_ty = exp_ty;
    return exp_ty;
}

// A byte-string literal `b"..."` materializes as a `[u8]` slice: decode its bytes into
// a fresh flat blob, then build the {ptr@0, len@8} header (mirrors lower.cnr
// lower_str_into; the blob lives in flat memory so slice indexing loads through ptr@0).
fn gen_bytes(c: write C, pp: read P, src: [u8], i: u32, exp_ty: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize i];
    let clen: usize = conv usize decoded_len(src, nd.p0, nd.p1);
    emit_alloc(c, clen, 1usize);
    let blob_slot: i32 = spill(c);
    let mut j: usize = nd.p0;
    let mut k: usize = 0usize;
    while j < nd.p1 {
        let mut dec: u8 = src[j];
        if src[j] == 92u8 && j + 1usize < nd.p1 {
            let nx: u8 = src[j + 1usize];
            if nx == 34u8 { dec = 34u8; }
            else if nx == 92u8 { dec = 92u8; }
            else if nx == 110u8 { dec = 10u8; }
            else if nx == 116u8 { dec = 9u8; }
            else { dec = nx; }
            j = j + 2usize;
        } else {
            j = j + 1usize;
        }
        emit_const(c, conv u64 dec, 0);
        emit_store_flat(c, 6, blob_slot, k);
        k = k + 1usize;
    }
    emit_alloc(c, 16usize, 8usize);
    let hdr_slot: i32 = spill(c);
    reload_rax(c, blob_slot);
    emit_store_flat(c, W_USIZE, hdr_slot, 0usize);
    emit_const(c, conv u64 clen, 0);
    emit_store_flat(c, W_USIZE, hdr_slot, 8usize);
    reload_rax(c, hdr_slot);
    c.*.cur_agg_ty = exp_ty;
    return exp_ty;
}

// ---- forward declarations via mutual recursion -------------------------------
fn gen_value(c: write C, pp: read P, src: [u8], i: u32, exp_w: i32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    c.*.cur_p0 = nd.p0;
    c.*.cur_p1 = nd.p1;
    if nd.tag == T_PAREN { return gen_value(c, pp, src, nd.a, exp_w); }
    if nd.tag == T_INT {
        emit_const(c, nd.ival, 0);
        return lit_width(nd.suf, exp_w);
    }
    if nd.tag == T_NEGINT {
        emit_const(c, nd.ival, 1);
        return lit_width(nd.suf, exp_w);
    }
    if nd.tag == T_BOOL {
        emit_const(c, nd.ival, 0);
        return W_BOOL;
    }
    if nd.tag == T_ID {
        let s: i32 = lookup(c, src, nd.p0, nd.p1);
        if s >= 0 {
            reload_rax(c, s);
            if c.luk_flat != 0 { emit_load_flat(c, c.luk_w); }
            return c.luk_w;
        }
        let si: i32 = find_static_idx(c, src, nd.p0, nd.p1);
        if si >= 0 {
            let sty: u32 = c.st_ty[conv usize si];
            let sw: i32 = scalar_width(pp, src, sty);
            if sw != 0 {
                emit_static_load(c, si);
                emit_load_flat(c, sw);
                return sw;
            }
            emit_static_load(c, si);
            c.*.cur_agg_ty = sty;
            return W_AGG;
        }
        let fid: u32 = find_fn(pp, src, c.head, nd.p0, nd.p1);
        if fid != 0u32 {
            emit_fn_addr(c, pp, src, fid);
            return W_USIZE;
        }
        c.*.err = 1;
        return 4;
    }
    if nd.tag == T_FIELD || nd.tag == T_INDEX {
        let pty: u32 = gen_place_addr(c, pp, src, i);
        let w: i32 = scalar_width(pp, src, pty);
        if w != 0 { emit_load_flat(c, w); return w; }
        c.*.cur_agg_ty = pty;
        return W_AGG;
    }
    if nd.tag == T_PREFIX && nd.op == PF_DEREF {
        let pty: u32 = gen_place_addr(c, pp, src, i);
        let w: i32 = scalar_width(pp, src, pty);
        if w != 0 { emit_load_flat(c, w); return w; }
        c.*.cur_agg_ty = pty;
        return W_AGG;
    }
    if nd.tag == T_PREFIX && (nd.op == PF_READ || nd.op == PF_WRITE) {
        let _t: u32 = gen_place_addr(c, pp, src, nd.a);
        return W_USIZE;
    }
    if nd.tag == T_CASTPTR || nd.tag == T_ADDRTOPTR {
        let _v: i32 = gen_value(c, pp, src, nd.b, W_USIZE);
        return W_USIZE;
    }
    if nd.tag == T_PTRNULL {
        emit_const(c, 0u64, 0);
        return W_USIZE;
    }
    if nd.tag == T_OFFSETOF {
        let sido: u32 = struct_of_ty(pp, src, c.head, nd.a);
        let offo: usize = field_off(pp, src, c.head, sido, nd.p0, nd.p1);
        emit_const(c, conv u64 offo, 0);
        return W_USIZE;
    }
    if nd.tag == T_GENERICVAL {
        let gfid: u32 = nd.c;
        if gfid == 0u32 { c.*.err = 1; return W_USIZE; }
        emit_fn_addr(c, pp, src, gfid);
        return W_USIZE;
    }
    if nd.tag == T_UNARY { return gen_unary(c, pp, src, i, exp_w); }
    if nd.tag == T_BIN { return gen_binary(c, pp, src, i, exp_w); }
    if nd.tag == T_CONV { return gen_conv(c, pp, src, i); }
    if nd.tag == T_CALL { return gen_call(c, pp, src, i); }
    if nd.tag == T_TRY { return gen_try(c, pp, src, i); }
    if nd.tag == T_BLOCK { let _s: i32 = gen_block(c, pp, src, i); return 12; }
    if nd.tag == T_IF { let _s: i32 = gen_if(c, pp, src, i); return 12; }
    if nd.tag == T_WHILE { let _s: i32 = gen_while(c, pp, src, i); return 12; }
    if nd.tag == T_LOOP { let _s: i32 = gen_loop(c, pp, src, i); return 12; }
    if nd.tag == T_UNSAFE { let _s: i32 = gen_block(c, pp, src, nd.a); return 12; }
    if nd.tag == T_WRAPPING {
        let save: i32 = c.regime;
        c.*.regime = 1;
        let _s: i32 = gen_block(c, pp, src, nd.a);
        c.*.regime = save;
        return 12;
    }
    if nd.tag == T_SATURATING {
        let save: i32 = c.regime;
        c.*.regime = 2;
        let _s: i32 = gen_block(c, pp, src, nd.a);
        c.*.regime = save;
        return 12;
    }
    if nd.tag == T_RETURN { let _s: i32 = gen_return(c, pp, src, i); return 12; }
    if nd.tag == T_BREAK {
        if c.loop_n == 0usize { c.*.err = 1; return 12; }
        emit_loop_exit_drops(c, pp, src, c.loop_depth[c.loop_n - 1usize]);
        bc(c, 9);
        bs(c, b"jmp ");
        blabel_ref(c, c.loop_brk[c.loop_n - 1usize]);
        bc(c, 10);
        return 12;
    }
    if nd.tag == T_CONTINUE {
        if c.loop_n == 0usize { c.*.err = 1; return 12; }
        emit_loop_exit_drops(c, pp, src, c.loop_depth[c.loop_n - 1usize]);
        bc(c, 9);
        bs(c, b"jmp ");
        blabel_ref(c, c.loop_cont[c.loop_n - 1usize]);
        bc(c, 10);
        return 12;
    }
    if nd.tag == T_MATCH { let _s: i32 = gen_match(c, pp, src, i); return 12; }
    if nd.tag == T_ASSERT { let _s: i32 = gen_assert(c, pp, src, i); return 12; }
    if nd.tag == T_PANIC {
        emit_fault(c, FK_PANIC, nd.p0, nd.p1);
        return 12;
    }
    c.*.err = 1;
    return 4;
}

fn gen_unary(c: write C, pp: read P, src: [u8], i: u32, exp_w: i32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    if nd.op == UN_NOT {
        let _w: i32 = gen_value(c, pp, src, nd.a, W_BOOL);
        bi(c, b"testq %rax, %rax");
        bi(c, b"sete %al");
        bi(c, b"movzbq %al, %rax");
        return W_BOOL;
    }
    let vw: i32 = gen_value(c, pp, src, nd.a, exp_w);
    let sty: i32 = concretize(vw);
    let fp0: usize = c.cur_p0;
    let fp1: usize = c.cur_p1;
    if nd.op == UN_BITNOT {
        bi(c, b"notq %rax");
        emit_canon(c, sty);
        return sty;
    }
    // UN_NEG
    if bits_of(sty) == 64 {
        bi(c, b"negq %rax");
        if c.regime == 0 && signedw(sty) != 0 {
            fault_unless(c, b"jno", FK_OVERFLOW, fp0, fp1);
        }
        emit_canon(c, sty);
        return sty;
    }
    bi(c, b"negq %rax");
    if c.regime == 0 {
        emit_range_check(c, sty, FK_OVERFLOW, fp0, fp1);
    }
    emit_canon(c, sty);
    return sty;
}

// left in %rax, right in %rcx after this helper.
fn gen_two(c: write C, pp: read P, src: [u8], la: u32, ra: u32, lexp: i32, rexp: i32) -> unit {
    let _lw: i32 = gen_value(c, pp, src, la, lexp);
    let ls: i32 = spill(c);
    let _rw: i32 = gen_value(c, pp, src, ra, rexp);
    bi(c, b"movq %rax, %rcx");
    reload_rax(c, ls);
    return;
}

fn gen_binary(c: write C, pp: read P, src: [u8], i: u32, exp_w: i32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let op: i32 = nd.op;
    if op == OP_AND || op == OP_OR { return gen_short_circuit(c, pp, src, i); }
    if op >= OP_EQ && op <= OP_GE { return gen_cmp(c, pp, src, i); }
    // arithmetic / bitwise / shift
    let mut opty: i32 = 0i32 - 1i32;
    if exp_w >= 1 && exp_w <= 10 { opty = exp_w; }
    let lw: i32 = gen_value(c, pp, src, nd.a, opty);
    let ls: i32 = spill(c);
    let mut sty: i32 = opty;
    if opty < 0 { sty = concretize(lw); }
    let mut rexp: i32 = sty;
    if op == OP_SHL || op == OP_SHR { rexp = 0i32 - 1i32; }
    let _rw: i32 = gen_value(c, pp, src, nd.b, rexp);
    bi(c, b"movq %rax, %rcx");
    reload_rax(c, ls);
    gen_arith(c, op, sty, nd.p0, nd.p1);
    return sty;
}

// %rax = left, %rcx = right; result -> %rax.
fn gen_arith(c: write C, op: i32, sty: i32, s: usize, e: usize) -> unit {
    let b: i32 = bits_of(sty);
    let sg: i32 = signedw(sty);
    if op == OP_ADD || op == OP_SUB || op == OP_MUL {
        if b == 64 {
            if op == OP_ADD { bi(c, b"addq %rcx, %rax"); }
            else if op == OP_SUB { bi(c, b"subq %rcx, %rax"); }
            else if sg != 0 { bi(c, b"imulq %rcx, %rax"); }
            else { bi(c, b"mulq %rcx"); }
            if c.regime == 0 {
                if sg != 0 { fault_unless(c, b"jno", FK_OVERFLOW, s, e); }
                else { fault_unless(c, b"jnc", FK_OVERFLOW, s, e); }
            }
            emit_canon(c, sty);
            return;
        }
        // narrow: compute in 64-bit (exact), then range-check.
        if op == OP_ADD { bi(c, b"addq %rcx, %rax"); }
        else if op == OP_SUB { bi(c, b"subq %rcx, %rax"); }
        else { bi(c, b"imulq %rcx, %rax"); }
        if c.regime == 0 {
            emit_range_check(c, sty, FK_OVERFLOW, s, e);
        }
        emit_canon(c, sty);
        return;
    }
    if op == OP_DIV || op == OP_REM {
        bi(c, b"testq %rcx, %rcx");
        fault_unless(c, b"jne", FK_DIVZERO, s, e);
        if sg == 0 {
            bi(c, b"xorl %edx, %edx");
            bi(c, b"divq %rcx");
            if op == OP_REM { bi(c, b"movq %rdx, %rax"); }
            emit_canon(c, sty);
            return;
        }
        // signed: guard type-MIN / -1.
        gen_signed_divrem(c, op, sty, s, e);
        emit_canon(c, sty);
        return;
    }
    if op == OP_BITAND { bi(c, b"andq %rcx, %rax"); emit_canon(c, sty); return; }
    if op == OP_BITOR { bi(c, b"orq %rcx, %rax"); emit_canon(c, sty); return; }
    if op == OP_BITXOR { bi(c, b"xorq %rcx, %rax"); emit_canon(c, sty); return; }
    // shifts: amount in %rcx (%cl). A negative amount faults in every regime.
    bi(c, b"testq %rcx, %rcx");
    fault_unless(c, b"jns", FK_OVERFLOW, s, e);
    if c.regime == 0 {
        bc(c, 9);
        bs(c, b"cmpq $");
        bn(c, conv u64 b);
        bs(c, b", %rcx");
        bc(c, 10);
        fault_unless(c, b"jb", FK_OVERFLOW, s, e);
    } else if c.regime == 1 {
        // wrapping: amount mod bits (bits is a power of two).
        bc(c, 9);
        bs(c, b"andq $");
        bn(c, conv u64 (b - 1));
        bs(c, b", %rcx");
        bc(c, 10);
    } else {
        // saturating: clamp an out-of-range amount to bits-1.
        bc(c, 9);
        bs(c, b"cmpq $");
        bn(c, conv u64 b);
        bs(c, b", %rcx");
        bc(c, 10);
        let sk: i32 = newlbl(c);
        bc(c, 9);
        bs(c, b"jb ");
        blabel_ref(c, sk);
        bc(c, 10);
        bc(c, 9);
        bs(c, b"movq $");
        bn(c, conv u64 (b - 1));
        bs(c, b", %rcx");
        bc(c, 10);
        blabel_def(c, sk);
    }
    if op == OP_SHL { bi(c, b"shlq %cl, %rax"); }
    else if sg != 0 { bi(c, b"sarq %cl, %rax"); }
    else { bi(c, b"shrq %cl, %rax"); }
    emit_canon(c, sty);
    return;
}

fn gen_signed_divrem(c: write C, op: i32, sty: i32, s: usize, e: usize) -> unit {
    // %rax = left, %rcx = right; both nonzero divisor already checked.
    let ok: i32 = newlbl(c);
    let done: i32 = newlbl(c);
    // detect left == type-min && right == -1
    if bits_of(sty) == 64 {
        bi(c, b"movabsq $-9223372036854775808, %r8");
    } else {
        bc(c, 9);
        bs(c, b"movq $");
        if smin_of(sty) < 0i64 {
            bc(c, 45);
            bn(c, conv u64 (0i64 - smin_of(sty)));
        } else {
            bn(c, conv u64 smin_of(sty));
        }
        bs(c, b", %r8");
        bc(c, 10);
    }
    bi(c, b"cmpq %r8, %rax");
    bc(c, 9);
    bs(c, b"jne ");
    blabel_ref(c, ok);
    bc(c, 10);
    bi(c, b"cmpq $-1, %rcx");
    bc(c, 9);
    bs(c, b"jne ");
    blabel_ref(c, ok);
    bc(c, 10);
    // overflow case
    if op == OP_REM {
        // type-MIN % -1 == 0
        bi(c, b"xorl %eax, %eax");
        bc(c, 9);
        bs(c, b"jmp ");
        blabel_ref(c, done);
        bc(c, 10);
    } else if c.regime == 0 {
        emit_fault(c, FK_OVERFLOW, s, e);
    } else if c.regime == 1 {
        // wrapping: MIN / -1 == MIN
        bc(c, 9);
        bs(c, b"jmp ");
        blabel_ref(c, done);
        bc(c, 10);
    } else {
        // saturating: MIN / -1 == MAX; left stays type-min in %rax, negate to max-ish
        bc(c, 9);
        bs(c, b"jmp ");
        blabel_ref(c, done);
        bc(c, 10);
    }
    blabel_def(c, ok);
    bi(c, b"cqto");
    bi(c, b"idivq %rcx");
    if op == OP_REM { bi(c, b"movq %rdx, %rax"); }
    blabel_def(c, done);
    return;
}

fn gen_cmp(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let op: i32 = nd.op;
    let lw: i32 = gen_value(c, pp, src, nd.a, 0i32 - 1i32);
    let ls: i32 = spill(c);
    let ot: i32 = concretize(lw);
    let _rw: i32 = gen_value(c, pp, src, nd.b, ot);
    bi(c, b"movq %rax, %rcx");
    reload_rax(c, ls);
    bi(c, b"cmpq %rcx, %rax");
    let un: i32 = 1i32 - signedw(ot);
    if op == OP_EQ { bi(c, b"sete %al"); }
    else if op == OP_NE { bi(c, b"setne %al"); }
    else if op == OP_LT { if un != 0 { bi(c, b"setb %al"); } else { bi(c, b"setl %al"); } }
    else if op == OP_LE { if un != 0 { bi(c, b"setbe %al"); } else { bi(c, b"setle %al"); } }
    else if op == OP_GT { if un != 0 { bi(c, b"seta %al"); } else { bi(c, b"setg %al"); } }
    else { if un != 0 { bi(c, b"setae %al"); } else { bi(c, b"setge %al"); } }
    bi(c, b"movzbq %al, %rax");
    return W_BOOL;
}

fn gen_short_circuit(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let op: i32 = nd.op;
    let rloc: i32 = newslot(c);
    let join: i32 = newlbl(c);
    let shortl: i32 = newlbl(c);
    let _lw: i32 = gen_value(c, pp, src, nd.a, W_BOOL);
    bi(c, b"testq %rax, %rax");
    if op == OP_AND {
        bc(c, 9);
        bs(c, b"jz ");
        blabel_ref(c, shortl);
        bc(c, 10);
    } else {
        bc(c, 9);
        bs(c, b"jnz ");
        blabel_ref(c, shortl);
        bc(c, 10);
    }
    let _rw: i32 = gen_value(c, pp, src, nd.b, W_BOOL);
    store_slot(c, rloc);
    bc(c, 9);
    bs(c, b"jmp ");
    blabel_ref(c, join);
    bc(c, 10);
    blabel_def(c, shortl);
    if op == OP_AND { bi(c, b"movq $0, %rax"); } else { bi(c, b"movq $1, %rax"); }
    store_slot(c, rloc);
    blabel_def(c, join);
    reload_rax(c, rloc);
    return W_BOOL;
}

fn gen_conv(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let vw: i32 = gen_value(c, pp, src, nd.b, 0i32 - 1i32);
    let tow: i32 = scalar_width(pp, src, nd.a);
    let fp0: usize = c.cur_p0;
    let fp1: usize = c.cur_p1;
    let svw: i32 = concretize(vw);
    if c.regime == 0 {
        // Range-check the source value against the TARGET range (ConvLoss).
        if signedw(svw) != 0 {
            // signed source: lower always, upper unless target is u64/usize.
            emit_conv_lower(c, tow, fp0, fp1);
            if tow != 9 && tow != 10 {
                emit_conv_upper_signed(c, tow, fp0, fp1);
            }
        } else {
            // unsigned source: value >= 0, so only an upper bound (unsigned).
            emit_conv_upper_unsigned(c, tow, fp0, fp1);
        }
    }
    emit_canon(c, tow);
    return tow;
}
// signed-source lower bound: fault if %rax < target-min.
fn emit_conv_lower(c: write C, tow: i32, s: usize, e: usize) -> unit {
    if bits_of(tow) == 64 {
        if signedw(tow) != 0 { return; }
        // target u64/usize: min is 0.
        bi(c, b"cmpq $0, %rax");
        fault_unless(c, b"jge", FK_CONVLOSS, s, e);
        return;
    }
    bc(c, 9);
    bs(c, b"cmpq $");
    if smin_of(tow) < 0i64 {
        bc(c, 45);
        bn(c, conv u64 (0i64 - smin_of(tow)));
    } else {
        bn(c, conv u64 smin_of(tow));
    }
    bs(c, b", %rax");
    bc(c, 10);
    fault_unless(c, b"jge", FK_CONVLOSS, s, e);
    return;
}
fn emit_conv_upper_signed(c: write C, tow: i32, s: usize, e: usize) -> unit {
    if bits_of(tow) == 64 {
        // target i64/isize: max is i64-max; a signed source always fits.
        return;
    }
    bc(c, 9);
    bs(c, b"movabsq $");
    bn(c, umax_of(tow));
    bs(c, b", %rcx");
    bc(c, 10);
    bi(c, b"cmpq %rcx, %rax");
    fault_unless(c, b"jle", FK_CONVLOSS, s, e);
    return;
}
fn emit_conv_upper_unsigned(c: write C, tow: i32, s: usize, e: usize) -> unit {
    if bits_of(tow) == 64 {
        if signedw(tow) == 0 { return; }
        // target i64/isize: max is i64-max; compare unsigned.
        bi(c, b"movabsq $9223372036854775807, %rcx");
        bi(c, b"cmpq %rcx, %rax");
        fault_unless(c, b"jbe", FK_CONVLOSS, s, e);
        return;
    }
    bc(c, 9);
    bs(c, b"movabsq $");
    bn(c, umax_of(tow));
    bs(c, b", %rcx");
    bc(c, 10);
    bi(c, b"cmpq %rcx, %rax");
    fault_unless(c, b"jbe", FK_CONVLOSS, s, e);
    return;
}

fn emit_arg_reg(c: write C, idx: usize) -> unit {
    if idx == 0usize { bs(c, b"%rdi"); return; }
    if idx == 1usize { bs(c, b"%rsi"); return; }
    if idx == 2usize { bs(c, b"%rdx"); return; }
    if idx == 3usize { bs(c, b"%rcx"); return; }
    if idx == 4usize { bs(c, b"%r8"); return; }
    bs(c, b"%r9");
    return;
}

// `len(x)`: a slice loads its len@8 word; a fixed array is its compile-time length
// (mirrors lower.cnr's `len` intrinsic).
fn gen_len(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let a0: u32 = nd.b;
    let mut ttn: u32 = expr_place_ty(c, pp, src, a0);
    let mut tnode: Node = pp.nodes[conv usize ttn];
    if tnode.tag == T_BORROW || tnode.tag == T_BORROWMUT {
        ttn = tnode.a;
        tnode = pp.nodes[conv usize ttn];
    }
    if tnode.tag == T_SLICE || tnode.tag == T_SLICEMUT {
        let _t: u32 = gen_place_addr(c, pp, src, a0);
        bi(c, b"addq $8, %rax");
        emit_load_flat(c, W_USIZE);
        return W_USIZE;
    }
    let n: usize = array_len_of(pp, tnode.a);
    emit_const(c, conv u64 n, 0);
    return W_USIZE;
}
// The mangled symbol suffix a fn/instance carries after `cnr_`: its source-span name,
// plus a `.<nodeid>` tag when the fn is a generic INSTANCE (ival != 0 -- mono's
// type-arg cons chain). A period cannot appear in a Candor identifier, so an instance
// symbol never collides with a plain fn's. Emitted into the function body byte pool.
fn emit_fn_sym_pool(c: write C, pp: read P, src: [u8], fnid: u32) -> unit {
    let nd: Node = pp.nodes[conv usize fnid];
    let mut j: usize = nd.p0;
    while j < nd.p1 { bc(c, conv i32 src[j]); j = j + 1usize; }
    if nd.ival != 0u64 { bc(c, 46); bn(c, conv u64 fnid); }
    return;
}
// Strip pointer wrappers (borrow/borrowmut/box) off a type node to its pointee -- the
// nominal a method receiver dispatches on (mirrors lower.cnr peel_box_tn + borrow peel).
fn peel_ptr_tn(pp: read P, tn: u32) -> u32 {
    let mut t: u32 = tn;
    loop {
        if t == 0u32 { return 0u32; }
        let n: Node = pp.nodes[conv usize t];
        if n.tag == T_BORROW || n.tag == T_BORROWMUT || n.tag == T_BOX { t = n.a; }
        else { return t; }
    }
}
// Build the method dispatch table from every concrete (a == 0) T_IMPL: key each method
// by (target struct-instance node, method-name span) -> the method fn node. Generic
// impl templates (a != 0) are skipped; mono has instantiated them as concrete T_IMPLs.
// Mirrors lower.cnr build_dispatch (codegen names the method fn by its node id, so no
// impl-node column is needed).
fn build_dispatch_cg(c: write C, pp: read P, src: [u8]) -> unit {
    let mut cur: u32 = c.head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_IMPL && nd.a == 0u32 {
            let sid: u32 = struct_of_ty(pp, src, c.head, nd.c);
            let mut mcur: u32 = nd.d;
            while mcur != 0u32 {
                let mnd: Node = pp.nodes[conv usize mcur];
                let k: usize = c.disp_n;
                c.*.disp_sid[k] = sid;
                c.*.disp_p0[k] = mnd.p0;
                c.*.disp_p1[k] = mnd.p1;
                c.*.disp_fn[k] = mcur;
                c.*.disp_n = k + 1usize;
                mcur = mnd.nx;
            }
        }
        cur = nd.nx;
    }
    return;
}
fn disp_index_cg(c: write C, src: [u8], sid: u32, s: usize, en: usize) -> i32 {
    let mut i: usize = 0usize;
    while i < c.disp_n {
        if c.disp_sid[i] == sid && name_eq(src, c.disp_p0[i], c.disp_p1[i], s, en) {
            return conv i32 i;
        }
        i = i + 1usize;
    }
    return 0i32 - 1i32;
}
// `recv.m(args)` -> a direct `call` to the resolved impl method, passing the receiver's
// flat OFFSET (its Candor address) as the leading `self` arg. Mirrors lower.cnr
// lower_method_call: resolve the receiver place's nominal, look up (nominal, method) in
// the dispatch table, then hand `self` by address. codegen already passes borrow params
// by address (N6), and gen_place_addr leaves the receiver's flat offset in %rax -- which
// IS `self`'s address whether the base is a value place or an already-borrow local.
fn gen_method_call(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let callee: Node = pp.nodes[conv usize nd.a];
    let base: u32 = callee.a;
    let recv_tn: u32 = gen_place_addr(c, pp, src, base);
    let self_slot: i32 = spill(c);
    let sid: u32 = struct_of_ty(pp, src, c.head, peel_ptr_tn(pp, recv_tn));
    let li: i32 = disp_index_cg(c, src, sid, callee.p0, callee.p1);
    if li < 0 { c.*.err = 1; return 4; }
    let fnid: u32 = c.disp_fn[conv usize li];
    let fnnd: Node = pp.nodes[conv usize fnid];
    let self_param: u32 = fnnd.c;
    let mut retn: u32 = 0u32;
    let mut ret_borrow: i32 = 0;
    if fnnd.e != 0u32 {
        retn = pp.nodes[conv usize fnnd.e].a;
        let rmode: i32 = pp.nodes[conv usize fnnd.e].op;
        if rmode == 1 || rmode == 2 { ret_borrow = 1; }
    }
    let mut retw: i32 = scalar_width(pp, src, retn);
    if ret_borrow != 0 { retw = W_USIZE; retn = 0u32; }
    // args: self (its address, already spilled) is arg 0; the rest follow, matched to
    // the method's post-self params.
    let mut argslots: [16]i32 = [0i32; 16];
    argslots[0] = self_slot;
    let mut na: usize = 1usize;
    let mut argc: u32 = nd.b;
    let mut parc: u32 = pp.nodes[conv usize self_param].nx;
    while argc != 0u32 {
        let pty: u32 = pp.nodes[conv usize parc].a;
        let pw: i32 = scalar_width(pp, src, pty);
        if pw != 0 {
            let _aw: i32 = gen_value(c, pp, src, argc, pw);
        } else {
            let _at: u32 = gen_agg(c, pp, src, argc, pty);
        }
        argslots[na] = spill(c);
        if pw == 0 && !is_copy(pp, src, c.head, pty) { mark_moved(c, pp, src, argc); }
        na = na + 1usize;
        argc = pp.nodes[conv usize argc].nx;
        parc = pp.nodes[conv usize parc].nx;
    }
    let mut k: usize = 0usize;
    while k < na {
        bc(c, 9); bs(c, b"movq "); bslot(c, argslots[k]); bs(c, b", "); emit_arg_reg(c, k); bc(c, 10);
        k = k + 1usize;
    }
    bc(c, 9); bs(c, b"call cnr_meth."); bn(c, conv u64 fnid); bc(c, 10);
    if retw != 0 { return retw; }
    if retn != 0u32 && ty_size(pp, src, c.head, retn) > 0usize {
        c.*.cur_agg_ty = retn;
        return W_AGG;
    }
    return 12;
}
fn gen_call(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let callee: Node = pp.nodes[conv usize nd.a];
    if callee.tag == T_FIELD { return gen_method_call(c, pp, src, i); }
    if callee.tag != T_ID { c.*.err = 1; return 4; }
    if span_eq(src, callee.p0, callee.p1, b"trace") {
        let _w: i32 = gen_value(c, pp, src, nd.b, 4);
        bi(c, b"movq %rax, %rdi");
        bi(c, b"call rt_trace");
        return 12;
    }
    if span_eq(src, callee.p0, callee.p1, b"addr_of") || span_eq(src, callee.p0, callee.p1, b"addr_of_mut") {
        let _t: u32 = gen_place_addr(c, pp, src, nd.b);
        return W_USIZE;
    }
    if span_eq(src, callee.p0, callee.p1, b"ptr_read") { return gen_ptr_read(c, pp, src, i); }
    if span_eq(src, callee.p0, callee.p1, b"ptr_write") { return gen_ptr_write(c, pp, src, i); }
    if span_eq(src, callee.p0, callee.p1, b"ptr_offset") { return gen_ptr_offset(c, pp, src, i); }
    if span_eq(src, callee.p0, callee.p1, b"unbox") { return gen_unbox(c, pp, src, i); }
    if span_eq(src, callee.p0, callee.p1, b"is_null") {
        let _v: i32 = gen_value(c, pp, src, nd.b, W_USIZE);
        bi(c, b"testq %rax, %rax");
        bi(c, b"sete %al");
        bi(c, b"movzbq %al, %rax");
        return W_BOOL;
    }
    if span_eq(src, callee.p0, callee.p1, b"ptr_to_addr") {
        let _v: i32 = gen_value(c, pp, src, nd.b, W_USIZE);
        return W_USIZE;
    }
    if span_eq(src, callee.p0, callee.p1, b"len") { return gen_len(c, pp, src, i); }
    let mut fnid: u32 = nd.c;
    if fnid == 0u32 { fnid = find_fn(pp, src, c.head, callee.p0, callee.p1); }
    if fnid == 0u32 { return gen_indirect_call(c, pp, src, i); }
    let fnnd: Node = pp.nodes[conv usize fnid];
    let mut retn: u32 = 0u32;
    let mut ret_borrow: i32 = 0;
    if fnnd.e != 0u32 {
        retn = pp.nodes[conv usize fnnd.e].a;
        let rmode: i32 = pp.nodes[conv usize fnnd.e].op;
        if rmode == 1 || rmode == 2 { ret_borrow = 1; }
    }
    let mut retw: i32 = scalar_width(pp, src, retn);
    if ret_borrow != 0 { retw = W_USIZE; retn = 0u32; }
    // Evaluate args into fresh temp slots (left to right), then load arg regs.
    let mut argslots: [16]i32 = [0i32; 16];
    let mut na: usize = 0usize;
    let mut argc: u32 = nd.b;
    let mut parc: u32 = fnnd.c;
    while argc != 0u32 {
        let pty: u32 = pp.nodes[conv usize parc].a;
        let pw: i32 = scalar_width(pp, src, pty);
        if pw != 0 {
            let _aw: i32 = gen_value(c, pp, src, argc, pw);
        } else {
            let _at: u32 = gen_agg(c, pp, src, argc, pty);
        }
        argslots[na] = spill(c);
        if pw == 0 && !is_copy(pp, src, c.head, pty) { mark_moved(c, pp, src, argc); }
        na = na + 1usize;
        argc = pp.nodes[conv usize argc].nx;
        parc = pp.nodes[conv usize parc].nx;
    }
    let mut k: usize = 0usize;
    while k < na {
        bc(c, 9);
        bs(c, b"movq ");
        bslot(c, argslots[k]);
        bs(c, b", ");
        emit_arg_reg(c, k);
        bc(c, 10);
        k = k + 1usize;
    }
    bc(c, 9);
    bs(c, b"call cnr_");
    emit_fn_sym_pool(c, pp, src, fnid);
    bc(c, 10);
    if retw != 0 { return retw; }
    if retn != 0u32 && ty_size(pp, src, c.head, retn) > 0usize {
        c.*.cur_agg_ty = retn;
        return W_AGG;
    }
    return 12;
}

// ---- NG2: the `?` operator + From-widening ----------------------------------
// `expr?` (T_TRY): evaluate the operand to a result-shaped enum, then branch on its
// ok/err tag. The ok arm unwraps the word-sized ok payload as the `?` value and joins;
// the err arm From-widens the error payload to the enclosing fn's error type and early-
// returns the widened result enum. Mirrors lower.cnr lower_try + interp.cnr eval_try. The
// result-enum shape marks its ok variant with T_VARIANT.op == 1 (0-based variant index).
fn ok_variant_index_cg(pp: read P, eid: u32) -> i32 {
    if eid == 0u32 { return 0i32 - 1i32; }
    let enode: Node = pp.nodes[conv usize eid];
    let mut cur: u32 = enode.b;
    let mut k: i32 = 0;
    while cur != 0u32 {
        let vd: Node = pp.nodes[conv usize cur];
        if vd.op == 1 { return k; }
        k = k + 1i32;
        cur = vd.nx;
    }
    return 0i32 - 1i32;
}
fn err_variant_index_cg(pp: read P, eid: u32) -> i32 {
    if eid == 0u32 { return 0i32 - 1i32; }
    let enode: Node = pp.nodes[conv usize eid];
    let mut cur: u32 = enode.b;
    let mut k: i32 = 0;
    while cur != 0u32 {
        let vd: Node = pp.nodes[conv usize cur];
        if vd.op != 1 { return k; }
        k = k + 1i32;
        cur = vd.nx;
    }
    return 0i32 - 1i32;
}
// `impl From[src] for tgt`'s owning concrete T_IMPL node (0 if none): iface name `From`,
// target enum == tgt_eid, iface arg-0 enum == src_eid (mirrors lower.cnr find_from_impl).
// mono has already instantiated a generic From impl into a concrete (a == 0) T_IMPL.
fn find_from_impl_cg(pp: read P, src: [u8], head: u32, src_eid: u32, tgt_eid: u32) -> u32 {
    let mut cur: u32 = head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_IMPL && nd.a == 0u32 && span_eq(src, nd.p0, nd.p1, b"From") {
            let te: u32 = enum_of_ty(pp, src, head, nd.c);
            let mut se: u32 = 0u32;
            if nd.b != 0u32 { se = enum_of_ty(pp, src, head, nd.b); }
            if te == tgt_eid && se == src_eid { return cur; }
        }
        cur = pp.nodes[conv usize cur].nx;
    }
    return 0u32;
}
fn from_method_of_cg(pp: read P, src: [u8], impl_id: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize impl_id];
    let mut mc: u32 = nd.d;
    while mc != 0u32 {
        let mnd: Node = pp.nodes[conv usize mc];
        if span_eq(src, mnd.p0, mnd.p1, b"from") { return mc; }
        mc = mnd.nx;
    }
    return 0u32;
}
// The err arm: From-widen the operand's active error payload (e1) into the enclosing fn's
// error type (e2), build the return enum (tag = error variant, payload = the widened e2),
// and leave its flat offset in %rax (aggregate return convention). Same result type (no
// widening) leaves the operand offset in %rax as-is. Mirrors lower.cnr lower_try_from +
// interp.cnr eval_try_from. The `from(e1)` call rides the established impl-method ABI:
// e1 by value when word-sized, else by address (its flat offset), in %rdi.
fn gen_try_from(c: write C, pp: read P, src: [u8], s_local: i32, eid: u32) -> unit {
    let err_idx: i32 = err_variant_index_cg(pp, eid);
    let evid: u32 = variant_by_index(pp, eid, err_idx);
    let e1ty: u32 = variant_payload_ty(pp, evid, 0);
    let e1off: usize = variant_payload_off(pp, src, c.head, evid, 0);
    let e1_eid: u32 = enum_of_ty(pp, src, c.head, e1ty);
    let rty: u32 = c.ret_ty;
    let reid: u32 = enum_of_ty(pp, src, c.head, rty);
    if reid == eid {
        reload_rax(c, s_local);
        return;
    }
    let ret_err_idx: i32 = err_variant_index_cg(pp, reid);
    let rvid: u32 = variant_by_index(pp, reid, ret_err_idx);
    let e2ty: u32 = variant_payload_ty(pp, rvid, 0);
    let e2off: usize = variant_payload_off(pp, src, c.head, rvid, 0);
    let e2_eid: u32 = enum_of_ty(pp, src, c.head, e2ty);
    let impl_id: u32 = find_from_impl_cg(pp, src, c.head, e1_eid, e2_eid);
    if impl_id == 0u32 { c.*.err = 1; return; }
    let from_fn: u32 = from_method_of_cg(pp, src, impl_id);
    if from_fn == 0u32 { c.*.err = 1; return; }
    let pw: i32 = scalar_width(pp, src, e1ty);
    reload_rax(c, s_local);
    if e1off != 0usize { bc(c, 9); bs(c, b"addq $"); bn(c, conv u64 e1off); bs(c, b", %rax"); bc(c, 10); }
    if pw != 0 { emit_load_flat(c, pw); }
    bi(c, b"movq %rax, %rdi");
    bc(c, 9); bs(c, b"call cnr_meth."); bn(c, conv u64 from_fn); bc(c, 10);
    let from_slot: i32 = spill(c);
    let size: usize = enum_size(pp, src, c.head, reid);
    let align: usize = ty_align(pp, src, c.head, rty);
    emit_alloc(c, size, align);
    let ret_slot: i32 = spill(c);
    emit_const(c, conv u64 ret_err_idx, 0);
    emit_store_flat(c, 9, ret_slot, 0usize);
    reload_rax(c, from_slot);
    emit_copy_to(c, ret_slot, e2off, ty_size(pp, src, c.head, e2ty));
    reload_rax(c, ret_slot);
    return;
}
fn gen_try(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    // Materialize the operand enum; its flat offset lives in s_local.
    let op_ty: u32 = gen_agg(c, pp, src, nd.a, 0u32);
    let s_local: i32 = spill(c);
    let eid: u32 = enum_of_ty(pp, src, c.head, op_ty);
    if eid == 0u32 { c.*.err = 1; return 4; }
    let ok_idx: i32 = ok_variant_index_cg(pp, eid);
    if ok_idx < 0 { c.*.err = 1; return 4; }
    // Read tag@0 once and compare against the ok index.
    reload_rax(c, s_local);
    emit_load_flat(c, 9);
    let tag_slot: i32 = spill(c);
    let errl: i32 = newlbl(c);
    let join: i32 = newlbl(c);
    reload_rax(c, tag_slot);
    bc(c, 9); bs(c, b"cmpq $"); bn(c, conv u64 ok_idx); bs(c, b", %rax"); bc(c, 10);
    bc(c, 9); bs(c, b"jne "); blabel_ref(c, errl); bc(c, 10);
    // Ok arm: unwrap the word-sized ok payload as the `?` value, store it, join.
    let okvid: u32 = variant_by_index(pp, eid, ok_idx);
    let okpty: u32 = variant_payload_ty(pp, okvid, 0);
    let okoff: usize = variant_payload_off(pp, src, c.head, okvid, 0);
    let okw: i32 = scalar_width(pp, src, okpty);
    if okw == 0 { c.*.err = 1; return 4; }
    let res_slot: i32 = newslot(c);
    reload_rax(c, s_local);
    if okoff != 0usize { bc(c, 9); bs(c, b"addq $"); bn(c, conv u64 okoff); bs(c, b", %rax"); bc(c, 10); }
    emit_load_flat(c, okw);
    store_slot(c, res_slot);
    bc(c, 9); bs(c, b"jmp "); blabel_ref(c, join); bc(c, 10);
    // Err arm: From-widen the error payload, then run the fn's return sequence early.
    blabel_def(c, errl);
    gen_try_from(c, pp, src, s_local, eid);
    let rs: i32 = spill(c);
    emit_return_drops(c, pp, src);
    reload_rax(c, rs);
    emit_epilogue(c);
    blabel_def(c, join);
    reload_rax(c, res_slot);
    return okw;
}
// One match arm: bind the matched variant's payload sub-patterns in a fresh drop-scope
// (scalar copy loads the value; an aggregate payload byte-copies into a fresh local; a
// non-copy payload additionally marks the scrutinee's `_i` path moved and registers the
// bound local for drop), emit the arm body, then drop the arm scope. `idx < 0` (a
// wildcard/binding arm) binds nothing, mirroring lower.cnr lower_match_arm.
fn gen_match_arm(c: write C, pp: read P, src: [u8], arm: u32, scrut: u32, scrut_slot: i32, eid: u32, idx: i32, want_val: i32, res_slot: i32, res_w: i32, res_ty: u32) -> unit {
    let an: Node = pp.nodes[conv usize arm];
    let pat: Node = pp.nodes[conv usize an.a];
    let bsave: usize = c.bnd_n;
    scope_push(c);
    if idx >= 0 && pat.tag == T_PVARIANT {
        let vid: u32 = variant_by_index(pp, eid, idx);
        let mut sp: u32 = pat.b;
        let mut i: i32 = 0;
        while sp != 0u32 {
            let spn: Node = pp.nodes[conv usize sp];
            if spn.tag == T_PVARIANT {
                c.*.err = 1;
                scope_pop_drops(c, pp, src);
                c.*.bnd_n = bsave;
                return;
            }
            if spn.tag != T_WILD {
                let pty: u32 = variant_payload_ty(pp, vid, i);
                let off: usize = variant_payload_off(pp, src, c.head, vid, i);
                let w: i32 = scalar_width(pp, src, pty);
                if w != 0 {
                    let loc: i32 = newslot(c);
                    reload_rax(c, scrut_slot);
                    if off != 0usize {
                        bc(c, 9); bs(c, b"addq $"); bn(c, conv u64 off); bs(c, b", %rax"); bc(c, 10);
                    }
                    emit_load_flat(c, w);
                    store_slot(c, loc);
                    bind(c, spn.p0, spn.p1, loc, w, pty, 0i32 - 1i32, 0);
                } else {
                    let size: usize = ty_size(pp, src, c.head, pty);
                    let al: usize = ty_align(pp, src, c.head, pty);
                    let loc: i32 = newslot(c);
                    emit_alloc(c, size, al);
                    store_slot(c, loc);
                    reload_rax(c, scrut_slot);
                    if off != 0usize {
                        bc(c, 9); bs(c, b"addq $"); bn(c, conv u64 off); bs(c, b", %rax"); bc(c, 10);
                    }
                    emit_copy_to(c, loc, 0usize, size);
                    let mut lid: i32 = 0i32 - 1i32;
                    if !is_copy(pp, src, c.head, pty) {
                        mark_moved_payload(c, pp, src, scrut, i);
                        if needs_drop(pp, src, c.head, pty) {
                            lid = reg_dloc(c, loc, pty);
                        }
                    }
                    bind(c, spn.p0, spn.p1, loc, 0, pty, lid, 0);
                }
            }
            i = i + 1i32;
            sp = spn.nx;
        }
    }
    if want_val != 0 {
        if res_w != 0 {
            let _v: i32 = gen_value(c, pp, src, an.b, res_w);
            emit_canon(c, res_w);
            store_slot(c, res_slot);
        } else {
            let _t: u32 = gen_agg(c, pp, src, an.b, res_ty);
            emit_copy_to(c, res_slot, 0usize, ty_size(pp, src, c.head, res_ty));
        }
    } else {
        let _sc: i32 = gen_value(c, pp, src, an.b, 0i32 - 1i32);
    }
    scope_pop_drops(c, pp, src);
    c.*.bnd_n = bsave;
    return;
}
// T_MATCH: resolve the scrutinee place to its flat offset, read the tag@0 once, then a
// per-arm test chain -- a variant arm compares the tag and `jne`s past its arm block
// (first-match order); a wildcard/binding arm is the unconditional tail. Each arm jumps
// to the shared join; a non-exhaustive tail faults (Panic). Mirrors lower.cnr
// lower_match_full's Cmp/Branch shape.
// Resolve a match scrutinee to its enum value's flat offset in %rax, returning the
// enum type node. A place scrutinee resolves directly; a non-place scrutinee (recorded
// in the mat table) is either an owned aggregate value materialized in place, or a
// borrow-returning call whose result IS the pointee address (mirrors lower.cnr
// lower_match_full's materialize/hold split).
fn gen_match_scrut(c: write C, pp: read P, src: [u8], scrut: u32) -> u32 {
    let midx: i32 = mat_lookup(c, scrut);
    if midx >= 0 {
        let stn: u32 = c.mat_tn[conv usize midx];
        if c.mat_hold[conv usize midx] != 0 {
            let _w: i32 = gen_value(c, pp, src, scrut, W_USIZE);
        } else {
            let _t: u32 = gen_agg(c, pp, src, scrut, stn);
        }
        return stn;
    }
    return gen_place_addr(c, pp, src, scrut);
}
// The shared match core: resolve the scrutinee, read tag@0 once, per-arm test chain.
// `want_val != 0` routes each arm's result into `res_slot` (scalar store / aggregate
// copy); otherwise the arm is a statement. Mirrors lower.cnr lower_match_full.
fn gen_match_core(c: write C, pp: read P, src: [u8], i: u32, want_val: i32, res_slot: i32, res_w: i32, res_ty: u32) -> unit {
    let nd: Node = pp.nodes[conv usize i];
    let scrut: u32 = nd.a;
    let stn: u32 = gen_match_scrut(c, pp, src, scrut);
    let scrut_slot: i32 = spill(c);
    let eid: u32 = enum_of_ty(pp, src, c.head, stn);
    if eid == 0u32 { c.*.err = 1; return; }
    reload_rax(c, scrut_slot);
    emit_load_flat(c, 9);
    let tag_slot: i32 = spill(c);
    let join: i32 = newlbl(c);
    let mut test_open: i32 = 1;
    let mut arm: u32 = nd.b;
    while arm != 0u32 {
        if test_open == 0 { break; }
        let an: Node = pp.nodes[conv usize arm];
        let pat: Node = pp.nodes[conv usize an.a];
        if pat.tag == T_WILD || pat.tag == T_BIND {
            gen_match_arm(c, pp, src, arm, scrut, scrut_slot, eid, 0i32 - 1i32, want_val, res_slot, res_w, res_ty);
            bc(c, 9); bs(c, b"jmp "); blabel_ref(c, join); bc(c, 10);
            test_open = 0;
        } else {
            let vname: Node = pp.nodes[conv usize pat.a];
            let vidx: i32 = variant_index_by_name(pp, src, eid, vname.p0, vname.p1);
            if vidx < 0 { c.*.err = 1; return; }
            let nextl: i32 = newlbl(c);
            reload_rax(c, tag_slot);
            bc(c, 9); bs(c, b"cmpq $"); bn(c, conv u64 vidx); bs(c, b", %rax"); bc(c, 10);
            bc(c, 9); bs(c, b"jne "); blabel_ref(c, nextl); bc(c, 10);
            gen_match_arm(c, pp, src, arm, scrut, scrut_slot, eid, vidx, want_val, res_slot, res_w, res_ty);
            bc(c, 9); bs(c, b"jmp "); blabel_ref(c, join); bc(c, 10);
            blabel_def(c, nextl);
        }
        arm = an.nx;
    }
    if test_open != 0 {
        emit_fault(c, FK_PANIC, nd.p0, nd.p1);
    }
    blabel_def(c, join);
    return;
}
fn gen_match(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    gen_match_core(c, pp, src, i, 0, 0i32 - 1i32, 0, 0u32);
    return 12;
}
// A value-producing match (build.rs dst): materialize each arm's aggregate result into
// a fresh flat temp and leave its offset in %rax (aggregate convention).
fn gen_match_value(c: write C, pp: read P, src: [u8], i: u32, exp_ty: u32) -> u32 {
    let size: usize = ty_size(pp, src, c.head, exp_ty);
    let align: usize = ty_align(pp, src, c.head, exp_ty);
    let res_slot: i32 = newslot(c);
    emit_alloc(c, size, align);
    store_slot(c, res_slot);
    gen_match_core(c, pp, src, i, 1, res_slot, 0, exp_ty);
    reload_rax(c, res_slot);
    c.*.cur_agg_ty = exp_ty;
    return exp_ty;
}
fn gen_if(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let _cw: i32 = gen_value(c, pp, src, nd.a, W_BOOL);
    let elsel: i32 = newlbl(c);
    let endl: i32 = newlbl(c);
    bi(c, b"testq %rax, %rax");
    bc(c, 9);
    bs(c, b"jz ");
    blabel_ref(c, elsel);
    bc(c, 10);
    let _s1: i32 = gen_block(c, pp, src, nd.b);
    bc(c, 9);
    bs(c, b"jmp ");
    blabel_ref(c, endl);
    bc(c, 10);
    blabel_def(c, elsel);
    if nd.c != 0u32 {
        let _s2: i32 = gen_value(c, pp, src, nd.c, 0i32 - 1i32);
    }
    blabel_def(c, endl);
    return 12;
}

fn gen_while(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let headl: i32 = newlbl(c);
    let exitl: i32 = newlbl(c);
    blabel_def(c, headl);
    let _cw: i32 = gen_value(c, pp, src, nd.a, W_BOOL);
    bi(c, b"testq %rax, %rax");
    bc(c, 9);
    bs(c, b"jz ");
    blabel_ref(c, exitl);
    bc(c, 10);
    c.*.loop_cont[c.loop_n] = headl;
    c.*.loop_brk[c.loop_n] = exitl;
    c.*.loop_depth[c.loop_n] = c.sco_depth;
    c.*.loop_n = c.loop_n + 1usize;
    let _s1: i32 = gen_block(c, pp, src, nd.b);
    c.*.loop_n = c.loop_n - 1usize;
    bc(c, 9);
    bs(c, b"jmp ");
    blabel_ref(c, headl);
    bc(c, 10);
    blabel_def(c, exitl);
    return 12;
}

fn gen_loop(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let bodyl: i32 = newlbl(c);
    let exitl: i32 = newlbl(c);
    blabel_def(c, bodyl);
    c.*.loop_cont[c.loop_n] = bodyl;
    c.*.loop_brk[c.loop_n] = exitl;
    c.*.loop_depth[c.loop_n] = c.sco_depth;
    c.*.loop_n = c.loop_n + 1usize;
    let _s1: i32 = gen_block(c, pp, src, nd.a);
    c.*.loop_n = c.loop_n - 1usize;
    bc(c, 9);
    bs(c, b"jmp ");
    blabel_ref(c, bodyl);
    bc(c, 10);
    blabel_def(c, exitl);
    return 12;
}

fn gen_assert(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let _cw: i32 = gen_value(c, pp, src, nd.a, W_BOOL);
    let fp0: usize = c.cur_p0;
    let fp1: usize = c.cur_p1;
    bi(c, b"testq %rax, %rax");
    let okl: i32 = newlbl(c);
    bc(c, 9);
    bs(c, b"jnz ");
    blabel_ref(c, okl);
    bc(c, 10);
    emit_fault(c, FK_ASSERT, fp0, fp1);
    blabel_def(c, okl);
    return 12;
}

fn emit_epilogue(c: write C) -> unit {
    bi(c, b"movq %rbp, %rsp");
    bi(c, b"popq %rbp");
    bi(c, b"ret");
    return;
}

fn gen_return(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    if nd.a != 0u32 {
        if c.ret_w != 0 {
            let _w: i32 = gen_value(c, pp, src, nd.a, c.ret_w);
            emit_canon(c, c.ret_w);
        } else if c.ret_ty != 0u32 && ty_size(pp, src, c.head, c.ret_ty) > 0usize {
            let _t: u32 = gen_agg(c, pp, src, nd.a, c.ret_ty);
            if !is_copy(pp, src, c.head, c.ret_ty) { mark_moved(c, pp, src, nd.a); }
        } else {
            let _w: i32 = gen_value(c, pp, src, nd.a, c.ret_w);
            emit_canon(c, c.ret_w);
        }
        // The returned value is consumed (moved out); drop the rest, preserving it.
        let rs: i32 = spill(c);
        emit_return_drops(c, pp, src);
        reload_rax(c, rs);
    } else {
        emit_return_drops(c, pp, src);
        bi(c, b"xorl %eax, %eax");
    }
    emit_epilogue(c);
    return 12;
}

fn gen_stmt(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_LET {
        let tn: u32 = nd.a;
        if is_agg_ty(pp, src, c.head, tn) {
            let size: usize = ty_size(pp, src, c.head, tn);
            let align: usize = ty_align(pp, src, c.head, tn);
            let s: i32 = newslot(c);
            emit_alloc(c, size, align);
            store_slot(c, s);
            if nd.b != 0u32 {
                let _t: u32 = gen_agg(c, pp, src, nd.b, tn);
                emit_copy_to(c, s, 0usize, size);
                if !is_copy(pp, src, c.head, tn) { mark_moved(c, pp, src, nd.b); }
            }
            let mut lid: i32 = 0i32 - 1i32;
            if needs_drop(pp, src, c.head, tn) && !is_copy(pp, src, c.head, tn) {
                lid = reg_dloc(c, s, tn);
            }
            bind(c, nd.p0, nd.p1, s, 0, tn, lid, 0);
            return 0;
        }
        let mut w: i32 = scalar_width(pp, src, tn);
        let s: i32 = newslot(c);
        // A scalar whose address is taken must live in FLAT memory (so addr_of and
        // through-pointer writes alias its real storage); its slot holds the offset.
        if w != 0 && is_addr_taken(c, src, nd.p0, nd.p1) {
            emit_alloc(c, wsize(w), wsize(w));
            store_slot(c, s);
            if nd.b != 0u32 {
                let _v: i32 = gen_value(c, pp, src, nd.b, w);
                emit_canon(c, w);
                emit_store_flat(c, w, s, 0usize);
            }
            bind(c, nd.p0, nd.p1, s, w, tn, 0i32 - 1i32, 1);
            return 0;
        }
        if nd.b != 0u32 {
            let vw: i32 = gen_value(c, pp, src, nd.b, w);
            if w == 0 { w = vw; }
            emit_canon(c, w);
            store_slot(c, s);
        }
        bind(c, nd.p0, nd.p1, s, w, tn, 0i32 - 1i32, 0);
        return 0;
    }
    if nd.tag == T_ASSIGN {
        let place: Node = pp.nodes[conv usize nd.a];
        if place.tag == T_ID {
            let slot: i32 = lookup(c, src, place.p0, place.p1);
            if slot < 0 { c.*.err = 1; return 1; }
            let w: i32 = c.luk_w;
            let is_flat: i32 = c.luk_flat;
            if w != 0 {
                let _vw: i32 = gen_value(c, pp, src, nd.b, w);
                emit_canon(c, w);
                if is_flat != 0 { emit_store_flat(c, w, slot, 0usize); } else { store_slot(c, slot); }
                return 0;
            }
            let aty: u32 = c.luk_ty;
            let _t: u32 = gen_agg(c, pp, src, nd.b, aty);
            emit_copy_to(c, slot, 0usize, ty_size(pp, src, c.head, aty));
            return 0;
        }
        let pty: u32 = gen_place_addr(c, pp, src, nd.a);
        let pw: i32 = scalar_width(pp, src, pty);
        let pslot: i32 = spill(c);
        if pw != 0 {
            let _vw: i32 = gen_value(c, pp, src, nd.b, pw);
            emit_canon(c, pw);
            emit_store_flat(c, pw, pslot, 0usize);
            return 0;
        }
        let _t: u32 = gen_agg(c, pp, src, nd.b, pty);
        emit_copy_to(c, pslot, 0usize, ty_size(pp, src, c.head, pty));
        return 0;
    }
    let _r: i32 = gen_value(c, pp, src, i, 0i32 - 1i32);
    return 0;
}

fn gen_block(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let bsave: usize = c.bnd_n;
    scope_push(c);
    let nd: Node = pp.nodes[conv usize i];
    let mut cur: u32 = nd.a;
    while cur != 0u32 {
        let _s: i32 = gen_stmt(c, pp, src, cur);
        cur = pp.nodes[conv usize cur].nx;
    }
    scope_pop_drops(c, pp, src);
    c.*.bnd_n = bsave;
    return 0;
}

fn gen_fn(c: write C, pp: read P, src: [u8], fnid: u32, kind: i32) -> unit {
    let nd: Node = pp.nodes[conv usize fnid];
    // reset per-function state
    c.*.bbuf_n = 0usize;
    c.*.bnd_n = 0usize;
    c.*.slot_next = 0usize;
    c.*.slot_max = 0usize;
    c.*.loop_n = 0usize;
    c.*.regime = 0;
    c.*.sco_n = 0usize;
    c.*.sco_depth = 0usize;
    c.*.mv_n = 0usize;
    c.*.mv_seg_n = 0usize;
    c.*.dloc_n = 0usize;
    let mut retn: u32 = 0u32;
    if nd.e != 0u32 { retn = pp.nodes[conv usize nd.e].a; }
    c.*.ret_w = scalar_width(pp, src, retn);
    c.*.ret_ty = retn;
    // A borrow-returning fn (`-> read/write T`) yields the pointee ADDRESS: a word-
    // sized scalar, never an aggregate copy.
    if nd.e != 0u32 {
        let rmode: i32 = pp.nodes[conv usize nd.e].op;
        if rmode == 1 || rmode == 2 { c.*.ret_w = W_USIZE; c.*.ret_ty = 0u32; }
    }
    // params: slot per param (in declaration order), bound to their names. An owned
    // aggregate param (by value) that needs drop is registered in the param scope.
    scope_push(c);
    let mut pslots: [16]i32 = [0i32; 16];
    let mut ptys: [16]u32 = [0u32; 16];
    let mut pc: u32 = nd.c;
    let mut np: usize = 0usize;
    while pc != 0u32 {
        let pn: Node = pp.nodes[conv usize pc];
        let pw: i32 = scalar_width(pp, src, pn.a);
        let s: i32 = newslot(c);
        let mut plid: i32 = 0i32 - 1i32;
        if pw == 0 && needs_drop(pp, src, c.head, pn.a) && !is_copy(pp, src, c.head, pn.a) {
            plid = reg_dloc(c, s, pn.a);
        }
        bind(c, pn.p0, pn.p1, s, pw, pn.a, plid, 0);
        pslots[np] = s;
        ptys[np] = pn.a;
        np = np + 1usize;
        pc = pn.nx;
    }
    // copy incoming argument registers into the param slots.
    let mut k: usize = 0usize;
    while k < np {
        bc(c, 9);
        bs(c, b"movq ");
        emit_arg_reg(c, k);
        bs(c, b", ");
        bslot(c, pslots[k]);
        bc(c, 10);
        k = k + 1usize;
    }
    // Aggregate params arrive as a pointer (the caller's Candor offset); copy the
    // bytes into a fresh flat-memory local so the callee owns its by-value copy
    // (mirrors lower.rs's aggregate-param prologue).
    let mut k2: usize = 0usize;
    while k2 < np {
        let pty: u32 = ptys[k2];
        if is_agg_ty(pp, src, c.head, pty) {
            let size: usize = ty_size(pp, src, c.head, pty);
            let align: usize = ty_align(pp, src, c.head, pty);
            reload_rax(c, pslots[k2]);
            let ctmp: i32 = spill(c);
            emit_alloc(c, size, align);
            store_slot(c, pslots[k2]);
            emit_copy_from(c, pslots[k2], ctmp, size);
        }
        k2 = k2 + 1usize;
    }
    let _b: i32 = gen_block(c, pp, src, nd.d);
    // implicit return (fall-through): drop the param scope, then default _0 to 0.
    scope_pop_drops(c, pp, src);
    bi(c, b"xorl %eax, %eax");
    emit_epilogue(c);
    // Now the frame size is known; stream the function.
    emit_fn_streaming(c, pp, src, kind, fnid);
    return;
}
// Stream a compiled function's label + SysV prologue (frame sized from slot_max) + the
// buffered body. `kind`: 0 = free fn (`cnr_<name>[.<id>]`), 1 = drop hook
// (`cnr_drophk_<name>[.<id>]`), 3 = impl method (`cnr_meth.<id>`). A generic instance
// (ival != 0) gets a `.<nodeid>` suffix so its symbol is distinct from its siblings.
fn emit_fn_streaming(c: write C, pp: read P, src: [u8], kind: i32, defid: u32) -> unit {
    let nd: Node = pp.nodes[conv usize defid];
    let mut frame: usize = 8usize * c.slot_max;
    frame = ((frame + 15usize) / 16usize) * 16usize;
    trace(10);
    if kind == 3 {
        emit_bytes_direct(b"cnr_meth.");
        emit_num_direct(conv u64 defid);
    } else {
        emit_bytes_direct(b"cnr_");
        if kind == 1 { emit_bytes_direct(b"drophk_"); }
        let mut j: usize = nd.p0;
        while j < nd.p1 {
            trace(conv i64 src[j]);
            j = j + 1usize;
        }
        if nd.ival != 0u64 { trace(46); emit_num_direct(conv u64 defid); }
    }
    trace(58); trace(10); // ":\n"
    emit_line(b"pushq %rbp");
    emit_line(b"movq %rsp, %rbp");
    if frame > 0usize {
        trace(9);
        emit_bytes_direct(b"subq $");
        emit_num_direct(conv u64 frame);
        emit_bytes_direct(b", %rsp");
        trace(10);
    }
    let mut bi2: usize = 0usize;
    while bi2 < c.bbuf_n {
        trace(conv i64 c.bbuf[bi2]);
        bi2 = bi2 + 1usize;
    }
    return;
}
// Emit a struct drop hook `drop(write self) { ... }` as an asm fn `cnr_drophk_<Name>`.
// `self` is a borrow: its slot holds the flat offset passed in %rdi (no by-value
// copy), so `self.field` reads/writes the caller's value. Reuses the N1/N2 body gen.
fn gen_hook(c: write C, pp: read P, src: [u8], sid: u32) -> unit {
    let snode: Node = pp.nodes[conv usize sid];
    c.*.bbuf_n = 0usize;
    c.*.bnd_n = 0usize;
    c.*.slot_next = 0usize;
    c.*.slot_max = 0usize;
    c.*.loop_n = 0usize;
    c.*.regime = 0;
    c.*.sco_n = 0usize;
    c.*.sco_depth = 0usize;
    c.*.mv_n = 0usize;
    c.*.mv_seg_n = 0usize;
    c.*.dloc_n = 0usize;
    c.*.ret_w = 0;
    c.*.ret_ty = 0u32;
    let selfslot: i32 = newslot(c);
    bc(c, 9); bs(c, b"movq %rdi, "); bslot(c, selfslot); bc(c, 10);
    let sp0: usize = find_self(src);
    bind(c, sp0, sp0 + 4usize, selfslot, 0, sid, 0i32 - 1i32, 0);
    let _b: i32 = gen_block(c, pp, src, snode.c);
    bi(c, b"xorl %eax, %eax");
    emit_epilogue(c);
    emit_fn_streaming(c, pp, src, 1, sid);
    return;
}

// Emit a per-enum drop-glue fn `cnr_dropenum_<eid>(%rdi = value flat offset)`: run the
// enum's tag-directed drop (no partial-move info). A self-referential enum's payload drop
// re-enters this glue via a `call`, so recursion is bounded at runtime, not at codegen.
fn gen_enum_glue(c: write C, pp: read P, src: [u8], eid: u32) -> unit {
    c.*.bbuf_n = 0usize;
    c.*.bnd_n = 0usize;
    c.*.slot_next = 0usize;
    c.*.slot_max = 0usize;
    c.*.loop_n = 0usize;
    c.*.regime = 0;
    c.*.sco_n = 0usize;
    c.*.sco_depth = 0usize;
    c.*.mv_n = 0usize;
    c.*.mv_seg_n = 0usize;
    c.*.dloc_n = 0usize;
    c.*.ret_w = 0;
    c.*.ret_ty = 0u32;
    let selfslot: i32 = newslot(c);
    bc(c, 9); bs(c, b"movq %rdi, "); bslot(c, selfslot); bc(c, 10);
    emit_enum_drop(c, pp, src, selfslot, eid, 0i32 - 1i32);
    bi(c, b"xorl %eax, %eax");
    emit_epilogue(c);
    emit_glue_streaming(c, eid);
    return;
}
fn emit_glue_streaming(c: write C, eid: u32) -> unit {
    let mut frame: usize = 8usize * c.slot_max;
    frame = ((frame + 15usize) / 16usize) * 16usize;
    trace(10);
    emit_bytes_direct(b"cnr_dropenum_");
    emit_num_direct(conv u64 eid);
    trace(58); trace(10);
    emit_line(b"pushq %rbp");
    emit_line(b"movq %rsp, %rbp");
    if frame > 0usize {
        trace(9);
        emit_bytes_direct(b"subq $");
        emit_num_direct(conv u64 frame);
        emit_bytes_direct(b", %rsp");
        trace(10);
    }
    let mut bi2: usize = 0usize;
    while bi2 < c.bbuf_n {
        trace(conv i64 c.bbuf[bi2]);
        bi2 = bi2 + 1usize;
    }
    return;
}
fn emit_bytes_direct(s: [u8]) -> unit {
    let mut i: usize = 0usize;
    while i < len(s) {
        trace(conv i64 s[i]);
        i = i + 1usize;
    }
    return;
}
fn emit_num_direct(v: u64) -> unit {
    if v == 0u64 { trace(48); return; }
    let mut b: [24]u8 = [0u8; 24];
    let mut cnt: usize = 0usize;
    let mut x: u64 = v;
    while x > 0u64 {
        b[cnt] = conv u8 (48u64 + x % 10u64);
        x = x / 10u64;
        cnt = cnt + 1usize;
    }
    let mut i: usize = cnt;
    while i > 0usize {
        i = i - 1usize;
        trace(conv i64 b[i]);
    }
    return;
}
fn emit_line(s: [u8]) -> unit {
    trace(9);
    emit_bytes_direct(s);
    trace(10);
    return;
}

// ---- N5: box/alloc/rawptr/fnptr/statics ------------------------------------
// rawptr/fnptr are 8-byte scalars whose stored value is the CANDOR FLAT OFFSET
// (a rawptr) or the callee's code address (a fn-ptr). Deref/ptr_read compute
// MEM_BASE+offset (the same address model as the N2 flat aggregates + lower.rs).

fn wsize(w: i32) -> usize {
    let b: i32 = bits_of(w);
    if b == 8 { return 1usize; }
    if b == 16 { return 2usize; }
    if b == 32 { return 4usize; }
    return 8usize;
}
// The pointee type of a rawptr type descriptor (rawptr/cast_ptr/addr_to_ptr/ptr_null).
fn rawptr_inner(pp: read P, tn: u32) -> u32 {
    if tn == 0u32 { return 0u32; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_RAWPTR || nd.tag == T_CASTPTR || nd.tag == T_ADDRTOPTR || nd.tag == T_PTRNULL {
        return nd.a;
    }
    return 0u32;
}
// Index of a top-level static by name, or -1.
fn find_static_idx(c: write C, src: [u8], p0: usize, p1: usize) -> i32 {
    let mut i: usize = 0usize;
    while i < c.st_n {
        if name_eq(src, p0, p1, c.st_p0[i], c.st_p1[i]) { return conv i32 i; }
        i = i + 1usize;
    }
    return 0i32 - 1i32;
}
// Whether a local name has its address taken anywhere (addr_of/addr_of_mut): such
// a scalar must be flat-allocated so a through-pointer write aliases its storage.
fn is_addr_taken(c: write C, src: [u8], p0: usize, p1: usize) -> bool {
    let mut i: usize = 0usize;
    while i < c.at_n {
        if name_eq(src, p0, p1, c.at_p0[i], c.at_p1[i]) { return true; }
        i = i + 1usize;
    }
    return false;
}
// The (non-pointer) static type of a place expression, WITHOUT emitting code:
// used to look up a field's declared type for pointee resolution.
fn expr_place_ty(c: write C, pp: read P, src: [u8], i: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_PAREN { return expr_place_ty(c, pp, src, nd.a); }
    if nd.tag == T_ID {
        let s: i32 = lookup(c, src, nd.p0, nd.p1);
        if s >= 0 { return c.luk_ty; }
        let si: i32 = find_static_idx(c, src, nd.p0, nd.p1);
        if si >= 0 { return c.st_ty[conv usize si]; }
        return 0u32;
    }
    if nd.tag == T_FIELD {
        let bt: u32 = expr_place_ty(c, pp, src, nd.a);
        let sid: u32 = struct_of_ty(pp, src, c.head, bt);
        return field_ty(pp, src, sid, nd.p0, nd.p1);
    }
    return 0u32;
}
// The static-type NODE of a rawptr-valued expression, for pointee resolution
// (mirrors interp's cur_ty threading). A typed local/field carries its rawptr
// node; a cast/addr_to/null IS its own descriptor; ptr_offset keeps its base's.
fn ptr_type_node(c: write C, pp: read P, src: [u8], i: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_PAREN { return ptr_type_node(c, pp, src, nd.a); }
    if nd.tag == T_CASTPTR || nd.tag == T_ADDRTOPTR || nd.tag == T_PTRNULL { return i; }
    if nd.tag == T_ID || nd.tag == T_FIELD { return expr_place_ty(c, pp, src, i); }
    if nd.tag == T_CALL {
        let callee: Node = pp.nodes[conv usize nd.a];
        if callee.tag == T_ID && span_eq(src, callee.p0, callee.p1, b"ptr_offset") {
            return ptr_type_node(c, pp, src, nd.b);
        }
        // A call returning a rawptr (e.g. `task_of(...) -> rawptr Task`): the pointee
        // is resolved from the callee's declared return type.
        if callee.tag == T_ID {
            let fid: u32 = find_fn(pp, src, c.head, callee.p0, callee.p1);
            if fid != 0u32 {
                let fnnd: Node = pp.nodes[conv usize fid];
                if fnnd.e != 0u32 { return pp.nodes[conv usize fnnd.e].a; }
            }
        }
    }
    return 0u32;
}
// Load a static's flat offset (its .data slot `cnr_stat<idx>`) into %rax.
fn emit_static_load(c: write C, idx: i32) -> unit {
    bc(c, 9); bs(c, b"movq cnr_stat"); bn(c, conv u64 idx); bs(c, b"(%rip), %rax"); bc(c, 10);
    return;
}
// A fn name as a value: its code address into %rax (fn-ptr value). `fnid` selects the
// concrete fn (a mono instance for a `name::[T]` generic value), so its symbol matches
// the definition (mangled `.<nodeid>` for instances).
fn emit_fn_addr(c: write C, pp: read P, src: [u8], fnid: u32) -> unit {
    bc(c, 9); bs(c, b"leaq cnr_");
    emit_fn_sym_pool(c, pp, src, fnid);
    bs(c, b"(%rip), %rax"); bc(c, 10);
    return;
}
// ---- structural Alloc / AllocVtable identification (name-agnostic) ----------
fn field_is_fnptr(pp: read P, src: [u8], sid: u32, name: [u8]) -> bool {
    let snode: Node = pp.nodes[conv usize sid];
    let mut cur: u32 = snode.b;
    while cur != 0u32 {
        let fd: Node = pp.nodes[conv usize cur];
        if span_eq(src, fd.p0, fd.p1, name) {
            let fty: Node = pp.nodes[conv usize fd.a];
            return fty.tag == T_FNPTR;
        }
        cur = fd.nx;
    }
    return false;
}
fn find_alloc_vt(pp: read P, src: [u8], head: u32) -> u32 {
    let mut cur: u32 = head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_STRUCT {
            if field_is_fnptr(pp, src, cur, b"alloc") && field_is_fnptr(pp, src, cur, b"free") { return cur; }
        }
        cur = nd.nx;
    }
    return 0u32;
}
fn find_alloc_handle(pp: read P, src: [u8], head: u32) -> u32 {
    let mut cur: u32 = head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_STRUCT {
            let mut fc: u32 = nd.b;
            while fc != 0u32 {
                let fd: Node = pp.nodes[conv usize fc];
                if span_eq(src, fd.p0, fd.p1, b"vt") {
                    let fty: Node = pp.nodes[conv usize fd.a];
                    if fty.tag == T_RAWPTR { return cur; }
                }
                fc = fd.nx;
            }
        }
        cur = nd.nx;
    }
    return 0u32;
}
// ---- BoxResult enum synthesis (mirrors interp synth_boxresults) -------------
fn cg_inode(p: write P, nd: Node) -> u32 {
    let i: u32 = p.n;
    p.*.nodes[conv usize i] = nd;
    p.*.n = i + 1u32;
    return i;
}
fn cg_needle(src: [u8], needle: [u8]) -> usize {
    let n: usize = len(src);
    let m: usize = len(needle);
    let mut i: usize = 0usize;
    while i + m <= n {
        let mut j: usize = 0usize;
        let mut ok: bool = true;
        while j < m {
            if src[i + j] != needle[j] { ok = false; break; }
            j = j + 1usize;
        }
        if ok { return i; }
        i = i + 1usize;
    }
    return n;
}
fn synth_boxresults(p: write P, src: [u8]) -> unit {
    let srclen: usize = len(src);
    let mut boxed0: usize = cg_needle(src, b"boxed");
    let mut boxed1: usize = boxed0 + 5usize;
    if boxed1 > srclen { boxed0 = 0usize; boxed1 = 0usize; }
    let mut oom0: usize = cg_needle(src, b"oom");
    let mut oom1: usize = oom0 + 3usize;
    if oom1 > srclen { oom0 = 0usize; oom1 = 0usize; }
    let n0: u32 = p.n;
    let mut i: u32 = 1u32;
    while i < n0 {
        let nd: Node = p.nodes[conv usize i];
        if nd.tag == T_BOXRESULT {
            let mut bn: Node = nnew(T_BOX);
            bn.a = nd.a;
            let boxid: u32 = cg_inode(p, bn);
            let mut vo: Node = nnew(T_VARIANT);
            vo.p0 = oom0;
            vo.p1 = oom1;
            let oomid: u32 = cg_inode(p, vo);
            let mut vb: Node = nnew(T_VARIANT);
            vb.p0 = boxed0;
            vb.p1 = boxed1;
            vb.a = boxid;
            vb.nx = oomid;
            let boxedid: u32 = cg_inode(p, vb);
            let mut en: Node = nnew(T_ENUM);
            en.op = 0;
            en.b = boxedid;
            let enid: u32 = cg_inode(p, en);
            p.*.nodes[conv usize i].c = enid;
        }
        i = i + 1u32;
    }
    return;
}
// ---- non-place match scrutinee: synthetic type nodes (mirrors lower.cnr prep_synth) --
fn is_ident_char_cg(b: u8) -> bool {
    if b >= 97u8 && b <= 122u8 { return true; }
    if b >= 65u8 && b <= 90u8 { return true; }
    if b >= 48u8 && b <= 57u8 { return true; }
    if b == 95u8 { return true; }
    return false;
}
fn match_at_cg(src: [u8], i: usize, kw: [u8]) -> bool {
    let k: usize = len(kw);
    let mut j: usize = 0usize;
    while j < k {
        if src[i + j] != kw[j] { return false; }
        j = j + 1usize;
    }
    return true;
}
// Find a whole-token occurrence of `kw` in `src`; returns its start or len(src).
fn find_tok_cg(src: [u8], kw: [u8]) -> usize {
    let n: usize = len(src);
    let k: usize = len(kw);
    if k == 0usize { return n; }
    let mut i: usize = 0usize;
    while i + k <= n {
        if match_at_cg(src, i, kw) {
            let mut before_ok: bool = true;
            if i > 0usize { before_ok = !is_ident_char_cg(src[i - 1usize]); }
            let mut after_ok: bool = true;
            if i + k < n { after_ok = !is_ident_char_cg(src[i + k]); }
            if before_ok && after_ok { return i; }
        }
        i = i + 1usize;
    }
    return n;
}
// A synthetic scalar type node (T_SC) for width `w`; spans the keyword in `src`.
fn synth_scalar_cg(p: write P, src: [u8], w: i32) -> u32 {
    let n: usize = len(src);
    let mut sp: usize = n;
    let mut ep: usize = n;
    if w == 4 { sp = find_tok_cg(src, b"i64"); ep = sp + 3usize; }
    else if w == 3 { sp = find_tok_cg(src, b"i32"); ep = sp + 3usize; }
    else if w == 8 { sp = find_tok_cg(src, b"u32"); ep = sp + 3usize; }
    else if w == 6 { sp = find_tok_cg(src, b"u8"); ep = sp + 2usize; }
    else if w == 9 { sp = find_tok_cg(src, b"u64"); ep = sp + 3usize; }
    else if w == 10 { sp = find_tok_cg(src, b"usize"); ep = sp + 5usize; }
    else if w == 5 { sp = find_tok_cg(src, b"isize"); ep = sp + 5usize; }
    let mut nd: Node = nnew(T_SC);
    nd.p0 = sp;
    nd.p1 = ep;
    return cg_inode(p, nd);
}
fn add_named_cg(p: write P, p0: usize, p1: usize) -> u32 {
    let mut nd: Node = nnew(T_NAMED);
    nd.p0 = p0;
    nd.p1 = p1;
    return cg_inode(p, nd);
}
fn add_array_cg(p: write P, size: u32, elem: u32) -> u32 {
    let mut nd: Node = nnew(T_ARRAY);
    nd.a = size;
    nd.b = elem;
    return cg_inode(p, nd);
}
fn add_boxresult_cg(p: write P, inner: u32) -> u32 {
    let mut nd: Node = nnew(T_BOXRESULT);
    nd.a = inner;
    return cg_inode(p, nd);
}
// The type node of a box(...) value argument (infer over the subset).
fn synth_ty_for_value(p: write P, src: [u8], e: u32) -> u32 {
    let nd: Node = p.nodes[conv usize e];
    if nd.tag == T_PAREN { return synth_ty_for_value(p, src, nd.a); }
    if nd.tag == T_INT { return synth_scalar_cg(p, src, lit_width(nd.suf, 4)); }
    if nd.tag == T_NEGINT { return synth_scalar_cg(p, src, lit_width(nd.suf, 4)); }
    if nd.tag == T_ARRAYREP {
        let elem: u32 = synth_ty_for_value(p, src, nd.a);
        return add_array_cg(p, nd.b, elem);
    }
    if nd.tag == T_ENUMCTOR { return add_named_cg(p, nd.p0, nd.p1); }
    if nd.tag == T_STRUCTLIT { return add_named_cg(p, nd.p0, nd.p1); }
    return 0u32;
}
fn is_place_cg(p: write P, i: u32) -> bool {
    let nd: Node = p.nodes[conv usize i];
    if nd.tag == T_PAREN { return is_place_cg(p, nd.a); }
    if nd.tag == T_ID || nd.tag == T_FIELD || nd.tag == T_INDEX { return true; }
    if nd.tag == T_PREFIX && nd.op == PF_DEREF { return true; }
    return false;
}
fn find_fn_w(p: write P, src: [u8], head: u32, p0: usize, p1: usize) -> u32 {
    let mut cur: u32 = head;
    while cur != 0u32 {
        let nd: Node = p.nodes[conv usize cur];
        if nd.tag == T_FN && name_eq(src, p0, p1, nd.p0, nd.p1) { return cur; }
        cur = nd.nx;
    }
    return 0u32;
}
// Wrap every `read`/`write` param's declared type in a synthetic borrow node, so the
// param is treated as a word-sized pointer (passed by address, drop-inert) rather than a
// by-value aggregate copy (mirrors lower.cnr new_local_borrow / build.rs borrow params).
fn synth_borrow_params(p: write P, src: [u8]) -> unit {
    let orig_n: u32 = p.n;
    let mut i: u32 = 1u32;
    while i < orig_n {
        let nd: Node = p.nodes[conv usize i];
        if nd.tag == T_PARAM && (nd.op == 1 || nd.op == 2) {
            let mut tag: i32 = T_BORROW;
            if nd.op == 2 { tag = T_BORROWMUT; }
            let mut bnode: Node = nnew(tag);
            bnode.a = nd.a;
            let bid: u32 = cg_inode(p, bnode);
            p.*.nodes[conv usize i].a = bid;
        }
        i = i + 1u32;
    }
    return;
}
// The recorded materialized-scrutinee index for `scrut`, or -1 if it is a place.
fn mat_lookup(c: write C, scrut: u32) -> i32 {
    let mut k: usize = 0usize;
    while k < c.mat_n {
        if c.mat_scrut[k] == scrut { return conv i32 k; }
        k = k + 1usize;
    }
    return 0i32 - 1i32;
}
// Record the materialized-scrutinee type for every non-place `match` scrutinee: a
// `box(...)` yields a synthetic BoxResult, a call yields the callee's declared return
// type (a borrow return is held as the pointee address). Runs BEFORE synth_boxresults
// so the synthesized BoxResult nodes also acquire their enum bodies.
fn prep_match_synth(p: write P, src: [u8], c: write C, head: u32) -> unit {
    let orig_n: u32 = p.n;
    let mut i: u32 = 1u32;
    while i < orig_n {
        let nd: Node = p.nodes[conv usize i];
        if nd.tag == T_MATCH {
            let scrut: u32 = nd.a;
            if !is_place_cg(p, scrut) {
                let cn: Node = p.nodes[conv usize scrut];
                if cn.tag == T_CALL {
                    let callee: Node = p.nodes[conv usize cn.a];
                    let mut stn: u32 = 0u32;
                    let mut hold: i32 = 0;
                    if span_eq(src, callee.p0, callee.p1, b"box") {
                        let a0: u32 = cn.b;
                        let a1: u32 = p.nodes[conv usize a0].nx;
                        let inner: u32 = synth_ty_for_value(p, src, a1);
                        stn = add_boxresult_cg(p, inner);
                    } else {
                        let fnid: u32 = find_fn_w(p, src, head, callee.p0, callee.p1);
                        if fnid != 0u32 {
                            let fnnd: Node = p.nodes[conv usize fnid];
                            if fnnd.e != 0u32 {
                                let rt: Node = p.nodes[conv usize fnnd.e];
                                stn = rt.a;
                                if rt.op == 1 || rt.op == 2 { hold = 1; }
                            }
                        }
                    }
                    let k: usize = c.mat_n;
                    c.*.mat_scrut[k] = scrut;
                    c.*.mat_tn[k] = stn;
                    c.*.mat_hold[k] = hold;
                    c.*.mat_n = k + 1usize;
                }
            }
        }
        i = i + 1u32;
    }
    return;
}
// ---- box / unbox / free / drop_box -----------------------------------------
// Indirect-call the vtable `free(ctx, ptr, size, align)` fn-ptr from a Box's vt.
fn call_free(c: write C, pp: read P, src: [u8], ctx_slot: i32, vt_slot: i32, ptr_slot: i32, size: usize, align: usize) -> unit {
    let free_off: usize = field_off_lit(pp, src, c.head, c.alloc_vt_sid, b"free");
    reload_rax(c, vt_slot);
    if free_off != 0usize { bc(c, 9); bs(c, b"addq $"); bn(c, conv u64 free_off); bs(c, b", %rax"); bc(c, 10); }
    emit_load_flat(c, W_USIZE);
    let fnslot: i32 = spill(c);
    bc(c, 9); bs(c, b"movq "); bslot(c, ctx_slot); bs(c, b", %rdi"); bc(c, 10);
    bc(c, 9); bs(c, b"movq "); bslot(c, ptr_slot); bs(c, b", %rsi"); bc(c, 10);
    bc(c, 9); bs(c, b"movl $"); bn(c, conv u64 size); bs(c, b", %edx"); bc(c, 10);
    bc(c, 9); bs(c, b"movl $"); bn(c, conv u64 align); bs(c, b", %ecx"); bc(c, 10);
    bc(c, 9); bs(c, b"movq "); bslot(c, fnslot); bs(c, b", %rax"); bc(c, 10);
    bi(c, b"call *%rax");
    return;
}
// Drop a Box at flat offset [off_slot] ({ptr@0,ctx@8,vt@16}): if ptr!=0, drop the
// pointee (recursively) then indirect-call free (pointee-then-free order).
fn drop_box(c: write C, pp: read P, src: [u8], off_slot: i32, inner: u32) -> unit {
    reload_rax(c, off_slot);
    emit_load_flat(c, W_USIZE);
    let ptr_slot: i32 = spill(c);
    reload_rax(c, off_slot);
    bi(c, b"addq $8, %rax");
    emit_load_flat(c, W_USIZE);
    let ctx_slot: i32 = spill(c);
    reload_rax(c, off_slot);
    bi(c, b"addq $16, %rax");
    emit_load_flat(c, W_USIZE);
    let vt_slot: i32 = spill(c);
    let skip: i32 = newlbl(c);
    reload_rax(c, ptr_slot);
    bi(c, b"testq %rax, %rax");
    bc(c, 9); bs(c, b"jz "); blabel_ref(c, skip); bc(c, 10);
    if needs_drop(pp, src, c.head, inner) {
        reload_rax(c, ptr_slot);
        let pslot: i32 = spill(c);
        emit_drop_at(c, pp, src, pslot, inner, 0i32 - 1i32);
    }
    let size: usize = ty_size(pp, src, c.head, inner);
    let align: usize = ty_align(pp, src, c.head, inner);
    call_free(c, pp, src, ctx_slot, vt_slot, ptr_slot, size, align);
    blabel_def(c, skip);
    return;
}
// `box(alloc, v)`: read ctx/vt from the Alloc handle, indirect-call the vtable
// alloc for [size,align]; null -> BoxResult::oom (drop+consume v); else move v
// into the pointee and build BoxResult::boxed { Box {ptr,ctx,vt} }. Leaves the
// 32-byte BoxResult's flat offset in %rax. Mirrors interp bi_box / lower.rs box_op.
fn gen_box(c: write C, pp: read P, src: [u8], i: u32, exp_ty: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize i];
    let brty: u32 = exp_ty;
    let inner: u32 = pp.nodes[conv usize brty].a;
    let a0: u32 = nd.b;
    let a1: u32 = pp.nodes[conv usize a0].nx;
    let _at: u32 = gen_agg(c, pp, src, a0, 0u32);
    let alloc_slot: i32 = spill(c);
    let ctx_off: usize = field_off_lit(pp, src, c.head, c.alloc_sid, b"ctx");
    let vt_off: usize = field_off_lit(pp, src, c.head, c.alloc_sid, b"vt");
    reload_rax(c, alloc_slot);
    if ctx_off != 0usize { bc(c, 9); bs(c, b"addq $"); bn(c, conv u64 ctx_off); bs(c, b", %rax"); bc(c, 10); }
    emit_load_flat(c, W_USIZE);
    let ctx_slot: i32 = spill(c);
    reload_rax(c, alloc_slot);
    if vt_off != 0usize { bc(c, 9); bs(c, b"addq $"); bn(c, conv u64 vt_off); bs(c, b", %rax"); bc(c, 10); }
    emit_load_flat(c, W_USIZE);
    let vt_slot: i32 = spill(c);
    let vw: i32 = scalar_width(pp, src, inner);
    let mut val_slot: i32 = 0i32 - 1i32;
    let mut size: usize = 0usize;
    let mut align: usize = 1usize;
    if vw != 0 {
        let _v: i32 = gen_value(c, pp, src, a1, vw);
        emit_canon(c, vw);
        val_slot = spill(c);
        size = wsize(vw);
        align = wsize(vw);
    } else {
        let _t: u32 = gen_agg(c, pp, src, a1, inner);
        val_slot = spill(c);
        size = ty_size(pp, src, c.head, inner);
        align = ty_align(pp, src, c.head, inner);
    }
    let alloc_off: usize = field_off_lit(pp, src, c.head, c.alloc_vt_sid, b"alloc");
    reload_rax(c, vt_slot);
    if alloc_off != 0usize { bc(c, 9); bs(c, b"addq $"); bn(c, conv u64 alloc_off); bs(c, b", %rax"); bc(c, 10); }
    emit_load_flat(c, W_USIZE);
    let afn_slot: i32 = spill(c);
    bc(c, 9); bs(c, b"movq "); bslot(c, ctx_slot); bs(c, b", %rdi"); bc(c, 10);
    bc(c, 9); bs(c, b"movl $"); bn(c, conv u64 size); bs(c, b", %esi"); bc(c, 10);
    bc(c, 9); bs(c, b"movl $"); bn(c, conv u64 align); bs(c, b", %edx"); bc(c, 10);
    bc(c, 9); bs(c, b"movq "); bslot(c, afn_slot); bs(c, b", %rax"); bc(c, 10);
    bi(c, b"call *%rax");
    let ret_slot: i32 = spill(c);
    emit_alloc(c, 32usize, 8usize);
    let bra_slot: i32 = spill(c);
    if vw == 0 {
        mark_moved(c, pp, src, a1);
    }
    let oom_l: i32 = newlbl(c);
    let done_l: i32 = newlbl(c);
    reload_rax(c, ret_slot);
    bi(c, b"testq %rax, %rax");
    bc(c, 9); bs(c, b"jz "); blabel_ref(c, oom_l); bc(c, 10);
    // boxed: move v into the pointee, then build the Box in the payload.
    if vw != 0 {
        reload_rax(c, val_slot);
        emit_store_flat(c, vw, ret_slot, 0usize);
    } else {
        reload_rax(c, val_slot);
        emit_copy_to(c, ret_slot, 0usize, size);
    }
    emit_const(c, 0u64, 0);
    emit_store_flat(c, W_USIZE, bra_slot, 0usize);
    reload_rax(c, ret_slot);
    emit_store_flat(c, W_USIZE, bra_slot, 8usize);
    reload_rax(c, ctx_slot);
    emit_store_flat(c, W_USIZE, bra_slot, 16usize);
    reload_rax(c, vt_slot);
    emit_store_flat(c, W_USIZE, bra_slot, 24usize);
    bc(c, 9); bs(c, b"jmp "); blabel_ref(c, done_l); bc(c, 10);
    blabel_def(c, oom_l);
    if vw == 0 {
        emit_drop_at(c, pp, src, val_slot, inner, 0i32 - 1i32);
    }
    emit_const(c, 1u64, 0);
    emit_store_flat(c, W_USIZE, bra_slot, 0usize);
    blabel_def(c, done_l);
    reload_rax(c, bra_slot);
    c.*.cur_agg_ty = brty;
    return brty;
}
// `unbox(bx)`: move the pointee out into a fresh slot, indirect-call free, and
// consume the box (mark it moved). Leaves the inner value (scalar in %rax, or an
// aggregate's flat offset). Mirrors interp bi_unbox / lower.rs unbox_op.
fn gen_unbox(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let a0: u32 = nd.b;
    let bxty: u32 = expr_place_ty(c, pp, src, a0);
    let inner: u32 = pp.nodes[conv usize bxty].a;
    let _t: u32 = gen_agg(c, pp, src, a0, 0u32);
    let bx_slot: i32 = spill(c);
    mark_moved(c, pp, src, a0);
    reload_rax(c, bx_slot);
    emit_load_flat(c, W_USIZE);
    let ptr_slot: i32 = spill(c);
    reload_rax(c, bx_slot);
    bi(c, b"addq $8, %rax");
    emit_load_flat(c, W_USIZE);
    let ctx_slot: i32 = spill(c);
    reload_rax(c, bx_slot);
    bi(c, b"addq $16, %rax");
    emit_load_flat(c, W_USIZE);
    let vt_slot: i32 = spill(c);
    let iw: i32 = scalar_width(pp, src, inner);
    let size: usize = ty_size(pp, src, c.head, inner);
    let align: usize = ty_align(pp, src, c.head, inner);
    if iw != 0 {
        reload_rax(c, ptr_slot);
        emit_load_flat(c, iw);
        let res_slot: i32 = spill(c);
        call_free(c, pp, src, ctx_slot, vt_slot, ptr_slot, wsize(iw), wsize(iw));
        reload_rax(c, res_slot);
        return iw;
    }
    emit_alloc(c, size, align);
    let dst_slot: i32 = spill(c);
    emit_copy_from(c, dst_slot, ptr_slot, size);
    call_free(c, pp, src, ctx_slot, vt_slot, ptr_slot, size, align);
    reload_rax(c, dst_slot);
    c.*.cur_agg_ty = inner;
    return W_AGG;
}
// `ptr_read(p)`: load the pointee through the rawptr (MEM_BASE+offset). Scalar
// yields %rax; aggregate copies into a fresh slot and yields its offset.
fn gen_ptr_read(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let inner: u32 = rawptr_inner(pp, ptr_type_node(c, pp, src, nd.b));
    let iw: i32 = scalar_width(pp, src, inner);
    if iw != 0 {
        let _p: i32 = gen_value(c, pp, src, nd.b, W_USIZE);
        emit_load_flat(c, iw);
        return iw;
    }
    let _p: i32 = gen_value(c, pp, src, nd.b, W_USIZE);
    let ptr_slot: i32 = spill(c);
    let size: usize = ty_size(pp, src, c.head, inner);
    let align: usize = ty_align(pp, src, c.head, inner);
    emit_alloc(c, size, align);
    let dst_slot: i32 = spill(c);
    emit_copy_from(c, dst_slot, ptr_slot, size);
    reload_rax(c, dst_slot);
    c.*.cur_agg_ty = inner;
    return W_AGG;
}
// `ptr_write(p, v)`: store v through the rawptr. Scalar stores the low bytes;
// aggregate byte-copies + consumes a non-copy v.
fn gen_ptr_write(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let vexpr: u32 = pp.nodes[conv usize nd.b].nx;
    let inner: u32 = rawptr_inner(pp, ptr_type_node(c, pp, src, nd.b));
    let _p: i32 = gen_value(c, pp, src, nd.b, W_USIZE);
    let ptr_slot: i32 = spill(c);
    let iw: i32 = scalar_width(pp, src, inner);
    if iw != 0 {
        let _v: i32 = gen_value(c, pp, src, vexpr, iw);
        emit_canon(c, iw);
        emit_store_flat(c, iw, ptr_slot, 0usize);
        return 12;
    }
    let _t: u32 = gen_agg(c, pp, src, vexpr, inner);
    emit_copy_to(c, ptr_slot, 0usize, ty_size(pp, src, c.head, inner));
    if !is_copy(pp, src, c.head, inner) { mark_moved(c, pp, src, vexpr); }
    return 12;
}
// `ptr_offset(base, n)`: advance a rawptr by n elements of its pointee (stride =
// size_of(inner)); wrapping arithmetic. Leaves the new rawptr offset in %rax.
fn gen_ptr_offset(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let nexpr: u32 = pp.nodes[conv usize nd.b].nx;
    let inner: u32 = rawptr_inner(pp, ptr_type_node(c, pp, src, nd.b));
    let stride: usize = ty_size(pp, src, c.head, inner);
    let _b: i32 = gen_value(c, pp, src, nd.b, W_USIZE);
    let base_slot: i32 = spill(c);
    let _n: i32 = gen_value(c, pp, src, nexpr, 5);
    bc(c, 9); bs(c, b"imulq $"); bn(c, conv u64 stride); bs(c, b", %rax, %rax"); bc(c, 10);
    bc(c, 9); bs(c, b"movq "); bslot(c, base_slot); bs(c, b", %rcx"); bc(c, 10);
    bi(c, b"addq %rcx, %rax");
    return W_USIZE;
}
// ---- statics: alloc flat storage + run initializers before main ------------
// Emit `cnr_static_init`: for each static, rt_stack_alloc its storage, record the
// offset in its `.data` slot, then evaluate its initializer into that storage.
fn gen_static_init(c: write C, pp: read P, src: [u8]) -> unit {
    c.*.bbuf_n = 0usize;
    c.*.bnd_n = 0usize;
    c.*.slot_next = 0usize;
    c.*.slot_max = 0usize;
    c.*.loop_n = 0usize;
    c.*.regime = 0;
    c.*.sco_n = 0usize;
    c.*.sco_depth = 0usize;
    c.*.mv_n = 0usize;
    c.*.mv_seg_n = 0usize;
    c.*.dloc_n = 0usize;
    c.*.ret_w = 0;
    c.*.ret_ty = 0u32;
    let mut k: usize = 0usize;
    while k < c.st_n {
        let ty: u32 = c.st_ty[k];
        let val: u32 = c.st_val[k];
        let size: usize = ty_size(pp, src, c.head, ty);
        let align: usize = ty_align(pp, src, c.head, ty);
        if is_agg_ty(pp, src, c.head, ty) {
            emit_alloc(c, size, align);
            let base: i32 = spill(c);
            bc(c, 9); bs(c, b"movq %rax, cnr_stat"); bn(c, conv u64 k); bs(c, b"(%rip)"); bc(c, 10);
            let _t: u32 = gen_agg(c, pp, src, val, ty);
            emit_copy_to(c, base, 0usize, size);
        } else {
            let w: i32 = scalar_width(pp, src, ty);
            emit_alloc(c, wsize(w), wsize(w));
            bc(c, 9); bs(c, b"movq %rax, cnr_stat"); bn(c, conv u64 k); bs(c, b"(%rip)"); bc(c, 10);
            let base: i32 = spill(c);
            let _v: i32 = gen_value(c, pp, src, val, w);
            emit_canon(c, w);
            emit_store_flat(c, w, base, 0usize);
        }
        k = k + 1usize;
    }
    bi(c, b"xorl %eax, %eax");
    emit_epilogue(c);
    emit_static_init_streaming(c);
    return;
}
// Stream `cnr_static_init:` with the SysV prologue (frame from slot_max) + body.
fn emit_static_init_streaming(c: write C) -> unit {
    let mut frame: usize = 8usize * c.slot_max;
    frame = ((frame + 15usize) / 16usize) * 16usize;
    emit_bytes_direct(b"cnr_static_init:");
    trace(10);
    emit_line(b"pushq %rbp");
    emit_line(b"movq %rsp, %rbp");
    if frame > 0usize {
        trace(9);
        emit_bytes_direct(b"subq $");
        emit_num_direct(conv u64 frame);
        emit_bytes_direct(b", %rsp");
        trace(10);
    }
    let mut bi2: usize = 0usize;
    while bi2 < c.bbuf_n {
        trace(conv i64 c.bbuf[bi2]);
        bi2 = bi2 + 1usize;
    }
    return;
}

fn peel_box_addr(c: write C, pp: read P, src: [u8], bt: u32) -> u32 {
    let mut t: u32 = bt;
    loop {
        let n: Node = pp.nodes[conv usize t];
        if n.tag == T_BOX {
            // A Box local holds the {ptr,ctx,vt} header offset; the pointee address is
            // ptr@0, so peeling a Box loads it. A borrow already holds the pointee
            // address directly (like a rawptr), so peeling a borrow is address-preserving.
            emit_load_flat(c, W_USIZE);
            t = n.a;
        } else if n.tag == T_BORROW || n.tag == T_BORROWMUT {
            t = n.a;
        } else {
            return t;
        }
    }
}
// An indirect call `fp(args)` through a fn-pointer-valued local (`call *%rax`).
fn gen_indirect_call(c: write C, pp: read P, src: [u8], i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let callee: Node = pp.nodes[conv usize nd.a];
    let s: i32 = lookup(c, src, callee.p0, callee.p1);
    if s < 0 { c.*.err = 1; return 4; }
    let fpty: u32 = c.luk_ty;
    let fpnode: Node = pp.nodes[conv usize fpty];
    let retw: i32 = scalar_width(pp, src, fpnode.b);
    let mut argslots: [16]i32 = [0i32; 16];
    let mut na: usize = 0usize;
    let mut argc: u32 = nd.b;
    let mut parc: u32 = fpnode.a;
    while argc != 0u32 {
        let pty: u32 = pp.nodes[conv usize parc].a;
        let pw: i32 = scalar_width(pp, src, pty);
        if pw != 0 {
            let _aw: i32 = gen_value(c, pp, src, argc, pw);
        } else {
            let _at: u32 = gen_agg(c, pp, src, argc, pty);
        }
        argslots[na] = spill(c);
        na = na + 1usize;
        argc = pp.nodes[conv usize argc].nx;
        parc = pp.nodes[conv usize parc].nx;
    }
    reload_rax(c, s);
    let fnslot: i32 = spill(c);
    let mut k: usize = 0usize;
    while k < na {
        bc(c, 9); bs(c, b"movq "); bslot(c, argslots[k]); bs(c, b", "); emit_arg_reg(c, k); bc(c, 10);
        k = k + 1usize;
    }
    bc(c, 9); bs(c, b"movq "); bslot(c, fnslot); bs(c, b", %rax"); bc(c, 10);
    bi(c, b"call *%rax");
    if retw != 0 { return retw; }
    if fpnode.b != 0u32 && ty_size(pp, src, c.head, fpnode.b) > 0usize {
        c.*.cur_agg_ty = fpnode.b;
        return W_AGG;
    }
    return 12;
}

pub fn codegen_dump(src: [u8], buf: read Buf) -> unit {
    let mut p: P = P { nodes: [nnew(0); 49152], n: 1u32, pos: 0usize, no_struct: 0, dreg: 0u32, dtp: 0u32, mmode: 0, mreg: 0u32, mty: 0u32, uses: 0u32 };
    let head: u32 = parse_program(write p, src, buf);
    mono_program(write p, src, head);
    let mut c: C = C {
        head: head,
        bbuf: [0u8; 1048576],
        bbuf_n: 0usize,
        bnd_p0: [0usize; 1024],
        bnd_p1: [0usize; 1024],
        bnd_slot: [0i32; 1024],
        bnd_w: [0i32; 1024],
        bnd_ty: [0u32; 1024],
        bnd_n: 0usize,
        slot_next: 0usize,
        slot_max: 0usize,
        loop_cont: [0i32; 64],
        loop_brk: [0i32; 64],
        loop_n: 0usize,
        lbl: 0,
        ret_w: 4,
        ret_ty: 0u32,
        regime: 0,
        cur_p0: 0usize,
        cur_p1: 0usize,
        cur_agg_ty: 0u32,
        luk_slot: 0,
        luk_w: 0,
        luk_ty: 0u32,
        luk_locid: 0i32 - 1i32,
        dloc_slot: [0i32; 256],
        dloc_ty: [0u32; 256],
        dloc_n: 0usize,
        sco_local: [0i32; 256],
        sco_mark: [0usize; 64],
        sco_depth: 0usize,
        sco_n: 0usize,
        mv_local: [0i32; 256],
        mv_seg_start: [0usize; 256],
        mv_seg_count: [0usize; 256],
        mv_seg_p0: [0usize; 512],
        mv_seg_p1: [0usize; 512],
        mv_seg_syn: [0i32 - 1i32; 512],
        mv_seg_n: 0usize,
        mv_n: 0usize,
        loop_depth: [0usize; 64],
        bnd_locid: [0i32; 1024],
        st_p0: [0usize; 64],
        st_p1: [0usize; 64],
        st_ty: [0u32; 64],
        st_val: [0u32; 64],
        st_n: 0usize,
        alloc_sid: 0u32,
        alloc_vt_sid: 0u32,
        at_p0: [0usize; 64],
        at_p1: [0usize; 64],
        at_n: 0usize,
        bnd_flat: [0i32; 1024],
        luk_flat: 0,
        mat_scrut: [0u32; 64],
        mat_tn: [0u32; 64],
        mat_hold: [0i32; 64],
        mat_n: 0usize,
        glue_eid: [0u32; 128],
        glue_n: 0usize,
        disp_sid: [0u32; 128],
        disp_p0: [0usize; 128],
        disp_p1: [0usize; 128],
        disp_fn: [0u32; 128],
        disp_n: 0usize,
        err: 0,
    };
    // Record non-place match scrutinees (synthesizing their BoxResult/return types),
    // THEN materialize every BoxResult into a real enum.
    synth_borrow_params(write p, src);
    prep_match_synth(write p, src, write c, head);
    synth_boxresults(write p, src);
    c.alloc_vt_sid = find_alloc_vt(read p, src, head);
    c.alloc_sid = find_alloc_handle(read p, src, head);
    build_dispatch_cg(write c, read p, src);
    let mut scur: u32 = head;
    while scur != 0u32 {
        let snd: Node = p.nodes[conv usize scur];
        if snd.tag == T_STATIC {
            let sk: usize = c.st_n;
            c.st_p0[sk] = snd.p0;
            c.st_p1[sk] = snd.p1;
            c.st_ty[sk] = snd.a;
            c.st_val[sk] = snd.b;
            c.st_n = sk + 1usize;
        }
        scur = snd.nx;
    }
    let mut ai: u32 = 1u32;
    while ai < p.n {
        let and2: Node = p.nodes[conv usize ai];
        if and2.tag == T_CALL {
            let acallee: Node = p.nodes[conv usize and2.a];
            if acallee.tag == T_ID && (span_eq(src, acallee.p0, acallee.p1, b"addr_of") || span_eq(src, acallee.p0, acallee.p1, b"addr_of_mut")) {
                let mut arg: u32 = and2.b;
                let mut argn: Node = p.nodes[conv usize arg];
                while argn.tag == T_PAREN { arg = argn.a; argn = p.nodes[conv usize arg]; }
                if argn.tag == T_ID {
                    let ak: usize = c.at_n;
                    c.at_p0[ak] = argn.p0;
                    c.at_p1[ak] = argn.p1;
                    c.at_n = ak + 1usize;
                }
            }
        }
        // A `read x`/`write x` borrow of a scalar local takes its address, so that
        // local must live in flat memory (its slot holds the offset the borrow passes).
        if and2.tag == T_PREFIX && (and2.op == PF_READ || and2.op == PF_WRITE) {
            let mut arg: u32 = and2.a;
            let mut argn: Node = p.nodes[conv usize arg];
            while argn.tag == T_PAREN { arg = argn.a; argn = p.nodes[conv usize arg]; }
            if argn.tag == T_ID {
                let ak: usize = c.at_n;
                c.at_p0[ak] = argn.p0;
                c.at_p1[ak] = argn.p1;
                c.at_n = ak + 1usize;
            }
        }
        ai = ai + 1u32;
    }
    // header: entry alias jumps to the compiled `main`.
    emit_bytes_direct(b".text");
    trace(10);
    emit_bytes_direct(b".globl candor_entry");
    trace(10);
    emit_bytes_direct(b"candor_entry:");
    trace(10);
    if c.st_n > 0usize { emit_line(b"call cnr_static_init"); }
    emit_line(b"jmp cnr_main");
    let mut cur: u32 = head;
    while cur != 0u32 {
        let nd: Node = p.nodes[conv usize cur];
        if nd.tag == T_FN && nd.a == 0u32 {
            gen_fn(write c, read p, src, cur, 0);
        }
        cur = nd.nx;
    }
    // Impl-method fns: each concrete (a == 0) T_IMPL method compiles to a free asm fn
    // `cnr_meth.<fnid>`, the `call` target a method-call site resolves via the dispatch
    // table (mirrors lower.cnr's impl-method emission loop).
    let mut ic: u32 = head;
    while ic != 0u32 {
        let icn: Node = p.nodes[conv usize ic];
        if icn.tag == T_IMPL && icn.a == 0u32 {
            let mut mc: u32 = icn.d;
            while mc != 0u32 {
                let mcn: Node = p.nodes[conv usize mc];
                gen_fn(write c, read p, src, mc, 3);
                mc = mcn.nx;
            }
        }
        ic = icn.nx;
    }
    // Struct drop hooks as asm fns (called by the drop schedule above).
    let mut curh: u32 = head;
    while curh != 0u32 {
        let ndh: Node = p.nodes[conv usize curh];
        if ndh.tag == T_STRUCT && ndh.c != 0u32 {
            gen_hook(write c, read p, src, curh);
        }
        curh = ndh.nx;
    }
    // Per-enum drop-glue fns (worklist: emitting one may register more).
    let mut gi: usize = 0usize;
    while gi < c.glue_n {
        gen_enum_glue(write c, read p, src, c.glue_eid[gi]);
        gi = gi + 1usize;
    }
    if c.st_n > 0usize {
        gen_static_init(write c, read p, src);
        emit_bytes_direct(b".data");
        trace(10);
        let mut si: usize = 0usize;
        while si < c.st_n {
            emit_bytes_direct(b"cnr_stat");
            emit_num_direct(conv u64 si);
            emit_bytes_direct(b": .quad 0");
            trace(10);
            si = si + 1usize;
        }
    }
    return;
}
