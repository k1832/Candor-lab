// The SECOND self-interpreting slice of Candor (S2): the S1 scalar tree-walker
// extended with a FLAT BYTE-MEMORY model plus STRUCTS and ARRAYS. It executes an
// in-subset Candor program directly over the self-hosted parser's Node arena and
// reproduces the Rust reference interpreter (`prototype/src/interp/`) byte-exact --
// same `main` return, same `trace` sequence, same fault identity (kind + span).
// Gated by EXECUTION equality in prototype/tests/selfhost_interp.rs.
//
// This is a LIBRARY module composed with the `lexer` and `parser` modules; it
// IMPORTS their arena/emit vocabulary via the `use` decls below.
//
// SUBSET (P6). S1's integer/bool scalars, control flow, arithmetic+faults, calls
// and recursion; PLUS (S2): a byte-addressable stack arena in `E`; a type/layout
// table extracted from the arena AST (`size_of`/`align_of`/field-offset for scalars,
// declared structs, and `[N]T` arrays); struct literals + field read/assign + nested
// structs; struct by-value params/returns; array literals (`[e; N]` and `[a, b, ...]`),
// index read/assign, and the `Bounds` fault (`i >= len`). S2 stays on COPY aggregates
// (structs/arrays of scalars), so there is NO drop obligation yet -- `trace` output is
// purely explicit `trace(x)` calls, never a drop side-effect. Move/drop is S3.
//
// VALUE MODEL (S2 convergence). Locals and aggregates live in a flat byte-addressable
// stack arena (bump-allocated, reset per block/call); a scalar local is stored/loaded
// by (address, width) instead of S1's pure `i64` slot. Scalar arithmetic still flows
// through the `cur_val`/`cur_w` registers (byte-exact with the oracle); an aggregate
// value is carried as an ADDRESS: `cur_w == 0` marks it, `cur_val` is the address, and
// `cur_ty` is its type node. Addresses never surface in the observable dump (RET/TRACE
// are values; FAULT spans are SOURCE spans), so the arena's base/size are free choices.
// `interp.cnr` is NOT self-checked in this slice, so it uses the full language.

use lexer::{Buf, span_eq, emit_num, emit_sp, emit_nl, decoded_len};
use parser::{Node, P, nnew, parse_program, emit_lit, T_FN, T_SC, T_LET, T_ASSIGN, T_INT, T_NEGINT, T_BOOL, T_ID, T_UNARY, T_BIN, T_CALL, T_BLOCK, T_IF, T_LOOP, T_WHILE, T_RETURN, T_BREAK, T_CONTINUE, T_ASSERT, T_PANIC, T_PAREN, T_STRUCT, T_NAMED, T_ARRAY, T_FIELD, T_INDEX, T_ARRAYLIT, T_ARRAYREP, T_STRUCTLIT, OP_ADD, OP_SUB, OP_MUL, OP_DIV, OP_REM, OP_EQ, OP_NE, OP_LT, OP_LE, OP_GT, OP_GE, OP_AND, OP_OR, OP_BITAND, OP_BITOR, OP_BITXOR, OP_SHL, OP_SHR, UN_NEG, UN_NOT, UN_BITNOT, T_ENUM, T_VARIANT, T_ENUMCTOR, T_MATCH, T_PVARIANT, T_WILD, T_BIND, T_STATIC, T_RAWPTR, T_FNPTR, T_UNSAFE, T_OFFSETOF, T_CASTPTR, T_ADDRTOPTR, T_PTRNULL, T_BOX, T_BOXRESULT, T_PREFIX, PF_DEREF, PF_READ, PF_WRITE, T_CONV, T_BORROW, T_BORROWMUT, T_SLICE, T_SLICEMUT, T_BYTES, T_STR, T_PARAM, T_APP, T_GENERICVAL, T_IMPL, T_TRY};
use mono::{mono_program};

// ---- fault kind codes (shared with the Rust harness) ------------------------
static FK_OVERFLOW: i32 = 0;
static FK_DIVZERO: i32 = 1;
static FK_ASSERT: i32 = 2;
static FK_PANIC: i32 = 3;
static FK_BOUNDS: i32 = 4;
static FK_CONVLOSS: i32 = 5;

// ---- width codes: 1..10 mirror the lexer's suffix codes; 11 = bool; 0 = unit ----
static W_BOOL: i32 = 11;
static W_USIZE: i32 = 10;

// ---- interpreter state ------------------------------------------------------
// Locals are a flat stack keyed by name span; `cur_base` marks the current call
// frame's floor. Each local now owns an ADDRESS into `mem` (`loc_addr`) plus a
// width (`loc_w`, 0 for aggregates) and its type node (`loc_ty`). Recursion is
// carried by interp.cnr's OWN Candor call stack -- `call_fn` restores loc_n and
// stack_bump on return. The byte store is PAGED (S6a): `pages` is a small pool of
// 4096-byte frames, `pagedir` maps a 12-bit page number to a pool slot (sentinel
// -1 = untouched), and `page_bump` hands out the next free slot. `xlate` maps a
// linear address to a backing offset, allocating+zeroing a frame on first touch --
// so a program may use sparse high addresses (up to 32 MiB) without a dense array.
struct E {
    head: u32,
    loc_p0: [1024]usize,
    loc_p1: [1024]usize,
    loc_addr: [1024]usize,
    loc_w: [1024]i32,
    loc_ty: [1024]u32,
    loc_n: usize,
    cur_base: usize,
    cur_retw: i32,
    cur_retty: u32,
    cur_result_addr: usize,
    cur_val: i64,
    cur_w: i32,
    cur_ty: u32,
    ret_val: i64,
    ret_w: i32,
    arg_val: [16]i64,
    arg_w: [16]i32,
    arg_addr: [16]usize,
    arg_n: usize,
    pages: [524288]u8,
    pagedir: [8192]i32,
    page_bump: usize,
    stack_bump: usize,
    plc_addr: usize,
    plc_w: i32,
    plc_ty: u32,
    trace_out: [1024]i64,
    trace_n: usize,
    fault_kind: i32,
    fault_p0: usize,
    fault_p1: usize,
    cur_p0: usize,
    cur_p1: usize,
    loc_owns: [1024]u8,
    mv_local: [512]usize,
    mv_field: [512]i32,
    mv_n: usize,
    tmp_addr: [256]usize,
    tmp_ty: [256]u32,
    tmp_live: [256]u8,
    tmp_n: usize,
    cur_org: i32,
    cur_org_a: usize,
    cur_org_b: i32,
    self_p0: usize,
    self_p1: usize,
    static_p0: [64]usize,
    static_p1: [64]usize,
    static_addr: [64]usize,
    static_w: [64]i32,
    static_ty: [64]u32,
    static_init: [64]u32,
    static_n: usize,
    alloc_vt_sid: u32,
    alloc_sid: u32,
    cur_exp_ty: u32,
    gen_boxresult: u32,
    gen_box: u32,
    gen_inner: u32,
    scw: [16]u32,
    bv_ptr: usize,
    bv_len: usize,
    mv_ew: i32,
    mv_val: i64,
    mv_addr: usize,
    mv_org: i32,
    mv_oa: usize,
    mv_ob: i32,
    // impl-method dispatch table (T2): (target struct-instance node, method-name
    // span) -> the method's fn node id. Built at startup from concrete T_IMPL nodes.
    disp_sid: [64]u32,
    disp_p0: [64]usize,
    disp_p1: [64]usize,
    disp_fn: [64]u32,
    disp_n: usize,
}

// ---- bit-pattern reinterpretation via wrapping conv (no transmute needed) ----
fn to_u64(x: i64) -> u64 {
    let mut r: u64 = 0u64;
    wrapping { r = conv u64 x; }
    return r;
}
fn to_i64b(x: u64) -> i64 {
    let mut r: i64 = 0;
    wrapping { r = conv i64 x; }
    return r;
}

fn imin() -> i64 { return 0 - 9223372036854775807i64 - 1i64; }
fn imax() -> i64 { return 9223372036854775807i64; }

// ---- width metadata ----------------------------------------------------------
fn w_is64(w: i32) -> bool { return w == 4 || w == 5 || w == 9 || w == 10; }
fn w_signed(w: i32) -> bool { return w >= 1 && w <= 5; }
fn w_bits(w: i32) -> i32 {
    if w == 1 || w == 6 { return 8; }
    if w == 2 || w == 7 { return 16; }
    if w == 3 || w == 8 { return 32; }
    return 64;
}
// Byte width of a scalar (bool and the 8-bit ints are 1 byte).
fn w_size(w: i32) -> usize {
    if w == 1 || w == 6 || w == W_BOOL { return 1usize; }
    if w == 2 || w == 7 { return 2usize; }
    if w == 3 || w == 8 { return 4usize; }
    return 8usize;
}
fn smin(w: i32) -> i64 {
    if w == 1 { return 0 - 128i64; }
    if w == 2 { return 0 - 32768i64; }
    if w == 3 { return 0 - 2147483648i64; }
    return imin();
}
fn smax(w: i32) -> i64 {
    if w == 1 { return 127i64; }
    if w == 2 { return 32767i64; }
    if w == 3 { return 2147483647i64; }
    return imax();
}
fn umax(w: i32) -> u64 {
    if w == 6 { return 255u64; }
    if w == 7 { return 65535u64; }
    if w == 8 { return 4294967295u64; }
    return 18446744073709551615u64;
}

// Reduce a value to a narrow type's bit pattern (mask to width, then re-sign),
// mirroring the oracle's `fit_bits` for bitwise/shift results. bits <= 32 here.
fn fit_bits(x: i64, w: i32) -> i64 {
    let bits: i32 = w_bits(w);
    let m1: i64 = (1i64 << bits) - 1i64;
    let mut masked: i64 = x & m1;
    if w_signed(w) {
        let half: i64 = 1i64 << (bits - 1i32);
        if (masked & half) != 0i64 {
            masked = masked - (1i64 << bits);
        }
    }
    return masked;
}

// ---- scalar-type name -> width code -----------------------------------------
fn sc_width(src: [u8], s: usize, en: usize) -> i32 {
    if span_eq(src, s, en, b"i8") { return 1; }
    if span_eq(src, s, en, b"i16") { return 2; }
    if span_eq(src, s, en, b"i32") { return 3; }
    if span_eq(src, s, en, b"i64") { return 4; }
    if span_eq(src, s, en, b"isize") { return 5; }
    if span_eq(src, s, en, b"u8") { return 6; }
    if span_eq(src, s, en, b"u16") { return 7; }
    if span_eq(src, s, en, b"u32") { return 8; }
    if span_eq(src, s, en, b"u64") { return 9; }
    if span_eq(src, s, en, b"usize") { return 10; }
    if span_eq(src, s, en, b"bool") { return W_BOOL; }
    return 0;
}

fn name_eq(src: [u8], a0: usize, a1: usize, b0: usize, b1: usize) -> bool {
    if a1 - a0 != b1 - b0 { return false; }
    let mut i: usize = 0usize;
    let n: usize = a1 - a0;
    while i < n {
        if src[a0 + i] != src[b0 + i] { return false; }
        i = i + 1usize;
    }
    return true;
}

// ---- synthetic Box/BoxResult enum shape (startup, mirrors the oracle's
// compiler-known `BoxResult` enum). The parser never emits enum/variant nodes for
// `BoxResult T`, so at startup we append, for every `T_BOXRESULT` annotation node,
// a matching `{ boxed(Box T), oom }` enum: a `T_BOX` payload node, two `T_VARIANT`
// nodes (spans point at the `boxed`/`oom` bytes in the source so a `match` pattern
// name compares equal), and a `T_ENUM` linked back through the `T_BOXRESULT` node's
// `.c`. `enum_of_ty` then routes a `T_BOXRESULT` to this synthetic enum, so match,
// enum-size and enum-drop all reuse the S4 machinery unchanged.
fn inode(p: write P, nd: Node) -> u32 {
    let i: u32 = p.n;
    p.*.nodes[conv usize i] = nd;
    p.*.n = i + 1u32;
    return i;
}
fn find_needle(src: [u8], needle: [u8]) -> usize {
    let n: usize = len(src);
    let m: usize = len(needle);
    let mut i: usize = 0usize;
    while i + m <= n {
        let mut j: usize = 0usize;
        let mut ok: bool = true;
        while j < m {
            if src[i + j] != needle[j] { ok = false; break; }
            j = j + 1usize;
        }
        if ok { return i; }
        i = i + 1usize;
    }
    return n;
}
fn synth_boxresults(p: write P, src: [u8]) -> unit {
    let srclen: usize = len(src);
    let mut boxed0: usize = find_needle(src, b"boxed");
    let mut boxed1: usize = boxed0 + 5usize;
    if boxed1 > srclen { boxed0 = 0usize; boxed1 = 0usize; }
    let mut oom0: usize = find_needle(src, b"oom");
    let mut oom1: usize = oom0 + 3usize;
    if oom1 > srclen { oom0 = 0usize; oom1 = 0usize; }
    let n0: u32 = p.n;
    let mut i: u32 = 1u32;
    while i < n0 {
        let nd: Node = p.nodes[conv usize i];
        if nd.tag == T_BOXRESULT {
            let mut bn: Node = nnew(T_BOX);
            bn.a = nd.a;
            let boxid: u32 = inode(p, bn);
            let mut vo: Node = nnew(T_VARIANT);
            vo.p0 = oom0;
            vo.p1 = oom1;
            let oomid: u32 = inode(p, vo);
            let mut vb: Node = nnew(T_VARIANT);
            vb.p0 = boxed0;
            vb.p1 = boxed1;
            vb.a = boxid;
            vb.nx = oomid;
            let boxedid: u32 = inode(p, vb);
            let mut en: Node = nnew(T_ENUM);
            en.op = 0;
            en.b = boxedid;
            let enid: u32 = inode(p, en);
            p.*.nodes[conv usize i].c = enid;
        }
        i = i + 1u32;
    }
    return;
}
// A generic BoxResult scaffold (used when a `box(...)`/`BoxResult::*` has no
// annotated `BoxResult T` in scope: 11_1/11_5 match a box directly). Mirrors the
// oracle deriving the result type from the value: the boxed payload's inner type
// rides `e.gen_inner`, set at each box; size (32) is inner-independent.
fn synth_generic_boxresult(p: write P, src: [u8], e: write E) -> unit {
    let srclen: usize = len(src);
    let mut boxed0: usize = find_needle(src, b"boxed");
    let mut boxed1: usize = boxed0 + 5usize;
    if boxed1 > srclen { boxed0 = 0usize; boxed1 = 0usize; }
    let mut oom0: usize = find_needle(src, b"oom");
    let mut oom1: usize = oom0 + 3usize;
    if oom1 > srclen { oom0 = 0usize; oom1 = 0usize; }
    let mut bn: Node = nnew(T_BOX);
    bn.a = 0u32;
    let boxid: u32 = inode(p, bn);
    let mut vo: Node = nnew(T_VARIANT);
    vo.p0 = oom0;
    vo.p1 = oom1;
    let oomid: u32 = inode(p, vo);
    let mut vb: Node = nnew(T_VARIANT);
    vb.p0 = boxed0;
    vb.p1 = boxed1;
    vb.a = boxid;
    vb.nx = oomid;
    let boxedid: u32 = inode(p, vb);
    let mut en: Node = nnew(T_ENUM);
    en.op = 0;
    en.b = boxedid;
    let enid: u32 = inode(p, en);
    let mut br: Node = nnew(T_BOXRESULT);
    br.a = 0u32;
    br.c = enid;
    let brid: u32 = inode(p, br);
    e.*.gen_boxresult = brid;
    e.*.gen_box = boxid;
    e.*.gen_inner = 0u32;
    return;
}
// A synthetic `T_SC` scalar type node per width (span points at the type name in
// source), so a scalar boxed WITHOUT an annotation (11_1's `box(a, 1234)`) still
// carries a real inner type node for its Box deref/unbox/drop.
fn synth_scw(p: write P, src: [u8], e: write E, w: i32, name: [u8]) -> unit {
    let pos: usize = find_needle(src, name);
    if pos < len(src) {
        let mut nd: Node = nnew(T_SC);
        nd.p0 = pos;
        nd.p1 = pos + len(name);
        e.*.scw[conv usize w] = inode(p, nd);
    }
    return;
}
fn synth_scalar_nodes(p: write P, src: [u8], e: write E) -> unit {
    synth_scw(p, src, e, 1, b"i8");
    synth_scw(p, src, e, 2, b"i16");
    synth_scw(p, src, e, 3, b"i32");
    synth_scw(p, src, e, 4, b"i64");
    synth_scw(p, src, e, 5, b"isize");
    synth_scw(p, src, e, 6, b"u8");
    synth_scw(p, src, e, 7, b"u16");
    synth_scw(p, src, e, 8, b"u32");
    synth_scw(p, src, e, 9, b"u64");
    synth_scw(p, src, e, 10, b"usize");
    synth_scw(p, src, e, 11, b"bool");
    return;
}
// The element type node for an array literal/rep VALUE: an enum-ctor or struct-lit
// value names its type (a `T_NAMED` over the name span); scalar/other values -> 0.
fn synth_elem_type(p: write P, valnode: u32) -> u32 {
    let vn: Node = p.nodes[conv usize valnode];
    if vn.tag == T_ENUMCTOR || vn.tag == T_STRUCTLIT {
        let mut nm: Node = nnew(T_NAMED);
        nm.p0 = vn.p0;
        nm.p1 = vn.p1;
        return inode(p, nm);
    }
    return 0u32;
}
// Give each aggregate-element array-rep a concrete `[N]T` type node (stored in its
// `.c`), so a value like `[Node::leaf(0); 4096]` can be sized when boxed -- the
// oracle's array value carries its `Array(elem, N)` type. Scalar reps stay untyped.
fn synth_array_types(p: write P) -> unit {
    let n0: u32 = p.n;
    let mut i: u32 = 1u32;
    while i < n0 {
        let nd: Node = p.nodes[conv usize i];
        if nd.tag == T_ARRAYREP {
            let et: u32 = synth_elem_type(p, nd.a);
            if et != 0u32 {
                let mut arr: Node = nnew(T_ARRAY);
                arr.a = nd.b;
                arr.b = et;
                let aid: u32 = inode(p, arr);
                p.*.nodes[conv usize i].c = aid;
            }
        }
        i = i + 1u32;
    }
    return;
}
// A `read`/`write` parameter is a BORROW (a pointer), but the parser records the
// borrow kind in the param's `.op` and stores the INNER type in `.a`. Give each
// such param a real `T_BORROW`/`T_BORROWMUT` type node (rewriting `.a`), so the
// interp stores it as an 8-byte pointer scalar and `param.*` derefs correctly.
fn synth_param_borrows(p: write P) -> unit {
    let n0: u32 = p.n;
    let mut i: u32 = 1u32;
    while i < n0 {
        let nd: Node = p.nodes[conv usize i];
        if nd.tag == T_PARAM {
            if nd.op == 1 {
                let mut b: Node = nnew(T_BORROW);
                b.a = nd.a;
                let bid: u32 = inode(p, b);
                p.*.nodes[conv usize i].a = bid;
            } else if nd.op == 2 {
                let mut b: Node = nnew(T_BORROWMUT);
                b.a = nd.a;
                let bid: u32 = inode(p, b);
                p.*.nodes[conv usize i].a = bid;
            }
        }
        i = i + 1u32;
    }
    return;
}

// ---- item + local resolution -------------------------------------------------
fn find_main(pp: read P, src: [u8], e: write E) -> u32 {
    let mut cur: u32 = e.head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_FN && span_eq(src, nd.p0, nd.p1, b"main") {
            return cur;
        }
        cur = nd.nx;
    }
    return 0u32;
}
fn find_fn(pp: read P, src: [u8], e: write E, s: usize, en: usize) -> u32 {
    let mut cur: u32 = e.head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_FN && name_eq(src, nd.p0, nd.p1, s, en) {
            return cur;
        }
        cur = nd.nx;
    }
    return 0u32;
}
// The declared struct named [s,en), or 0 if absent.
fn find_struct(pp: read P, src: [u8], e: write E, s: usize, en: usize) -> u32 {
    let mut cur: u32 = e.head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_STRUCT && name_eq(src, nd.p0, nd.p1, s, en) {
            return cur;
        }
        cur = nd.nx;
    }
    return 0u32;
}
// The declared enum named [s,en), or 0 if absent.
fn find_enum(pp: read P, src: [u8], e: write E, s: usize, en: usize) -> u32 {
    let mut cur: u32 = e.head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_ENUM && name_eq(src, nd.p0, nd.p1, s, en) {
            return cur;
        }
        cur = nd.nx;
    }
    return 0u32;
}
// Index of the static named [s,en), or a count-sized sentinel if absent.
fn find_static(src: [u8], e: write E, s: usize, en: usize) -> usize {
    let mut i: usize = 0usize;
    while i < e.static_n {
        if name_eq(src, s, en, e.static_p0[i], e.static_p1[i]) { return i; }
        i = i + 1usize;
    }
    return e.static_n;
}
// ---- structural Alloc / AllocVtable identification (NEVER by name) -----------
// Mirrors the oracle's `Interp::new` predicate (src/interp/eval.rs:236-248): the
// vtable is the struct carrying fn-ptr fields `alloc` AND `free`; the Alloc
// handle is the struct whose `vt` field is a `rawptr` to that vtable. Computed
// once at startup (like the oracle). S5a stores the two struct ids as the ABI
// seam; S5b's `box`/`unbox` resolve `ctx`/`vt`/`alloc`/`free` offsets through
// `field_off` off these -- so box stays name-agnostic.
fn field_named_is_fnptr(pp: read P, src: [u8], sid: u32, name: [u8]) -> bool {
    let snode: Node = pp.nodes[conv usize sid];
    let mut cur: u32 = snode.b;
    while cur != 0u32 {
        let fd: Node = pp.nodes[conv usize cur];
        if span_eq(src, fd.p0, fd.p1, name) {
            let fty: Node = pp.nodes[conv usize fd.a];
            return fty.tag == T_FNPTR;
        }
        cur = fd.nx;
    }
    return false;
}
fn find_alloc_vtable_struct(pp: read P, src: [u8], e: write E) -> u32 {
    let mut cur: u32 = e.head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_STRUCT {
            if field_named_is_fnptr(pp, src, cur, b"alloc") && field_named_is_fnptr(pp, src, cur, b"free") {
                return cur;
            }
        }
        cur = nd.nx;
    }
    return 0u32;
}
fn find_alloc_struct(pp: read P, src: [u8], e: write E, vtid: u32) -> u32 {
    if vtid == 0u32 { return 0u32; }
    let vtn: Node = pp.nodes[conv usize vtid];
    let mut cur: u32 = e.head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_STRUCT {
            let mut fc: u32 = nd.b;
            while fc != 0u32 {
                let fd: Node = pp.nodes[conv usize fc];
                if span_eq(src, fd.p0, fd.p1, b"vt") {
                    let fty: Node = pp.nodes[conv usize fd.a];
                    if fty.tag == T_RAWPTR {
                        let inner: Node = pp.nodes[conv usize fty.a];
                        if (inner.tag == T_NAMED || inner.tag == T_SC) && name_eq(src, inner.p0, inner.p1, vtn.p0, vtn.p1) {
                            return cur;
                        }
                    }
                }
                fc = fd.nx;
            }
        }
        cur = nd.nx;
    }
    return 0u32;
}
// Index of the in-scope local named [s,en), or a count-sized sentinel if absent.
fn find_local(src: [u8], e: write E, s: usize, en: usize) -> usize {
    let mut i: usize = e.loc_n;
    while i > e.cur_base {
        i = i - 1usize;
        if name_eq(src, s, en, e.loc_p0[i], e.loc_p1[i]) {
            return i;
        }
    }
    return e.loc_n;
}
fn loc_push(e: write E, s: usize, en: usize, addr: usize, w: i32, ty: u32, owns: i32) -> unit {
    let i: usize = e.loc_n;
    e.*.loc_p0[i] = s;
    e.*.loc_p1[i] = en;
    e.*.loc_addr[i] = addr;
    e.*.loc_w[i] = w;
    e.*.loc_ty[i] = ty;
    e.*.loc_owns[i] = conv u8 owns;
    e.*.loc_n = i + 1usize;
    return;
}

fn set_fault(e: write E, kind: i32, p0: usize, p1: usize) -> unit {
    e.*.fault_kind = kind;
    e.*.fault_p0 = p0;
    e.*.fault_p1 = p1;
    return;
}

// The width a literal / operand takes: an explicit suffix wins; otherwise an
// integer `expected` width; otherwise i64 (code 4). Mirrors the oracle's int_type.
fn lit_width(suf: i32, exp_w: i32) -> i32 {
    if suf != 0 { return suf; }
    if exp_w >= 1 && exp_w <= 10 { return exp_w; }
    return 4;
}

// ---- paged byte memory (S6a; the flat model of src/interp/mem.rs, made sparse) --
fn round_up_us(x: usize, a: usize) -> usize {
    if a <= 1usize { return x; }
    return ((x + a - 1usize) / a) * a;
}
fn bump_alloc(e: write E, size: usize, align: usize) -> usize {
    let a: usize = round_up_us(e.stack_bump, align);
    e.*.stack_bump = a + size;
    return a;
}
// Translate a linear address to an offset into the `pages` pool. The high bits are
// the page number (4096 = 2^12, so a shift+mask, no division); a page is bound to a
// pool slot on first touch and its frame zeroed then -- zero-on-alloc, so a byte a
// program never wrote still reads 0 (load-bearing for enum padding: a whole-value
// copy that spans a variant's unwritten tail must see zeros, matching the oracle).
fn xlate(e: write E, addr: usize) -> usize {
    let page: usize = addr >> 12usize;
    let off: usize = addr & 4095usize;
    // Capacity guard (defensive for S7's Vec/Map): an address >= 32 MiB overruns
    // `pagedir`, and exhausting the 128-frame `pages` pool overruns `pages` -- both
    // silent OOB today. Signal a Bounds fault (the nearest oracle bad-address kind)
    // instead. The corpus stays in bounds, so no fixture output changes.
    if page >= 8192usize {
        set_fault(e, FK_BOUNDS, e.cur_p0, e.cur_p1);
        return 0usize;
    }
    if e.pagedir[page] < 0i32 {
        if e.page_bump >= 128usize {
            set_fault(e, FK_BOUNDS, e.cur_p0, e.cur_p1);
            return 0usize;
        }
        let slot: usize = e.page_bump;
        e.*.page_bump = slot + 1usize;
        e.*.pagedir[page] = conv i32 slot;
        let base: usize = slot * 4096usize;
        let mut z: usize = 0usize;
        while z < 4096usize {
            e.*.pages[base + z] = 0u8;
            z = z + 1usize;
        }
    }
    let mapped: usize = conv usize e.pagedir[page];
    return mapped * 4096usize + off;
}
// Load a scalar of width `w` from `addr`, little-endian, sign/zero-extended into
// the i64 register exactly as S1/the oracle's read_int represents it. Each byte is
// translated independently, so a load straddling a page boundary is handled.
fn mem_load(e: write E, addr: usize, w: i32) -> i64 {
    let size: usize = w_size(w);
    let mut raw: u64 = 0u64;
    let mut k: usize = 0usize;
    while k < size {
        let pa: usize = xlate(e, addr + k);
        let byte: u64 = conv u64 e.pages[pa];
        let sh: u64 = conv u64 (8usize * k);
        wrapping { raw = raw | (byte << sh); }
        k = k + 1usize;
    }
    if w_signed(w) && size < 8usize {
        let bits: i32 = w_bits(w);
        let mut half: u64 = 0u64;
        wrapping { half = 1u64 << (conv u64 (bits - 1i32)); }
        if (raw & half) != 0u64 {
            let mut lowmask: u64 = 0u64;
            wrapping { lowmask = (1u64 << (conv u64 bits)) - 1u64; }
            let allones: u64 = 18446744073709551615u64;
            raw = raw | (allones ^ lowmask);
        }
    }
    return to_i64b(raw);
}
fn mem_store(e: write E, addr: usize, val: i64, w: i32) -> unit {
    let size: usize = w_size(w);
    let mut u: u64 = to_u64(val);
    let mut k: usize = 0usize;
    while k < size {
        let b: u8 = conv u8 (u & 255u64);
        let pa: usize = xlate(e, addr + k);
        e.*.pages[pa] = b;
        u = u >> 8u64;
        k = k + 1usize;
    }
    return;
}
// Per-byte translation of both endpoints, so a copy spanning page boundaries on the
// source or destination side (a struct straddling a 4096 frame) copies correctly.
fn mem_copy(e: write E, dst: usize, s: usize, size: usize) -> unit {
    let mut k: usize = 0usize;
    while k < size {
        let spa: usize = xlate(e, s + k);
        let b: u8 = e.pages[spa];
        let dpa: usize = xlate(e, dst + k);
        e.*.pages[dpa] = b;
        k = k + 1usize;
    }
    return;
}
fn zero_slot(e: write E, addr: usize, size: usize) -> unit {
    let mut k: usize = 0usize;
    while k < size {
        let pa: usize = xlate(e, addr + k);
        e.*.pages[pa] = 0u8;
        k = k + 1usize;
    }
    return;
}

// ---- type / layout table extracted from the arena AST ------------------------
// A "type descriptor" is an arena node: a scalar/struct name is `T_NAMED`, an
// array is `T_ARRAY` (`.a` = length node, `.b` = element type), and a struct VALUE
// carries its `T_STRUCT` decl node directly. `size_of`/`align_of` mirror
// src/interp/layout.rs: scalars by width; arrays = round_up(size,align) stride * len;
// structs = fields in DECLARED order at natural alignment, size rounded to the
// struct's alignment (= max field alignment).
fn scalar_width(pp: read P, src: [u8], tn: u32) -> i32 {
    if tn == 0u32 { return 0; }
    let nd: Node = pp.nodes[conv usize tn];
    if (nd.tag == T_NAMED || nd.tag == T_SC) { return sc_width(src, nd.p0, nd.p1); }
    if nd.tag == T_RAWPTR || nd.tag == T_FNPTR { return W_USIZE; }
    if nd.tag == T_BORROW || nd.tag == T_BORROWMUT { return W_USIZE; }
    return 0;
}
// A rawptr / fn-ptr type node carries its pointee type in `.a`. A declared
// `rawptr T` and the cast_ptr/addr_to_ptr/ptr_null intrinsics all store the
// pointee in `.a`, so this recovers the pointee type from any rawptr value's
// `cur_ty` (set when a rawptr scalar is produced).
fn rawptr_inner(pp: read P, tn: u32) -> u32 {
    if tn == 0u32 { return 0u32; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_RAWPTR || nd.tag == T_CASTPTR || nd.tag == T_ADDRTOPTR || nd.tag == T_PTRNULL {
        return nd.a;
    }
    return 0u32;
}
// The `T_STRUCT` decl node for a struct type descriptor, or 0 if not a struct.
fn struct_of_ty(pp: read P, src: [u8], e: write E, tn: u32) -> u32 {
    if tn == 0u32 { return 0u32; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_APP && nd.b != 0u32 { return struct_of_ty(pp, src, e, nd.b); }
    if nd.tag == T_STRUCT { return tn; }
    if (nd.tag == T_NAMED || nd.tag == T_SC) {
        if sc_width(src, nd.p0, nd.p1) != 0 { return 0u32; }
        return find_struct(pp, src, e, nd.p0, nd.p1);
    }
    return 0u32;
}
// The `T_ENUM` decl node for an enum type descriptor, or 0 if not an enum. A
// scrutinee's `cur_ty` may be an enum decl node directly (a constructor result)
// OR a `T_NAMED` local/param, so route both through here.
fn enum_of_ty(pp: read P, src: [u8], e: write E, tn: u32) -> u32 {
    if tn == 0u32 { return 0u32; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_APP && nd.b != 0u32 { return enum_of_ty(pp, src, e, nd.b); }
    if nd.tag == T_BOXRESULT { return nd.c; }
    if nd.tag == T_ENUM { return tn; }
    if (nd.tag == T_NAMED || nd.tag == T_SC) {
        if sc_width(src, nd.p0, nd.p1) != 0 { return 0u32; }
        return find_enum(pp, src, e, nd.p0, nd.p1);
    }
    return 0u32;
}
fn array_len_of(pp: read P, sn: u32) -> usize {
    let nd: Node = pp.nodes[conv usize sn];
    if nd.tag == T_INT { return conv usize nd.ival; }
    // Named lengths (`[N]T` with a `static` N) need a const table -> S3+.
    return 0usize;
}
// ---- compiler-known std collection recognizers (mirror the oracle's Type::App
// "Vec"/"Map" special-cases and the synthesized nominal `String`) ---------------
fn is_vec_ty(pp: read P, src: [u8], tn: u32) -> bool {
    if tn == 0u32 { return false; }
    let nd: Node = pp.nodes[conv usize tn];
    return nd.tag == T_APP && span_eq(src, nd.p0, nd.p1, b"Vec");
}
fn is_map_ty(pp: read P, src: [u8], tn: u32) -> bool {
    if tn == 0u32 { return false; }
    let nd: Node = pp.nodes[conv usize tn];
    return nd.tag == T_APP && span_eq(src, nd.p0, nd.p1, b"Map");
}
fn is_string_ty(pp: read P, src: [u8], tn: u32) -> bool {
    if tn == 0u32 { return false; }
    let nd: Node = pp.nodes[conv usize tn];
    return nd.tag == T_NAMED && span_eq(src, nd.p0, nd.p1, b"String");
}
// The element/value type node of a Vec/Map App (the sole type argument).
fn coll_elem_ty(pp: read P, tn: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize tn];
    return nd.a;
}
// A little-endian usize load/store over the flat store (Vec/Map/String words).
fn ld_us(e: write E, addr: usize) -> usize {
    return conv usize to_u64(mem_load(e, addr, W_USIZE));
}
fn st_us(e: write E, addr: usize, v: usize) -> unit {
    mem_store(e, addr, conv i64 v, W_USIZE);
    return;
}

fn ty_size(pp: read P, src: [u8], e: write E, tn: u32) -> usize {
    if tn == 0u32 { return 0usize; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_APP && nd.b != 0u32 { return ty_size(pp, src, e, nd.b); }
    // Compiler-known std `Vec[T]`/`Map[V]`: five u64 words {buf,len,cap,ctx,vt}.
    if nd.tag == T_APP {
        if span_eq(src, nd.p0, nd.p1, b"Vec") || span_eq(src, nd.p0, nd.p1, b"Map") { return 40usize; }
    }
    if nd.tag == T_STR { return 16usize; }
    if (nd.tag == T_NAMED || nd.tag == T_SC) {
        let w: i32 = sc_width(src, nd.p0, nd.p1);
        if w != 0 { return w_size(w); }
        if span_eq(src, nd.p0, nd.p1, b"String") { return 40usize; }
        if span_eq(src, nd.p0, nd.p1, b"str") { return 16usize; }
        let sid: u32 = find_struct(pp, src, e, nd.p0, nd.p1);
        if sid != 0u32 { return struct_size(pp, src, e, sid); }
        let eid: u32 = find_enum(pp, src, e, nd.p0, nd.p1);
        if eid != 0u32 { return enum_size(pp, src, e, eid); }
        return 0usize;
    }
    if nd.tag == T_STRUCT { return struct_size(pp, src, e, tn); }
    if nd.tag == T_ENUM { return enum_size(pp, src, e, tn); }
    if nd.tag == T_RAWPTR || nd.tag == T_FNPTR { return 8usize; }
    if nd.tag == T_BORROW || nd.tag == T_BORROWMUT { return 8usize; }
    if nd.tag == T_SLICE || nd.tag == T_SLICEMUT { return 16usize; }
    if nd.tag == T_BOX { return 24usize; }
    if nd.tag == T_BOXRESULT { return 32usize; }
    if nd.tag == T_ARRAY {
        let n: usize = array_len_of(pp, nd.a);
        let esz: usize = ty_size(pp, src, e, nd.b);
        let eal: usize = ty_align(pp, src, e, nd.b);
        return round_up_us(esz, eal) * n;
    }
    return 0usize;
}
fn ty_align(pp: read P, src: [u8], e: write E, tn: u32) -> usize {
    if tn == 0u32 { return 1usize; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_APP && nd.b != 0u32 { return ty_align(pp, src, e, nd.b); }
    if nd.tag == T_APP {
        if span_eq(src, nd.p0, nd.p1, b"Vec") || span_eq(src, nd.p0, nd.p1, b"Map") { return 8usize; }
    }
    if nd.tag == T_STR { return 8usize; }
    if (nd.tag == T_NAMED || nd.tag == T_SC) {
        let w: i32 = sc_width(src, nd.p0, nd.p1);
        if w != 0 { return w_size(w); }
        if span_eq(src, nd.p0, nd.p1, b"String") { return 8usize; }
        if span_eq(src, nd.p0, nd.p1, b"str") { return 8usize; }
        let sid: u32 = find_struct(pp, src, e, nd.p0, nd.p1);
        if sid != 0u32 { return struct_align(pp, src, e, sid); }
        let eid: u32 = find_enum(pp, src, e, nd.p0, nd.p1);
        if eid != 0u32 { return 8usize; }
        return 1usize;
    }
    if nd.tag == T_STRUCT { return struct_align(pp, src, e, tn); }
    if nd.tag == T_ENUM { return 8usize; }
    if nd.tag == T_RAWPTR || nd.tag == T_FNPTR { return 8usize; }
    if nd.tag == T_BORROW || nd.tag == T_BORROWMUT { return 8usize; }
    if nd.tag == T_SLICE || nd.tag == T_SLICEMUT { return 8usize; }
    if nd.tag == T_BOX || nd.tag == T_BOXRESULT { return 8usize; }
    if nd.tag == T_ARRAY { return ty_align(pp, src, e, nd.b); }
    return 1usize;
}
fn struct_size(pp: read P, src: [u8], e: write E, sid: u32) -> usize {
    if sid == 0u32 { return 0usize; }
    let snode: Node = pp.nodes[conv usize sid];
    let mut off: usize = 0usize;
    let mut align: usize = 1usize;
    let mut cur: u32 = snode.b;
    while cur != 0u32 {
        let fd: Node = pp.nodes[conv usize cur];
        let a: usize = ty_align(pp, src, e, fd.a);
        if a > align { align = a; }
        off = round_up_us(off, a);
        off = off + ty_size(pp, src, e, fd.a);
        cur = fd.nx;
    }
    return round_up_us(off, align);
}
fn struct_align(pp: read P, src: [u8], e: write E, sid: u32) -> usize {
    if sid == 0u32 { return 1usize; }
    let snode: Node = pp.nodes[conv usize sid];
    let mut align: usize = 1usize;
    let mut cur: u32 = snode.b;
    while cur != 0u32 {
        let fd: Node = pp.nodes[conv usize cur];
        let a: usize = ty_align(pp, src, e, fd.a);
        if a > align { align = a; }
        cur = fd.nx;
    }
    return align;
}
// Byte offset of field [fs,fen) within struct `sid` (declared-order layout).
fn field_off(pp: read P, src: [u8], e: write E, sid: u32, fs: usize, fen: usize) -> usize {
    let snode: Node = pp.nodes[conv usize sid];
    let mut off: usize = 0usize;
    let mut cur: u32 = snode.b;
    while cur != 0u32 {
        let fd: Node = pp.nodes[conv usize cur];
        let a: usize = ty_align(pp, src, e, fd.a);
        off = round_up_us(off, a);
        if name_eq(src, fs, fen, fd.p0, fd.p1) { return off; }
        off = off + ty_size(pp, src, e, fd.a);
        cur = fd.nx;
    }
    return 0usize;
}
// Byte offset of the field named by a byte-string LITERAL within struct `sid`
// (name-agnostic ABI resolution: box/unbox find `ctx`/`vt`/`alloc`/`free` here).
fn field_off_lit(pp: read P, src: [u8], e: write E, sid: u32, name: [u8]) -> usize {
    let snode: Node = pp.nodes[conv usize sid];
    let mut off: usize = 0usize;
    let mut cur: u32 = snode.b;
    while cur != 0u32 {
        let fd: Node = pp.nodes[conv usize cur];
        let a: usize = ty_align(pp, src, e, fd.a);
        off = round_up_us(off, a);
        if span_eq(src, fd.p0, fd.p1, name) { return off; }
        off = off + ty_size(pp, src, e, fd.a);
        cur = fd.nx;
    }
    return 0usize;
}
// Type node of field [fs,fen) within struct `sid`.
fn field_ty(pp: read P, src: [u8], sid: u32, fs: usize, fen: usize) -> u32 {
    let snode: Node = pp.nodes[conv usize sid];
    let mut cur: u32 = snode.b;
    while cur != 0u32 {
        let fd: Node = pp.nodes[conv usize cur];
        if name_eq(src, fs, fen, fd.p0, fd.p1) { return fd.a; }
        cur = fd.nx;
    }
    return 0u32;
}
// Is `tn` an aggregate (a real struct/array with bytes), not a scalar or unit?
fn ty_is_agg(pp: read P, src: [u8], e: write E, tn: u32) -> bool {
    if tn == 0u32 { return false; }
    if scalar_width(pp, src, tn) != 0 { return false; }
    return ty_size(pp, src, e, tn) > 0usize;
}

// ---- copyability + drop obligation (ported from src/types.rs is_copy/needs_drop) ----
// A struct is `copy` iff it carries the `copy` marker (T_STRUCT.op), declares no
// drop hook (T_STRUCT.c == 0), and every field is copy. Scalars/arrays-of-copy are
// copy. A struct NEEDS drop iff it has a hook or transitively holds a needs-drop
// field. These gate every S3 addition, so S1/S2 (scalars + `copy` aggregates) are
// drop-inert and unchanged.
fn is_copy(pp: read P, src: [u8], e: write E, tn: u32) -> bool {
    if tn == 0u32 { return true; }
    // Compiler-known std collections are owning (allocator-bearing), never copy.
    if is_vec_ty(pp, src, tn) || is_map_ty(pp, src, tn) || is_string_ty(pp, src, tn) { return false; }
    if scalar_width(pp, src, tn) != 0 { return true; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_BOX || nd.tag == T_BOXRESULT { return false; }
    if nd.tag == T_ARRAY { return is_copy(pp, src, e, nd.b); }
    let sid: u32 = struct_of_ty(pp, src, e, tn);
    if sid != 0u32 {
        let snode: Node = pp.nodes[conv usize sid];
        if snode.op == 0 { return false; }
        if snode.c != 0u32 { return false; }
        let mut cur: u32 = snode.b;
        while cur != 0u32 {
            let fd: Node = pp.nodes[conv usize cur];
            if !is_copy(pp, src, e, fd.a) { return false; }
            cur = fd.nx;
        }
        return true;
    }
    let eid: u32 = enum_of_ty(pp, src, e, tn);
    if eid != 0u32 {
        let enode: Node = pp.nodes[conv usize eid];
        if enode.op == 0 { return false; }
        let mut vc: u32 = enode.b;
        while vc != 0u32 {
            let vd: Node = pp.nodes[conv usize vc];
            let mut pc: u32 = vd.a;
            while pc != 0u32 {
                let pn: Node = pp.nodes[conv usize pc];
                if !is_copy(pp, src, e, pc) { return false; }
                pc = pn.nx;
            }
            vc = vd.nx;
        }
        return true;
    }
    return true;
}
fn needs_drop(pp: read P, src: [u8], e: write E, tn: u32) -> bool {
    if tn == 0u32 { return false; }
    // Vec/Map free their buffer (+ elements/keys) on drop; String frees its buffer.
    if is_vec_ty(pp, src, tn) || is_map_ty(pp, src, tn) || is_string_ty(pp, src, tn) { return true; }
    if scalar_width(pp, src, tn) != 0 { return false; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_BOX || nd.tag == T_BOXRESULT { return true; }
    if nd.tag == T_ARRAY { return needs_drop(pp, src, e, nd.b); }
    let sid: u32 = struct_of_ty(pp, src, e, tn);
    if sid != 0u32 {
        let snode: Node = pp.nodes[conv usize sid];
        if snode.c != 0u32 { return true; }
        let mut cur: u32 = snode.b;
        while cur != 0u32 {
            let fd: Node = pp.nodes[conv usize cur];
            if needs_drop(pp, src, e, fd.a) { return true; }
            cur = fd.nx;
        }
        return false;
    }
    let eid: u32 = enum_of_ty(pp, src, e, tn);
    if eid != 0u32 {
        let enode: Node = pp.nodes[conv usize eid];
        let mut vc: u32 = enode.b;
        while vc != 0u32 {
            let vd: Node = pp.nodes[conv usize vc];
            let mut pc: u32 = vd.a;
            while pc != 0u32 {
                let pn: Node = pp.nodes[conv usize pc];
                if needs_drop(pp, src, e, pc) { return true; }
                pc = pn.nx;
            }
            vc = vd.nx;
        }
        return false;
    }
    return false;
}
// Declared-order 0-based position of field [fs,fen) in struct sid.
fn field_index(pp: read P, src: [u8], sid: u32, fs: usize, fen: usize) -> i32 {
    let snode: Node = pp.nodes[conv usize sid];
    let mut cur: u32 = snode.b;
    let mut k: i32 = 0;
    while cur != 0u32 {
        let fd: Node = pp.nodes[conv usize cur];
        if name_eq(src, fs, fen, fd.p0, fd.p1) { return k; }
        k = k + 1i32;
        cur = fd.nx;
    }
    return 0 - 1i32;
}

// ---- enum layout (mirrors src/interp/layout.rs enum_size/payload_offset) -----
// Enum layout: {tag: u64 @0, payload @8}. The payload is laid out struct-style
// (declared order, natural alignment) from offset 8; enum size = round_up(8 +
// max padded-payload, 8), enum align = 8 always. Tag = the variant's 0-based
// declared index. The payload chain is a raw type-node `nx`-chain (each node IS
// the field's type), so this generalizes S2's struct-field layout.
fn payload_size(pp: read P, src: [u8], e: write E, head: u32) -> usize {
    let mut off: usize = 0usize;
    let mut align: usize = 1usize;
    let mut cur: u32 = head;
    while cur != 0u32 {
        let tn: Node = pp.nodes[conv usize cur];
        let a: usize = ty_align(pp, src, e, cur);
        if a > align { align = a; }
        off = round_up_us(off, a);
        off = off + ty_size(pp, src, e, cur);
        cur = tn.nx;
    }
    return round_up_us(off, align);
}
fn enum_size(pp: read P, src: [u8], e: write E, eid: u32) -> usize {
    if eid == 0u32 { return 0usize; }
    let enode: Node = pp.nodes[conv usize eid];
    let mut max: usize = 0usize;
    let mut cur: u32 = enode.b;
    while cur != 0u32 {
        let vd: Node = pp.nodes[conv usize cur];
        let psz: usize = payload_size(pp, src, e, vd.a);
        if psz > max { max = psz; }
        cur = vd.nx;
    }
    return round_up_us(8usize + max, 8usize);
}
// The `T_VARIANT` node at 0-based declared index `idx`, or 0 if out of range.
fn variant_by_index(pp: read P, eid: u32, idx: i32) -> u32 {
    let enode: Node = pp.nodes[conv usize eid];
    let mut cur: u32 = enode.b;
    let mut k: i32 = 0;
    while cur != 0u32 {
        if k == idx { return cur; }
        let vd: Node = pp.nodes[conv usize cur];
        k = k + 1i32;
        cur = vd.nx;
    }
    return 0u32;
}
// 0-based declared index of the variant named [s,en), or -1 if absent.
fn variant_index_by_name(pp: read P, src: [u8], eid: u32, s: usize, en: usize) -> i32 {
    let enode: Node = pp.nodes[conv usize eid];
    let mut cur: u32 = enode.b;
    let mut k: i32 = 0;
    while cur != 0u32 {
        let vd: Node = pp.nodes[conv usize cur];
        if name_eq(src, vd.p0, vd.p1, s, en) { return k; }
        k = k + 1i32;
        cur = vd.nx;
    }
    return 0 - 1i32;
}
// Offset (from the enum base, INCLUDING the tag) of payload field `i`.
fn variant_payload_off(pp: read P, src: [u8], e: write E, vid: u32, i: i32) -> usize {
    let vd: Node = pp.nodes[conv usize vid];
    let mut off: usize = 0usize;
    let mut k: i32 = 0;
    let mut cur: u32 = vd.a;
    while cur != 0u32 {
        let tn: Node = pp.nodes[conv usize cur];
        let a: usize = ty_align(pp, src, e, cur);
        off = round_up_us(off, a);
        if k == i { return 8usize + off; }
        off = off + ty_size(pp, src, e, cur);
        k = k + 1i32;
        cur = tn.nx;
    }
    return 8usize;
}
// Type node of payload field `i` of variant `vid`, or 0 if absent.
fn variant_payload_ty(pp: read P, vid: u32, i: i32) -> u32 {
    let vd: Node = pp.nodes[conv usize vid];
    let mut k: i32 = 0;
    let mut cur: u32 = vd.a;
    while cur != 0u32 {
        if k == i { return cur; }
        let tn: Node = pp.nodes[conv usize cur];
        k = k + 1i32;
        cur = tn.nx;
    }
    return 0u32;
}

// ---- move-mask side table (whole-value + ONE-LEVEL partial move) -------------
// Each row records a moved sub-path of a local: mv_field == -1 marks the whole
// local moved, mv_field >= 0 marks that field index moved. `consume` at a move-out
// site pushes a row; scope/frame exit consults it to suppress the source's drop.
fn mv_push(e: write E, li: usize, fi: i32) -> unit {
    let k: usize = e.mv_n;
    e.*.mv_local[k] = li;
    e.*.mv_field[k] = fi;
    e.*.mv_n = k + 1usize;
    return;
}
fn whole_moved(e: write E, li: usize) -> bool {
    let mut i: usize = 0usize;
    while i < e.mv_n {
        if e.mv_local[i] == li && e.mv_field[i] == 0 - 1i32 { return true; }
        i = i + 1usize;
    }
    return false;
}
fn partially_moved(e: write E, li: usize) -> bool {
    let mut i: usize = 0usize;
    while i < e.mv_n {
        if e.mv_local[i] == li && e.mv_field[i] >= 0i32 { return true; }
        i = i + 1usize;
    }
    return false;
}
fn field_moved(e: write E, li: usize, fi: i32) -> bool {
    let mut i: usize = 0usize;
    while i < e.mv_n {
        if e.mv_local[i] == li {
            if e.mv_field[i] == 0 - 1i32 || e.mv_field[i] == fi { return true; }
        }
        i = i + 1usize;
    }
    return false;
}
// Re-own local `li` wholesale (reassignment): drop all its moved rows.
fn set_owned_whole(e: write E, li: usize) -> unit {
    let mut w: usize = 0usize;
    let mut r: usize = 0usize;
    while r < e.mv_n {
        if e.mv_local[r] != li {
            e.*.mv_local[w] = e.mv_local[r];
            e.*.mv_field[w] = e.mv_field[r];
            w = w + 1usize;
        }
        r = r + 1usize;
    }
    e.*.mv_n = w;
    return;
}
// Discard mask rows for locals at or above `base` (scope/frame exit reuses those
// local indices; stale rows would corrupt a later local reusing the slot).
fn clear_locals_from(e: write E, base: usize) -> unit {
    let mut w: usize = 0usize;
    let mut r: usize = 0usize;
    while r < e.mv_n {
        if e.mv_local[r] < base {
            e.*.mv_local[w] = e.mv_local[r];
            e.*.mv_field[w] = e.mv_field[r];
            w = w + 1usize;
        }
        r = r + 1usize;
    }
    e.*.mv_n = w;
    return;
}

// ---- temps (non-copy values materialized during a statement) -----------------
// Only NON-copy aggregates register a temp; a copy aggregate creates none, so the
// S2 corpus produces no temps. A temp consumed by a move is killed (live = 0) and
// not dropped; a live temp is dropped at statement end (drop_stmt_temps).
fn reg_temp(e: write E, addr: usize, ty: u32) -> usize {
    let i: usize = e.tmp_n;
    e.*.tmp_addr[i] = addr;
    e.*.tmp_ty[i] = ty;
    e.*.tmp_live[i] = 1u8;
    e.*.tmp_n = i + 1usize;
    return i;
}
// Apply a recorded move-out: org 1 kills a temp; 2 marks the whole local moved;
// 3 marks one field of the local moved.
fn do_consume(e: write E, org: i32, a: usize, b: i32) -> unit {
    if org == 1 {
        e.*.tmp_live[a] = 0u8;
    } else if org == 2 {
        mv_push(e, a, 0 - 1i32);
    } else if org == 3 {
        mv_push(e, a, b);
    }
    return;
}

// ---- the trace-producing drop core -------------------------------------------
// run_drop_hook binds `self` to the value's address (a borrow: owns = 0, so it is
// not itself dropped) and executes the struct's drop-hook block, exactly like the
// oracle's run_drop_hook -- so `trace(self.id)` inside the hook fires the observable
// drop trace. cur_base/loc_n/stack_bump are saved and restored like a call frame.
fn run_drop_hook(pp: read P, src: [u8], e: write E, hook: u32, addr: usize, sid: u32) -> i32 {
    let saved_base: usize = e.cur_base;
    let base: usize = e.loc_n;
    let base_bump: usize = e.stack_bump;
    e.*.cur_base = base;
    loc_push(e, e.self_p0, e.self_p1, addr, 0, sid, 0);
    let st: i32 = exec_block(pp, src, e, hook);
    clear_locals_from(e, base);
    e.*.loc_n = base;
    e.*.stack_bump = base_bump;
    e.*.cur_base = saved_base;
    return st;
}
// Drop a struct's fields in REVERSE declared order, skipping moved fields; `li` is
// the owning local's index (for the mask) or -1 when there is no mask (a temp or a
// nested sub-value, which the one-level model never tracks as partially moved).
fn drop_fields_rev(pp: read P, src: [u8], e: write E, addr: usize, sid: u32, li: i64) -> i32 {
    let snode: Node = pp.nodes[conv usize sid];
    let mut foff: [64]usize = [0usize; 64];
    let mut ftyp: [64]u32 = [0u32; 64];
    let mut n: usize = 0usize;
    let mut off: usize = 0usize;
    let mut cur: u32 = snode.b;
    while cur != 0u32 {
        let fd: Node = pp.nodes[conv usize cur];
        let a: usize = ty_align(pp, src, e, fd.a);
        off = round_up_us(off, a);
        foff[n] = off;
        ftyp[n] = fd.a;
        off = off + ty_size(pp, src, e, fd.a);
        n = n + 1usize;
        cur = fd.nx;
    }
    let mut k: usize = n;
    while k > 0usize {
        k = k - 1usize;
        let mut skip: bool = false;
        if li >= 0i64 {
            if field_moved(e, conv usize li, conv i32 k) { skip = true; }
        }
        if !skip {
            let sc: i32 = drop_value(pp, src, e, addr + foff[k], ftyp[k], 0 - 1i64);
            if sc != 0 { return sc; }
        }
    }
    return 0;
}
// Drop the ACTIVE variant's payload fields in REVERSE order, skipping fields the
// move-mask marks moved (a bound non-copy payload). `li` is the owning local's
// index for the mask, or -1 for a temp/nested value. Enums carry no drop hook,
// so this is the whole of enum drop -- tag-directed, the dual of drop_fields_rev.
fn drop_variant_rev(pp: read P, src: [u8], e: write E, addr: usize, vid: u32, li: i64) -> i32 {
    let vd: Node = pp.nodes[conv usize vid];
    let mut foff: [64]usize = [0usize; 64];
    let mut ftyp: [64]u32 = [0u32; 64];
    let mut n: usize = 0usize;
    let mut off: usize = 0usize;
    let mut cur: u32 = vd.a;
    while cur != 0u32 {
        let tn: Node = pp.nodes[conv usize cur];
        let a: usize = ty_align(pp, src, e, cur);
        off = round_up_us(off, a);
        foff[n] = 8usize + off;
        ftyp[n] = cur;
        off = off + ty_size(pp, src, e, cur);
        n = n + 1usize;
        cur = tn.nx;
    }
    let mut k: usize = n;
    while k > 0usize {
        k = k - 1usize;
        let mut skip: bool = false;
        if li >= 0i64 {
            if field_moved(e, conv usize li, conv i32 k) { skip = true; }
        }
        if !skip {
            let sc: i32 = drop_value(pp, src, e, addr + foff[k], ftyp[k], 0 - 1i64);
            if sc != 0 { return sc; }
        }
    }
    return 0;
}
// Drop the value of type `tn` at `addr` (universal LIFO order). A struct runs its
// hook FIRST (whole value), unless partially moved, THEN drops fields reverse; an
// array drops elements reverse; scalars/copy are inert. `li` carries the mask.
// Compiler-known std `Vec[T]` drop (mirrors src/interp/eval.rs drop_value Vec arm):
// drop each LIVE element (`0..len`) in REVERSE, then free the backing buffer
// through the carried allocator. Popped elements decremented `len` and are not
// re-dropped. A null buffer (empty/never-grown Vec) frees nothing.
fn drop_vec(pp: read P, src: [u8], e: write E, addr: usize, tn: u32) -> i32 {
    let buf: usize = ld_us(e, addr);
    if buf != 0usize {
        let elem: u32 = coll_elem_ty(pp, tn);
        let stride: usize = stride_of(pp, src, e, elem);
        let len: usize = ld_us(e, addr + 8usize);
        let mut k: usize = len;
        while k > 0usize {
            k = k - 1usize;
            let sc: i32 = drop_value(pp, src, e, buf + k * stride, elem, 0 - 1i64);
            if sc != 0 { return sc; }
        }
        let cap: usize = ld_us(e, addr + 16usize);
        let ctx: i64 = mem_load(e, addr + 24usize, W_USIZE);
        let vt: i64 = mem_load(e, addr + 32usize, W_USIZE);
        return call_free(pp, src, e, ctx, vt, buf, cap * stride, ty_align(pp, src, e, elem));
    }
    return 0;
}
// Compiler-known std hash `Map[V]` drop (mirrors the oracle's Map arm): free each
// LIVE key byte-copy, drop each LIVE value, then free the bucket buffer.
fn drop_map(pp: read P, src: [u8], e: write E, addr: usize, tn: u32) -> i32 {
    let buf: usize = ld_us(e, addr);
    if buf != 0usize {
        let valty: u32 = coll_elem_ty(pp, tn);
        let stride: usize = map_stride(pp, src, e, valty);
        let cap: usize = ld_us(e, addr + 16usize);
        let ctx: i64 = mem_load(e, addr + 24usize, W_USIZE);
        let vt: i64 = mem_load(e, addr + 32usize, W_USIZE);
        let mut i: usize = 0usize;
        while i < cap {
            let b: usize = buf + i * stride;
            if mem_load(e, b, W_USIZE) == 1i64 {
                let kptr: usize = ld_us(e, b + 8usize);
                let klen: usize = ld_us(e, b + 16usize);
                let fc: i32 = call_free(pp, src, e, ctx, vt, kptr, klen, 1usize);
                if fc != 0 { return fc; }
                let dc: i32 = drop_value(pp, src, e, b + 24usize, valty, 0 - 1i64);
                if dc != 0 { return dc; }
            }
            i = i + 1usize;
        }
        return call_free(pp, src, e, ctx, vt, buf, cap * stride, 8usize);
    }
    return 0;
}
// Compiler-known `String` drop: free its heap buffer through the carried vtable.
fn drop_string(pp: read P, src: [u8], e: write E, addr: usize) -> i32 {
    let buf: usize = ld_us(e, addr);
    if buf != 0usize {
        let cap: usize = ld_us(e, addr + 16usize);
        let ctx: i64 = mem_load(e, addr + 24usize, W_USIZE);
        let vt: i64 = mem_load(e, addr + 32usize, W_USIZE);
        return call_free(pp, src, e, ctx, vt, buf, cap, 1usize);
    }
    return 0;
}
fn drop_value(pp: read P, src: [u8], e: write E, addr: usize, tn: u32, li: i64) -> i32 {
    if is_vec_ty(pp, src, tn) { return drop_vec(pp, src, e, addr, tn); }
    if is_map_ty(pp, src, tn) { return drop_map(pp, src, e, addr, tn); }
    if is_string_ty(pp, src, tn) { return drop_string(pp, src, e, addr); }
    let sid: u32 = struct_of_ty(pp, src, e, tn);
    if sid != 0u32 {
        let mut partial: bool = false;
        if li >= 0i64 { partial = partially_moved(e, conv usize li); }
        if !partial {
            let snode: Node = pp.nodes[conv usize sid];
            if snode.c != 0u32 {
                let sc: i32 = run_drop_hook(pp, src, e, snode.c, addr, sid);
                if sc != 0 { return sc; }
            }
        }
        return drop_fields_rev(pp, src, e, addr, sid, li);
    }
    let eid: u32 = enum_of_ty(pp, src, e, tn);
    if eid != 0u32 {
        let tagv: i64 = mem_load(e, addr, W_USIZE);
        let vid: u32 = variant_by_index(pp, eid, conv i32 tagv);
        return drop_variant_rev(pp, src, e, addr, vid, li);
    }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_BOX {
        let mut binner: u32 = nd.a;
        if tn == e.gen_box { binner = e.gen_inner; }
        return drop_box(pp, src, e, addr, binner);
    }
    if nd.tag == T_ARRAY {
        let n: usize = array_len_of(pp, nd.a);
        let elem: u32 = nd.b;
        let esz: usize = ty_size(pp, src, e, elem);
        let eal: usize = ty_align(pp, src, e, elem);
        let stride: usize = round_up_us(esz, eal);
        let mut k: usize = n;
        while k > 0usize {
            k = k - 1usize;
            let sc: i32 = drop_value(pp, src, e, addr + k * stride, elem, 0 - 1i64);
            if sc != 0 { return sc; }
        }
        return 0;
    }
    return 0;
}
// The alloc-on-drop core for a `Box T` at `addr` (fields ptr@0, ctx@8, vt@16).
// If the pointer is live, the pointee is dropped FIRST (recursive inner-type drop
// -- a `Box` of a `Box` recurses), THEN the storage is freed through the carried
// vtable. Order is load-bearing: pointee-then-free (mirrors src/interp/eval.rs
// drop_box). A null pointer (a moved-out box) drops nothing.
fn drop_box(pp: read P, src: [u8], e: write E, addr: usize, inner: u32) -> i32 {
    let ptr: usize = conv usize to_u64(mem_load(e, addr, W_USIZE));
    let ctx: i64 = mem_load(e, addr + 8usize, W_USIZE);
    let vt: i64 = mem_load(e, addr + 16usize, W_USIZE);
    if ptr != 0usize {
        let sc: i32 = drop_value(pp, src, e, ptr, inner, 0 - 1i64);
        if sc != 0 { return sc; }
        let size: usize = ty_size(pp, src, e, inner);
        let align: usize = ty_align(pp, src, e, inner);
        return call_free(pp, src, e, ctx, vt, ptr, size, align);
    }
    return 0;
}
// Indirect free: read the `free` fn-ptr out of the vtable and call
// `free(ctx, ptr, size, align)` (all 8-byte scalars). Reuses `call_fn`, the same
// path S5a used for indirect `alloc` calls.
fn call_free(pp: read P, src: [u8], e: write E, ctx: i64, vt: i64, ptr: usize, size: usize, align: usize) -> i32 {
    let free_off: usize = field_off_lit(pp, src, e, e.alloc_vt_sid, b"free");
    let vt_addr: usize = conv usize to_u64(vt);
    let ffn: u32 = conv u32 to_u64(mem_load(e, vt_addr + free_off, W_USIZE));
    e.*.arg_val[0] = ctx;
    e.*.arg_w[0] = W_USIZE;
    e.*.arg_addr[0] = 0usize;
    e.*.arg_val[1] = conv i64 ptr;
    e.*.arg_w[1] = W_USIZE;
    e.*.arg_addr[1] = 0usize;
    e.*.arg_val[2] = conv i64 size;
    e.*.arg_w[2] = W_USIZE;
    e.*.arg_addr[2] = 0usize;
    e.*.arg_val[3] = conv i64 align;
    e.*.arg_w[3] = W_USIZE;
    e.*.arg_addr[3] = 0usize;
    e.*.arg_n = 4usize;
    return call_fn(pp, src, e, ffn);
}
// Scan the source once for a "self" span; run_drop_hook binds `self` by matching
// these bytes (find_local compares src bytes), so the hook body's `self` resolves.
fn set_self_span(src: [u8], e: write E) -> unit {
    let n: usize = len(src);
    let mut i: usize = 0usize;
    while i + 4usize <= n {
        if src[i] == 115u8 && src[i + 1usize] == 101u8 && src[i + 2usize] == 108u8 && src[i + 3usize] == 102u8 {
            e.*.self_p0 = i;
            e.*.self_p1 = i + 4usize;
            return;
        }
        i = i + 1usize;
    }
    return;
}

// ---- comparisons -------------------------------------------------------------
fn cmp_op(op: i32, a: i64, b: i64, w: i32) -> i64 {
    let eq: bool = a == b;
    if op == OP_EQ { if eq { return 1i64; } return 0i64; }
    if op == OP_NE { if eq { return 0i64; } return 1i64; }
    let mut lt: bool = false;
    if w_signed(w) {
        lt = a < b;
    } else {
        lt = to_u64(a) < to_u64(b);
    }
    if op == OP_LT { if lt { return 1i64; } return 0i64; }
    if op == OP_LE { if lt || eq { return 1i64; } return 0i64; }
    if op == OP_GT { if !lt && !eq { return 1i64; } return 0i64; }
    if !lt { return 1i64; }
    return 0i64;
}

// ---- signed arithmetic: wrapping compute + sign-based overflow detection -----
fn arith_signed(op: i32, a: i64, b: i64, w: i32, e: write E, p0: usize, p1: usize) -> i32 {
    let mn: i64 = smin(w);
    let mx: i64 = smax(w);
    if op == OP_DIV {
        if b == 0i64 { set_fault(e, FK_DIVZERO, p0, p1); return 1; }
        if b == 0i64 - 1i64 && a == mn { set_fault(e, FK_OVERFLOW, p0, p1); return 1; }
        let q: i64 = a / b;
        if q < mn || q > mx { set_fault(e, FK_OVERFLOW, p0, p1); return 1; }
        e.*.cur_val = q; e.*.cur_w = w; return 0;
    }
    if op == OP_REM {
        if b == 0i64 { set_fault(e, FK_DIVZERO, p0, p1); return 1; }
        e.*.cur_val = a % b; e.*.cur_w = w; return 0;
    }
    let mut wrapped: i64 = 0i64;
    let mut ov: bool = false;
    if op == OP_ADD {
        wrapping { wrapped = a + b; }
        let sa: bool = a < 0i64;
        let sb: bool = b < 0i64;
        let sw: bool = wrapped < 0i64;
        ov = (sa == sb) && (sw != sa);
    } else if op == OP_SUB {
        wrapping { wrapped = a - b; }
        let sa: bool = a < 0i64;
        let sb: bool = b < 0i64;
        let sw: bool = wrapped < 0i64;
        ov = (sa != sb) && (sw != sa);
    } else {
        wrapping { wrapped = a * b; }
        if a == 0i64 {
            ov = false;
        } else if (a == 0i64 - 1i64 && b == imin()) || (b == 0i64 - 1i64 && a == imin()) {
            ov = true;
        } else {
            let chk: i64 = wrapped / a;
            ov = chk != b;
        }
    }
    if ov { set_fault(e, FK_OVERFLOW, p0, p1); return 1; }
    if wrapped < mn || wrapped > mx { set_fault(e, FK_OVERFLOW, p0, p1); return 1; }
    e.*.cur_val = wrapped; e.*.cur_w = w; return 0;
}

// ---- unsigned arithmetic: wrapping compute in u64 + carry/borrow detection ---
fn arith_unsigned(op: i32, a: i64, b: i64, w: i32, e: write E, p0: usize, p1: usize) -> i32 {
    let au: u64 = to_u64(a);
    let bu: u64 = to_u64(b);
    let mxu: u64 = umax(w);
    if op == OP_DIV {
        if bu == 0u64 { set_fault(e, FK_DIVZERO, p0, p1); return 1; }
        e.*.cur_val = to_i64b(au / bu); e.*.cur_w = w; return 0;
    }
    if op == OP_REM {
        if bu == 0u64 { set_fault(e, FK_DIVZERO, p0, p1); return 1; }
        e.*.cur_val = to_i64b(au % bu); e.*.cur_w = w; return 0;
    }
    let mut wrapped: u64 = 0u64;
    let mut ov: bool = false;
    if op == OP_ADD {
        wrapping { wrapped = au + bu; }
        if wrapped < au { ov = true; }
        if wrapped > mxu { ov = true; }
    } else if op == OP_SUB {
        if au < bu {
            ov = true;
        } else {
            wrapping { wrapped = au - bu; }
            if wrapped > mxu { ov = true; }
        }
    } else {
        wrapping { wrapped = au * bu; }
        if au != 0u64 {
            let chk: u64 = wrapped / au;
            if chk != bu { ov = true; }
        }
        if wrapped > mxu { ov = true; }
    }
    if ov { set_fault(e, FK_OVERFLOW, p0, p1); return 1; }
    e.*.cur_val = to_i64b(wrapped); e.*.cur_w = w; return 0;
}

// ---- bitwise -----------------------------------------------------------------
fn bit_op(op: i32, a: i64, b: i64, w: i32, e: write E) -> unit {
    let mut r: i64 = 0i64;
    if op == OP_BITAND { r = a & b; }
    else if op == OP_BITOR { r = a | b; }
    else { r = a ^ b; }
    if !w_is64(w) { r = fit_bits(r, w); }
    e.*.cur_val = r; e.*.cur_w = w;
    return;
}

// ---- shifts ------------------------------------------------------------------
fn shift_op(op: i32, a: i64, amt: i64, w: i32, e: write E, p0: usize, p1: usize) -> i32 {
    if amt < 0i64 { set_fault(e, FK_OVERFLOW, p0, p1); return 1; }
    let bits: i64 = conv i64 w_bits(w);
    if amt >= bits { set_fault(e, FK_OVERFLOW, p0, p1); return 1; }
    let mut r: i64 = 0i64;
    if op == OP_SHL {
        if w_is64(w) {
            if w_signed(w) {
                wrapping { r = a << amt; }
            } else {
                let au: u64 = to_u64(a);
                let mut ru: u64 = 0u64;
                wrapping { ru = au << amt; }
                r = to_i64b(ru);
            }
        } else {
            wrapping { r = a << amt; }
            r = fit_bits(r, w);
        }
    } else {
        if w_signed(w) {
            r = a >> amt;
            if !w_is64(w) { r = fit_bits(r, w); }
        } else {
            let au: u64 = to_u64(a);
            r = to_i64b(au >> amt);
            if !w_is64(w) { r = fit_bits(r, w); }
        }
    }
    e.*.cur_val = r; e.*.cur_w = w; return 0;
}

// ---- places (l-values): locals, struct fields, array elements ----------------
// Resolves an addressable expression to (plc_addr, plc_w, plc_ty). A scalar place
// has plc_w in 1..11; an aggregate place has plc_w == 0 and plc_ty its type node.
// The running cur_span is threaded so the Bounds fault reports the base array's
// span, exactly like eval.rs's eval_place.
// Auto-deref the current place through any `Box` layers (a field/index access on
// a `Box T` reads THROUGH the box, mirroring the oracle's `peel_place`). Each
// layer reads the pointer at the place and re-bases on the pointee.
fn peel_box_place(pp: read P, e: write E) -> unit {
    loop {
        let boxid: u32 = e.plc_ty;
        let bnode: Node = pp.nodes[conv usize boxid];
        if bnode.tag == T_BOX || bnode.tag == T_BORROW || bnode.tag == T_BORROWMUT {
            let ptr: i64 = mem_load(e, e.plc_addr, W_USIZE);
            e.*.plc_addr = conv usize to_u64(ptr);
            let mut inner: u32 = bnode.a;
            if boxid == e.gen_box { inner = e.gen_inner; }
            e.*.plc_ty = inner;
        } else {
            return;
        }
    }
}
fn eval_place(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    e.*.cur_p0 = nd.p0;
    e.*.cur_p1 = nd.p1;
    let tg: i32 = nd.tag;
    if tg == T_PAREN {
        return eval_place(pp, src, e, nd.a);
    }
    if tg == T_PREFIX {
        if nd.op == PF_DEREF {
            // `get(...).*`: a std collection `get` returns a `read T` borrow whose
            // referent address IS the produced value (not stored in a place). Peel
            // the deref by evaluating the call and re-basing on that address.
            let opn: Node = pp.nodes[conv usize nd.a];
            if opn.tag == T_CALL {
                let scc: i32 = eval_expr(pp, src, e, nd.a, W_USIZE);
                if scc != 0 { return scc; }
                e.*.plc_addr = conv usize to_u64(e.cur_val);
                e.*.plc_ty = e.cur_ty;
                e.*.plc_w = scalar_width(pp, src, e.cur_ty);
                return 0;
            }
            let sc: i32 = eval_place(pp, src, e, nd.a);
            if sc != 0 { return sc; }
            let boxid: u32 = e.plc_ty;
            let bnode: Node = pp.nodes[conv usize boxid];
            let mut inner: u32 = bnode.a;
            if boxid == e.gen_box { inner = e.gen_inner; }
            let ptr: i64 = mem_load(e, e.plc_addr, W_USIZE);
            e.*.plc_addr = conv usize to_u64(ptr);
            e.*.plc_ty = inner;
            e.*.plc_w = scalar_width(pp, src, inner);
            return 0;
        }
    }
    if tg == T_ID {
        let idx: usize = find_local(src, e, nd.p0, nd.p1);
        if idx != e.loc_n {
            e.*.plc_addr = e.loc_addr[idx];
            e.*.plc_w = e.loc_w[idx];
            e.*.plc_ty = e.loc_ty[idx];
            return 0;
        }
        let si: usize = find_static(src, e, nd.p0, nd.p1);
        if si != e.static_n {
            e.*.plc_addr = e.static_addr[si];
            e.*.plc_w = e.static_w[si];
            e.*.plc_ty = e.static_ty[si];
            return 0;
        }
        // Neither a local nor a static: an unresolved name is an internal
        // invariant violation (analysis rejects it upstream), so fault explicitly
        // rather than re-reading `loc_addr[loc_n]`, the out-of-frame sentinel slot.
        set_fault(e, FK_PANIC, nd.p0, nd.p1);
        return 1;
    }
    if tg == T_FIELD {
        let sc: i32 = eval_place(pp, src, e, nd.a);
        if sc != 0 { return sc; }
        peel_box_place(pp, e);
        let base_addr: usize = e.plc_addr;
        let base_ty: u32 = e.plc_ty;
        let sid: u32 = struct_of_ty(pp, src, e, base_ty);
        let off: usize = field_off(pp, src, e, sid, nd.p0, nd.p1);
        let fty: u32 = field_ty(pp, src, sid, nd.p0, nd.p1);
        e.*.plc_addr = base_addr + off;
        e.*.plc_ty = fty;
        e.*.plc_w = scalar_width(pp, src, fty);
        return 0;
    }
    if tg == T_INDEX {
        let sc: i32 = eval_expr(pp, src, e, nd.b, W_USIZE);
        if sc != 0 { return sc; }
        let iv: u64 = to_u64(e.cur_val);
        let sc2: i32 = eval_place(pp, src, e, nd.a);
        if sc2 != 0 { return sc2; }
        peel_box_place(pp, e);
        let base_addr: usize = e.plc_addr;
        let arr_ty: u32 = e.plc_ty;
        let arrnd: Node = pp.nodes[conv usize arr_ty];
        if arrnd.tag == T_SLICE || arrnd.tag == T_SLICEMUT || arrnd.tag == T_STR {
            let sptr: usize = conv usize to_u64(mem_load(e, base_addr, W_USIZE));
            let slen: usize = conv usize to_u64(mem_load(e, base_addr + 8usize, W_USIZE));
            if iv >= conv u64 slen {
                set_fault(e, FK_BOUNDS, e.cur_p0, e.cur_p1);
                return 1;
            }
            let selem: u32 = arrnd.a;
            let sesz: usize = ty_size(pp, src, e, selem);
            let seal: usize = ty_align(pp, src, e, selem);
            let sstride: usize = round_up_us(sesz, seal);
            e.*.plc_addr = sptr + (conv usize iv) * sstride;
            e.*.plc_ty = selem;
            e.*.plc_w = scalar_width(pp, src, selem);
            return 0;
        }
        let n: usize = array_len_of(pp, arrnd.a);
        if iv >= conv u64 n {
            set_fault(e, FK_BOUNDS, e.cur_p0, e.cur_p1);
            return 1;
        }
        let elem: u32 = arrnd.b;
        let esz: usize = ty_size(pp, src, e, elem);
        let eal: usize = ty_align(pp, src, e, elem);
        let stride: usize = round_up_us(esz, eal);
        e.*.plc_addr = base_addr + (conv usize iv) * stride;
        e.*.plc_ty = elem;
        e.*.plc_w = scalar_width(pp, src, elem);
        return 0;
    }
    // Not a supported place form in S2; evaluate as a value (unreached by fixtures).
    return eval_expr(pp, src, e, i, 0 - 1i32);
}
// Materialize the resolved place into cur_val/cur_w (scalar) or the aggregate
// address channel (cur_val = address, cur_w = 0, cur_ty = type node).
fn load_place(e: write E) -> i32 {
    if e.plc_w != 0 {
        let v: i64 = mem_load(e, e.plc_addr, e.plc_w);
        e.*.cur_val = v;
        e.*.cur_w = e.plc_w;
        e.*.cur_ty = e.plc_ty;
    } else {
        e.*.cur_val = conv i64 e.plc_addr;
        e.*.cur_w = 0;
        e.*.cur_ty = e.plc_ty;
    }
    return 0;
}

// ---- struct + array constructors ---------------------------------------------
fn find_finit(pp: read P, src: [u8], head: u32, fs: usize, fen: usize) -> u32 {
    let mut cur: u32 = head;
    while cur != 0u32 {
        let fi: Node = pp.nodes[conv usize cur];
        if name_eq(src, fi.p0, fi.p1, fs, fen) { return cur; }
        cur = fi.nx;
    }
    return 0u32;
}
fn eval_struct_lit(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let mut sid: u32 = nd.b;
    if sid == 0u32 { sid = find_struct(pp, src, e, nd.p0, nd.p1); }
    let size: usize = struct_size(pp, src, e, sid);
    let align: usize = struct_align(pp, src, e, sid);
    let addr: usize = bump_alloc(e, size, align);
    zero_slot(e, addr, size);
    // Write each field at its offset in DECLARED order (matching the oracle's
    // field-evaluation order, which is observable if a field value calls trace).
    let snode: Node = pp.nodes[conv usize sid];
    let mut off: usize = 0usize;
    let mut fcur: u32 = snode.b;
    while fcur != 0u32 {
        let fdef: Node = pp.nodes[conv usize fcur];
        let fty: u32 = fdef.a;
        let a: usize = ty_align(pp, src, e, fty);
        off = round_up_us(off, a);
        let finit: u32 = find_finit(pp, src, nd.a, fdef.p0, fdef.p1);
        if finit != 0u32 {
            let fin: Node = pp.nodes[conv usize finit];
            let fw: i32 = scalar_width(pp, src, fty);
            if fw != 0 {
                let sc: i32 = eval_expr(pp, src, e, fin.a, fw);
                if sc != 0 { return sc; }
                mem_store(e, addr + off, e.cur_val, fw);
            } else {
                let sc: i32 = eval_expr(pp, src, e, fin.a, 0 - 1i32);
                if sc != 0 { return sc; }
                let forg: i32 = e.cur_org;
                let foa: usize = e.cur_org_a;
                let fob: i32 = e.cur_org_b;
                let sa: usize = conv usize e.cur_val;
                let fsz: usize = ty_size(pp, src, e, fty);
                mem_copy(e, addr + off, sa, fsz);
                if !is_copy(pp, src, e, fty) {
                    do_consume(e, forg, foa, fob);
                }
            }
        }
        off = off + ty_size(pp, src, e, fty);
        fcur = fdef.nx;
    }
    e.*.cur_val = conv i64 addr;
    e.*.cur_w = 0;
    e.*.cur_ty = sid;
    e.*.cur_org = 0;
    if !is_copy(pp, src, e, sid) {
        let ti: usize = reg_temp(e, addr, sid);
        e.*.cur_org = 1;
        e.*.cur_org_a = ti;
    }
    return 0;
}
fn eval_array_rep(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    // Oracle order: evaluate the size (`.b`), then the repeated value (`.a`).
    let scn: i32 = eval_expr(pp, src, e, nd.b, W_USIZE);
    if scn != 0 { return scn; }
    let n: usize = conv usize to_u64(e.cur_val);
    let scv: i32 = eval_expr(pp, src, e, nd.a, 0 - 1i32);
    if scv != 0 { return scv; }
    let ew: i32 = e.cur_w;
    let ety: u32 = e.cur_ty;
    let vval: i64 = e.cur_val;
    let mut esz: usize = 0usize;
    let mut eal: usize = 1usize;
    if ew != 0 {
        esz = w_size(ew);
        eal = w_size(ew);
    } else {
        esz = ty_size(pp, src, e, ety);
        eal = ty_align(pp, src, e, ety);
    }
    let stride: usize = round_up_us(esz, eal);
    let addr: usize = bump_alloc(e, stride * n, eal);
    let mut k: usize = 0usize;
    while k < n {
        if ew != 0 {
            mem_store(e, addr + k * stride, vval, ew);
        } else {
            mem_copy(e, addr + k * stride, conv usize vval, esz);
        }
        k = k + 1usize;
    }
    e.*.cur_val = conv i64 addr;
    e.*.cur_w = 0;
    e.*.cur_ty = nd.c;
    return 0;
}
fn eval_array_lit(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let mut ev_val: [16]i64 = [0i64; 16];
    let mut ev_w: [16]i32 = [0; 16];
    let mut ev_ty: [16]u32 = [0u32; 16];
    let mut m: usize = 0usize;
    let mut cur: u32 = nd.a;
    while cur != 0u32 {
        let cn: Node = pp.nodes[conv usize cur];
        let sc: i32 = eval_expr(pp, src, e, cur, 0 - 1i32);
        if sc != 0 { return sc; }
        ev_val[m] = e.cur_val;
        ev_w[m] = e.cur_w;
        ev_ty[m] = e.cur_ty;
        m = m + 1usize;
        cur = cn.nx;
    }
    let ew: i32 = ev_w[0];
    let mut esz: usize = 0usize;
    let mut eal: usize = 1usize;
    if ew != 0 {
        esz = w_size(ew);
        eal = w_size(ew);
    } else {
        esz = ty_size(pp, src, e, ev_ty[0]);
        eal = ty_align(pp, src, e, ev_ty[0]);
    }
    let stride: usize = round_up_us(esz, eal);
    let addr: usize = bump_alloc(e, stride * m, eal);
    let mut k: usize = 0usize;
    while k < m {
        if ew != 0 {
            mem_store(e, addr + k * stride, ev_val[k], ew);
        } else {
            mem_copy(e, addr + k * stride, conv usize ev_val[k], esz);
        }
        k = k + 1usize;
    }
    e.*.cur_val = conv i64 addr;
    e.*.cur_w = 0;
    e.*.cur_ty = 0u32;
    return 0;
}

// ---- enum constructors + match ----------------------------------------------
// Construct an enum value: resolve the enum + variant, allocate its size, write
// the tag as u64 @0, then store/copy each payload arg at its payload offset. The
// value is left in the aggregate channel (addr in cur_val, cur_w == 0, cur_ty =
// the enum decl node); a non-copy enum registers a temp like a struct literal.
fn eval_enum_ctor(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let mut eid: u32 = nd.c;
    if eid == 0u32 { eid = find_enum(pp, src, e, nd.p0, nd.p1); }
    if span_eq(src, nd.p0, nd.p1, b"BoxResult") {
        eid = enum_of_ty(pp, src, e, e.gen_boxresult);
    }
    let vnamenode: Node = pp.nodes[conv usize nd.a];
    let vidx: i32 = variant_index_by_name(pp, src, eid, vnamenode.p0, vnamenode.p1);
    let vid: u32 = variant_by_index(pp, eid, vidx);
    let size: usize = enum_size(pp, src, e, eid);
    let addr: usize = bump_alloc(e, size, 8usize);
    zero_slot(e, addr, size);
    mem_store(e, addr, conv i64 vidx, W_USIZE);
    let mut k: i32 = 0;
    let mut cur: u32 = nd.b;
    while cur != 0u32 {
        let an: Node = pp.nodes[conv usize cur];
        let off: usize = variant_payload_off(pp, src, e, vid, k);
        let pty: u32 = variant_payload_ty(pp, vid, k);
        let pw: i32 = scalar_width(pp, src, pty);
        if pw != 0 {
            let sc: i32 = eval_expr(pp, src, e, cur, pw);
            if sc != 0 { return sc; }
            mem_store(e, addr + off, e.cur_val, pw);
        } else {
            let sc: i32 = eval_expr(pp, src, e, cur, 0 - 1i32);
            if sc != 0 { return sc; }
            let forg: i32 = e.cur_org;
            let foa: usize = e.cur_org_a;
            let fob: i32 = e.cur_org_b;
            let sa: usize = conv usize e.cur_val;
            let fsz: usize = ty_size(pp, src, e, pty);
            mem_copy(e, addr + off, sa, fsz);
            if !is_copy(pp, src, e, pty) {
                do_consume(e, forg, foa, fob);
            }
        }
        k = k + 1i32;
        cur = an.nx;
    }
    e.*.cur_val = conv i64 addr;
    e.*.cur_w = 0;
    e.*.cur_ty = eid;
    e.*.cur_org = 0;
    if !is_copy(pp, src, e, eid) {
        let ti: usize = reg_temp(e, addr, eid);
        e.*.cur_org = 1;
        e.*.cur_org_a = ti;
    }
    return 0;
}
// Evaluate a match: peel the scrutinee to its enum place, read the tag, pick the
// FIRST source-order arm whose pattern matches (variant pattern by name; wildcard
// / bare-binding match any), then run the arm in a fresh scope. Bindings pull from
// the active variant's payload offsets: a copy payload is byte-copied to a fresh
// slot; a non-copy payload is aliased and the scrutinee's payload field is marked
// moved in the move-mask (so the scrutinee's later drop skips it). S4 targets
// OWNED scrutinees; borrowed/boxed peeling is deferred.
fn eval_match(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let sc: i32 = eval_expr(pp, src, e, nd.a, 0 - 1i32);
    if sc != 0 { return sc; }
    let scrut_addr: usize = conv usize e.cur_val;
    let scrut_ty: u32 = e.cur_ty;
    let scrut_org: i32 = e.cur_org;
    let scrut_org_a: usize = e.cur_org_a;
    let eid: u32 = enum_of_ty(pp, src, e, scrut_ty);
    let tagv: i64 = mem_load(e, scrut_addr, W_USIZE);
    let vid: u32 = variant_by_index(pp, eid, conv i32 tagv);
    let vnode: Node = pp.nodes[conv usize vid];
    let mut chosen: u32 = 0u32;
    let mut acur: u32 = nd.b;
    while acur != 0u32 {
        let arm: Node = pp.nodes[conv usize acur];
        let pat: Node = pp.nodes[conv usize arm.a];
        if pat.tag == T_WILD || pat.tag == T_BIND {
            chosen = acur;
            break;
        }
        if pat.tag == T_PVARIANT {
            let pnamenode: Node = pp.nodes[conv usize pat.a];
            if name_eq(src, pnamenode.p0, pnamenode.p1, vnode.p0, vnode.p1) {
                chosen = acur;
                break;
            }
        }
        acur = arm.nx;
    }
    if chosen == 0u32 {
        set_fault(e, FK_PANIC, nd.p0, nd.p1);
        return 1;
    }
    let base: usize = e.loc_n;
    let base_bump: usize = e.stack_bump;
    let armnd: Node = pp.nodes[conv usize chosen];
    let patnd: Node = pp.nodes[conv usize armnd.a];
    if patnd.tag == T_PVARIANT {
        let mut k: i32 = 0;
        let mut pcur: u32 = patnd.b;
        while pcur != 0u32 {
            let subnd: Node = pp.nodes[conv usize pcur];
            let off: usize = variant_payload_off(pp, src, e, vid, k);
            let pty: u32 = variant_payload_ty(pp, vid, k);
            let sub_addr: usize = scrut_addr + off;
            if subnd.tag == T_BIND {
                let pw: i32 = scalar_width(pp, src, pty);
                if is_copy(pp, src, e, pty) {
                    let psz: usize = ty_size(pp, src, e, pty);
                    let pal: usize = ty_align(pp, src, e, pty);
                    let slot: usize = bump_alloc(e, psz, pal);
                    mem_copy(e, slot, sub_addr, psz);
                    loc_push(e, subnd.p0, subnd.p1, slot, pw, pty, 1);
                } else {
                    loc_push(e, subnd.p0, subnd.p1, sub_addr, 0, pty, 1);
                    if scrut_org == 2 {
                        mv_push(e, scrut_org_a, k);
                    }
                }
            }
            k = k + 1i32;
            pcur = subnd.nx;
        }
    }
    let mut bs: i32 = eval_expr(pp, src, e, armnd.b, 0 - 1i32);
    if bs != 1 {
        if drop_owned_locals_from(pp, src, e, base) != 0 { bs = 1; }
    }
    clear_locals_from(e, base);
    e.*.loc_n = base;
    e.*.stack_bump = base_bump;
    return bs;
}

// ---- `?` operator + `From`-based error widening (design 0007 §7.1) -----------
// 0-based index of the `ok`-marked variant (T_VARIANT.op == 1), or -1 if none.
fn ok_variant_index(pp: read P, eid: u32) -> i32 {
    if eid == 0u32 { return 0 - 1i32; }
    let enode: Node = pp.nodes[conv usize eid];
    let mut cur: u32 = enode.b;
    let mut k: i32 = 0;
    while cur != 0u32 {
        let vd: Node = pp.nodes[conv usize cur];
        if vd.op == 1 { return k; }
        k = k + 1i32;
        cur = vd.nx;
    }
    return 0 - 1i32;
}
// 0-based index of the FIRST non-`ok` (error) variant, or -1 if none.
fn err_variant_index(pp: read P, eid: u32) -> i32 {
    if eid == 0u32 { return 0 - 1i32; }
    let enode: Node = pp.nodes[conv usize eid];
    let mut cur: u32 = enode.b;
    let mut k: i32 = 0;
    while cur != 0u32 {
        let vd: Node = pp.nodes[conv usize cur];
        if vd.op != 1 { return k; }
        k = k + 1i32;
        cur = vd.nx;
    }
    return 0 - 1i32;
}
// Resolve `impl From[src] for tgt`'s `from` fn node: scan concrete T_IMPL blocks
// whose iface name is `From`, target enum == `tgt_eid`, and iface arg-0 == `src_eid`.
fn find_from_fn(pp: read P, src: [u8], e: write E, src_eid: u32, tgt_eid: u32) -> u32 {
    let mut cur: u32 = e.head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_IMPL && nd.a == 0u32 && span_eq(src, nd.p0, nd.p1, b"From") {
            let te: u32 = enum_of_ty(pp, src, e, nd.c);
            let mut se: u32 = 0u32;
            if nd.b != 0u32 { se = enum_of_ty(pp, src, e, nd.b); }
            if te == tgt_eid && se == src_eid {
                let mut mcur: u32 = nd.d;
                while mcur != 0u32 {
                    let mnd: Node = pp.nodes[conv usize mcur];
                    if span_eq(src, mnd.p0, mnd.p1, b"from") { return mcur; }
                    mcur = mnd.nx;
                }
            }
        }
        cur = nd.nx;
    }
    return 0u32;
}
// `expr?`: evaluate the operand to a result-shaped enum; on the `ok` variant,
// unwrap its payload and continue; on the error variant, `From`-convert the
// payload to the enclosing fn's declared error type and EARLY-RETURN (status 2).
// Mirrors src/interp/eval.rs eval_try / eval_try_from.
fn eval_try(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let sc: i32 = eval_expr(pp, src, e, nd.a, 0 - 1i32);
    if sc != 0 { return sc; }
    let enum_addr: usize = conv usize e.cur_val;
    let op_ty: u32 = e.cur_ty;
    let op_org: i32 = e.cur_org;
    let op_org_a: usize = e.cur_org_a;
    let op_org_b: i32 = e.cur_org_b;
    let eid: u32 = enum_of_ty(pp, src, e, op_ty);
    let tag: i32 = conv i32 mem_load(e, enum_addr, W_USIZE);
    let ok_idx: i32 = ok_variant_index(pp, eid);
    let vid: u32 = variant_by_index(pp, eid, tag);
    if tag == ok_idx {
        let pty: u32 = variant_payload_ty(pp, vid, 0);
        let off: usize = variant_payload_off(pp, src, e, vid, 0);
        let pw: i32 = scalar_width(pp, src, pty);
        if pw != 0 {
            e.*.cur_val = mem_load(e, enum_addr + off, pw);
            e.*.cur_w = pw;
            e.*.cur_ty = pty;
            e.*.cur_org = 0;
            if !is_copy(pp, src, e, op_ty) { do_consume(e, op_org, op_org_a, op_org_b); }
            return 0;
        }
        let psz: usize = ty_size(pp, src, e, pty);
        let pal: usize = ty_align(pp, src, e, pty);
        let slot: usize = bump_alloc(e, psz, pal);
        mem_copy(e, slot, enum_addr + off, psz);
        if !is_copy(pp, src, e, op_ty) { do_consume(e, op_org, op_org_a, op_org_b); }
        e.*.cur_val = conv i64 slot;
        e.*.cur_w = 0;
        e.*.cur_ty = pty;
        e.*.cur_org = 0;
        if !is_copy(pp, src, e, pty) {
            let ti: usize = reg_temp(e, slot, pty);
            e.*.cur_org = 1;
            e.*.cur_org_a = ti;
        }
        return 0;
    }
    return eval_try_from(pp, src, e, enum_addr, eid, vid, op_ty, op_org, op_org_a, op_org_b);
}
fn eval_try_from(pp: read P, src: [u8], e: write E, enum_addr: usize, eid: u32, vid: u32, op_ty: u32, op_org: i32, op_org_a: usize, op_org_b: i32) -> i32 {
    // The operand's active (error) payload e1.
    let e1ty: u32 = variant_payload_ty(pp, vid, 0);
    let e1off: usize = variant_payload_off(pp, src, e, vid, 0);
    let e1_eid: u32 = enum_of_ty(pp, src, e, e1ty);
    // The enclosing fn's declared error type: return enum's non-`ok` payload e2.
    let rty: u32 = e.cur_retty;
    let reid: u32 = enum_of_ty(pp, src, e, rty);
    // Same result type: no widening -- early-return the operand value as-is.
    if reid == eid {
        mem_copy(e, e.cur_result_addr, enum_addr, ty_size(pp, src, e, rty));
        if !is_copy(pp, src, e, op_ty) { do_consume(e, op_org, op_org_a, op_org_b); }
        return 2;
    }
    let ret_err_idx: i32 = err_variant_index(pp, reid);
    let rvid: u32 = variant_by_index(pp, reid, ret_err_idx);
    let e2ty: u32 = variant_payload_ty(pp, rvid, 0);
    let e2off: usize = variant_payload_off(pp, src, e, rvid, 0);
    let e2_eid: u32 = enum_of_ty(pp, src, e, e2ty);
    let from_fn: u32 = find_from_fn(pp, src, e, e1_eid, e2_eid);
    if from_fn == 0u32 {
        let onode: Node = pp.nodes[conv usize e1ty];
        set_fault(e, FK_PANIC, onode.p0, onode.p1);
        return 1;
    }
    // Call `from(e1)`; e1 rides an aggregate arg (its enum payload) or a scalar.
    let pw: i32 = scalar_width(pp, src, e1ty);
    if pw != 0 {
        e.*.arg_val[0] = mem_load(e, enum_addr + e1off, pw);
        e.*.arg_w[0] = pw;
        e.*.arg_addr[0] = 0usize;
    } else {
        e.*.arg_val[0] = 0i64;
        e.*.arg_w[0] = 0;
        e.*.arg_addr[0] = enum_addr + e1off;
    }
    e.*.arg_n = 1usize;
    let cs: i32 = call_fn(pp, src, e, from_fn);
    if cs != 0 { return cs; }
    let from_addr: usize = conv usize e.cur_val;
    // Build the return enum in the caller's result slot: tag = error variant,
    // payload = the widened e2.
    let ret_addr: usize = e.cur_result_addr;
    zero_slot(e, ret_addr, ty_size(pp, src, e, rty));
    mem_store(e, ret_addr, conv i64 ret_err_idx, W_USIZE);
    mem_copy(e, ret_addr + e2off, from_addr, ty_size(pp, src, e, e2ty));
    if !is_copy(pp, src, e, op_ty) { do_consume(e, op_org, op_org_a, op_org_b); }
    return 2;
}

// ---- conv (integer widening/narrowing) --------------------------------------
// Mirrors src/interp/eval.rs eval_conv: read the source integer at its declared
// signedness, then range-check against the TARGET scalar's range. In-range keeps
// the value (its bit pattern already fits the target width); out-of-range in the
// checked regime is a ConvLoss fault (the corpus stays in range). `sw`/`tw` are
// width codes; unsigned values are compared via their u64 magnitude.
fn conv_in_range(sval: i64, sw: i32, tw: i32) -> bool {
    if w_signed(tw) {
        let lo: i64 = smin(tw);
        let hi: i64 = smax(tw);
        if w_signed(sw) {
            return sval >= lo && sval <= hi;
        }
        return to_u64(sval) <= to_u64(hi);
    }
    let hi: u64 = umax(tw);
    if w_signed(sw) {
        if sval < 0i64 { return false; }
        return to_u64(sval) <= hi;
    }
    return to_u64(sval) <= hi;
}
fn eval_conv(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let sc: i32 = eval_expr(pp, src, e, nd.b, 0 - 1i32);
    if sc != 0 { return sc; }
    let sw: i32 = e.cur_w;
    let sval: i64 = e.cur_val;
    let tnode: Node = pp.nodes[conv usize nd.a];
    let tw: i32 = sc_width(src, tnode.p0, tnode.p1);
    if conv_in_range(sval, sw, tw) {
        e.*.cur_val = sval;
        e.*.cur_w = tw;
        e.*.cur_ty = 0u32;
        e.*.cur_org = 0;
        return 0;
    }
    set_fault(e, FK_CONVLOSS, e.cur_p0, e.cur_p1);
    return 1;
}
// ---- byte-string literal (`b"..."`) -----------------------------------------
// Mirrors src/interp/eval.rs BytesLit: decode the literal's bytes into memory,
// then materialize a `[u8]` fat pointer {ptr@0, len@8} (16 bytes) over them. The
// escape decoding matches the lexer's `emit_decoded`.
fn eval_bytes_lit(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let n: usize = conv usize decoded_len(src, nd.p0, nd.p1);
    let mut dn: usize = n;
    if dn == 0usize { dn = 1usize; }
    let data: usize = bump_alloc(e, dn, 1usize);
    let mut si: usize = nd.p0;
    let mut k: usize = 0usize;
    while si < nd.p1 {
        let mut dec: u8 = src[si];
        if src[si] == 92u8 && si + 1usize < nd.p1 {
            let nx: u8 = src[si + 1usize];
            if nx == 34u8 { dec = 34u8; }
            else if nx == 92u8 { dec = 92u8; }
            else if nx == 110u8 { dec = 10u8; }
            else if nx == 116u8 { dec = 9u8; }
            else { dec = nx; }
            si = si + 2usize;
        } else {
            si = si + 1usize;
        }
        mem_store(e, data + k, conv i64 dec, 6);
        k = k + 1usize;
    }
    let fat: usize = bump_alloc(e, 16usize, 8usize);
    mem_store(e, fat, conv i64 data, W_USIZE);
    mem_store(e, fat + 8usize, conv i64 n, W_USIZE);
    e.*.cur_val = conv i64 fat;
    e.*.cur_w = 0;
    e.*.cur_ty = 0u32;
    e.*.cur_org = 0;
    return 0;
}

// ---- expression evaluation ---------------------------------------------------
// Status: 0 normal, 1 fault, 2 return, 3 break, 4 continue. A normal scalar value
// is left in E.cur_val / E.cur_w; a normal aggregate value is an ADDRESS in
// E.cur_val with E.cur_w == 0 and its type node in E.cur_ty.
fn eval_expr(pp: read P, src: [u8], e: write E, i: u32, exp_w: i32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let tg: i32 = nd.tag;
    e.*.cur_p0 = nd.p0;
    e.*.cur_p1 = nd.p1;
    e.*.cur_org = 0;
    if tg == T_INT {
        let w: i32 = lit_width(nd.suf, exp_w);
        e.*.cur_val = to_i64b(nd.ival);
        e.*.cur_w = w;
        return 0;
    }
    if tg == T_NEGINT {
        let w: i32 = lit_width(nd.suf, exp_w);
        let mut v: i64 = 0i64;
        wrapping { v = 0i64 - conv i64 nd.ival; }
        e.*.cur_val = v;
        e.*.cur_w = w;
        return 0;
    }
    if tg == T_BOOL {
        e.*.cur_val = conv i64 nd.ival;
        e.*.cur_w = W_BOOL;
        return 0;
    }
    if tg == T_GENERICVAL {
        // A generic fn named as a value (`f::[T]`): its value is the resolved
        // instance's arena node id (an 8-byte fn-ptr), like fn-name-as-value.
        e.*.cur_val = conv i64 nd.c;
        e.*.cur_w = W_USIZE;
        e.*.cur_ty = 0u32;
        return 0;
    }
    if tg == T_ID {
        let idx: usize = find_local(src, e, nd.p0, nd.p1);
        if idx != e.loc_n {
            let w: i32 = e.loc_w[idx];
            if w != 0 {
                let v: i64 = mem_load(e, e.loc_addr[idx], w);
                e.*.cur_val = v;
                e.*.cur_w = w;
                e.*.cur_ty = e.loc_ty[idx];
            } else {
                e.*.cur_val = conv i64 e.loc_addr[idx];
                e.*.cur_w = 0;
                e.*.cur_ty = e.loc_ty[idx];
                if !is_copy(pp, src, e, e.loc_ty[idx]) {
                    e.*.cur_org = 2;
                    e.*.cur_org_a = idx;
                }
            }
            return 0;
        }
        let si: usize = find_static(src, e, nd.p0, nd.p1);
        if si != e.static_n {
            let sw: i32 = e.static_w[si];
            if sw != 0 {
                e.*.cur_val = mem_load(e, e.static_addr[si], sw);
                e.*.cur_w = sw;
                e.*.cur_ty = e.static_ty[si];
            } else {
                e.*.cur_val = conv i64 e.static_addr[si];
                e.*.cur_w = 0;
                e.*.cur_ty = e.static_ty[si];
            }
            return 0;
        }
        // A bare name that is neither local nor static resolves to a FUNCTION:
        // its value is the fn's arena node id (an 8-byte usize fn-ptr), exactly
        // the oracle's fn-name-as-value (src/interp/eval.rs:722-728).
        let fid: u32 = find_fn(pp, src, e, nd.p0, nd.p1);
        if fid != 0u32 {
            e.*.cur_val = conv i64 fid;
            e.*.cur_w = W_USIZE;
            e.*.cur_ty = 0u32;
            return 0;
        }
        e.*.cur_val = 0i64;
        e.*.cur_w = 0;
        return 0;
    }
    if tg == T_PREFIX {
        if nd.op == PF_DEREF {
            let sc: i32 = eval_place(pp, src, e, i);
            if sc != 0 { return sc; }
            return load_place(e);
        }
        if nd.op == PF_READ || nd.op == PF_WRITE {
            let sc: i32 = eval_place(pp, src, e, nd.a);
            if sc != 0 { return sc; }
            e.*.cur_val = conv i64 e.plc_addr;
            e.*.cur_w = W_USIZE;
            e.*.cur_ty = 0u32;
            e.*.cur_org = 0;
            return 0;
        }
    }
    if tg == T_CONV {
        return eval_conv(pp, src, e, i);
    }
    if tg == T_BYTES {
        return eval_bytes_lit(pp, src, e, i);
    }
    if tg == T_STR {
        // A `str` literal materializes the SAME fat-pointer bytes as `b"..."`, but
        // carries a str type (so `len`/byteview reads and String keys route right).
        let sc: i32 = eval_bytes_lit(pp, src, e, i);
        if sc != 0 { return sc; }
        e.*.cur_ty = i;
        return 0;
    }
    if tg == T_FIELD || tg == T_INDEX {
        let sc: i32 = eval_place(pp, src, e, i);
        if sc != 0 { return sc; }
        let lr: i32 = load_place(e);
        if lr != 0 { return lr; }
        // A non-copy field read off a direct local is a ONE-LEVEL partial move.
        if tg == T_FIELD && e.cur_w == 0 && !is_copy(pp, src, e, e.cur_ty) {
            let bnode: Node = pp.nodes[conv usize nd.a];
            if bnode.tag == T_ID {
                let bli: usize = find_local(src, e, bnode.p0, bnode.p1);
                let bsid: u32 = struct_of_ty(pp, src, e, e.loc_ty[bli]);
                let bfi: i32 = field_index(pp, src, bsid, nd.p0, nd.p1);
                e.*.cur_org = 3;
                e.*.cur_org_a = bli;
                e.*.cur_org_b = bfi;
            }
        }
        return 0;
    }
    if tg == T_STRUCTLIT {
        return eval_struct_lit(pp, src, e, i);
    }
    if tg == T_ARRAYLIT {
        return eval_array_lit(pp, src, e, i);
    }
    if tg == T_ARRAYREP {
        return eval_array_rep(pp, src, e, i);
    }
    if tg == T_ENUMCTOR {
        return eval_enum_ctor(pp, src, e, i);
    }
    if tg == T_MATCH {
        return eval_match(pp, src, e, i);
    }
    if tg == T_TRY {
        return eval_try(pp, src, e, i);
    }
    if tg == T_UNSAFE {
        // `unsafe "why" { ... }` runs its body block; its raw-pointer ops are
        // the same primitives, just check-gated (the oracle also just runs it).
        return exec_block(pp, src, e, nd.a);
    }
    if tg == T_CASTPTR {
        // Reinterpret: keep the address, change the static pointee type. `.b` is
        // the pointer arg; `.a` (this node) records the new pointee for ptr_read.
        let sc: i32 = eval_expr(pp, src, e, nd.b, W_USIZE);
        if sc != 0 { return sc; }
        e.*.cur_w = W_USIZE;
        e.*.cur_ty = i;
        return 0;
    }
    if tg == T_ADDRTOPTR {
        // A usize address literal becomes a rawptr over the SMALL arena.
        let sc: i32 = eval_expr(pp, src, e, nd.b, W_USIZE);
        if sc != 0 { return sc; }
        e.*.cur_w = W_USIZE;
        e.*.cur_ty = i;
        return 0;
    }
    if tg == T_PTRNULL {
        e.*.cur_val = 0i64;
        e.*.cur_w = W_USIZE;
        e.*.cur_ty = i;
        return 0;
    }
    if tg == T_OFFSETOF {
        // offsetof(T, field): the S2 layout table gives the field's byte offset by
        // name-span (nd.a = struct type, [nd.p0, nd.p1) = field name), as a usize.
        let sid: u32 = struct_of_ty(pp, src, e, nd.a);
        let off: usize = field_off(pp, src, e, sid, nd.p0, nd.p1);
        e.*.cur_val = conv i64 off;
        e.*.cur_w = W_USIZE;
        e.*.cur_ty = 0u32;
        e.*.cur_org = 0;
        return 0;
    }
    if tg == T_PAREN {
        return eval_expr(pp, src, e, nd.a, exp_w);
    }
    if tg == T_UNARY {
        return eval_unary(pp, src, e, i, exp_w);
    }
    if tg == T_BIN {
        return eval_binary(pp, src, e, i, exp_w);
    }
    if tg == T_CALL {
        return eval_call(pp, src, e, i);
    }
    if tg == T_BLOCK {
        return exec_block(pp, src, e, i);
    }
    if tg == T_IF {
        let sc: i32 = eval_expr(pp, src, e, nd.a, W_BOOL);
        if sc != 0 { return sc; }
        if e.cur_val != 0i64 {
            return exec_block(pp, src, e, nd.b);
        }
        if nd.c != 0u32 {
            return eval_expr(pp, src, e, nd.c, 0 - 1i32);
        }
        e.*.cur_val = 0i64; e.*.cur_w = 0;
        return 0;
    }
    if tg == T_WHILE {
        loop {
            let sc: i32 = eval_expr(pp, src, e, nd.a, W_BOOL);
            if sc != 0 { return sc; }
            if e.cur_val == 0i64 { break; }
            let bs: i32 = exec_block(pp, src, e, nd.b);
            if bs == 1 || bs == 2 { return bs; }
            if bs == 3 { break; }
        }
        e.*.cur_val = 0i64; e.*.cur_w = 0;
        return 0;
    }
    if tg == T_LOOP {
        loop {
            let bs: i32 = exec_block(pp, src, e, nd.a);
            if bs == 1 || bs == 2 { return bs; }
            if bs == 3 { break; }
        }
        e.*.cur_val = 0i64; e.*.cur_w = 0;
        return 0;
    }
    if tg == T_RETURN {
        let rty: u32 = e.cur_retty;
        if nd.a != 0u32 {
            if ty_is_agg(pp, src, e, rty) {
                let sc: i32 = eval_expr(pp, src, e, nd.a, 0 - 1i32);
                if sc != 0 { return sc; }
                let rorg: i32 = e.cur_org;
                let roa: usize = e.cur_org_a;
                let rob: i32 = e.cur_org_b;
                let sa: usize = conv usize e.cur_val;
                let sz: usize = ty_size(pp, src, e, rty);
                mem_copy(e, e.cur_result_addr, sa, sz);
                if !is_copy(pp, src, e, rty) {
                    do_consume(e, rorg, roa, rob);
                }
            } else {
                let sc: i32 = eval_expr(pp, src, e, nd.a, e.cur_retw);
                if sc != 0 { return sc; }
                e.*.ret_val = e.cur_val;
                e.*.ret_w = e.cur_retw;
            }
        } else {
            e.*.ret_val = 0i64;
            e.*.ret_w = e.cur_retw;
        }
        return 2;
    }
    if tg == T_BREAK { return 3; }
    if tg == T_CONTINUE { return 4; }
    if tg == T_ASSERT {
        let sc: i32 = eval_expr(pp, src, e, nd.a, W_BOOL);
        if sc != 0 { return sc; }
        if e.cur_val == 0i64 {
            set_fault(e, FK_ASSERT, e.cur_p0, e.cur_p1);
            return 1;
        }
        e.*.cur_val = 0i64; e.*.cur_w = 0;
        return 0;
    }
    if tg == T_PANIC {
        set_fault(e, FK_PANIC, nd.p0, nd.p1);
        return 1;
    }
    e.*.cur_val = 0i64; e.*.cur_w = 0;
    return 0;
}

fn eval_unary(pp: read P, src: [u8], e: write E, i: u32, exp_w: i32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    if nd.op == UN_NOT {
        let sc: i32 = eval_expr(pp, src, e, nd.a, W_BOOL);
        if sc != 0 { return sc; }
        if e.cur_val == 0i64 { e.*.cur_val = 1i64; } else { e.*.cur_val = 0i64; }
        e.*.cur_w = W_BOOL;
        return 0;
    }
    let sc: i32 = eval_expr(pp, src, e, nd.a, exp_w);
    if sc != 0 { return sc; }
    let a: i64 = e.cur_val;
    let w: i32 = e.cur_w;
    if nd.op == UN_NEG {
        if a == smin(w) {
            set_fault(e, FK_OVERFLOW, e.cur_p0, e.cur_p1);
            return 1;
        }
        let mut r: i64 = 0i64;
        wrapping { r = 0i64 - a; }
        if r < smin(w) || r > smax(w) {
            set_fault(e, FK_OVERFLOW, e.cur_p0, e.cur_p1);
            return 1;
        }
        e.*.cur_val = r; e.*.cur_w = w;
        return 0;
    }
    // UN_BITNOT: ~a == a ^ -1, then re-fit narrow types.
    let mut r: i64 = a ^ (0i64 - 1i64);
    if !w_is64(w) { r = fit_bits(r, w); }
    e.*.cur_val = r; e.*.cur_w = w;
    return 0;
}

fn eval_binary(pp: read P, src: [u8], e: write E, i: u32, exp_w: i32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let op: i32 = nd.op;
    if op == OP_AND || op == OP_OR {
        let sc: i32 = eval_expr(pp, src, e, nd.a, W_BOOL);
        if sc != 0 { return sc; }
        let lb: bool = e.cur_val != 0i64;
        let mut res: bool = false;
        if op == OP_AND {
            if lb {
                let sr: i32 = eval_expr(pp, src, e, nd.b, W_BOOL);
                if sr != 0 { return sr; }
                res = e.cur_val != 0i64;
            } else {
                res = false;
            }
        } else {
            if lb {
                res = true;
            } else {
                let sr: i32 = eval_expr(pp, src, e, nd.b, W_BOOL);
                if sr != 0 { return sr; }
                res = e.cur_val != 0i64;
            }
        }
        if res { e.*.cur_val = 1i64; } else { e.*.cur_val = 0i64; }
        e.*.cur_w = W_BOOL;
        return 0;
    }
    if op == OP_EQ || op == OP_NE || op == OP_LT || op == OP_LE || op == OP_GT || op == OP_GE {
        let sl: i32 = eval_expr(pp, src, e, nd.a, 0 - 1i32);
        if sl != 0 { return sl; }
        let a: i64 = e.cur_val;
        let w: i32 = e.cur_w;
        let sr: i32 = eval_expr(pp, src, e, nd.b, w);
        if sr != 0 { return sr; }
        let b: i64 = e.cur_val;
        e.*.cur_val = cmp_op(op, a, b, w);
        e.*.cur_w = W_BOOL;
        return 0;
    }
    // arithmetic / bitwise / shift
    let mut exp_int: i32 = 0 - 1i32;
    if exp_w >= 1 && exp_w <= 10 { exp_int = exp_w; }
    let sl: i32 = eval_expr(pp, src, e, nd.a, exp_int);
    if sl != 0 { return sl; }
    let a: i64 = e.cur_val;
    let mut sty: i32 = e.cur_w;
    if exp_int != 0 - 1i32 { sty = exp_int; }
    if op == OP_SHL || op == OP_SHR {
        let sr: i32 = eval_expr(pp, src, e, nd.b, 0 - 1i32);
        if sr != 0 { return sr; }
        let amt: i64 = e.cur_val;
        e.*.cur_p0 = nd.p0;
        e.*.cur_p1 = nd.p1;
        return shift_op(op, a, amt, sty, e, nd.p0, nd.p1);
    }
    let sr: i32 = eval_expr(pp, src, e, nd.b, sty);
    if sr != 0 { return sr; }
    let b: i64 = e.cur_val;
    if op == OP_BITAND || op == OP_BITOR || op == OP_BITXOR {
        bit_op(op, a, b, sty, e);
        return 0;
    }
    e.*.cur_p0 = nd.p0;
    e.*.cur_p1 = nd.p1;
    if w_signed(sty) {
        return arith_signed(op, a, b, sty, e, nd.p0, nd.p1);
    }
    return arith_unsigned(op, a, b, sty, e, nd.p0, nd.p1);
}

// The width of a function's declared scalar return type (i64 fallback for a
// missing/unit/aggregate annotation, matching a scalar `main`).
fn fn_ret_width(pp: read P, src: [u8], fnid: u32) -> i32 {
    let fnd: Node = pp.nodes[conv usize fnid];
    if fnd.e == 0u32 { return 4; }
    let rt: Node = pp.nodes[conv usize fnd.e];
    if rt.a == 0u32 { return 4; }
    return scalar_width(pp, src, rt.a);
}
// The type node of a function's declared return type (0 if none).
fn fn_ret_tynode(pp: read P, fnid: u32) -> u32 {
    let fnd: Node = pp.nodes[conv usize fnid];
    if fnd.e == 0u32 { return 0u32; }
    let rt: Node = pp.nodes[conv usize fnd.e];
    return rt.a;
}

// `box(alloc, v)` (mirrors src/interp/eval.rs bi_box). Reads `ctx`/`vt` from the
// Alloc handle (arg0), sizes `v` (arg1), reads the `alloc` fn-ptr out of the
// vtable and INDIRECT-CALLs `alloc(ctx, size, align)`. On null it takes the OOM
// arm -- drop+consume `v`, tag = 1 (oom); otherwise it MOVES `v` into the heap
// slot and builds the `Box` {ptr, ctx, vt} inside the boxed payload (tag = 0).
// The result type node (a `T_BOXRESULT`) rides `cur_exp_ty`, set by the enclosing
// `let` -- the same node the synthetic enum is linked from.
fn bi_box(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let mut rty: u32 = e.cur_exp_ty;
    if rty == 0u32 || pp.nodes[conv usize rty].tag != T_BOXRESULT {
        rty = e.gen_boxresult;
    }
    let a0: u32 = nd.b;
    let a0nd: Node = pp.nodes[conv usize a0];
    let a1: u32 = a0nd.nx;
    let sc0: i32 = eval_expr(pp, src, e, a0, 0 - 1i32);
    if sc0 != 0 { return sc0; }
    let alloc_addr: usize = conv usize e.cur_val;
    let ctx_off: usize = field_off_lit(pp, src, e, e.alloc_sid, b"ctx");
    let vt_off: usize = field_off_lit(pp, src, e, e.alloc_sid, b"vt");
    let ctx: i64 = mem_load(e, alloc_addr + ctx_off, W_USIZE);
    let vt: i64 = mem_load(e, alloc_addr + vt_off, W_USIZE);
    let vt_addr: usize = conv usize to_u64(vt);
    let scv: i32 = eval_expr(pp, src, e, a1, 0 - 1i32);
    if scv != 0 { return scv; }
    let vw: i32 = e.cur_w;
    let vty: u32 = e.cur_ty;
    let vval: i64 = e.cur_val;
    let vorg: i32 = e.cur_org;
    let voa: usize = e.cur_org_a;
    let vob: i32 = e.cur_org_b;
    if rty == e.gen_boxresult {
        if vw != 0 { e.*.gen_inner = e.scw[conv usize vw]; } else { e.*.gen_inner = vty; }
    }
    let mut vsz: usize = 0usize;
    let mut val: usize = 1usize;
    let mut vcopy: bool = true;
    if vw != 0 {
        vsz = w_size(vw);
        val = w_size(vw);
    } else {
        vsz = ty_size(pp, src, e, vty);
        val = ty_align(pp, src, e, vty);
        vcopy = is_copy(pp, src, e, vty);
    }
    let alloc_off: usize = field_off_lit(pp, src, e, e.alloc_vt_sid, b"alloc");
    let afn: u32 = conv u32 to_u64(mem_load(e, vt_addr + alloc_off, W_USIZE));
    e.*.arg_val[0] = ctx;
    e.*.arg_w[0] = W_USIZE;
    e.*.arg_addr[0] = 0usize;
    e.*.arg_val[1] = conv i64 vsz;
    e.*.arg_w[1] = W_USIZE;
    e.*.arg_addr[1] = 0usize;
    e.*.arg_val[2] = conv i64 val;
    e.*.arg_w[2] = W_USIZE;
    e.*.arg_addr[2] = 0usize;
    e.*.arg_n = 3usize;
    let cs: i32 = call_fn(pp, src, e, afn);
    if cs != 0 { return cs; }
    let ret: usize = conv usize to_u64(e.cur_val);
    let braddr: usize = bump_alloc(e, 32usize, 8usize);
    zero_slot(e, braddr, 32usize);
    if ret == 0usize {
        if vw == 0 {
            let dc: i32 = drop_value(pp, src, e, conv usize vval, vty, 0 - 1i64);
            if dc != 0 { return dc; }
            if !vcopy { do_consume(e, vorg, voa, vob); }
        }
        mem_store(e, braddr, 1i64, W_USIZE);
    } else {
        if vw != 0 {
            mem_store(e, ret, vval, vw);
        } else {
            mem_copy(e, ret, conv usize vval, vsz);
            if !vcopy { do_consume(e, vorg, voa, vob); }
        }
        mem_store(e, braddr, 0i64, W_USIZE);
        mem_store(e, braddr + 8usize, conv i64 ret, W_USIZE);
        mem_store(e, braddr + 16usize, ctx, W_USIZE);
        mem_store(e, braddr + 24usize, vt, W_USIZE);
    }
    e.*.cur_val = conv i64 braddr;
    e.*.cur_w = 0;
    e.*.cur_ty = rty;
    e.*.cur_org = 0;
    let ti: usize = reg_temp(e, braddr, rty);
    e.*.cur_org = 1;
    e.*.cur_org_a = ti;
    return 0;
}
// `unbox(box)` (mirrors src/interp/eval.rs bi_unbox). Reads the Box (ptr@0,
// ctx@8, vt@16), MOVES the pointee bytes out into a fresh slot, FREES the box
// storage through the vtable, and CONSUMES the box origin (so its later drop is
// suppressed -- unbox frees AND consumes). Yields the inner value.
fn bi_unbox(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let a0: u32 = nd.b;
    let sc: i32 = eval_expr(pp, src, e, a0, 0 - 1i32);
    if sc != 0 { return sc; }
    let bxaddr: usize = conv usize e.cur_val;
    let bxty: u32 = e.cur_ty;
    let borg: i32 = e.cur_org;
    let boa: usize = e.cur_org_a;
    let bob: i32 = e.cur_org_b;
    let bnode: Node = pp.nodes[conv usize bxty];
    let mut inner: u32 = bnode.a;
    if bxty == e.gen_box { inner = e.gen_inner; }
    let ptr: usize = conv usize to_u64(mem_load(e, bxaddr, W_USIZE));
    let ctx: i64 = mem_load(e, bxaddr + 8usize, W_USIZE);
    let vt: i64 = mem_load(e, bxaddr + 16usize, W_USIZE);
    let size: usize = ty_size(pp, src, e, inner);
    let align: usize = ty_align(pp, src, e, inner);
    let slot: usize = bump_alloc(e, size, align);
    zero_slot(e, slot, size);
    mem_copy(e, slot, ptr, size);
    let fc: i32 = call_free(pp, src, e, ctx, vt, ptr, size, align);
    if fc != 0 { return fc; }
    do_consume(e, borg, boa, bob);
    let iw: i32 = scalar_width(pp, src, inner);
    if iw != 0 {
        e.*.cur_val = mem_load(e, slot, iw);
        e.*.cur_w = iw;
        e.*.cur_ty = inner;
        e.*.cur_org = 0;
    } else {
        e.*.cur_val = conv i64 slot;
        e.*.cur_w = 0;
        e.*.cur_ty = inner;
        e.*.cur_org = 0;
        if !is_copy(pp, src, e, inner) {
            let ti: usize = reg_temp(e, slot, inner);
            e.*.cur_org = 1;
            e.*.cur_org_a = ti;
        }
    }
    return 0;
}

// ===================================================================
// Compiler-known std collections: String / Vec[T] / Map[V]. Ported bi_* from
// src/interp/eval.rs onto interp.cnr's flat/paged memory + the Alloc indirect-call
// path. Layout for all three: { buf @0, len @8, cap @16, ctx @24, vt @32 } (5 u64
// words). Growth is alloc-new + copy + free-old (the vtable exposes no realloc).
// ===================================================================

fn nxt(pp: read P, x: u32) -> u32 { return pp.nodes[conv usize x].nx; }
// Leave a unit result (`push`/`insert`/... return unit).
fn ret_none(e: write E) -> i32 {
    e.*.cur_val = 0i64;
    e.*.cur_w = 0;
    e.*.cur_org = 0;
    return 0;
}
// Leave an owned aggregate result at `addr`, registering a drop-temp for a non-copy
// type (so a move consumes it, else it drops at statement end).
fn yield_temp(pp: read P, src: [u8], e: write E, addr: usize, ty: u32) -> i32 {
    e.*.cur_val = conv i64 addr;
    e.*.cur_w = 0;
    e.*.cur_ty = ty;
    e.*.cur_org = 0;
    if !is_copy(pp, src, e, ty) {
        let ti: usize = reg_temp(e, addr, ty);
        e.*.cur_org = 1;
        e.*.cur_org_a = ti;
    }
    return 0;
}
// Padded stride of a Vec element / a Map bucket ({state,keyptr,keylen,value}).
fn stride_of(pp: read P, src: [u8], e: write E, elem: u32) -> usize {
    return round_up_us(ty_size(pp, src, e, elem), ty_align(pp, src, e, elem));
}
fn map_stride(pp: read P, src: [u8], e: write E, valty: u32) -> usize {
    return round_up_us(24usize + ty_size(pp, src, e, valty), 8usize);
}
// Indirect alloc: read the `alloc` fn-ptr from the vtable and call
// `alloc(ctx, size, align)`. The returned pointer lands in `e.cur_val`.
fn call_alloc(pp: read P, src: [u8], e: write E, ctx: i64, vt: i64, size: usize, align: usize) -> i32 {
    let alloc_off: usize = field_off_lit(pp, src, e, e.alloc_vt_sid, b"alloc");
    let afn: u32 = conv u32 to_u64(mem_load(e, conv usize to_u64(vt) + alloc_off, W_USIZE));
    e.*.arg_val[0] = ctx;
    e.*.arg_w[0] = W_USIZE;
    e.*.arg_addr[0] = 0usize;
    e.*.arg_val[1] = conv i64 size;
    e.*.arg_w[1] = W_USIZE;
    e.*.arg_addr[1] = 0usize;
    e.*.arg_val[2] = conv i64 align;
    e.*.arg_w[2] = W_USIZE;
    e.*.arg_addr[2] = 0usize;
    e.*.arg_n = 3usize;
    return call_fn(pp, src, e, afn);
}
// Evaluate a `str`/`[u8]` argument and read its fat pointer into `e.bv_ptr`/`bv_len`.
fn load_byteview(pp: read P, src: [u8], e: write E, argnode: u32) -> i32 {
    let sc: i32 = eval_expr(pp, src, e, argnode, 0 - 1i32);
    if sc != 0 { return sc; }
    let fat: usize = conv usize e.cur_val;
    let p0v: usize = ld_us(e, fat);
    let l0v: usize = ld_us(e, fat + 8usize);
    e.*.bv_ptr = p0v;
    e.*.bv_len = l0v;
    return 0;
}
// Evaluate a by-value element/value argument, stashing it (a scalar in `mv_val`,
// else an aggregate address + move-origin) for a later `commit_move` — decoupled
// so a grow/rehash may intervene, as the oracle's eval-then-move-into-slot does.
fn eval_move_src(pp: read P, src: [u8], e: write E, argnode: u32, elem: u32) -> i32 {
    let ew: i32 = scalar_width(pp, src, elem);
    e.*.mv_ew = ew;
    if ew != 0 {
        let sc: i32 = eval_expr(pp, src, e, argnode, ew);
        if sc != 0 { return sc; }
        e.*.mv_val = e.cur_val;
    } else {
        let sc: i32 = eval_expr(pp, src, e, argnode, 0 - 1i32);
        if sc != 0 { return sc; }
        e.*.mv_addr = conv usize e.cur_val;
        e.*.mv_org = e.cur_org;
        e.*.mv_oa = e.cur_org_a;
        e.*.mv_ob = e.cur_org_b;
    }
    return 0;
}
fn commit_move(pp: read P, src: [u8], e: write E, dst: usize, elem: u32) -> unit {
    if e.mv_ew != 0 {
        mem_store(e, dst, e.mv_val, e.mv_ew);
    } else {
        mem_copy(e, dst, e.mv_addr, ty_size(pp, src, e, elem));
        if !is_copy(pp, src, e, elem) { do_consume(e, e.mv_org, e.mv_oa, e.mv_ob); }
    }
    return;
}
// Ensure the {buf,len,cap,...} owner at `base` has room for `need` more `unit`-sized
// slots, growing via alloc-new + copy + free-old (String `unit`=1/`mincap`=8; Vec
// `unit`=stride/`mincap`=4). Faults `Panic` on OOM (the fixtures never OOM).
fn buf_reserve(pp: read P, src: [u8], e: write E, base: usize, usz: usize, align: usize, need: usize, mincap: usize) -> i32 {
    let len: usize = ld_us(e, base + 8usize);
    let cap: usize = ld_us(e, base + 16usize);
    if len + need <= cap { return 0; }
    let mut newcap: usize = len + need;
    if cap * 2usize > newcap { newcap = cap * 2usize; }
    if newcap < mincap { newcap = mincap; }
    let ctx: i64 = mem_load(e, base + 24usize, W_USIZE);
    let vt: i64 = mem_load(e, base + 32usize, W_USIZE);
    let ac: i32 = call_alloc(pp, src, e, ctx, vt, newcap * usz, align);
    if ac != 0 { return ac; }
    let newbuf: usize = conv usize to_u64(e.cur_val);
    if newbuf == 0usize { set_fault(e, FK_PANIC, e.cur_p0, e.cur_p1); return 1; }
    let oldbuf: usize = ld_us(e, base);
    if len > 0usize && oldbuf != 0usize { mem_copy(e, newbuf, oldbuf, len * usz); }
    if oldbuf != 0usize {
        let fc: i32 = call_free(pp, src, e, ctx, vt, oldbuf, cap * usz, align);
        if fc != 0 { return fc; }
    }
    st_us(e, base, newbuf);
    st_us(e, base + 16usize, newcap);
    return 0;
}

// A std collection constructor: `vec_new`/`map_new`/`string_new(a: read Alloc)` —
// an empty 40-byte owner carrying the handle's ctx/vt. The result type rides
// `cur_exp_ty` (the enclosing `let`'s annotation), like `box`.
fn bi_coll_new(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let rty: u32 = e.cur_exp_ty;
    let sc: i32 = eval_expr(pp, src, e, pp.nodes[conv usize i].b, 0 - 1i32);
    if sc != 0 { return sc; }
    let alloc_addr: usize = conv usize e.cur_val;
    let ctx: i64 = mem_load(e, alloc_addr + field_off_lit(pp, src, e, e.alloc_sid, b"ctx"), W_USIZE);
    let vt: i64 = mem_load(e, alloc_addr + field_off_lit(pp, src, e, e.alloc_sid, b"vt"), W_USIZE);
    let addr: usize = bump_alloc(e, 40usize, 8usize);
    zero_slot(e, addr, 40usize);
    mem_store(e, addr + 24usize, ctx, W_USIZE);
    mem_store(e, addr + 32usize, vt, W_USIZE);
    return yield_temp(pp, src, e, addr, rty);
}

// ---- String -----------------------------------------------------------------
// `push` appends one scalar, `append` a byte view; both grow then copy at the end.
// SUBSET: `push` encodes single-byte (ASCII) scalars only — the fixtures push
// ASCII; multibyte UTF-8 encoding is out of this interpreter's subset (like
// substr/char_at).
fn bi_string_add(pp: read P, src: [u8], e: write E, i: u32, is_push: bool) -> i32 {
    let a0: u32 = pp.nodes[conv usize i].b;
    let sc: i32 = eval_expr(pp, src, e, a0, 0 - 1i32);
    if sc != 0 { return sc; }
    let base: usize = conv usize e.cur_val;
    let mut c: u64 = 0u64;
    let mut sptr: usize = 0usize;
    let mut need: usize = 1usize;
    if is_push {
        let scv: i32 = eval_expr(pp, src, e, nxt(pp, a0), 8);
        if scv != 0 { return scv; }
        c = to_u64(e.cur_val) & 255u64;
    } else {
        let bc: i32 = load_byteview(pp, src, e, nxt(pp, a0));
        if bc != 0 { return bc; }
        sptr = e.bv_ptr;
        need = e.bv_len;
    }
    let rc: i32 = buf_reserve(pp, src, e, base, 1usize, 1usize, need, 8usize);
    if rc != 0 { return rc; }
    let dst: usize = ld_us(e, base) + ld_us(e, base + 8usize);
    if is_push {
        mem_store(e, dst, conv i64 c, 6);
    } else {
        mem_copy(e, dst, sptr, need);
    }
    st_us(e, base + 8usize, ld_us(e, base + 8usize) + need);
    return ret_none(e);
}
fn bi_string_as_str(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let sc: i32 = eval_expr(pp, src, e, pp.nodes[conv usize i].b, 0 - 1i32);
    if sc != 0 { return sc; }
    let base: usize = conv usize e.cur_val;
    let fat: usize = bump_alloc(e, 16usize, 8usize);
    st_us(e, fat, ld_us(e, base));
    st_us(e, fat + 8usize, ld_us(e, base + 8usize));
    e.*.cur_val = conv i64 fat;
    e.*.cur_w = 0;
    e.*.cur_ty = 0u32;
    e.*.cur_org = 0;
    return 0;
}

// ---- Vec[T] -----------------------------------------------------------------
fn bi_vec_push(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let a0: u32 = pp.nodes[conv usize i].b;
    let elem: u32 = coll_elem_ty(pp, coll_arg_ty(pp, src, e, a0));
    let sc: i32 = eval_expr(pp, src, e, a0, 0 - 1i32);
    if sc != 0 { return sc; }
    let base: usize = conv usize e.cur_val;
    let mc: i32 = eval_move_src(pp, src, e, nxt(pp, a0), elem);
    if mc != 0 { return mc; }
    let stride: usize = stride_of(pp, src, e, elem);
    let rc: i32 = buf_reserve(pp, src, e, base, stride, ty_align(pp, src, e, elem), 1usize, 4usize);
    if rc != 0 { return rc; }
    let len: usize = ld_us(e, base + 8usize);
    commit_move(pp, src, e, ld_us(e, base) + len * stride, elem);
    st_us(e, base + 8usize, len + 1usize);
    return ret_none(e);
}
fn bi_vec_pop(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let rty: u32 = e.cur_exp_ty;
    let a0: u32 = pp.nodes[conv usize i].b;
    let elem: u32 = coll_elem_ty(pp, coll_arg_ty(pp, src, e, a0));
    let sc: i32 = eval_expr(pp, src, e, a0, 0 - 1i32);
    if sc != 0 { return sc; }
    let base: usize = conv usize e.cur_val;
    let eid: u32 = enum_of_ty(pp, src, e, rty);
    let len: usize = ld_us(e, base + 8usize);
    let addr: usize = bump_alloc(e, enum_size(pp, src, e, eid), 8usize);
    zero_slot(e, addr, enum_size(pp, src, e, eid));
    if len == 0usize {
        mem_store(e, addr, conv i64 variant_index_by_lit(pp, src, eid, b"None"), W_USIZE);
    } else {
        let newlen: usize = len - 1usize;
        let srcaddr: usize = ld_us(e, base) + newlen * stride_of(pp, src, e, elem);
        st_us(e, base + 8usize, newlen);
        let someidx: i32 = variant_index_by_lit(pp, src, eid, b"Some");
        mem_store(e, addr, conv i64 someidx, W_USIZE);
        let off: usize = variant_payload_off(pp, src, e, variant_by_index(pp, eid, someidx), 0);
        mem_copy(e, addr + off, srcaddr, ty_size(pp, src, e, elem));
    }
    return yield_temp(pp, src, e, addr, eid);
}
fn bi_vec_get(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let a0: u32 = pp.nodes[conv usize i].b;
    let elem: u32 = coll_elem_ty(pp, coll_arg_ty(pp, src, e, a0));
    let sc: i32 = eval_expr(pp, src, e, a0, 0 - 1i32);
    if sc != 0 { return sc; }
    let base: usize = conv usize e.cur_val;
    let len: usize = ld_us(e, base + 8usize);
    let scv: i32 = eval_expr(pp, src, e, nxt(pp, a0), W_USIZE);
    if scv != 0 { return scv; }
    let idx: usize = conv usize to_u64(e.cur_val);
    if idx >= len {
        set_fault(e, FK_BOUNDS, e.cur_p0, e.cur_p1);
        return 1;
    }
    e.*.cur_val = conv i64 (ld_us(e, base) + idx * stride_of(pp, src, e, elem));
    e.*.cur_w = W_USIZE;
    e.*.cur_ty = elem;
    e.*.cur_org = 0;
    return 0;
}

// ---- Map[V] (byte-string keys; 64-bit FNV-1a; open addressing) --------------
fn map_hash_mem(e: write E, kptr: usize, klen: usize) -> u64 {
    let mut h: u64 = 14695981039346656037u64;
    let mut i: usize = 0usize;
    while i < klen {
        let b: u64 = to_u64(mem_load(e, kptr + i, 6));
        wrapping {
            h = h ^ b;
            h = h * 1099511628211u64;
        }
        i = i + 1usize;
    }
    return h;
}
fn key_eq_mem(e: write E, aptr: usize, alen: usize, bptr: usize, blen: usize) -> bool {
    if alen != blen { return false; }
    let mut i: usize = 0usize;
    while i < alen {
        if mem_load(e, aptr + i, 6) != mem_load(e, bptr + i, 6) { return false; }
        i = i + 1usize;
    }
    return true;
}
// The slot of `key` if present, else `cap` (the not-found sentinel; a valid slot is
// always < cap). Linear probing terminates at the first empty bucket (no removes).
fn map_find(e: write E, buf: usize, cap: usize, stride: usize, kptr: usize, klen: usize) -> usize {
    if cap == 0usize || buf == 0usize { return cap; }
    let mask: usize = cap - 1usize;
    let mut idx: usize = conv usize (map_hash_mem(e, kptr, klen) & conv u64 mask);
    loop {
        let b: usize = buf + idx * stride;
        if mem_load(e, b, W_USIZE) == 0i64 { return cap; }
        if ld_us(e, b + 16usize) == klen {
            if key_eq_mem(e, ld_us(e, b + 8usize), klen, kptr, klen) { return idx; }
        }
        idx = (idx + 1usize) & mask;
    }
}
fn map_find_empty(e: write E, buf: usize, cap: usize, stride: usize, kptr: usize, klen: usize) -> usize {
    let mask: usize = cap - 1usize;
    let mut idx: usize = conv usize (map_hash_mem(e, kptr, klen) & conv u64 mask);
    loop {
        if mem_load(e, buf + idx * stride, W_USIZE) == 0i64 { return idx; }
        idx = (idx + 1usize) & mask;
    }
}
fn map_reserve(pp: read P, src: [u8], e: write E, base: usize, valty: u32) -> i32 {
    let len: usize = ld_us(e, base + 8usize);
    let cap: usize = ld_us(e, base + 16usize);
    if cap != 0usize && (len + 1usize) * 4usize <= cap * 3usize { return 0; }
    let stride: usize = map_stride(pp, src, e, valty);
    let mut newcap: usize = 8usize;
    if cap != 0usize { newcap = cap * 2usize; }
    let ctx: i64 = mem_load(e, base + 24usize, W_USIZE);
    let vt: i64 = mem_load(e, base + 32usize, W_USIZE);
    let ac: i32 = call_alloc(pp, src, e, ctx, vt, newcap * stride, 8usize);
    if ac != 0 { return ac; }
    let newbuf: usize = conv usize to_u64(e.cur_val);
    if newbuf == 0usize { set_fault(e, FK_PANIC, e.cur_p0, e.cur_p1); return 1; }
    zero_slot(e, newbuf, newcap * stride);
    let oldbuf: usize = ld_us(e, base);
    if oldbuf != 0usize {
        let vsz: usize = ty_size(pp, src, e, valty);
        let mut ii: usize = 0usize;
        while ii < cap {
            let ob: usize = oldbuf + ii * stride;
            if mem_load(e, ob, W_USIZE) == 1i64 {
                let kptr: usize = ld_us(e, ob + 8usize);
                let klen: usize = ld_us(e, ob + 16usize);
                let nb: usize = newbuf + map_find_empty(e, newbuf, newcap, stride, kptr, klen) * stride;
                st_us(e, nb, 1usize);
                st_us(e, nb + 8usize, kptr);
                st_us(e, nb + 16usize, klen);
                if vsz > 0usize { mem_copy(e, nb + 24usize, ob + 24usize, vsz); }
            }
            ii = ii + 1usize;
        }
        let fc: i32 = call_free(pp, src, e, ctx, vt, oldbuf, cap * stride, 8usize);
        if fc != 0 { return fc; }
    }
    st_us(e, base, newbuf);
    st_us(e, base + 16usize, newcap);
    return 0;
}
fn bi_map_insert(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let a0: u32 = pp.nodes[conv usize i].b;
    let valty: u32 = coll_elem_ty(pp, coll_arg_ty(pp, src, e, a0));
    let sc: i32 = eval_expr(pp, src, e, a0, 0 - 1i32);
    if sc != 0 { return sc; }
    let base: usize = conv usize e.cur_val;
    let bc: i32 = load_byteview(pp, src, e, nxt(pp, a0));
    if bc != 0 { return bc; }
    let kptr: usize = e.bv_ptr;
    let klen: usize = e.bv_len;
    let mc: i32 = eval_move_src(pp, src, e, nxt(pp, nxt(pp, a0)), valty);
    if mc != 0 { return mc; }
    let stride: usize = map_stride(pp, src, e, valty);
    let buf0: usize = ld_us(e, base);
    let cap0: usize = ld_us(e, base + 16usize);
    let fslot: usize = map_find(e, buf0, cap0, stride, kptr, klen);
    if fslot != cap0 {
        let voff: usize = buf0 + fslot * stride + 24usize;
        let dc: i32 = drop_value(pp, src, e, voff, valty, 0 - 1i64);
        if dc != 0 { return dc; }
        commit_move(pp, src, e, voff, valty);
        return ret_none(e);
    }
    let rc: i32 = map_reserve(pp, src, e, base, valty);
    if rc != 0 { return rc; }
    let buf: usize = ld_us(e, base);
    let slot: usize = map_find_empty(e, buf, ld_us(e, base + 16usize), stride, kptr, klen);
    let ctx: i64 = mem_load(e, base + 24usize, W_USIZE);
    let vt: i64 = mem_load(e, base + 32usize, W_USIZE);
    let ac: i32 = call_alloc(pp, src, e, ctx, vt, klen, 1usize);
    if ac != 0 { return ac; }
    let kbuf: usize = conv usize to_u64(e.cur_val);
    if kbuf == 0usize { set_fault(e, FK_PANIC, e.cur_p0, e.cur_p1); return 1; }
    mem_copy(e, kbuf, kptr, klen);
    let b: usize = buf + slot * stride;
    st_us(e, b, 1usize);
    st_us(e, b + 8usize, kbuf);
    st_us(e, b + 16usize, klen);
    commit_move(pp, src, e, b + 24usize, valty);
    st_us(e, base + 8usize, ld_us(e, base + 8usize) + 1usize);
    return ret_none(e);
}
// `contains` (is_get=false → bool) and `get` (is_get=true → borrow, faulting on a
// missing key) share the same find; only the result differs.
fn bi_map_lookup(pp: read P, src: [u8], e: write E, i: u32, is_get: bool) -> i32 {
    let a0: u32 = pp.nodes[conv usize i].b;
    let valty: u32 = coll_elem_ty(pp, coll_arg_ty(pp, src, e, a0));
    let sc: i32 = eval_expr(pp, src, e, a0, 0 - 1i32);
    if sc != 0 { return sc; }
    let base: usize = conv usize e.cur_val;
    let bc: i32 = load_byteview(pp, src, e, nxt(pp, a0));
    if bc != 0 { return bc; }
    let stride: usize = map_stride(pp, src, e, valty);
    let buf: usize = ld_us(e, base);
    let cap: usize = ld_us(e, base + 16usize);
    let slot: usize = map_find(e, buf, cap, stride, e.bv_ptr, e.bv_len);
    if is_get {
        if slot == cap {
            set_fault(e, FK_BOUNDS, e.cur_p0, e.cur_p1);
            return 1;
        }
        e.*.cur_val = conv i64 (buf + slot * stride + 24usize);
        e.*.cur_w = W_USIZE;
        e.*.cur_ty = valty;
        e.*.cur_org = 0;
        return 0;
    }
    if slot != cap { e.*.cur_val = 1i64; } else { e.*.cur_val = 0i64; }
    e.*.cur_w = W_BOOL;
    e.*.cur_org = 0;
    return 0;
}
// 0-based declared index of the variant whose name equals a byte-string literal.
fn variant_index_by_lit(pp: read P, src: [u8], eid: u32, name: [u8]) -> i32 {
    let enode: Node = pp.nodes[conv usize eid];
    let mut cur: u32 = enode.b;
    let mut k: i32 = 0;
    while cur != 0u32 {
        let vd: Node = pp.nodes[conv usize cur];
        if span_eq(src, vd.p0, vd.p1, name) { return k; }
        k = k + 1i32;
        cur = vd.nx;
    }
    return 0 - 1i32;
}
// Peel a `read`/`write` borrow and resolve arg0's collection type via its direct
// local/static's declared type node (mirrors the oracle's arg0_is_* static probe).
fn coll_arg_ty(pp: read P, src: [u8], e: write E, argnode: u32) -> u32 {
    if argnode == 0u32 { return 0u32; }
    let nd: Node = pp.nodes[conv usize argnode];
    let mut inner: u32 = argnode;
    if nd.tag == T_PREFIX {
        if nd.op == PF_READ || nd.op == PF_WRITE { inner = nd.a; }
    }
    let innd: Node = pp.nodes[conv usize inner];
    if innd.tag == T_ID {
        let li: usize = find_local(src, e, innd.p0, innd.p1);
        if li != e.loc_n { return e.loc_ty[li]; }
        let si: usize = find_static(src, e, innd.p0, innd.p1);
        if si != e.static_n { return e.static_ty[si]; }
    }
    return 0u32;
}

// ---- impl-method dispatch (T2) ----------------------------------------------
// Build the dispatch table from every concrete (non-generic) T_IMPL: key each
// method by (target struct-instance node, method-name span). Generic impl
// templates (type-params present) are skipped -- mono has already instantiated
// them at each reached concrete target as their own concrete T_IMPL nodes.
fn build_dispatch(pp: read P, src: [u8], e: write E) -> unit {
    let mut cur: u32 = e.head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_IMPL && nd.a == 0u32 {
            let sid: u32 = struct_of_ty(pp, src, e, nd.c);
            let mut mcur: u32 = nd.d;
            while mcur != 0u32 {
                let mnd: Node = pp.nodes[conv usize mcur];
                let k: usize = e.disp_n;
                e.*.disp_sid[k] = sid;
                e.*.disp_p0[k] = mnd.p0;
                e.*.disp_p1[k] = mnd.p1;
                e.*.disp_fn[k] = mcur;
                e.*.disp_n = k + 1usize;
                mcur = mnd.nx;
            }
        }
        cur = nd.nx;
    }
    return;
}
fn dispatch_lookup(src: [u8], e: write E, sid: u32, s: usize, en: usize) -> u32 {
    let mut i: usize = 0usize;
    while i < e.disp_n {
        if e.disp_sid[i] == sid && name_eq(src, e.disp_p0[i], e.disp_p1[i], s, en) {
            return e.disp_fn[i];
        }
        i = i + 1usize;
    }
    return 0u32;
}
// Dispatch `recv.m(args)`: type the receiver place to a struct instance, look up
// the impl method, then bind the receiver as the method's synthetic `self`
// (a `read`/`write` self is a borrow -> pass the receiver address as an 8-byte
// pointer scalar, exactly as call_fn expects a borrow param). Nested receivers
// like `self.inner.m()` fall out for free: eval_place types the field.
fn eval_method_call(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let callee: Node = pp.nodes[conv usize nd.a];
    let base: u32 = callee.a;
    let sc0: i32 = eval_place(pp, src, e, base);
    if sc0 != 0 { return sc0; }
    peel_box_place(pp, e);
    let recv_addr: usize = e.plc_addr;
    let recv_ty: u32 = e.plc_ty;
    let sid: u32 = struct_of_ty(pp, src, e, recv_ty);
    let fnid: u32 = dispatch_lookup(src, e, sid, callee.p0, callee.p1);
    if fnid == 0u32 {
        set_fault(e, FK_PANIC, callee.p0, callee.p1);
        return 1;
    }
    let mut av: [16]i64 = [0i64; 16];
    let mut aw: [16]i32 = [0; 16];
    let mut aa: [16]usize = [0usize; 16];
    av[0] = conv i64 recv_addr;
    aw[0] = W_USIZE;
    aa[0] = 0usize;
    let mut k: usize = 1usize;
    let params: u32 = pp.nodes[conv usize fnid].c;
    let mut pcur: u32 = 0u32;
    if params != 0u32 { pcur = pp.nodes[conv usize params].nx; }
    let mut cur: u32 = nd.b;
    while cur != 0u32 {
        let an: Node = pp.nodes[conv usize cur];
        let mut ptype: u32 = 0u32;
        if pcur != 0u32 {
            let pm: Node = pp.nodes[conv usize pcur];
            ptype = pm.a;
            pcur = pm.nx;
        }
        let pw: i32 = scalar_width(pp, src, ptype);
        if pw != 0 {
            let sc: i32 = eval_expr(pp, src, e, cur, pw);
            if sc != 0 { return sc; }
            av[k] = e.cur_val;
            aw[k] = e.cur_w;
            aa[k] = 0usize;
        } else {
            let sc: i32 = eval_expr(pp, src, e, cur, 0 - 1i32);
            if sc != 0 { return sc; }
            aw[k] = 0;
            aa[k] = conv usize e.cur_val;
            if !is_copy(pp, src, e, ptype) {
                do_consume(e, e.cur_org, e.cur_org_a, e.cur_org_b);
            }
        }
        k = k + 1usize;
        cur = an.nx;
    }
    let mut j: usize = 0usize;
    while j < k {
        e.*.arg_val[j] = av[j];
        e.*.arg_w[j] = aw[j];
        e.*.arg_addr[j] = aa[j];
        j = j + 1usize;
    }
    e.*.arg_n = k;
    let cs: i32 = call_fn(pp, src, e, fnid);
    if cs != 0 { return cs; }
    e.*.cur_org = 0;
    if e.cur_w == 0 && !is_copy(pp, src, e, e.cur_ty) {
        let ti: usize = reg_temp(e, conv usize e.cur_val, e.cur_ty);
        e.*.cur_org = 1;
        e.*.cur_org_a = ti;
    }
    return 0;
}
fn eval_call(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let callee: Node = pp.nodes[conv usize nd.a];
    // A method call `recv.m(args)` parses as a T_CALL with a T_FIELD callee;
    // dispatch it on the receiver's static nominal type (design 0007 static dispatch,
    // mirroring the oracle eval.rs:1571-1601).
    if callee.tag == T_FIELD {
        return eval_method_call(pp, src, e, i);
    }
    if span_eq(src, callee.p0, callee.p1, b"trace") {
        let sc: i32 = eval_expr(pp, src, e, nd.b, 4);
        if sc != 0 { return sc; }
        let k: usize = e.trace_n;
        e.*.trace_out[k] = e.cur_val;
        e.*.trace_n = k + 1usize;
        e.*.cur_val = 0i64; e.*.cur_w = 0;
        e.*.cur_org = 0;
        return 0;
    }
    if span_eq(src, callee.p0, callee.p1, b"addr_of") || span_eq(src, callee.p0, callee.p1, b"addr_of_mut") {
        let sc: i32 = eval_place(pp, src, e, nd.b);
        if sc != 0 { return sc; }
        e.*.cur_val = conv i64 e.plc_addr;
        e.*.cur_w = W_USIZE;
        e.*.cur_ty = 0u32;
        e.*.cur_org = 0;
        return 0;
    }
    if span_eq(src, callee.p0, callee.p1, b"ptr_read") {
        let sc: i32 = eval_expr(pp, src, e, nd.b, W_USIZE);
        if sc != 0 { return sc; }
        let paddr: usize = conv usize to_u64(e.cur_val);
        let inner: u32 = rawptr_inner(pp, e.cur_ty);
        let iw: i32 = scalar_width(pp, src, inner);
        if iw != 0 {
            e.*.cur_val = mem_load(e, paddr, iw);
            e.*.cur_w = iw;
            e.*.cur_ty = inner;
            e.*.cur_org = 0;
        } else {
            let size: usize = ty_size(pp, src, e, inner);
            let align: usize = ty_align(pp, src, e, inner);
            let slot: usize = bump_alloc(e, size, align);
            mem_copy(e, slot, paddr, size);
            e.*.cur_val = conv i64 slot;
            e.*.cur_w = 0;
            e.*.cur_ty = inner;
            e.*.cur_org = 0;
            if !is_copy(pp, src, e, inner) {
                let ti: usize = reg_temp(e, slot, inner);
                e.*.cur_org = 1;
                e.*.cur_org_a = ti;
            }
        }
        return 0;
    }
    if span_eq(src, callee.p0, callee.p1, b"ptr_write") {
        let sc: i32 = eval_expr(pp, src, e, nd.b, W_USIZE);
        if sc != 0 { return sc; }
        let paddr: usize = conv usize to_u64(e.cur_val);
        let vnode: Node = pp.nodes[conv usize nd.b];
        let sc2: i32 = eval_expr(pp, src, e, vnode.nx, 0 - 1i32);
        if sc2 != 0 { return sc2; }
        if e.cur_w != 0 {
            mem_store(e, paddr, e.cur_val, e.cur_w);
        } else {
            let vorg: i32 = e.cur_org;
            let voa: usize = e.cur_org_a;
            let vob: i32 = e.cur_org_b;
            let vty: u32 = e.cur_ty;
            let sa: usize = conv usize e.cur_val;
            let vsz: usize = ty_size(pp, src, e, vty);
            mem_copy(e, paddr, sa, vsz);
            if !is_copy(pp, src, e, vty) {
                do_consume(e, vorg, voa, vob);
            }
        }
        e.*.cur_val = 0i64;
        e.*.cur_w = 0;
        e.*.cur_org = 0;
        return 0;
    }
    if span_eq(src, callee.p0, callee.p1, b"is_null") {
        let sc: i32 = eval_expr(pp, src, e, nd.b, W_USIZE);
        if sc != 0 { return sc; }
        let av: u64 = to_u64(e.cur_val);
        if av == 0u64 { e.*.cur_val = 1i64; } else { e.*.cur_val = 0i64; }
        e.*.cur_w = W_BOOL;
        e.*.cur_org = 0;
        return 0;
    }
    if span_eq(src, callee.p0, callee.p1, b"len") {
        // `len(read Vec[T]/Map[V])` and `len(read String)` read the length word at
        // offset 8 of the collection the borrow points at.
        let lt: u32 = coll_arg_ty(pp, src, e, nd.b);
        if is_vec_ty(pp, src, lt) || is_map_ty(pp, src, lt) || is_string_ty(pp, src, lt) {
            let scb: i32 = eval_expr(pp, src, e, nd.b, 0 - 1i32);
            if scb != 0 { return scb; }
            let cbase: usize = conv usize e.cur_val;
            let cln: usize = ld_us(e, cbase + 8usize);
            e.*.cur_val = conv i64 cln;
            e.*.cur_w = W_USIZE;
            e.*.cur_ty = 0u32;
            e.*.cur_org = 0;
            return 0;
        }
        let sc: i32 = eval_expr(pp, src, e, nd.b, 0 - 1i32);
        if sc != 0 { return sc; }
        let saddr: usize = conv usize e.cur_val;
        let snode: Node = pp.nodes[conv usize e.cur_ty];
        let mut ln: usize = 0usize;
        if snode.tag == T_SLICE || snode.tag == T_SLICEMUT || snode.tag == T_STR || span_eq(src, snode.p0, snode.p1, b"str") {
            ln = conv usize to_u64(mem_load(e, saddr + 8usize, W_USIZE));
        } else if snode.tag == T_ARRAY {
            ln = array_len_of(pp, snode.a);
        }
        e.*.cur_val = conv i64 ln;
        e.*.cur_w = W_USIZE;
        e.*.cur_ty = 0u32;
        e.*.cur_org = 0;
        return 0;
    }
    if span_eq(src, callee.p0, callee.p1, b"box") {
        return bi_box(pp, src, e, i);
    }
    if span_eq(src, callee.p0, callee.p1, b"unbox") {
        return bi_unbox(pp, src, e, i);
    }
    if span_eq(src, callee.p0, callee.p1, b"ptr_offset") {
        // ptr_offset(p, n): advance a rawptr by `n` elements of its pointee. Stride
        // is ty_size(inner); `n` is isize (may be negative). Mirrors bi_ptr_offset.
        let sc: i32 = eval_expr(pp, src, e, nd.b, W_USIZE);
        if sc != 0 { return sc; }
        let base: usize = conv usize to_u64(e.cur_val);
        let pty: u32 = e.cur_ty;
        let inner: u32 = rawptr_inner(pp, pty);
        let stride: usize = ty_size(pp, src, e, inner);
        let pnode: Node = pp.nodes[conv usize nd.b];
        let sc2: i32 = eval_expr(pp, src, e, pnode.nx, 5);
        if sc2 != 0 { return sc2; }
        let n: i64 = e.cur_val;
        let mut na: i64 = 0i64;
        wrapping { na = conv i64 base + n * conv i64 stride; }
        e.*.cur_val = na;
        e.*.cur_w = W_USIZE;
        e.*.cur_ty = pty;
        e.*.cur_org = 0;
        return 0;
    }
    if span_eq(src, callee.p0, callee.p1, b"ptr_to_addr") {
        // ptr_to_addr(p): expose the pointer's address as a plain usize. A rawptr
        // scalar already carries its address in cur_val, so only the type changes.
        let sc: i32 = eval_expr(pp, src, e, nd.b, W_USIZE);
        if sc != 0 { return sc; }
        e.*.cur_w = W_USIZE;
        e.*.cur_ty = 0u32;
        e.*.cur_org = 0;
        return 0;
    }
    // ---- compiler-known std collection ops (dispatch mirrors the oracle's
    // eval.rs by-name + arg0-type routing; `_new` is unconditional, the rest gate
    // on arg0's static type so a same-named user fn is never intercepted) --------
    if span_eq(src, callee.p0, callee.p1, b"vec_new")
        || span_eq(src, callee.p0, callee.p1, b"map_new")
        || span_eq(src, callee.p0, callee.p1, b"string_new") {
        return bi_coll_new(pp, src, e, i);
    }
    let ct0: u32 = coll_arg_ty(pp, src, e, nd.b);
    if is_string_ty(pp, src, ct0) {
        if span_eq(src, callee.p0, callee.p1, b"push") { return bi_string_add(pp, src, e, i, true); }
        if span_eq(src, callee.p0, callee.p1, b"append") { return bi_string_add(pp, src, e, i, false); }
        if span_eq(src, callee.p0, callee.p1, b"as_str") { return bi_string_as_str(pp, src, e, i); }
    }
    if is_vec_ty(pp, src, ct0) {
        if span_eq(src, callee.p0, callee.p1, b"push") { return bi_vec_push(pp, src, e, i); }
        if span_eq(src, callee.p0, callee.p1, b"pop") { return bi_vec_pop(pp, src, e, i); }
        if span_eq(src, callee.p0, callee.p1, b"get") { return bi_vec_get(pp, src, e, i); }
    }
    if is_map_ty(pp, src, ct0) {
        if span_eq(src, callee.p0, callee.p1, b"insert") { return bi_map_insert(pp, src, e, i); }
        if span_eq(src, callee.p0, callee.p1, b"get") { return bi_map_lookup(pp, src, e, i, true); }
        if span_eq(src, callee.p0, callee.p1, b"contains") { return bi_map_lookup(pp, src, e, i, false); }
    }
    // Direct call (a declared fn) or, when the name is not a fn, an INDIRECT call
    // through a fn-ptr value: evaluate the callee expression -- which yields the
    // fn's arena node id -- and call that (the oracle's indirect path, :1604-1610).
    let mut fnid: u32 = nd.c;
    if fnid == 0u32 { fnid = find_fn(pp, src, e, callee.p0, callee.p1); }
    if fnid == 0u32 {
        let scc: i32 = eval_expr(pp, src, e, nd.a, W_USIZE);
        if scc != 0 { return scc; }
        fnid = conv u32 to_u64(e.cur_val);
    }
    // Evaluate arguments first (a nested call reuses E.arg_*): scalars into arg_val,
    // aggregates as an address in arg_addr (the source temp survives on the bump
    // until call_fn copies it into the callee's by-value param slot).
    let mut av: [16]i64 = [0i64; 16];
    let mut aw: [16]i32 = [0; 16];
    let mut aa: [16]usize = [0usize; 16];
    let mut k: usize = 0usize;
    let mut cur: u32 = nd.b;
    let params: u32 = pp.nodes[conv usize fnid].c;
    let mut pcur: u32 = params;
    while cur != 0u32 {
        let an: Node = pp.nodes[conv usize cur];
        let mut ptype: u32 = 0u32;
        if pcur != 0u32 {
            let pm: Node = pp.nodes[conv usize pcur];
            ptype = pm.a;
            pcur = pm.nx;
        }
        let pw: i32 = scalar_width(pp, src, ptype);
        if pw != 0 {
            let sc: i32 = eval_expr(pp, src, e, cur, pw);
            if sc != 0 { return sc; }
            av[k] = e.cur_val;
            aw[k] = e.cur_w;
            aa[k] = 0usize;
        } else {
            let sc: i32 = eval_expr(pp, src, e, cur, 0 - 1i32);
            if sc != 0 { return sc; }
            aw[k] = 0;
            aa[k] = conv usize e.cur_val;
            // A by-value non-copy aggregate argument is moved into the param slot.
            if !is_copy(pp, src, e, ptype) {
                do_consume(e, e.cur_org, e.cur_org_a, e.cur_org_b);
            }
        }
        k = k + 1usize;
        cur = an.nx;
    }
    let mut j: usize = 0usize;
    while j < k {
        e.*.arg_val[j] = av[j];
        e.*.arg_w[j] = aw[j];
        e.*.arg_addr[j] = aa[j];
        j = j + 1usize;
    }
    e.*.arg_n = k;
    let cs: i32 = call_fn(pp, src, e, fnid);
    if cs != 0 { return cs; }
    e.*.cur_org = 0;
    if e.cur_w == 0 && !is_copy(pp, src, e, e.cur_ty) {
        let ti: usize = reg_temp(e, conv usize e.cur_val, e.cur_ty);
        e.*.cur_org = 1;
        e.*.cur_org_a = ti;
    }
    return 0;
}

// Run a function to completion. Arguments live in E.arg_* on entry. An aggregate
// return is delivered through a caller-owned `ret_slot` reserved BELOW the frame's
// reset point (so it survives the stack_bump reset); a scalar return rides the
// ret_val register. Returns 0 (normal, result in E.cur_val) or 1 (fault).
// Drop the owned, not-moved locals in `[base, loc_n)` in reverse -- the shared
// exit path for a block, call, and match frame. The five value registers
// (cur_val/cur_w/cur_ty and ret_val/ret_w) are saved across the loop and
// restored after: a `free` invoked mid-drop runs arbitrary interp code that
// clobbers the shared return registers (the S5b register-trap), so the save MUST
// wrap every owned-locals drop. Keeping it in one place stops a future drop
// caller from silently reintroducing that bug. Returns 1 if any drop faulted.
fn drop_owned_locals_from(pp: read P, src: [u8], e: write E, base: usize) -> i32 {
    let sv: i64 = e.cur_val;
    let sw: i32 = e.cur_w;
    let sty: u32 = e.cur_ty;
    let srv: i64 = e.ret_val;
    let srw: i32 = e.ret_w;
    let mut fault: i32 = 0;
    let mut i: usize = e.loc_n;
    while i > base {
        i = i - 1usize;
        if e.loc_owns[i] != 0u8 {
            let ty: u32 = e.loc_ty[i];
            if needs_drop(pp, src, e, ty) && !whole_moved(e, i) {
                let dc: i32 = drop_value(pp, src, e, e.loc_addr[i], ty, conv i64 i);
                if dc != 0 { fault = 1; }
            }
        }
    }
    e.*.cur_val = sv;
    e.*.cur_w = sw;
    e.*.cur_ty = sty;
    e.*.ret_val = srv;
    e.*.ret_w = srw;
    return fault;
}
fn call_fn(pp: read P, src: [u8], e: write E, fnid: u32) -> i32 {
    let fnd: Node = pp.nodes[conv usize fnid];
    let rtynode: u32 = fn_ret_tynode(pp, fnid);
    let ragg: bool = ty_is_agg(pp, src, e, rtynode);
    let mut ret_slot: usize = 0usize;
    if ragg {
        let rsz: usize = ty_size(pp, src, e, rtynode);
        let ral: usize = ty_align(pp, src, e, rtynode);
        ret_slot = bump_alloc(e, rsz, ral);
    }
    let base_bump: usize = e.stack_bump;
    let saved_base: usize = e.cur_base;
    let saved_retw: i32 = e.cur_retw;
    let saved_retty: u32 = e.cur_retty;
    let saved_result: usize = e.cur_result_addr;
    let base: usize = e.loc_n;
    e.*.cur_base = base;
    e.*.cur_retw = fn_ret_width(pp, src, fnid);
    e.*.cur_retty = rtynode;
    e.*.cur_result_addr = ret_slot;
    let mut pcur: u32 = fnd.c;
    let mut k: usize = 0usize;
    while pcur != 0u32 {
        let pm: Node = pp.nodes[conv usize pcur];
        let ptype: u32 = pm.a;
        let pw: i32 = scalar_width(pp, src, ptype);
        let psz: usize = ty_size(pp, src, e, ptype);
        let pal: usize = ty_align(pp, src, e, ptype);
        let paddr: usize = bump_alloc(e, psz, pal);
        if pw != 0 {
            mem_store(e, paddr, e.arg_val[k], pw);
        } else {
            zero_slot(e, paddr, psz);
            let sa: usize = e.arg_addr[k];
            mem_copy(e, paddr, sa, psz);
        }
        loc_push(e, pm.p0, pm.p1, paddr, pw, ptype, 1);
        k = k + 1usize;
        pcur = pm.nx;
    }
    let st: i32 = exec_block(pp, src, e, fnd.d);
    let mut rc: i32 = 0;
    if st == 1 {
        rc = 1;
    } else if st == 2 {
        if ragg {
            e.*.cur_val = conv i64 ret_slot; e.*.cur_w = 0; e.*.cur_ty = rtynode;
        } else {
            e.*.cur_val = e.ret_val; e.*.cur_w = e.ret_w;
        }
        rc = 0;
    } else {
        if ragg {
            e.*.cur_val = conv i64 ret_slot; e.*.cur_w = 0; e.*.cur_ty = rtynode;
        } else {
            e.*.cur_val = 0i64; e.*.cur_w = e.cur_retw;
        }
        rc = 0;
    }
    if st != 1 {
        if drop_owned_locals_from(pp, src, e, base) != 0 { rc = 1; }
    }
    clear_locals_from(e, base);
    e.*.loc_n = base;
    e.*.stack_bump = base_bump;
    e.*.cur_base = saved_base;
    e.*.cur_retw = saved_retw;
    e.*.cur_retty = saved_retty;
    e.*.cur_result_addr = saved_result;
    return rc;
}

// A statement's non-copy temps are dropped in reverse creation order at its end
// (drop_stmt_temps), UNLESS a fault aborted it (abort semantics: no drops).
fn exec_stmt(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let tmp_base: usize = e.tmp_n;
    let st: i32 = exec_stmt_inner(pp, src, e, i);
    if st == 1 { return st; }
    let sv: i64 = e.cur_val;
    let sw: i32 = e.cur_w;
    let sty: u32 = e.cur_ty;
    let srv: i64 = e.ret_val;
    let srw: i32 = e.ret_w;
    let mut fault: i32 = 0;
    let mut k: usize = e.tmp_n;
    while k > tmp_base {
        k = k - 1usize;
        if e.tmp_live[k] != 0u8 {
            let dc: i32 = drop_value(pp, src, e, e.tmp_addr[k], e.tmp_ty[k], 0 - 1i64);
            if dc != 0 { fault = 1; }
        }
    }
    e.*.tmp_n = tmp_base;
    e.*.cur_val = sv;
    e.*.cur_w = sw;
    e.*.cur_ty = sty;
    e.*.ret_val = srv;
    e.*.ret_w = srw;
    if fault != 0 { return 1; }
    return st;
}

fn exec_stmt_inner(pp: read P, src: [u8], e: write E, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_LET {
        let tynode: u32 = nd.a;
        let w: i32 = scalar_width(pp, src, tynode);
        let size: usize = ty_size(pp, src, e, tynode);
        let align: usize = ty_align(pp, src, e, tynode);
        let addr: usize = bump_alloc(e, size, align);
        if w == 0 { zero_slot(e, addr, size); }
        if nd.b != 0u32 {
            if w != 0 {
                let sc: i32 = eval_expr(pp, src, e, nd.b, w);
                if sc != 0 { return sc; }
                mem_store(e, addr, e.cur_val, w);
            } else {
                e.*.cur_exp_ty = tynode;
                let sc: i32 = eval_expr(pp, src, e, nd.b, 0 - 1i32);
                if sc != 0 { return sc; }
                let lorg: i32 = e.cur_org;
                let loa: usize = e.cur_org_a;
                let lob: i32 = e.cur_org_b;
                let sa: usize = conv usize e.cur_val;
                mem_copy(e, addr, sa, size);
                if !is_copy(pp, src, e, tynode) {
                    do_consume(e, lorg, loa, lob);
                }
            }
        }
        loc_push(e, nd.p0, nd.p1, addr, w, tynode, 1);
        return 0;
    }
    if nd.tag == T_ASSIGN {
        let sc: i32 = eval_place(pp, src, e, nd.a);
        if sc != 0 { return sc; }
        let dst: usize = e.plc_addr;
        let dw: i32 = e.plc_w;
        let dty: u32 = e.plc_ty;
        if dw != 0 {
            let sc2: i32 = eval_expr(pp, src, e, nd.b, dw);
            if sc2 != 0 { return sc2; }
            mem_store(e, dst, e.cur_val, dw);
        } else {
            let sc2: i32 = eval_expr(pp, src, e, nd.b, 0 - 1i32);
            if sc2 != 0 { return sc2; }
            let aorg: i32 = e.cur_org;
            let aoa: usize = e.cur_org_a;
            let aob: i32 = e.cur_org_b;
            let sa: usize = conv usize e.cur_val;
            let sz: usize = ty_size(pp, src, e, dty);
            // A drop-bearing owned direct-local target drops its OLD value first
            // (after the RHS, honoring the RHS's move state), then re-owns.
            let tnode: Node = pp.nodes[conv usize nd.a];
            let mut tli: usize = 0usize;
            let mut has_li: bool = false;
            if tnode.tag == T_ID && !is_copy(pp, src, e, dty) {
                tli = find_local(src, e, tnode.p0, tnode.p1);
                has_li = true;
                if e.loc_owns[tli] != 0u8 && needs_drop(pp, src, e, dty) && !whole_moved(e, tli) {
                    let dc: i32 = drop_value(pp, src, e, dst, dty, conv i64 tli);
                    if dc != 0 { return 1; }
                }
            }
            mem_copy(e, dst, sa, sz);
            if !is_copy(pp, src, e, dty) {
                do_consume(e, aorg, aoa, aob);
            }
            if has_li { set_owned_whole(e, tli); }
        }
        return 0;
    }
    return eval_expr(pp, src, e, i, 0 - 1i32);
}

fn exec_block(pp: read P, src: [u8], e: write E, blk: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize blk];
    let base: usize = e.loc_n;
    let base_bump: usize = e.stack_bump;
    let mut st: i32 = 0;
    let mut cur: u32 = nd.a;
    while cur != 0u32 {
        let sn: Node = pp.nodes[conv usize cur];
        st = exec_stmt(pp, src, e, cur);
        if st != 0 { break; }
        cur = sn.nx;
    }
    if st != 1 {
        if drop_owned_locals_from(pp, src, e, base) != 0 { st = 1; }
    }
    clear_locals_from(e, base);
    e.*.loc_n = base;
    e.*.stack_bump = base_bump;
    return st;
}

// ---- canonical dump ----------------------------------------------------------
fn emit_inum(v: i64) -> unit {
    if v < 0i64 {
        trace(45);
        let mut mag: u64 = 0u64;
        wrapping { mag = conv u64 (0i64 - v); }
        emit_num(mag);
    } else {
        emit_num(conv u64 v);
    }
    return;
}

// Static pre-pass (mirrors run_main, src/interp/eval.rs:270-303). Phase 1
// reserves each `static`'s storage from the bump; phase 2 evaluates every
// initializer into its slot, resetting the bump between statics so only the
// static storage (below `static_top`) survives into `main`. Runs before `main`,
// so a vtable static a fn-ptr program reads is already populated.
fn run_statics(pp: read P, src: [u8], e: write E) -> unit {
    let mut scur: u32 = e.head;
    while scur != 0u32 {
        let snd: Node = pp.nodes[conv usize scur];
        if snd.tag == T_STATIC {
            let tynode: u32 = snd.a;
            let w: i32 = scalar_width(pp, src, tynode);
            let size: usize = ty_size(pp, src, e, tynode);
            let align: usize = ty_align(pp, src, e, tynode);
            let addr: usize = bump_alloc(e, size, align);
            let k: usize = e.static_n;
            e.*.static_p0[k] = snd.p0;
            e.*.static_p1[k] = snd.p1;
            e.*.static_addr[k] = addr;
            e.*.static_w[k] = w;
            e.*.static_ty[k] = tynode;
            e.*.static_init[k] = snd.b;
            e.*.static_n = k + 1usize;
        }
        scur = snd.nx;
    }
    let static_top: usize = e.stack_bump;
    let mut sj: usize = 0usize;
    while sj < e.static_n {
        let initn: u32 = e.static_init[sj];
        let addr: usize = e.static_addr[sj];
        let w: i32 = e.static_w[sj];
        if w != 0 {
            let sc: i32 = eval_expr(pp, src, e, initn, w);
            if sc == 0 { mem_store(e, addr, e.cur_val, w); }
        } else {
            let sc: i32 = eval_expr(pp, src, e, initn, 0 - 1i32);
            if sc == 0 {
                let size: usize = ty_size(pp, src, e, e.static_ty[sj]);
                mem_copy(e, addr, conv usize e.cur_val, size);
            }
        }
        e.*.stack_bump = static_top;
        sj = sj + 1usize;
    }
    e.*.tmp_n = 0usize;
    return;
}

pub fn interp_dump(src: [u8], buf: read Buf) -> unit {
    let mut p: P = P { nodes: [nnew(0); 49152], n: 1u32, pos: 0usize, no_struct: 0, dreg: 0u32, dtp: 0u32, mmode: 0, mreg: 0u32, mty: 0u32, uses: 0u32 };
    let head: u32 = parse_program(write p, src, buf);
    mono_program(write p, src, head);
    let mut e: E = E {
        head: head,
        loc_p0: [0usize; 1024],
        loc_p1: [0usize; 1024],
        loc_addr: [0usize; 1024],
        loc_w: [0; 1024],
        loc_ty: [0u32; 1024],
        loc_n: 0usize,
        cur_base: 0usize,
        cur_retw: 4,
        cur_retty: 0u32,
        cur_result_addr: 0usize,
        cur_val: 0i64,
        cur_w: 0,
        cur_ty: 0u32,
        ret_val: 0i64,
        ret_w: 4,
        arg_val: [0i64; 16],
        arg_w: [0; 16],
        arg_addr: [0usize; 16],
        arg_n: 0usize,
        pages: [0u8; 524288],
        pagedir: [0i32 - 1i32; 8192],
        page_bump: 0usize,
        stack_bump: 8usize,
        plc_addr: 0usize,
        plc_w: 0,
        plc_ty: 0u32,
        trace_out: [0i64; 1024],
        trace_n: 0usize,
        fault_kind: 0 - 1i32,
        fault_p0: 0usize,
        fault_p1: 0usize,
        cur_p0: 0usize,
        cur_p1: 0usize,
        loc_owns: [0u8; 1024],
        mv_local: [0usize; 512],
        mv_field: [0; 512],
        mv_n: 0usize,
        tmp_addr: [0usize; 256],
        tmp_ty: [0u32; 256],
        tmp_live: [0u8; 256],
        tmp_n: 0usize,
        cur_org: 0,
        cur_org_a: 0usize,
        cur_org_b: 0,
        self_p0: 0usize,
        self_p1: 0usize,
        static_p0: [0usize; 64],
        static_p1: [0usize; 64],
        static_addr: [0usize; 64],
        static_w: [0; 64],
        static_ty: [0u32; 64],
        static_init: [0u32; 64],
        static_n: 0usize,
        alloc_vt_sid: 0u32,
        alloc_sid: 0u32,
        cur_exp_ty: 0u32,
        gen_boxresult: 0u32,
        gen_box: 0u32,
        gen_inner: 0u32,
        scw: [0u32; 16],
        bv_ptr: 0usize,
        bv_len: 0usize,
        mv_ew: 0,
        mv_val: 0i64,
        mv_addr: 0usize,
        mv_org: 0,
        mv_oa: 0usize,
        mv_ob: 0,
        disp_sid: [0u32; 64],
        disp_p0: [0usize; 64],
        disp_p1: [0usize; 64],
        disp_fn: [0u32; 64],
        disp_n: 0usize,
    };
    set_self_span(src, write e);
    // Structural Alloc/AllocVtable identification, computed once at startup like
    // the oracle's `Interp::new`. Stored as the ABI seam S5b's box reads.
    let avt: u32 = find_alloc_vtable_struct(read p, src, write e);
    e.alloc_vt_sid = avt;
    e.alloc_sid = find_alloc_struct(read p, src, write e, avt);
    synth_boxresults(write p, src);
    synth_array_types(write p);
    synth_param_borrows(write p);
    synth_generic_boxresult(write p, src, write e);
    synth_scalar_nodes(write p, src, write e);
    build_dispatch(read p, src, write e);
    run_statics(read p, src, write e);
    let mainid: u32 = find_main(read p, src, write e);
    let mut ret: i64 = 0i64;
    if mainid != 0u32 {
        e.arg_n = 0usize;
        let st: i32 = call_fn(read p, src, write e, mainid);
        ret = e.cur_val;
    }
    if e.fault_kind >= 0 {
        emit_lit(b"FAULT");
        emit_sp();
        emit_num(conv u64 e.fault_kind);
        emit_sp();
        emit_num(conv u64 e.fault_p0);
        emit_sp();
        emit_num(conv u64 e.fault_p1);
        emit_nl();
        return;
    }
    emit_lit(b"RET");
    emit_sp();
    emit_inum(ret);
    emit_nl();
    let mut ti: usize = 0usize;
    while ti < e.trace_n {
        emit_lit(b"TRACE");
        emit_sp();
        emit_inum(e.trace_out[ti]);
        emit_nl();
        ti = ti + 1usize;
    }
    return;
}
