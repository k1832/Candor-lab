// Drives the `?` operator in a MULTI-FILE program (finding F2, now fixed):
// `same` propagates the error unchanged (same-type `?`), `cross` widens
// `IoErr` -> `AppErr` through the `impl From[IoErr] for AppErr` in `core::res`
// (cross-type `?`, design 0007 §7.1). Both resolve under the module-tree checker.
use core::res::{Res, IoErr, AppErr, read_at};

fn same(ok: bool) -> Res[i64, IoErr] {
    let n: i64 = read_at(ok)?;
    return Res::Ok(n + 1);
}

fn cross(ok: bool) -> Res[i64, AppErr] {
    let n: i64 = read_at(ok)?;
    return Res::Ok(n + 1);
}

fn main() -> i64 {
    let mut acc: i64 = 0;
    match same(true) { Res::Ok(v) => { acc = acc + v; } Res::Err(e) => { return -1; } }     // +43
    match cross(true) { Res::Ok(v) => { acc = acc + v; } Res::Err(e) => { return -2; } }     // +43
    // cross(false): `?` converts IoErr::Eof -> AppErr::FromIo(Eof) and early-returns.
    match cross(false) { Res::Ok(v) => { return -3; } Res::Err(e) => { acc = acc + 100; } }  // +100
    return acc;                                                                              // 186
}
