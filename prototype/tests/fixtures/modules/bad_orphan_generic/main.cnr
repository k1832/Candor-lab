// A generic impl placed in neither `List`'s nor `Weighable`'s module violates the
// orphan rule (design 0007 §2.3): the placement referent is the target head's
// module (`list`) or the interface's declaration module (`shape`).
use shape::{Weighable};
use list::{List};
impl[T] Weighable for List[T] {
    fn weight(read self) -> i64 {
        return self.w;
    }
}
fn main() -> i64 {
    return 0;
}
