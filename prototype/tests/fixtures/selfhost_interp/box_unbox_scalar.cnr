// S5b: box a scalar through a minimal in-arena bump allocator, match the
// `BoxResult`, and read the pointee back with `.*`. Exercises the box build
// sequence (indirect alloc, move-into-pointee, BoxResult::boxed construction),
// a `match` over a real `Box` payload, and the `.*` deref read. The `Box` frees
// itself when the arm returns (alloc-on-drop). SMALL arena window [8192,16384).
struct AllocVtable {
    alloc: fn(rawptr u8, usize, usize) -> rawptr u8,
    free: fn(rawptr u8, rawptr u8, usize, usize) -> unit,
}
copy struct Alloc { ctx: rawptr u8, vt: rawptr AllocVtable }
struct Bump { next: usize, end: usize }

fn bump_alloc(ctx: rawptr u8, size: usize, align: usize) -> rawptr u8 {
    unsafe "ctx points at the live Bump whose [next,end) window is this arena's alone" {
        let b: Bump = ptr_read(cast_ptr[Bump](ctx));
        let aligned: usize = (b.next + align - 1usize) / align * align;
        if aligned + size > b.end {
            return ptr_null[u8]();
        }
        ptr_write(cast_ptr[Bump](ctx), Bump { next: aligned + size, end: b.end });
        return addr_to_ptr[u8](aligned);
    }
}
fn bump_free(ctx: rawptr u8, ptr: rawptr u8, size: usize, align: usize) -> unit { return; }
static BUMP_VT: AllocVtable = AllocVtable { alloc: bump_alloc, free: bump_free };

fn main() alloc -> i64 {
    let mut st: Bump = Bump { next: 8192usize, end: 16384usize };
    unsafe "drive box through the vtable ABI over an arena-internal window" {
        let ctxp: rawptr u8 = cast_ptr[u8](addr_of_mut(st));
        let vtp: rawptr AllocVtable = addr_of(BUMP_VT);
        let al: Alloc = Alloc { ctx: ctxp, vt: vtp };
        let br: BoxResult i64 = box(al, 1234i64);
        match br {
            BoxResult::boxed(bx) => {
                return bx.*;
            },
            BoxResult::oom => {
                return 0 - 1i64;
            },
        }
    }
}
