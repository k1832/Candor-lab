// Cross-type `?` through a `From` impl (0007 §7.1).
enum IoErr { Bad }
enum AppErr { Wrap(IoErr) }
enum IoRes { ok IoOk(i64), IoBad(IoErr) }
enum AppRes { ok AppOk(i64), AppBad(AppErr) }
interface From[E] { fn from(e: E) -> Self; }
impl From[IoErr] for AppErr { fn from(e: IoErr) -> Self { return AppErr::Wrap(e); } }
fn reader(good: bool) -> IoRes { if good { return IoRes::IoOk(55); } return IoRes::IoBad(IoErr::Bad); }
fn app(good: bool) -> AppRes { let x: i64 = reader(good)?; return AppRes::AppOk(x); }
fn main() -> i64 {
    match app(false) {
        AppRes::AppOk(v) => { return v; }
        AppRes::AppBad(e) => { return 7; }
    }
}
