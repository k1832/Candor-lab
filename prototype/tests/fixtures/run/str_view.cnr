// Native str-view family (design 0013 §3/§4): `str_from` (UTF-8 validation → the
// `Utf8Res` enum) and `substr` (char-boundary byte slice → str). This fixture
// drives the validation scan across 1/2/3/4-byte valid sequences and the four
// ill-formed classes (bare continuation, overlong, surrogate, truncated), plus a
// boundary-valid `substr`, tracing each result. Every engine — the tree-walking
// oracle, the MIR interpreter, and the Cranelift / LLVM native backends — must
// agree byte-for-byte on the traced sequence and the folded return, including the
// EXACT `Invalid(offset)` (`str::from_utf8().valid_up_to()`).

// Validate `sl` and fold the outcome to an i64: the byte length on `Valid`, or
// `-1 - offset` on `Invalid` (so a valid run is >= 0 and an ill-formed run is
// <= -1, carrying the first bad-sequence offset).
fn check(sl: [u8]) -> i64 {
    match str_from(sl) {
        Utf8Res::Valid(s) => { return conv i64 len(s); }
        Utf8Res::Invalid(off) => { return 0 - 1 - conv i64 off; }
    }
}

fn main() -> i64 {
    let mut acc: i64 = 0;

    // Valid 1/2/3/4-byte sequences: "hi", "é", "€", "𝄞".
    let a1: [2]u8 = [104u8, 105u8];
    let r1: i64 = check(slice_of(a1)); trace(r1); acc = acc + r1;
    let a2: [2]u8 = [195u8, 169u8];
    let r2: i64 = check(slice_of(a2)); trace(r2); acc = acc + r2;
    let a3: [3]u8 = [226u8, 130u8, 172u8];
    let r3: i64 = check(slice_of(a3)); trace(r3); acc = acc + r3;
    let a4: [4]u8 = [240u8, 157u8, 132u8, 158u8];
    let r4: i64 = check(slice_of(a4)); trace(r4); acc = acc + r4;

    // Ill-formed: bare continuation at 1, overlong-2 at 0, overlong-3 at 0,
    // surrogate at 0, truncated multibyte at 1.
    let a5: [2]u8 = [65u8, 128u8];
    let r5: i64 = check(slice_of(a5)); trace(r5); acc = acc + r5;
    let a6: [2]u8 = [192u8, 128u8];
    let r6: i64 = check(slice_of(a6)); trace(r6); acc = acc + r6;
    let a7: [3]u8 = [224u8, 128u8, 128u8];
    let r7: i64 = check(slice_of(a7)); trace(r7); acc = acc + r7;
    let a8: [3]u8 = [237u8, 160u8, 128u8];
    let r8: i64 = check(slice_of(a8)); trace(r8); acc = acc + r8;
    let a9: [3]u8 = [65u8, 226u8, 130u8];
    let r9: i64 = check(slice_of(a9)); trace(r9); acc = acc + r9;

    // substr on a char boundary: "héllo"[0,3) == "hé" (3 bytes); mid-run [1,3)
    // == "é" (2 bytes). Trace the byte lengths.
    let sub1: str = substr("héllo", 0, 3);
    let l1: i64 = conv i64 len(sub1); trace(l1); acc = acc + l1;
    let sub2: str = substr("héllo", 1, 3);
    let l2: i64 = conv i64 len(sub2); trace(l2); acc = acc + l2;

    return acc;
}
