// `bitcast` corpus fixture (design 0016 §10). Exercises same-width float<->int BIT
// reinterpretation — f64<->i64 and f32<->i32, both directions — in a loop, so every
// engine (tree-walker, MIR, Cranelift no-opt/opt, LLVM) must agree bit-for-bit on
// the traced patterns. Bitcast changes no bits, never faults, and is regime-
// independent, so a round trip is the identity and a specific NaN payload survives
// exactly (unlike a computed NaN — see tests/floats.rs).
//
// The `trace` channel is 64-bit; a 32-bit result is widened via `conv i64 (bitcast
// u32 (..))` so the widening zero-extends (matching an f32's `to_bits()` u32).

fn main() -> i64 {
    // f64 <-> i64 round trips over a spread; each traced back-value equals its input.
    let vs: [4]f64 = [1.5, -8.25, 6.022e23, 0.0];
    let mut i: i64 = 0;
    while i < 4 {
        let x: f64 = vs[conv usize (i)];
        let bits: i64 = bitcast i64 (x);
        let back: f64 = bitcast f64 (bits);
        trace(back);
        i = i + 1;
    }

    // Known encodings: 1.0 -> 0x3FF0000000000000, and 0x4000000000000000 -> 2.0.
    trace(bitcast i64 (1.0));
    let two: f64 = bitcast f64 (0x4000000000000000);
    trace(two);

    // A specific quiet-NaN payload survives a round trip EXACTLY (no arithmetic).
    let n: f64 = bitcast f64 (0x7FF8000000000001);
    trace(bitcast i64 (n));

    // f32 <-> i32: known encoding 1.0f32 -> 0x3F800000, and a round trip back to f32.
    trace(conv i64 (bitcast u32 (1.0f32)));
    let f: f32 = bitcast f32 (0x3F800000);
    trace(f);

    // Sentinel 1: recover 2.0 from its reinterpreted pattern and truncate.
    return conv i64 (two) - 1;
}
