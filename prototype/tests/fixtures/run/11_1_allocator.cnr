struct AllocVtable {
    alloc: fn(ctx: rawptr u8, size: usize, align: usize) alloc -> rawptr u8,
    free: fn(ctx: rawptr u8, ptr: rawptr u8, size: usize, align: usize) alloc -> unit,
}

copy struct Alloc {
    ctx: rawptr u8,
    vt: rawptr AllocVtable,
}

struct Pool {
    head: rawptr u8,
    block_size: usize,
}

fn pool_alloc(ctx: rawptr u8, size: usize, align: usize) -> rawptr u8 {
    unsafe "pool owns [ctx..); head chains free blocks each >= block_size" {
        let p: Pool = ptr_read(cast_ptr[Pool](ctx));
        if is_null(p.head) {
            return ptr_null[u8]();
        }
        let block: rawptr u8 = p.head;
        let next: rawptr u8 = ptr_read(cast_ptr[rawptr u8](block));
        ptr_write(cast_ptr[Pool](ctx), Pool { head: next, block_size: p.block_size });
        return block;
    }
}

fn pool_free(ctx: rawptr u8, ptr: rawptr u8, size: usize, align: usize) -> unit {
    unsafe "push freed block onto head; block is >= pointer-sized" {
        let p: Pool = ptr_read(cast_ptr[Pool](ctx));
        ptr_write(cast_ptr[rawptr u8](ptr), p.head);
        ptr_write(cast_ptr[Pool](ctx), Pool { head: ptr, block_size: p.block_size });
    }
}

static POOL_VTABLE: AllocVtable = AllocVtable { alloc: pool_alloc, free: pool_free };

fn pool_handle(state: write Pool) -> Alloc {
    unsafe "ctx and vt must stay valid for the lifetime of every COPY of this Alloc handle and every Box it serves; the caller guarantees state and POOL_VTABLE outlive them all" {
        return Alloc { ctx: cast_ptr[u8](addr_of_mut(state.*)), vt: addr_of(POOL_VTABLE) };
    }
}

fn main() alloc -> i64 {
    unsafe "set up a free list of two 64-byte blocks in a scratch region" {
        let b0: rawptr u8 = addr_to_ptr[u8](2097152);
        let b1: rawptr u8 = addr_to_ptr[u8](2097216);
        ptr_write(cast_ptr[rawptr u8](b1), ptr_null[u8]());
        ptr_write(cast_ptr[rawptr u8](b0), b1);
        let mut pool: Pool = Pool { head: b0, block_size: 64 };
        let a: Alloc = pool_handle(write pool);
        // MIGRATE: two-arm BoxResult match -> `box(a, v)?` (author-assisted, design 0006 §5)
        match box(read a, 1234) {
            BoxResult::oom => return 0 - 1,
            BoxResult::boxed(bx) => {
                let v: i64 = bx.*;
                return v;
            },
        }
    }
}
