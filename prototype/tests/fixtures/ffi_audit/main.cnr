boundary
extern "C" {
    fn c_len(s: rawptr u8) foreign -> usize
        trust "POSIX 7: reads bytes to a NUL, retains nothing, no thread state" {
            valid_nul_terminated(s),
            no_retain(s),
        };
    fn c_raw(p: rawptr u8) foreign -> usize;
}

pub fn safe_len(s: rawptr u8) -> usize {
    unsafe "c_len trust discharged: s is a live NUL-terminated view" {
        return c_len(s);
    }
}

pub fn thin_raw(p: rawptr u8) foreign -> usize {
    unsafe "re-exported raw: caller must not outlive p" {
        return c_raw(p);
    }
}

pub fn checksum(x: usize) -> u32 { return conv u32 (x); }
export "C" fn candor_checksum(x: usize) -> u32 = checksum;

fn main() -> i64 { return 0; }
