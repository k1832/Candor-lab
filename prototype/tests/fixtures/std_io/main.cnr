boundary
// std::io — a POSIX I/O boundary module over libc (design 0011 boundary + 0013
// bytes/str). The externs carry the C-boundary TRUST (assumed-proven); the pub
// wrappers carry the ENFORCED value contracts and discharge the `foreign`
// effect, so the module's public surface is ordinary safe Candor — audit-clean.
//
// The extern symbols are `sys_*`, not the bare POSIX `read`/`write`, because
// `read`/`write` are Candor keywords (the borrow modes); binding these to the
// real libc `read`/`write` symbols needs a symbol-rename the edition lacks.

extern "C" {
    fn sys_open(path: rawptr u8, flags: i32, mode: i32) foreign -> i32
        trust "POSIX open(2): reads a NUL-terminated path, retains no pointer, thread-confined to this call" {
            valid_nul_terminated(path),
            no_retain(path),
        };
    fn sys_close(fd: i32) foreign -> i32
        trust "POSIX close(2): closes a descriptor; touches no Candor memory" {
        };
    fn sys_read(fd: i32, buf: rawptr u8, count: usize) foreign -> isize
        trust "POSIX read(2): writes at most count bytes into buf, retains no pointer, thread-confined" {
            valid_for(buf, count),
            no_retain(buf),
            thread_confined(buf),
        };
    fn sys_write(fd: i32, buf: rawptr u8, count: usize) foreign -> isize
        trust "POSIX write(2): reads at most count bytes from buf, retains no pointer, thread-confined" {
            valid_for(buf, count),
            no_retain(buf),
            thread_confined(buf),
        };
}

// result-shaped: `Count` is the `ok`-marked variant (design 0006).
pub enum IoResult {
    ok Count(usize),
    Fail(i32),
}

pub fn stdin() -> i32 { return 0i32; }
pub fn stdout() -> i32 { return 1i32; }
pub fn stderr() -> i32 { return 2i32; }

pub fn open_read(path: read [u8]) -> IoResult {
    unsafe "sys_open trust discharged: path is a live NUL-terminated [u8] view; open retains nothing (POSIX)" {
        let fd: i32 = sys_open(addr_of(path[0]), 0i32, 0i32);
        if fd < 0i32 {
            return IoResult::Fail(fd);
        }
        return IoResult::Count(conv usize fd);
    }
}

pub fn close(fd: i32) -> IoResult {
    unsafe "sys_close trust discharged: fd is a descriptor; close touches no Candor memory" {
        let r: i32 = sys_close(fd);
        if r < 0i32 {
            return IoResult::Fail(r);
        }
        return IoResult::Count(0usize);
    }
}

pub fn read_into(fd: i32, buf: write [u8]) -> IoResult {
    unsafe "sys_read trust discharged: buf is a live [u8] view valid for len(buf) bytes; read retains nothing (POSIX), thread-confined" {
        let n: isize = sys_read(fd, addr_of_mut(buf[0]), len(buf));
        if n < 0isize {
            return IoResult::Fail(conv i32 n);
        }
        return IoResult::Count(conv usize n);
    }
}

pub fn write_all(fd: i32, s: read [u8]) -> IoResult {
    let total: usize = len(s);
    if total == 0usize {
        return IoResult::Count(0usize);
    }
    unsafe "sys_write trust discharged: s is a live [u8] view valid for len(s) bytes; write retains nothing (POSIX), thread-confined" {
        let n: isize = sys_write(fd, addr_of(s[0]), total);
        if n < 0isize {
            return IoResult::Fail(conv i32 n);
        }
        if conv usize n < total {
            return IoResult::Fail(0i32 - 1i32);
        }
        return IoResult::Count(total);
    }
}

fn main() -> i64 {
    let name: [10]u8 = [105u8, 110u8, 112u8, 117u8, 116u8, 46u8, 116u8, 120u8, 116u8, 0u8];
    let fd: i32 = match open_read(slice_of(name)) {
        IoResult::Count(c) => conv i32 c,
        IoResult::Fail(e) => { return 0i64 - 1i64; },
    };
    let mut buf: [64]u8 = [0u8; 64];
    let n: usize = match read_into(fd, slice_of_mut(buf)) {
        IoResult::Count(c) => c,
        IoResult::Fail(e) => { return 0i64 - 2i64; },
    };
    let mut i: usize = 0usize;
    loop {
        if i >= n { break; }
        let c: u8 = buf[i];
        if c >= 97u8 && c <= 122u8 {
            buf[i] = c - 32u8;
        }
        i = i + 1usize;
    }
    let w: IoResult = write_all(stdout(), subslice(slice_of(buf), 0usize, n));
    let cr: IoResult = close(fd);
    return conv i64 n;
}
