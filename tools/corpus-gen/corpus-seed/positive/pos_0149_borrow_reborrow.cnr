// shape: borrow_reborrow — write-borrow mutation, then read-borrow observation
struct Acc { total: i64 }
fn bump(a: write Acc, d: i64) -> unit { a.*.total = a.total + d; }
fn peek(a: read Acc) -> i64 { return a.total; }
fn main() -> i64 {
    let mut acc: Acc = Acc { total: 5 };
    bump(write acc, -217);
    bump(write acc, 286);
    return peek(read acc);
}
