// Hidden acceptance battery. Authored against docs/basket/spec-scheduler.md
// §1.4/§3.1-3.2 and vectors T5/T6: strict priority across levels, FIFO within.
fn main() -> i64 {
    let mut s: Sched = Sched { q: [[0u32; 8]; 4], count: [0u32; 4] };
    let a0: bool = admit(write s, 20u32, 0u32);
    let a1: bool = admit(write s, 21u32, 2u32);
    let a2: bool = admit(write s, 22u32, 1u32);
    let a3: bool = admit(write s, 23u32, 0u32);
    assert(a0);
    assert(a1);
    assert(a2);
    assert(a3);
    let p0: i64 = pick_next(write s);
    let p1: i64 = pick_next(write s);
    let p2: i64 = pick_next(write s);
    let p3: i64 = pick_next(write s);
    let p4: i64 = pick_next(write s);
    let e0: bool = p0 == 20i64;
    let e1: bool = p1 == 23i64;
    let e2: bool = p2 == 22i64;
    let e3: bool = p3 == 21i64;
    let e4: bool = p4 == 0i64 - 1i64;
    assert(e0);
    assert(e1);
    assert(e2);
    assert(e3);
    assert(e4);
    return 0;
}
