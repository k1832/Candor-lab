// The 60-second hello. `trace(v)` records values in order; the return value is
// the program's i64 result.
//   candor run 01_hello.cnr        -> prints 42 (the return value)
//   candor compile 01_hello.cnr -o hello && ./hello   -> prints the trace, then
//                                                          exits with status 42
fn main() -> i64 {
    trace(1);
    trace(2);
    trace(3);
    return 42;
}
