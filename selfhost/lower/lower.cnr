// The FIRST Candor lowering (L1): a Candor program that lowers scalar + control-flow
// Candor to MIR and EMITS the L0 wire format (src/mir/serial.rs) so the Rust
// deserializer accepts it and the precise MIR interpreter runs it. Gated
// EXECUTIONALLY against the tree-walking oracle in tests/selfhost_lower.rs.
//
// This is the MVP proving Candor can emit a control-flow graph. It ports the
// scalar subset of the Rust reference lowering (src/mir/build.rs): integer/bool
// scalars; let/assign; if/else; while; loop + break/continue; return; arithmetic
// (+ - * / %) with the Checked/Wrapping/Saturating regimes and the Overflow/
// DivByZero fault edges; comparisons; && / || (short-circuit -> branch blocks);
// bitwise/shift; unary neg/not; trace(x); assert/panic (fault edges); direct
// non-generic fn calls with scalar params + return; conv (with the ConvLoss edge).
// Structs/arrays/enums/box/pointers/drop are OUT of subset (L2+).
//
// STRUCTURE: an IR-builder in flat arrays (locals, basic blocks) plus a byte POOL
// holding each statement's and terminator's already-rendered wire text as a chunk
// (blocks link their statement chunks intrusively; a block is built out of creation
// order via switch_to, so the text is buffered and assembled in block-id order at
// emit time). CFG flattening mirrors build.rs's lower_if/lower_while/lower_loop and
// a loop stack of (continue_bb, break_bb). Scalar width inference mirrors build.rs's
// int_type/concretize. Fault edges carry the operator span (T_BIN/T_CONV/T_PANIC
// node span, or the threaded cur_span for neg/assert) exactly as the oracle.
//
// This module is composed with the `lexer` and `parser` modules (use decls below).
// It is NOT self-checked in this slice, so it uses the full language.

use lexer::{Buf, span_eq, emit_num, emit_sp, emit_nl, emit_bytes, decoded_len};
use parser::{Node, P, nnew, parse_program, emit_lit, T_FN, T_PARAM, T_SC, T_NAMED, T_LET, T_ASSIGN, T_INT, T_NEGINT, T_BOOL, T_ID, T_UNARY, T_BIN, T_CALL, T_BLOCK, T_IF, T_LOOP, T_WHILE, T_RETURN, T_BREAK, T_CONTINUE, T_ASSERT, T_PANIC, T_PAREN, T_CONV, T_UNSAFE, T_WRAPPING, T_SATURATING, T_STRUCT, T_ARRAY, T_FIELD, T_INDEX, T_ARRAYLIT, T_ARRAYREP, T_STRUCTLIT, T_STR, T_BYTES, OP_ADD, OP_SUB, OP_MUL, OP_DIV, OP_REM, OP_EQ, OP_NE, OP_LT, OP_LE, OP_GT, OP_GE, OP_AND, OP_OR, OP_BITAND, OP_BITOR, OP_BITXOR, OP_SHL, OP_SHR, UN_NEG, UN_NOT, UN_BITNOT, T_ENUM, T_ENUMCTOR, T_MATCH, T_PVARIANT, T_WILD, T_BIND, T_VARIANT, T_ARM, T_NAME, T_STATIC, T_RAWPTR, T_BOX, T_BOXRESULT, T_FNPTR, T_FPPARAM, T_OFFSETOF, T_CASTPTR, T_ADDRTOPTR, T_PTRNULL, T_PREFIX, PF_DEREF, PF_READ, PF_WRITE, T_BORROW, T_BORROWMUT, T_SLICE, T_SLICEMUT, T_APP, T_GENERICVAL, T_IMPL, T_TRY};
use mono::{mono_program};
use layout::{ty_size, ty_align, field_off, field_ty, variant_by_index, variant_index_by_name, variant_payload_off, variant_payload_ty, struct_of_ty, enum_of_ty, is_copy, needs_drop, is_vec_ty, is_map_ty, is_string_ty, coll_elem_ty, array_len_of};

// ---- fault kind codes (the wire keyword table in serial.rs) -----------------
static FK_OVERFLOW: i32 = 0;
static FK_DIVZERO: i32 = 1;
static FK_ASSERT: i32 = 2;
static FK_PANIC: i32 = 3;
static FK_BOUNDS: i32 = 4;
static FK_CONVLOSS: i32 = 5;
static W_BOOL: i32 = 11;

// ---- builder state ----------------------------------------------------------
struct M {
    head: u32,
    loc_w: [512]i32,
    loc_named: [512]i32,
    loc_p0: [512]usize,
    loc_p1: [512]usize,
    loc_n: usize,
    blk_shead: [512]i32,
    blk_stail: [512]i32,
    blk_tstart: [512]usize,
    blk_tlen: [512]usize,
    blk_n: usize,
    pool: [1048576]u8,
    pool_n: usize,
    pn_start: [8192]usize,
    pn_len: [8192]usize,
    pn_nx: [8192]i32,
    pn_n: usize,
    bnd_p0: [512]usize,
    bnd_p1: [512]usize,
    bnd_local: [512]i32,
    bnd_w: [512]i32,
    bnd_n: usize,
    loop_cont: [64]i32,
    loop_brk: [64]i32,
    loop_n: usize,
    fp_p0: [256]usize,
    fp_p1: [256]usize,
    fp_n: usize,
    cur: i32,
    reachable: i32,
    regime: i32,
    ret_w: i32,
    fn_entry: i32,
    fn_np: i32,
    cur_p0: usize,
    cur_p1: usize,
    res_kind: i32,
    res_val: u64,
    res_neg: i32,
    res_w: i32,
    res_pointee: u32,
    res_israw: i32,
    plc_local: i32,
    plc_borrow: i32,
    plc_w: i32,
    luk_w: i32,
    o1k: i32,
    o1v: u64,
    o1n: i32,
    o1w: i32,
    o2k: i32,
    o2v: u64,
    o2n: i32,
    o2w: i32,
    loc_tn: [512]u32,
    loc_ptr: [512]i32,
    loc_box: [512]i32,
    bnd_tn: [512]u32,
    bnd_box: [512]i32,
    dbuf: [4096]u8,
    dbuf_n: usize,
    ret_tn: u32,
    plc_tn: u32,
    plc_box: i32,
    plc_base_kind: i32,
    plc_root_tmp: i32,
    plc_base_tn: u32,
    luk_tn: u32,
    luk_box: i32,
    str_tn: u32,
    mat_scrut: [64]u32,
    mat_tn: [64]u32,
    mat_hold: [64]i32,
    mat_n: usize,
    vscrut_on: i32,
    vscrut_node: u32,
    vscrut_root: i32,
    vscrut_tn: u32,
    vscrut_borrow: i32,
    idx_key: [32]u32,
    idx_vk: [32]i32,
    idx_vv: [32]u64,
    idx_vn: [32]i32,
    idx_vw: [32]i32,
    idx_cnt: usize,
    bret_fn: [64]u32,
    bret_tn: [64]u32,
    bret_n: usize,
    ak: [16]i32,
    av: [16]u64,
    an: [16]i32,
    aw: [16]i32,
    na: usize,
    sco_local: [1024]i32,
    sco_n: usize,
    sco_mark: [128]usize,
    sco_depth: usize,
    loop_depth: [64]usize,
    mv_local: [512]i32,
    mv_seg_start: [512]usize,
    mv_seg_count: [512]usize,
    mv_n: usize,
    mv_seg_p0: [1024]usize,
    mv_seg_p1: [1024]usize,
    mv_seg_syn: [1024]i32,
    mv_seg_n: usize,
    self_p0: usize,
    self_p1: usize,
    disp_sid: [256]u32,
    disp_p0: [256]usize,
    disp_p1: [256]usize,
    disp_fn: [256]u32,
    disp_impl: [256]u32,
    disp_n: usize,
    err: i32,
}

// ---- scalar-type name -> width code (mirrors interp.cnr / build.rs) ---------
fn sc_width(src: [u8], s: usize, en: usize) -> i32 {
    if span_eq(src, s, en, b"i8") { return 1; }
    if span_eq(src, s, en, b"i16") { return 2; }
    if span_eq(src, s, en, b"i32") { return 3; }
    if span_eq(src, s, en, b"i64") { return 4; }
    if span_eq(src, s, en, b"isize") { return 5; }
    if span_eq(src, s, en, b"u8") { return 6; }
    if span_eq(src, s, en, b"u16") { return 7; }
    if span_eq(src, s, en, b"u32") { return 8; }
    if span_eq(src, s, en, b"u64") { return 9; }
    if span_eq(src, s, en, b"usize") { return 10; }
    if span_eq(src, s, en, b"bool") { return W_BOOL; }
    if span_eq(src, s, en, b"unit") { return 12; }
    return 0;
}
fn scalar_width(pp: read P, src: [u8], tn: u32) -> i32 {
    if tn == 0u32 { return 0; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_NAMED || nd.tag == T_SC { return sc_width(src, nd.p0, nd.p1); }
    return 0;
}
// int_type / concretize (build.rs): a literal's width is its suffix, else the
// integer `expected` width, else i64 (code 4).
fn lit_width(suf: i32, exp_w: i32) -> i32 {
    if suf != 0 { return suf; }
    if exp_w >= 1 && exp_w <= 10 { return exp_w; }
    return 4;
}
fn concretize(w: i32) -> i32 {
    if w >= 1 && w <= 10 { return w; }
    if w == W_BOOL { return W_BOOL; }
    return 4;
}
fn name_eq(src: [u8], a0: usize, a1: usize, b0: usize, b1: usize) -> bool {
    if a1 - a0 != b1 - b0 { return false; }
    let n: usize = a1 - a0;
    let mut i: usize = 0usize;
    while i < n {
        if src[a0 + i] != src[b0 + i] { return false; }
        i = i + 1usize;
    }
    return true;
}

// ---- layout table (ported from interp.cnr / src/mir/layout.rs) ---------------
// Declared-order fields at natural alignment; struct size rounded to max field
// alignment; array stride = round_up(elem_size, elem_align). Pure over the arena
// AST + `head` (the item list), mirroring interp.cnr's ty_size/ty_align/field_off.
fn w_size(w: i32) -> usize {
    if w == 12 { return 0usize; }
    if w == 1 || w == 6 || w == W_BOOL { return 1usize; }
    if w == 2 || w == 7 { return 2usize; }
    if w == 3 || w == 8 { return 4usize; }
    return 8usize;
}
fn round_up_us(x: usize, a: usize) -> usize {
    if a <= 1usize { return x; }
    return ((x + a - 1usize) / a) * a;
}
fn stride_of(pp: read P, src: [u8], head: u32, elem: u32) -> usize {
    return round_up_us(ty_size(pp, src, head, elem), ty_align(pp, src, head, elem));
}


// A word-sized (8-byte, single-operand) type: scalar/bool, rawptr, fnptr, borrow.
fn is_wordy_tn(pp: read P, src: [u8], tn: u32) -> bool {
    if scalar_width(pp, src, tn) != 0 { return true; }
    if tn == 0u32 { return false; }
    let nd: Node = pp.nodes[conv usize tn];
    return nd.tag == T_RAWPTR || nd.tag == T_FNPTR || nd.tag == T_BORROW || nd.tag == T_BORROWMUT;
}
// The fn-pointer id (design 0007 §6.2) of a top-level fn name, or -1. Ids are
// assigned in program order over every callable: struct drop hooks, static inits,
// and fns (build.rs `reg`), so a fn value / vtable slot is a stable index.
fn fn_ptr_id_of(pp: read P, src: [u8], head: u32, p0: usize, p1: usize) -> i32 {
    let mut cur: u32 = head;
    let mut k: i32 = 0;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_STRUCT {
            if nd.c != 0u32 && nd.a == 0u32 { k = k + 1i32; }
        } else if nd.tag == T_STATIC {
            k = k + 1i32;
        } else if nd.tag == T_FN {
            if nd.a == 0u32 {
                if name_eq(src, p0, p1, nd.p0, nd.p1) { return k; }
                k = k + 1i32;
            }
        }
        cur = nd.nx;
    }
    return 0 - 1i32;
}
// The fn-pointer id of a specific fn NODE (a monomorphized instance named as a
// value via `name::[T]`); counting mirrors `fn_ptr_id_of`.
fn fn_ptr_id_of_node(pp: read P, head: u32, target: u32) -> i32 {
    let mut cur: u32 = head;
    let mut k: i32 = 0;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_STRUCT {
            if nd.c != 0u32 && nd.a == 0u32 { if cur == target { return k; } k = k + 1i32; }
        } else if nd.tag == T_STATIC {
            if cur == target { return k; }
            k = k + 1i32;
        } else if nd.tag == T_FN {
            if nd.a == 0u32 { if cur == target { return k; } k = k + 1i32; }
        }
        cur = nd.nx;
    }
    return 0 - 1i32;
}

// ---- pool primitives (statement / terminator wire text) ---------------------
fn pool_byte(m: write M, x: i32) -> unit {
    m.*.pool[m.pool_n] = conv u8 x;
    m.*.pool_n = m.pool_n + 1usize;
    return;
}
fn pool_lit(m: write M, s: [u8]) -> unit {
    let mut i: usize = 0usize;
    while i < len(s) {
        pool_byte(m, conv i32 s[i]);
        i = i + 1usize;
    }
    return;
}
fn pool_num(m: write M, v: u64) -> unit {
    if v == 0u64 { pool_byte(m, 48); return; }
    let mut b: [24]u8 = [0u8; 24];
    let mut cnt: usize = 0usize;
    let mut x: u64 = v;
    while x > 0u64 {
        b[cnt] = conv u8 (48u64 + x % 10u64);
        x = x / 10u64;
        cnt = cnt + 1usize;
    }
    let mut i: usize = cnt;
    while i > 0usize {
        i = i - 1usize;
        pool_byte(m, conv i32 b[i]);
    }
    return;
}
fn pool_qspan(m: write M, src: [u8], p0: usize, p1: usize) -> unit {
    pool_byte(m, 34);
    let mut i: usize = p0;
    while i < p1 {
        pool_byte(m, conv i32 src[i]);
        i = i + 1usize;
    }
    pool_byte(m, 34);
    return;
}
// ---- monomorphized instance names (mirror src/generics.rs inst_fn_name/mangle_ty).
// A generic decl's instance carries its concrete type-arg tuple as a cons chain
// in `ival` (set by the monomorphizer); a monomorphic decl has ival == 0 and thus
// keeps its bare name. The name is `base` then `$<mangle>` per type arg.
fn pool_inst_name(m: write M, pp: read P, src: [u8], id: u32) -> unit {
    let nd: Node = pp.nodes[conv usize id];
    let mut i: usize = nd.p0;
    while i < nd.p1 { pool_byte(m, conv i32 src[i]); i = i + 1usize; }
    let mut cur: u32 = conv u32 nd.ival;
    while cur != 0u32 {
        let cell: Node = pp.nodes[conv usize cur];
        pool_byte(m, 36);
        pool_mangle_ty(m, pp, src, cell.a);
        cur = cell.nx;
    }
    return;
}
fn pool_mangle_ty(m: write M, pp: read P, src: [u8], tn: u32) -> unit {
    let w: i32 = scalar_width(pp, src, tn);
    if w != 0 { pool_scalar(m, w); return; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_APP && nd.b != 0u32 { pool_inst_name(m, pp, src, nd.b); return; }
    let mut i: usize = nd.p0;
    while i < nd.p1 { pool_byte(m, conv i32 src[i]); i = i + 1usize; }
    return;
}
fn pool_qname(m: write M, pp: read P, src: [u8], id: u32) -> unit {
    pool_byte(m, 34);
    pool_inst_name(m, pp, src, id);
    pool_byte(m, 34);
    return;
}
fn pool_scalar(m: write M, w: i32) -> unit {
    if w == 1 { pool_lit(m, b"i8"); return; }
    if w == 2 { pool_lit(m, b"i16"); return; }
    if w == 3 { pool_lit(m, b"i32"); return; }
    if w == 4 { pool_lit(m, b"i64"); return; }
    if w == 5 { pool_lit(m, b"isize"); return; }
    if w == 6 { pool_lit(m, b"u8"); return; }
    if w == 7 { pool_lit(m, b"u16"); return; }
    if w == 8 { pool_lit(m, b"u32"); return; }
    if w == 9 { pool_lit(m, b"u64"); return; }
    if w == 10 { pool_lit(m, b"usize"); return; }
    if w == W_BOOL { pool_lit(m, b"bool"); return; }
    if w == 12 { pool_lit(m, b"unit"); return; }
    pool_lit(m, b"unit");
    return;
}
fn pool_binop(m: write M, op: i32) -> unit {
    if op == OP_ADD { pool_lit(m, b"add"); return; }
    if op == OP_SUB { pool_lit(m, b"sub"); return; }
    if op == OP_MUL { pool_lit(m, b"mul"); return; }
    if op == OP_DIV { pool_lit(m, b"div"); return; }
    if op == OP_REM { pool_lit(m, b"rem"); return; }
    if op == OP_EQ { pool_lit(m, b"eq"); return; }
    if op == OP_NE { pool_lit(m, b"ne"); return; }
    if op == OP_LT { pool_lit(m, b"lt"); return; }
    if op == OP_LE { pool_lit(m, b"le"); return; }
    if op == OP_GT { pool_lit(m, b"gt"); return; }
    if op == OP_GE { pool_lit(m, b"ge"); return; }
    if op == OP_AND { pool_lit(m, b"and"); return; }
    if op == OP_OR { pool_lit(m, b"or"); return; }
    if op == OP_BITAND { pool_lit(m, b"bitand"); return; }
    if op == OP_BITOR { pool_lit(m, b"bitor"); return; }
    if op == OP_BITXOR { pool_lit(m, b"bitxor"); return; }
    if op == OP_SHL { pool_lit(m, b"shl"); return; }
    pool_lit(m, b"shr");
    return;
}
fn pool_unop(m: write M, op: i32) -> unit {
    if op == UN_NEG { pool_lit(m, b"neg"); return; }
    if op == UN_NOT { pool_lit(m, b"not"); return; }
    pool_lit(m, b"bitnot");
    return;
}
fn pool_regime(m: write M, r: i32) -> unit {
    if r == 0 { pool_lit(m, b"checked"); return; }
    if r == 1 { pool_lit(m, b"wrapping"); return; }
    pool_lit(m, b"saturating");
    return;
}
fn pool_fault_kw(m: write M, k: i32) -> unit {
    if k == FK_OVERFLOW { pool_lit(m, b"overflow"); return; }
    if k == FK_DIVZERO { pool_lit(m, b"divzero"); return; }
    if k == FK_BOUNDS { pool_lit(m, b"bounds"); return; }
    if k == FK_CONVLOSS { pool_lit(m, b"convloss"); return; }
    if k == FK_ASSERT { pool_lit(m, b"assert"); return; }
    pool_lit(m, b"panic");
    return;
}
fn pool_operand(m: write M, k: i32, v: u64, ng: i32, w: i32) -> unit {
    if k == 1 {
        pool_lit(m, b"(oplocal ");
        pool_num(m, v);
        pool_byte(m, 41);
        return;
    }
    pool_lit(m, b"(const ");
    if ng != 0 { pool_byte(m, 45); }
    pool_num(m, v);
    pool_byte(m, 32);
    pool_scalar(m, w);
    pool_byte(m, 41);
    return;
}

// Emit a Type s-expression (serial.rs ty_to) into the pool, over an arena type
// node: scalars -> (scalar w); T_ARRAY -> (array <elem> (litlen N)); a struct name
// -> (named "Name"). Mirrors interp.cnr's layout view of type descriptors.
fn pool_ty(m: write M, pp: read P, src: [u8], tn: u32) -> unit {
    let w: i32 = scalar_width(pp, src, tn);
    if w != 0 {
        pool_lit(m, b"(scalar ");
        pool_scalar(m, w);
        pool_byte(m, 41);
        return;
    }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_ARRAY {
        pool_lit(m, b"(array ");
        pool_ty(m, pp, src, nd.b);
        pool_lit(m, b" (litlen ");
        pool_num(m, conv u64 array_len_of(pp, nd.a));
        pool_lit(m, b"))");
        return;
    }
    if nd.tag == T_RAWPTR { pool_lit(m, b"(rawptr "); pool_ty(m, pp, src, nd.a); pool_byte(m, 41); return; }
    if nd.tag == T_BOX { pool_lit(m, b"(box "); pool_ty(m, pp, src, nd.a); pool_byte(m, 41); return; }
    if nd.tag == T_BOXRESULT { pool_lit(m, b"(boxresult "); pool_ty(m, pp, src, nd.a); pool_byte(m, 41); return; }
    if nd.tag == T_BORROW { pool_lit(m, b"(borrow "); pool_ty(m, pp, src, nd.a); pool_byte(m, 41); return; }
    if nd.tag == T_BORROWMUT { pool_lit(m, b"(borrowmut "); pool_ty(m, pp, src, nd.a); pool_byte(m, 41); return; }
    if nd.tag == T_SLICE { pool_lit(m, b"(slice "); pool_ty(m, pp, src, nd.a); pool_byte(m, 41); return; }
    if nd.tag == T_SLICEMUT { pool_lit(m, b"(slicemut "); pool_ty(m, pp, src, nd.a); pool_byte(m, 41); return; }
    if nd.tag == T_FNPTR { pool_fnptr(m, pp, src, tn); return; }
    if tn_is_str_ty(pp, src, tn) { pool_lit(m, b"(str)"); return; }
    if nd.tag == T_APP && nd.b == 0u32 {
        pool_lit(m, b"(app ");
        pool_qspan(m, src, nd.p0, nd.p1);
        pool_byte(m, 32);
        pool_ty(m, pp, src, nd.a);
        pool_byte(m, 41);
        return;
    }
    if nd.tag == T_APP && nd.b != 0u32 {
        pool_lit(m, b"(named ");
        pool_qname(m, pp, src, nd.b);
        pool_byte(m, 41);
        return;
    }
    pool_lit(m, b"(named ");
    pool_qspan(m, src, nd.p0, nd.p1);
    pool_byte(m, 41);
    return;
}
fn pool_parammode(m: write M, mode: i32) -> unit {
    if mode == 1 { pool_lit(m, b"read"); return; }
    if mode == 2 { pool_lit(m, b"write"); return; }
    if mode == 3 { pool_lit(m, b"out"); return; }
    pool_lit(m, b"take");
    return;
}
fn pool_fnptr(m: write M, pp: read P, src: [u8], tn: u32) -> unit {
    let nd: Node = pp.nodes[conv usize tn];
    pool_lit(m, b"(fnptr ");
    if (nd.op / 1) % 2 != 0 { pool_lit(m, b"true "); } else { pool_lit(m, b"false "); }
    if (nd.op / 2) % 2 != 0 { pool_lit(m, b"true "); } else { pool_lit(m, b"false "); }
    pool_ty(m, pp, src, nd.b);
    pool_lit(m, b" (params (");
    let mut fp: u32 = nd.a;
    let mut first: i32 = 1;
    while fp != 0u32 {
        let fpn: Node = pp.nodes[conv usize fp];
        if first == 0 { pool_byte(m, 32); }
        pool_byte(m, 40);
        pool_parammode(m, fpn.op);
        pool_byte(m, 32);
        pool_ty(m, pp, src, fpn.a);
        pool_byte(m, 41);
        first = 0;
        fp = fpn.nx;
    }
    pool_lit(m, b")))");
    return;
}
// Render `(box <inner>)` wrapping a pointee node (the synthetic Box payload type).
fn pool_ty_boxwrap(m: write M, pp: read P, src: [u8], inner: u32) -> unit {
    pool_lit(m, b"(box ");
    pool_ty(m, pp, src, inner);
    pool_byte(m, 41);
    return;
}

// ---- destination-place buffer (dbuf) -----------------------------------------
// A place is `(place <root> (proj <entries>))`. Destination places (let/return/
// assign targets and each aggregate sub-field) are built into `dbuf` as the inner
// proj-entry text, so they survive the value lowering that follows (which renders
// its own READ places directly to the pool). Fills push/truncate `dbuf_n` as they
// descend field/element paths. `reloc_to_dbuf` reuses the pool primitives as a
// scratch, then relocates the rendered bytes into `dbuf` and rewinds the pool.
fn reloc_to_dbuf(m: write M, start: usize) -> unit {
    let mut j: usize = start;
    while j < m.pool_n {
        m.*.dbuf[m.dbuf_n] = m.pool[j];
        m.*.dbuf_n = m.dbuf_n + 1usize;
        j = j + 1usize;
    }
    m.*.pool_n = start;
    return;
}
fn dbuf_field(m: write M, pp: read P, src: [u8], off: usize, fty: u32) -> unit {
    let s: usize = m.pool_n;
    pool_lit(m, b" (field ");
    pool_num(m, conv u64 off);
    pool_byte(m, 32);
    pool_ty(m, pp, src, fty);
    pool_byte(m, 41);
    reloc_to_dbuf(m, s);
    return;
}
fn dbuf_field_boxwrap(m: write M, pp: read P, src: [u8], off: usize, inner: u32) -> unit {
    let s: usize = m.pool_n;
    pool_lit(m, b" (field ");
    pool_num(m, conv u64 off);
    pool_byte(m, 32);
    pool_ty_boxwrap(m, pp, src, inner);
    pool_byte(m, 41);
    reloc_to_dbuf(m, s);
    return;
}
fn dbuf_index_const(m: write M, ix: usize, stride: usize, ln: usize, sp0: usize, sp1: usize) -> unit {
    let s: usize = m.pool_n;
    pool_lit(m, b" (index (const ");
    pool_num(m, conv u64 ix);
    pool_lit(m, b" usize) ");
    pool_num(m, conv u64 stride);
    pool_byte(m, 32);
    pool_num(m, conv u64 ln);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    reloc_to_dbuf(m, s);
    return;
}
fn place_from_dbuf(m: write M, root: i32) -> unit {
    pool_lit(m, b"(place ");
    pool_num(m, conv u64 root);
    pool_lit(m, b" (proj");
    let mut j: usize = 0usize;
    while j < m.dbuf_n {
        pool_byte(m, conv i32 m.dbuf[j]);
        j = j + 1usize;
    }
    pool_lit(m, b"))");
    return;
}

// ---- IR-builder core --------------------------------------------------------
fn new_local(m: write M, w: i32, named: i32, p0: usize, p1: usize) -> i32 {
    let id: i32 = conv i32 m.loc_n;
    let k: usize = m.loc_n;
    m.*.loc_w[k] = w;
    m.*.loc_named[k] = named;
    m.*.loc_p0[k] = p0;
    m.*.loc_p1[k] = p1;
    m.*.loc_tn[k] = 0u32;
    m.*.loc_ptr[k] = 0;
    m.*.loc_box[k] = 0;
    m.*.loc_n = m.loc_n + 1usize;
    return id;
}
// An aggregate local: its type is the arena type node `tn` (emitted verbatim).
fn new_local_tn(m: write M, tn: u32, named: i32, p0: usize, p1: usize) -> i32 {
    let id: i32 = conv i32 m.loc_n;
    let k: usize = m.loc_n;
    m.*.loc_w[k] = 0;
    m.*.loc_named[k] = named;
    m.*.loc_p0[k] = p0;
    m.*.loc_p1[k] = p1;
    m.*.loc_tn[k] = tn;
    m.*.loc_ptr[k] = 0;
    m.*.loc_box[k] = 0;
    m.*.loc_n = m.loc_n + 1usize;
    return id;
}
// A caller-owned return-slot / by-value-argument pointer: `(rawptr <tn>)`.
fn new_local_ptr(m: write M, tn: u32, named: i32, p0: usize, p1: usize) -> i32 {
    let id: i32 = conv i32 m.loc_n;
    let k: usize = m.loc_n;
    m.*.loc_w[k] = 0;
    m.*.loc_named[k] = named;
    m.*.loc_p0[k] = p0;
    m.*.loc_p1[k] = p1;
    m.*.loc_tn[k] = tn;
    m.*.loc_ptr[k] = 1;
    m.*.loc_box[k] = 0;
    m.*.loc_n = m.loc_n + 1usize;
    return id;
}
// A borrow (`write self`) local: a word-sized pointer to `tn`, drop-inert.
fn new_local_borrow(m: write M, tn: u32, named: i32, p0: usize, p1: usize) -> i32 {
    let id: i32 = conv i32 m.loc_n;
    let k: usize = m.loc_n;
    m.*.loc_w[k] = 0;
    m.*.loc_named[k] = named;
    m.*.loc_p0[k] = p0;
    m.*.loc_p1[k] = p1;
    m.*.loc_tn[k] = tn;
    m.*.loc_ptr[k] = 2;
    m.*.loc_box[k] = 0;
    m.*.loc_n = m.loc_n + 1usize;
    return id;
}
// A shared borrow (`read x`) local: word-sized pointer to `tn`, drop-inert.
fn new_local_borrow_sh(m: write M, tn: u32, named: i32, p0: usize, p1: usize) -> i32 {
    let id: i32 = conv i32 m.loc_n;
    let k: usize = m.loc_n;
    m.*.loc_w[k] = 0;
    m.*.loc_named[k] = named;
    m.*.loc_p0[k] = p0;
    m.*.loc_p1[k] = p1;
    m.*.loc_tn[k] = tn;
    m.*.loc_ptr[k] = 3;
    m.*.loc_box[k] = 0;
    m.*.loc_n = m.loc_n + 1usize;
    return id;
}
// A Box local: 24-byte owned handle whose pointee type is the node `tn`.
fn new_local_box(m: write M, tn: u32, named: i32, p0: usize, p1: usize) -> i32 {
    let id: i32 = conv i32 m.loc_n;
    let k: usize = m.loc_n;
    m.*.loc_w[k] = 0;
    m.*.loc_named[k] = named;
    m.*.loc_p0[k] = p0;
    m.*.loc_p1[k] = p1;
    m.*.loc_tn[k] = tn;
    m.*.loc_ptr[k] = 0;
    m.*.loc_box[k] = 1;
    m.*.loc_n = m.loc_n + 1usize;
    return id;
}
fn new_block(m: write M) -> i32 {
    let id: i32 = conv i32 m.blk_n;
    let b: usize = m.blk_n;
    m.*.blk_shead[b] = 0 - 1i32;
    m.*.blk_stail[b] = 0 - 1i32;
    // default terminator: (return)
    let ts: usize = m.pool_n;
    pool_lit(m, b"(return)");
    m.*.blk_tstart[b] = ts;
    m.*.blk_tlen[b] = m.pool_n - ts;
    m.*.blk_n = m.blk_n + 1usize;
    return id;
}
fn switch_to(m: write M, b: i32) -> unit {
    m.*.cur = b;
    m.*.reachable = 1;
    return;
}
// Link the pool chunk [start, pool_n) as a statement of the current block.
fn chunk_end(m: write M, start: usize) -> unit {
    let k: usize = m.pn_n;
    m.*.pn_start[k] = start;
    m.*.pn_len[k] = m.pool_n - start;
    m.*.pn_nx[k] = 0 - 1i32;
    m.*.pn_n = m.pn_n + 1usize;
    let b: usize = conv usize m.cur;
    if m.blk_shead[b] < 0 {
        m.*.blk_shead[b] = conv i32 k;
    } else {
        m.*.pn_nx[conv usize m.blk_stail[b]] = conv i32 k;
    }
    m.*.blk_stail[b] = conv i32 k;
    return;
}

// ---- terminators (build.rs terminate: no-op when unreachable) ---------------
fn term_goto(m: write M, target: i32) -> unit {
    if m.reachable == 0 { return; }
    let b: usize = conv usize m.cur;
    let ts: usize = m.pool_n;
    pool_lit(m, b"(goto ");
    pool_num(m, conv u64 target);
    pool_byte(m, 41);
    m.*.blk_tstart[b] = ts;
    m.*.blk_tlen[b] = m.pool_n - ts;
    m.*.reachable = 0;
    return;
}
fn term_branch(m: write M, then_bb: i32, else_bb: i32) -> unit {
    if m.reachable == 0 { return; }
    let b: usize = conv usize m.cur;
    let ts: usize = m.pool_n;
    pool_lit(m, b"(branch ");
    pool_operand(m, m.o1k, m.o1v, m.o1n, m.o1w);
    pool_byte(m, 32);
    pool_num(m, conv u64 then_bb);
    pool_byte(m, 32);
    pool_num(m, conv u64 else_bb);
    pool_byte(m, 41);
    m.*.blk_tstart[b] = ts;
    m.*.blk_tlen[b] = m.pool_n - ts;
    m.*.reachable = 0;
    return;
}
fn term_return(m: write M) -> unit {
    if m.reachable == 0 { return; }
    let b: usize = conv usize m.cur;
    let ts: usize = m.pool_n;
    pool_lit(m, b"(return)");
    m.*.blk_tstart[b] = ts;
    m.*.blk_tlen[b] = m.pool_n - ts;
    m.*.reachable = 0;
    return;
}
fn term_fault(m: write M, kind: i32, p0: usize, p1: usize) -> unit {
    if m.reachable == 0 { return; }
    let b: usize = conv usize m.cur;
    let ts: usize = m.pool_n;
    pool_lit(m, b"(faultterm (fedge ");
    pool_fault_kw(m, kind);
    pool_byte(m, 32);
    pool_num(m, conv u64 p0);
    pool_byte(m, 32);
    pool_num(m, conv u64 p1);
    pool_lit(m, b"))");
    m.*.blk_tstart[b] = ts;
    m.*.blk_tlen[b] = m.pool_n - ts;
    m.*.reachable = 0;
    return;
}

// ---- operand slots + res helpers --------------------------------------------
fn set_res_local(m: write M, id: i32, w: i32) -> unit {
    m.*.res_kind = 1;
    m.*.res_val = conv u64 id;
    m.*.res_neg = 0;
    m.*.res_w = w;
    m.*.res_pointee = 0u32;
    m.*.res_israw = 0;
    return;
}
fn set_res_const(m: write M, v: u64, ng: i32, w: i32) -> unit {
    m.*.res_kind = 0;
    m.*.res_val = v;
    m.*.res_neg = ng;
    m.*.res_w = w;
    m.*.res_pointee = 0u32;
    m.*.res_israw = 0;
    return;
}
// Record pointer info for the last value: its pointee node + whether it is a rawptr
// (rawptr ptr_read/ptr_write are observable). Called after a pointer-valued result.
fn set_res_ptr(m: write M, pp: read P, tn: u32) -> unit {
    m.*.res_pointee = 0u32;
    m.*.res_israw = 0;
    if tn == 0u32 { return; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_RAWPTR { m.*.res_pointee = nd.a; m.*.res_israw = 1; return; }
    if nd.tag == T_BOX || nd.tag == T_BORROW || nd.tag == T_BORROWMUT { m.*.res_pointee = nd.a; return; }
    return;
}
fn set_o1(m: write M, k: i32, v: u64, ng: i32, w: i32) -> unit {
    m.*.o1k = k; m.*.o1v = v; m.*.o1n = ng; m.*.o1w = w;
    return;
}
fn set_o2(m: write M, k: i32, v: u64, ng: i32, w: i32) -> unit {
    m.*.o2k = k; m.*.o2v = v; m.*.o2n = ng; m.*.o2w = w;
    return;
}

// ---- statement emitters (append a pool chunk to the current block) ----------
// Each is a no-op when unreachable (build.rs emit).
fn st_store_use(m: write M, dst: i32, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (store (place ");
    pool_num(m, conv u64 dst);
    pool_lit(m, b" (proj)) (use ");
    pool_operand(m, m.o1k, m.o1v, m.o1n, m.o1w);
    pool_lit(m, b")) ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    chunk_end(m, s);
    return;
}
fn st_assign_use(m: write M, dst: i32, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (assign ");
    pool_num(m, conv u64 dst);
    pool_lit(m, b" (use ");
    pool_operand(m, m.o1k, m.o1v, m.o1n, m.o1w);
    pool_lit(m, b")) ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    chunk_end(m, s);
    return;
}
fn st_trace(m: write M, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (trace ");
    pool_operand(m, m.o1k, m.o1v, m.o1n, m.o1w);
    pool_lit(m, b") ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" true)");
    chunk_end(m, s);
    return;
}
fn st_assign_cmp(m: write M, dst: i32, op: i32, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (assign ");
    pool_num(m, conv u64 dst);
    pool_lit(m, b" (cmp ");
    pool_binop(m, op);
    pool_byte(m, 32);
    pool_operand(m, m.o1k, m.o1v, m.o1n, m.o1w);
    pool_byte(m, 32);
    pool_operand(m, m.o2k, m.o2v, m.o2n, m.o2w);
    pool_lit(m, b")) ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    chunk_end(m, s);
    return;
}
fn st_assign_bin(m: write M, dst: i32, op: i32, regime: i32, ty: i32, span0: usize, span1: usize, hasfault: i32, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (assign ");
    pool_num(m, conv u64 dst);
    pool_lit(m, b" (bin ");
    pool_binop(m, op);
    pool_byte(m, 32);
    pool_regime(m, regime);
    pool_byte(m, 32);
    pool_scalar(m, ty);
    pool_byte(m, 32);
    pool_operand(m, m.o1k, m.o1v, m.o1n, m.o1w);
    pool_byte(m, 32);
    pool_operand(m, m.o2k, m.o2v, m.o2n, m.o2w);
    pool_byte(m, 32);
    pool_num(m, conv u64 span0);
    pool_byte(m, 32);
    pool_num(m, conv u64 span1);
    pool_byte(m, 32);
    if hasfault != 0 {
        pool_lit(m, b"(some (fedge overflow ");
        pool_num(m, conv u64 span0);
        pool_byte(m, 32);
        pool_num(m, conv u64 span1);
        pool_lit(m, b"))");
    } else {
        pool_lit(m, b"(none)");
    }
    pool_lit(m, b")) ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    chunk_end(m, s);
    return;
}
fn st_assign_un(m: write M, dst: i32, op: i32, regime: i32, ty: i32, hasfault: i32, fp0: usize, fp1: usize, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (assign ");
    pool_num(m, conv u64 dst);
    pool_lit(m, b" (un ");
    pool_unop(m, op);
    pool_byte(m, 32);
    pool_regime(m, regime);
    pool_byte(m, 32);
    pool_scalar(m, ty);
    pool_byte(m, 32);
    pool_operand(m, m.o1k, m.o1v, m.o1n, m.o1w);
    pool_byte(m, 32);
    if hasfault != 0 {
        pool_lit(m, b"(some (fedge overflow ");
        pool_num(m, conv u64 fp0);
        pool_byte(m, 32);
        pool_num(m, conv u64 fp1);
        pool_lit(m, b"))");
    } else {
        pool_lit(m, b"(none)");
    }
    pool_lit(m, b")) ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    chunk_end(m, s);
    return;
}
fn st_assign_conv(m: write M, dst: i32, tow: i32, regime: i32, hasfault: i32, fp0: usize, fp1: usize, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (assign ");
    pool_num(m, conv u64 dst);
    pool_lit(m, b" (conv ");
    pool_scalar(m, tow);
    pool_byte(m, 32);
    pool_regime(m, regime);
    pool_byte(m, 32);
    pool_operand(m, m.o1k, m.o1v, m.o1n, m.o1w);
    pool_byte(m, 32);
    if hasfault != 0 {
        pool_lit(m, b"(some (fedge convloss ");
        pool_num(m, conv u64 fp0);
        pool_byte(m, 32);
        pool_num(m, conv u64 fp1);
        pool_lit(m, b"))");
    } else {
        pool_lit(m, b"(none)");
    }
    pool_lit(m, b")) ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    chunk_end(m, s);
    return;
}

// ---- environment (bindings; no drops in the scalar subset) ------------------
fn bind(m: write M, p0: usize, p1: usize, id: i32, w: i32, tn: u32) -> unit {
    let k: usize = m.bnd_n;
    m.*.bnd_p0[k] = p0;
    m.*.bnd_p1[k] = p1;
    m.*.bnd_local[k] = id;
    m.*.bnd_w[k] = w;
    m.*.bnd_tn[k] = tn;
    m.*.bnd_box[k] = m.loc_box[conv usize id];
    m.*.bnd_n = k + 1usize;
    scope_add(m, id);
    return;
}
// Innermost-first lookup (shadowing); returns local id or -1 and sets luk_w.
fn lookup(m: write M, src: [u8], p0: usize, p1: usize) -> i32 {
    let mut i: usize = m.bnd_n;
    while i > 0usize {
        i = i - 1usize;
        if name_eq(src, p0, p1, m.bnd_p0[i], m.bnd_p1[i]) {
            m.*.luk_w = m.bnd_w[i];
            m.*.luk_tn = m.bnd_tn[i];
            m.*.luk_box = m.bnd_box[i];
            return m.bnd_local[i];
        }
    }
    return 0 - 1i32;
}
fn find_fn(pp: read P, src: [u8], head: u32, p0: usize, p1: usize) -> u32 {
    let mut cur: u32 = head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_FN && name_eq(src, p0, p1, nd.p0, nd.p1) { return cur; }
        cur = nd.nx;
    }
    return 0u32;
}

// ---- drop schedule: scopes, move mask, Drop emission (mirrors build.rs) ------
// A drop-scope records the owned locals bound in it (declaration order). Scope
// exit / return / loop-exit drop them in REVERSE, pruned by the static move mask.
fn scope_push(m: write M) -> unit {
    m.*.sco_mark[m.sco_depth] = m.sco_n;
    m.*.sco_depth = m.sco_depth + 1usize;
    return;
}
fn scope_add(m: write M, id: i32) -> unit {
    m.*.sco_local[m.sco_n] = id;
    m.*.sco_n = m.sco_n + 1usize;
    return;
}
fn scope_pop_drops(pp: read P, src: [u8], m: write M) -> unit {
    m.*.sco_depth = m.sco_depth - 1usize;
    let start: usize = m.sco_mark[m.sco_depth];
    let mut i: usize = m.sco_n;
    while i > start {
        i = i - 1usize;
        emit_drop(pp, src, m, m.sco_local[i]);
    }
    m.*.sco_n = start;
    return;
}
// Every live scope, innermost-first (the `return` schedule).
fn emit_return_drops(pp: read P, src: [u8], m: write M) -> unit {
    let mut i: usize = m.sco_n;
    while i > 0usize {
        i = i - 1usize;
        emit_drop(pp, src, m, m.sco_local[i]);
    }
    return;
}
// Scopes opened inside the innermost loop body (the `break`/`continue` schedule).
fn emit_loop_exit_drops(pp: read P, src: [u8], m: write M, keep: usize) -> unit {
    let start: usize = m.sco_mark[keep];
    let mut i: usize = m.sco_n;
    while i > start {
        i = i - 1usize;
        emit_drop(pp, src, m, m.sco_local[i]);
    }
    return;
}
fn whole_moved(m: write M, id: i32) -> bool {
    let mut k: usize = 0usize;
    while k < m.mv_n {
        if m.mv_local[k] == id && m.mv_seg_count[k] == 0usize { return true; }
        k = k + 1usize;
    }
    return false;
}
// Emit `(stmt (drop <id> (moved <paths>)) 0 0 false)` carrying the local's move
// mask, so the interp drops only the still-owned sub-paths (INV-DROP).
fn st_drop(src: [u8], m: write M, id: i32) -> unit {
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (drop ");
    pool_num(m, conv u64 id);
    pool_lit(m, b" (moved");
    let mut k: usize = 0usize;
    while k < m.mv_n {
        if m.mv_local[k] == id {
            pool_lit(m, b" (path");
            let mut si: usize = m.mv_seg_start[k];
            let en: usize = si + m.mv_seg_count[k];
            while si < en {
                pool_byte(m, 32);
                if m.mv_seg_syn[si] >= 0 {
                    pool_byte(m, 34);
                    pool_byte(m, 95);
                    pool_num(m, conv u64 m.mv_seg_syn[si]);
                    pool_byte(m, 34);
                } else {
                    pool_qspan(m, src, m.mv_seg_p0[si], m.mv_seg_p1[si]);
                }
                si = si + 1usize;
            }
            pool_byte(m, 41);
        }
        k = k + 1usize;
    }
    pool_lit(m, b")) 0 0 false)");
    chunk_end(m, s);
    return;
}
// A `Drop` for a needs-drop, not-(whole-)moved owned local; borrows/pointers and
// copy/scalar locals emit nothing. No-op on the fault path (unreachable).
fn emit_drop(pp: read P, src: [u8], m: write M, id: i32) -> unit {
    if m.reachable == 0 { return; }
    if m.loc_ptr[conv usize id] != 0 { return; }
    let mut nd: i32 = 0;
    if m.loc_box[conv usize id] != 0 { nd = 1; }
    else if needs_drop(pp, src, m.head, m.loc_tn[conv usize id]) { nd = 1; }
    if nd == 0 { return; }
    if whole_moved(m, id) { return; }
    st_drop(src, m, id);
    return;
}
// The (root local, field-name path) a place names, appending segments to the seg
// pool; -1 for a non-trackable operand (temp, literal, index, call result).
fn collect_path(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    if m.vscrut_on != 0 && i == m.vscrut_node { return m.vscrut_root; }
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_PAREN { return collect_path(pp, src, m, nd.a); }
    if nd.tag == T_ID { return lookup(m, src, nd.p0, nd.p1); }
    if nd.tag == T_FIELD {
        let root: i32 = collect_path(pp, src, m, nd.a);
        if root < 0 { return 0 - 1i32; }
        let s: usize = m.mv_seg_n;
        m.*.mv_seg_p0[s] = nd.p0;
        m.*.mv_seg_p1[s] = nd.p1;
        m.*.mv_seg_syn[s] = 0 - 1i32;
        m.*.mv_seg_n = s + 1usize;
        return root;
    }
    return 0 - 1i32;
}
// Record `e` as moved out (a non-copy by-value consume) so its drop is pruned.
fn mark_moved(pp: read P, src: [u8], m: write M, i: u32) -> unit {
    let seg_start: usize = m.mv_seg_n;
    let root: i32 = collect_path(pp, src, m, i);
    if root < 0 { m.*.mv_seg_n = seg_start; return; }
    let k: usize = m.mv_n;
    m.*.mv_local[k] = root;
    m.*.mv_seg_start[k] = seg_start;
    m.*.mv_seg_count[k] = m.mv_seg_n - seg_start;
    m.*.mv_n = k + 1usize;
    return;
}
fn seg_is_prefix(m: write M, src: [u8], a0: usize, ac: usize, b0: usize, bc: usize) -> bool {
    if ac > bc { return false; }
    let mut k: usize = 0usize;
    while k < ac {
        if m.mv_seg_syn[a0 + k] != m.mv_seg_syn[b0 + k] { return false; }
        if m.mv_seg_syn[a0 + k] < 0 {
            if !name_eq(src, m.mv_seg_p0[a0 + k], m.mv_seg_p1[a0 + k], m.mv_seg_p0[b0 + k], m.mv_seg_p1[b0 + k]) { return false; }
        }
        k = k + 1usize;
    }
    return true;
}
// A reassignment reinitializes the target place: drop the move rows that overlap
// it (either is a prefix of the other), restoring ownership (build.rs set_owned).
fn reassign_reown(pp: read P, src: [u8], m: write M, i: u32) -> unit {
    let tstart: usize = m.mv_seg_n;
    let root: i32 = collect_path(pp, src, m, i);
    let tcount: usize = m.mv_seg_n - tstart;
    if root >= 0 {
        let mut w: usize = 0usize;
        let mut r: usize = 0usize;
        while r < m.mv_n {
            let mut keep: bool = true;
            if m.mv_local[r] == root {
                let rs: usize = m.mv_seg_start[r];
                let rc: usize = m.mv_seg_count[r];
                if seg_is_prefix(m, src, rs, rc, tstart, tcount) { keep = false; }
                if seg_is_prefix(m, src, tstart, tcount, rs, rc) { keep = false; }
            }
            if keep {
                m.*.mv_local[w] = m.mv_local[r];
                m.*.mv_seg_start[w] = m.mv_seg_start[r];
                m.*.mv_seg_count[w] = m.mv_seg_count[r];
                w = w + 1usize;
            }
            r = r + 1usize;
        }
        m.*.mv_n = w;
    }
    m.*.mv_seg_n = tstart;
    return;
}
// Scan the source once for the bytes `self`; the hook binds `self` by these bytes
// (lookup compares src bytes), so the hook body's `self` resolves. Same trick as
// interp.cnr's set_self_span.
fn set_self_span(src: [u8], m: write M) -> unit {
    let n: usize = len(src);
    let mut i: usize = 0usize;
    while i + 4usize <= n {
        if src[i] == 115u8 && src[i + 1usize] == 101u8 && src[i + 2usize] == 108u8 && src[i + 3usize] == 102u8 {
            m.*.self_p0 = i;
            m.*.self_p1 = i + 4usize;
            return;
        }
        i = i + 1usize;
    }
    return;
}

// ---- lowering ---------------------------------------------------------------
// Forward-declared via mutual recursion; Candor resolves within the module.

// ---- `?` operator + `From` widening (mirrors interp.cnr eval_try/eval_try_from
// and src/mir/build.rs lower_try). `expr?` on a result-shaped enum branches on the
// ok/err tag: the ok arm unwraps the (word-sized) ok payload as the `?` value and
// joins; the err arm `From`-converts the error payload to the enclosing fn's error
// type and early-returns the widened result (INV-DROP applies via emit_return_drops).
// The From impl is resolved from the concrete T_IMPL blocks keyed (iface From,
// target enum == the return error payload, iface-arg-0 enum == the operand error).
fn ok_variant_index(pp: read P, eid: u32) -> i32 {
    if eid == 0u32 { return 0 - 1i32; }
    let enode: Node = pp.nodes[conv usize eid];
    let mut cur: u32 = enode.b;
    let mut k: i32 = 0;
    while cur != 0u32 {
        let vd: Node = pp.nodes[conv usize cur];
        if vd.op == 1 { return k; }
        k = k + 1i32;
        cur = vd.nx;
    }
    return 0 - 1i32;
}
fn err_variant_index(pp: read P, eid: u32) -> i32 {
    if eid == 0u32 { return 0 - 1i32; }
    let enode: Node = pp.nodes[conv usize eid];
    let mut cur: u32 = enode.b;
    let mut k: i32 = 0;
    while cur != 0u32 {
        let vd: Node = pp.nodes[conv usize cur];
        if vd.op != 1 { return k; }
        k = k + 1i32;
        cur = vd.nx;
    }
    return 0 - 1i32;
}
// `impl From[src] for tgt`'s owning concrete T_IMPL node (0 if none): iface name
// `From`, target enum == `tgt_eid`, iface arg-0 enum == `src_eid`.
fn find_from_impl(pp: read P, src: [u8], head: u32, src_eid: u32, tgt_eid: u32) -> u32 {
    let mut cur: u32 = head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_IMPL && nd.a == 0u32 && span_eq(src, nd.p0, nd.p1, b"From") {
            let te: u32 = enum_of_ty(pp, src, head, nd.c);
            let mut se: u32 = 0u32;
            if nd.b != 0u32 { se = enum_of_ty(pp, src, head, nd.b); }
            if te == tgt_eid && se == src_eid { return cur; }
        }
        cur = pp.nodes[conv usize cur].nx;
    }
    return 0u32;
}
fn from_method_of(pp: read P, src: [u8], impl_id: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize impl_id];
    let mut mc: u32 = nd.d;
    while mc != 0u32 {
        let mnd: Node = pp.nodes[conv usize mc];
        if span_eq(src, mnd.p0, mnd.p1, b"from") { return mc; }
        mc = mnd.nx;
    }
    return 0u32;
}
// Render a read place `(place base (proj (field off <ty>)))` over a raw local base.
fn tryq_field_place(m: write M, pp: read P, src: [u8], base: i32, off: usize, is_scalar: i32, w: i32, fty: u32) -> unit {
    pool_lit(m, b"(place ");
    pool_num(m, conv u64 base);
    pool_lit(m, b" (proj (field ");
    pool_num(m, conv u64 off);
    pool_byte(m, 32);
    if is_scalar != 0 {
        pool_lit(m, b"(scalar ");
        pool_scalar(m, w);
        pool_byte(m, 41);
    } else {
        pool_ty(m, pp, src, fty);
    }
    pool_lit(m, b")))");
    return;
}
// `(stmt (store (place dst (proj)) (load (place base (proj (field off <ty>))) <ty>)) ...)`.
fn tryq_load_field(m: write M, pp: read P, src: [u8], dst: i32, base: i32, off: usize, is_scalar: i32, w: i32, fty: u32, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (store (place ");
    pool_num(m, conv u64 dst);
    pool_lit(m, b" (proj)) (load ");
    tryq_field_place(m, pp, src, base, off, is_scalar, w, fty);
    pool_byte(m, 32);
    if is_scalar != 0 {
        pool_lit(m, b"(scalar ");
        pool_scalar(m, w);
        pool_byte(m, 41);
    } else {
        pool_ty(m, pp, src, fty);
    }
    pool_lit(m, b")) ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    chunk_end(m, s);
    return;
}
// The err arm: `From`-widen the operand's error payload into the enclosing fn's
// error type and build the return enum in `_0` (mirrors interp.cnr eval_try_from).
// Same result type (no widening) copies the whole operand into `_0`.
fn lower_try_from(pp: read P, src: [u8], m: write M, s_local: i32, eid: u32, sp0: usize, sp1: usize) -> i32 {
    let err_idx: i32 = err_variant_index(pp, eid);
    let evid: u32 = variant_by_index(pp, eid, err_idx);
    let e1ty: u32 = variant_payload_ty(pp, evid, 0);
    let e1off: usize = variant_payload_off(pp, src, m.head, evid, 0);
    let e1_eid: u32 = enum_of_ty(pp, src, m.head, e1ty);
    let rty: u32 = m.ret_tn;
    let reid: u32 = enum_of_ty(pp, src, m.head, rty);
    if reid == eid {
        // Same result type: early-return the operand value as-is.
        if m.reachable != 0 {
            let s0: usize = m.pool_n;
            pool_lit(m, b"(stmt (copyval (place 0 (proj)) (place ");
            pool_num(m, conv u64 s_local);
            pool_lit(m, b" (proj)) ");
            pool_ty(m, pp, src, rty);
            pool_lit(m, b") ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, s0);
        }
        return 0;
    }
    let ret_err_idx: i32 = err_variant_index(pp, reid);
    let rvid: u32 = variant_by_index(pp, reid, ret_err_idx);
    let e2ty: u32 = variant_payload_ty(pp, rvid, 0);
    let e2off: usize = variant_payload_off(pp, src, m.head, rvid, 0);
    let e2_eid: u32 = enum_of_ty(pp, src, m.head, e2ty);
    let impl_id: u32 = find_from_impl(pp, src, m.head, e1_eid, e2_eid);
    if impl_id == 0u32 { m.*.err = 1; return 1; }
    let from_fn: u32 = from_method_of(pp, src, impl_id);
    if from_fn == 0u32 { m.*.err = 1; return 1; }
    // e1 -> the `from` argument: by value if word-sized, else by address.
    let pw: i32 = scalar_width(pp, src, e1ty);
    let mut argloc: i32 = 0;
    if pw != 0 {
        argloc = new_local(m, pw, 0, 0, 0);
        tryq_load_field(m, pp, src, argloc, s_local, e1off, 1, pw, 0u32, sp0, sp1);
        m.*.ak[0] = 1; m.*.av[0] = conv u64 argloc; m.*.an[0] = 0; m.*.aw[0] = pw;
    } else {
        argloc = new_local_ptr(m, e1ty, 0, 0, 0);
        if m.reachable != 0 {
            let sa: usize = m.pool_n;
            pool_lit(m, b"(stmt (assign ");
            pool_num(m, conv u64 argloc);
            pool_lit(m, b" (ref ");
            tryq_field_place(m, pp, src, s_local, e1off, 0, 0, e1ty);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, sa);
        }
        m.*.ak[0] = 1; m.*.av[0] = conv u64 argloc; m.*.an[0] = 0; m.*.aw[0] = 0;
    }
    m.*.na = 1usize;
    // e2 = from(e1) via the return-slot ABI (a rawptr to the callee's result).
    let fromloc: i32 = new_local_ptr(m, e2ty, 0, 0, 0);
    emit_method_call(m, pp, src, fromloc, impl_id, from_fn, sp0, sp1);
    // Build the return enum in `_0`: tag = error variant, payload = the widened e2.
    m.*.dbuf_n = 0usize;
    dbuf_field_scalar(m, 0usize, 9);
    set_o1(m, 0, conv u64 ret_err_idx, 0, 9);
    emit_store_dbuf(m, 0, sp0, sp1);
    m.*.dbuf_n = 0usize;
    dbuf_field(m, pp, src, e2off, e2ty);
    if m.reachable != 0 {
        let sc: usize = m.pool_n;
        pool_lit(m, b"(stmt (copyval ");
        place_from_dbuf(m, 0);
        pool_byte(m, 32);
        render_deref_place(m, pp, src, fromloc, e2ty);
        pool_byte(m, 32);
        pool_ty(m, pp, src, e2ty);
        pool_lit(m, b") ");
        pool_num(m, conv u64 sp0);
        pool_byte(m, 32);
        pool_num(m, conv u64 sp1);
        pool_lit(m, b" false)");
        chunk_end(m, sc);
    }
    m.*.dbuf_n = 0usize;
    return 0;
}
// `expr?`: materialize the operand enum, branch on its ok/err tag; the ok arm
// unwraps the (word-sized) ok payload as the `?` value; the err arm widens+returns.
fn lower_try(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let opnd: Node = pp.nodes[conv usize nd.a];
    if opnd.tag != T_CALL { m.*.err = 1; return 1; }
    let callee: Node = pp.nodes[conv usize opnd.a];
    if callee.tag != T_ID { m.*.err = 1; return 1; }
    let sp0: usize = opnd.p0;
    let sp1: usize = opnd.p1;
    let mut fnid: u32 = opnd.c;
    if fnid == 0u32 { fnid = find_fn(pp, src, m.head, callee.p0, callee.p1); }
    if fnid == 0u32 { m.*.err = 1; return 1; }
    let fnnd: Node = pp.nodes[conv usize fnid];
    let mut ety_tn: u32 = 0u32;
    let cbri: i32 = bret_lookup(m, fnid);
    if cbri >= 0 { ety_tn = m.bret_tn[conv usize cbri]; }
    else if fnnd.e != 0u32 { ety_tn = pp.nodes[conv usize fnnd.e].a; }
    let eid: u32 = enum_of_ty(pp, src, m.head, ety_tn);
    if eid == 0u32 { m.*.err = 1; return 1; }
    let ok_idx: i32 = ok_variant_index(pp, eid);
    if ok_idx < 0 { m.*.err = 1; return 1; }
    // Materialize the operand into a fresh enum temp.
    let s_local: i32 = new_local_tn(m, ety_tn, 0, 0, 0);
    m.*.dbuf_n = 0usize;
    let sc: i32 = lower_into(pp, src, m, nd.a, s_local, ety_tn);
    if sc != 0 { return sc; }
    // Read the tag and compare against the ok index.
    let tagloc: i32 = new_local(m, 9, 0, 0, 0);
    tryq_load_field(m, pp, src, tagloc, s_local, 0usize, 1, 9, 0u32, sp0, sp1);
    let cmploc: i32 = new_local(m, W_BOOL, 0, 0, 0);
    set_o1(m, 1, conv u64 tagloc, 0, 9);
    set_o2(m, 0, conv u64 ok_idx, 0, 9);
    st_assign_cmp(m, cmploc, OP_EQ, sp0, sp1);
    let ok_bb: i32 = new_block(m);
    let err_bb: i32 = new_block(m);
    let join: i32 = new_block(m);
    set_o1(m, 1, conv u64 cmploc, 0, W_BOOL);
    term_branch(m, ok_bb, err_bb);
    // Err arm: From-widen + early-return.
    switch_to(m, err_bb);
    let scf: i32 = lower_try_from(pp, src, m, s_local, eid, sp0, sp1);
    if scf != 0 { return scf; }
    emit_return_drops(pp, src, m);
    term_return(m);
    // Ok arm: unwrap the (word-sized) ok payload as the `?` value, then join.
    switch_to(m, ok_bb);
    let okvid: u32 = variant_by_index(pp, eid, ok_idx);
    let okpty: u32 = variant_payload_ty(pp, okvid, 0);
    let okoff: usize = variant_payload_off(pp, src, m.head, okvid, 0);
    let okw: i32 = scalar_width(pp, src, okpty);
    if okw == 0 { m.*.err = 1; return 1; }
    let valloc: i32 = new_local(m, okw, 0, 0, 0);
    tryq_load_field(m, pp, src, valloc, s_local, okoff, 1, okw, 0u32, sp0, sp1);
    term_goto(m, join);
    switch_to(m, join);
    set_res_local(m, valloc, okw);
    set_res_ptr(m, pp, 0u32);
    return 0;
}

fn lower_value(pp: read P, src: [u8], m: write M, i: u32, exp_w: i32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    m.*.cur_p0 = nd.p0;
    m.*.cur_p1 = nd.p1;
    if nd.tag == T_PAREN { return lower_value(pp, src, m, nd.a, exp_w); }
    if nd.tag == T_INT {
        let w: i32 = lit_width(nd.suf, exp_w);
        set_res_const(m, nd.ival, 0, w);
        return 0;
    }
    if nd.tag == T_NEGINT {
        let w: i32 = lit_width(nd.suf, exp_w);
        set_res_const(m, nd.ival, 1, w);
        return 0;
    }
    if nd.tag == T_BOOL {
        set_res_const(m, nd.ival, 0, W_BOOL);
        return 0;
    }
    if nd.tag == T_ID {
        let id: i32 = lookup(m, src, nd.p0, nd.p1);
        if id >= 0 { set_res_local(m, id, m.luk_w); set_res_ptr(m, pp, m.luk_tn); return 0; }
        if find_static(pp, src, m.head, nd.p0, nd.p1) != 0u32 {
            return lower_place_value(pp, src, m, i);
        }
        let fid: i32 = fn_ptr_id_of(pp, src, m.head, nd.p0, nd.p1);
        if fid >= 0 { set_res_const(m, conv u64 fid, 0, 9); return 0; }
        m.*.err = 1;
        return 1;
    }
    if nd.tag == T_GENERICVAL {
        let gfid: i32 = fn_ptr_id_of_node(pp, m.head, nd.c);
        if gfid >= 0 { set_res_const(m, conv u64 gfid, 0, 9); return 0; }
        m.*.err = 1;
        return 1;
    }
    if nd.tag == T_OFFSETOF {
        let sid: u32 = struct_of_ty(pp, src, m.head, nd.a);
        let off: usize = field_off(pp, src, m.head, sid, nd.p0, nd.p1);
        set_res_const(m, conv u64 off, 0, 10);
        return 0;
    }
    if nd.tag == T_CASTPTR { return lower_cast_ptr(pp, src, m, i); }
    if nd.tag == T_ADDRTOPTR { return lower_addr_to_ptr(pp, src, m, i); }
    if nd.tag == T_PTRNULL { return lower_ptr_null(pp, src, m, i); }
    if nd.tag == T_PREFIX {
        if nd.op == PF_DEREF {
            if is_coll_get_call(pp, src, m, nd.a) { return lower_deref_coll_get(pp, src, m, i); }
            return lower_place_value(pp, src, m, i);
        }
        if nd.op == PF_READ || nd.op == PF_WRITE { return lower_borrow_val(pp, src, m, i); }
        m.*.err = 1;
        return 1;
    }
    if nd.tag == T_UNARY { return lower_unary(pp, src, m, i, exp_w); }
    if nd.tag == T_BIN { return lower_binary(pp, src, m, i, exp_w); }
    if nd.tag == T_CONV { return lower_conv(pp, src, m, i); }
    if nd.tag == T_CALL { return lower_call(pp, src, m, i); }
    if nd.tag == T_BLOCK {
        let sc: i32 = lower_block(pp, src, m, i);
        set_res_const(m, 0u64, 0, 0);
        return sc;
    }
    if nd.tag == T_IF {
        let sc: i32 = lower_if(pp, src, m, i);
        set_res_const(m, 0u64, 0, 0);
        return sc;
    }
    if nd.tag == T_WHILE {
        let sc: i32 = lower_while(pp, src, m, i);
        set_res_const(m, 0u64, 0, 0);
        return sc;
    }
    if nd.tag == T_LOOP {
        let sc: i32 = lower_loop(pp, src, m, i);
        set_res_const(m, 0u64, 0, 0);
        return sc;
    }
    if nd.tag == T_UNSAFE {
        let sc: i32 = lower_block(pp, src, m, nd.a);
        set_res_const(m, 0u64, 0, 0);
        return sc;
    }
    if nd.tag == T_WRAPPING {
        let save: i32 = m.regime;
        m.*.regime = 1;
        let sc: i32 = lower_block(pp, src, m, nd.a);
        m.*.regime = save;
        set_res_const(m, 0u64, 0, 0);
        return sc;
    }
    if nd.tag == T_SATURATING {
        let save: i32 = m.regime;
        m.*.regime = 2;
        let sc: i32 = lower_block(pp, src, m, nd.a);
        m.*.regime = save;
        set_res_const(m, 0u64, 0, 0);
        return sc;
    }
    if nd.tag == T_RETURN {
        let sc: i32 = lower_return(pp, src, m, i);
        set_res_const(m, 0u64, 0, 0);
        return sc;
    }
    if nd.tag == T_BREAK {
        if m.loop_n == 0usize { m.*.err = 1; return 1; }
        emit_loop_exit_drops(pp, src, m, m.loop_depth[m.loop_n - 1usize]);
        term_goto(m, m.loop_brk[m.loop_n - 1usize]);
        set_res_const(m, 0u64, 0, 0);
        return 0;
    }
    if nd.tag == T_CONTINUE {
        if m.loop_n == 0usize { m.*.err = 1; return 1; }
        emit_loop_exit_drops(pp, src, m, m.loop_depth[m.loop_n - 1usize]);
        term_goto(m, m.loop_cont[m.loop_n - 1usize]);
        set_res_const(m, 0u64, 0, 0);
        return 0;
    }
    if nd.tag == T_ASSERT {
        let sc: i32 = lower_assert(pp, src, m, i);
        set_res_const(m, 0u64, 0, 0);
        return sc;
    }
    if nd.tag == T_PANIC {
        term_fault(m, FK_PANIC, nd.p0, nd.p1);
        set_res_const(m, 0u64, 0, 0);
        return 0;
    }
    if nd.tag == T_MATCH {
        let sc: i32 = lower_match_core(pp, src, m, i);
        set_res_const(m, 0u64, 0, 0);
        return sc;
    }
    if nd.tag == T_TRY {
        return lower_try(pp, src, m, i);
    }
    if nd.tag == T_FIELD || nd.tag == T_INDEX {
        return lower_place_value(pp, src, m, i);
    }
    m.*.err = 1;
    return 1;
}

// A wordy place read in value position (`id = load(<place>, <ty>)`): scalar leaves
// give a scalar-typed temp, rawptr/fnptr leaves a pointer-typed temp. Handles a
// static base (pre-emits its `staticaddr`) and Box auto-deref via `emit_projs`.
fn lower_place_value(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    place_base_prep(pp, src, m, i);
    m.*.idx_cnt = 0usize;
    prep_place(pp, src, m, i);
    let ttn: u32 = resolve_place_tn(pp, src, m, i);
    let w: i32 = scalar_width(pp, src, ttn);
    let mut id: i32 = 0;
    if w != 0 {
        id = new_local(m, w, 0, 0, 0);
    } else if is_wordy_tn(pp, src, ttn) {
        id = new_local_tn(m, ttn, 0, 0, 0);
    } else {
        m.*.err = 1;
        return 1;
    }
    if m.reachable != 0 {
        let s: usize = m.pool_n;
        pool_lit(m, b"(stmt (assign ");
        pool_num(m, conv u64 id);
        pool_lit(m, b" (load ");
        render_place_read(pp, src, m, i);
        pool_byte(m, 32);
        pool_ty(m, pp, src, ttn);
        pool_lit(m, b")) ");
        pool_num(m, conv u64 nd.p0);
        pool_byte(m, 32);
        pool_num(m, conv u64 nd.p1);
        pool_lit(m, b" false)");
        chunk_end(m, s);
    }
    if w != 0 { set_res_local(m, id, w); } else { set_res_local(m, id, 10); }
    set_res_ptr(m, pp, ttn);
    return 0;
}
// `read <place>` / `write <place>` in value position: a Borrow / BorrowMut temp
// holding the place's address (build.rs lower_borrow -> emit_temp(Ref(place))).
fn lower_borrow_val(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let inner: u32 = nd.a;
    let innd: Node = pp.nodes[conv usize inner];
    place_base_prep(pp, src, m, inner);
    m.*.idx_cnt = 0usize;
    prep_place(pp, src, m, inner);
    let tn: u32 = resolve_place_tn(pp, src, m, inner);
    let mut tmp: i32 = 0;
    if nd.op == PF_WRITE { tmp = new_local_borrow(m, tn, 0, 0, 0); }
    else { tmp = new_local_borrow_sh(m, tn, 0, 0, 0); }
    if m.reachable != 0 {
        let s: usize = m.pool_n;
        pool_lit(m, b"(stmt (assign ");
        pool_num(m, conv u64 tmp);
        pool_lit(m, b" (ref ");
        render_place_read(pp, src, m, inner);
        pool_lit(m, b")) ");
        pool_num(m, conv u64 innd.p0);
        pool_byte(m, 32);
        pool_num(m, conv u64 innd.p1);
        pool_lit(m, b" false)");
        chunk_end(m, s);
    }
    set_res_local(m, tmp, 10);
    return 0;
}

// cast_ptr[T](p): reinterpret an address as `rawptr T` (a plain Use of the operand).
fn lower_cast_ptr(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let sc: i32 = lower_value(pp, src, m, nd.b, 0 - 1i32);
    if sc != 0 { return sc; }
    set_o1(m, m.res_kind, m.res_val, m.res_neg, m.res_w);
    let sp0: usize = m.cur_p0;
    let sp1: usize = m.cur_p1;
    let tmp: i32 = new_local_ptr(m, nd.a, 0, 0, 0);
    st_assign_use(m, tmp, sp0, sp1);
    set_res_local(m, tmp, 10);
    m.*.res_pointee = nd.a;
    m.*.res_israw = 1;
    return 0;
}
// addr_to_ptr[T](addr): a fixed usize address becomes `rawptr T`.
fn lower_addr_to_ptr(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let sc: i32 = lower_value(pp, src, m, nd.b, 10);
    if sc != 0 { return sc; }
    set_o1(m, m.res_kind, m.res_val, m.res_neg, m.res_w);
    let sp0: usize = m.cur_p0;
    let sp1: usize = m.cur_p1;
    let tmp: i32 = new_local_ptr(m, nd.a, 0, 0, 0);
    st_assign_use(m, tmp, sp0, sp1);
    set_res_local(m, tmp, 10);
    m.*.res_pointee = nd.a;
    m.*.res_israw = 1;
    return 0;
}
// ptr_null[T](): the reserved null pointer (address 0) as `rawptr T`.
fn lower_ptr_null(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    set_o1(m, 0, 0u64, 0, 9);
    let tmp: i32 = new_local_ptr(m, nd.a, 0, 0, 0);
    st_assign_use(m, tmp, nd.p0, nd.p1);
    set_res_local(m, tmp, 10);
    m.*.res_pointee = nd.a;
    m.*.res_israw = 1;
    return 0;
}

fn lower_unary(pp: read P, src: [u8], m: write M, i: u32, exp_w: i32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    if nd.op == UN_NOT {
        let sc: i32 = lower_value(pp, src, m, nd.a, W_BOOL);
        if sc != 0 { return sc; }
        let vk: i32 = m.res_kind; let vv: u64 = m.res_val; let vn: i32 = m.res_neg;
        let id: i32 = new_local(m, W_BOOL, 0, 0, 0);
        set_o1(m, vk, vv, vn, W_BOOL);
        st_assign_un(m, id, UN_NOT, m.regime, W_BOOL, 0, 0, 0, m.cur_p0, m.cur_p1);
        set_res_local(m, id, W_BOOL);
        return 0;
    }
    // neg / bitnot
    let sc: i32 = lower_value(pp, src, m, nd.a, exp_w);
    if sc != 0 { return sc; }
    let vk: i32 = m.res_kind; let vv: u64 = m.res_val; let vn: i32 = m.res_neg; let vw: i32 = m.res_w;
    let sty: i32 = concretize(vw);
    let fp0: usize = m.cur_p0; let fp1: usize = m.cur_p1;
    let mut hasfault: i32 = 0;
    if nd.op == UN_NEG && m.regime == 0 { hasfault = 1; }
    let id: i32 = new_local(m, sty, 0, 0, 0);
    set_o1(m, vk, vv, vn, sty);
    st_assign_un(m, id, nd.op, m.regime, sty, hasfault, fp0, fp1, fp0, fp1);
    set_res_local(m, id, sty);
    return 0;
}

fn lower_binary(pp: read P, src: [u8], m: write M, i: u32, exp_w: i32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let op: i32 = nd.op;
    if op == OP_AND || op == OP_OR { return lower_short_circuit(pp, src, m, i); }
    if op >= OP_EQ && op <= OP_GE {
        let sc: i32 = lower_value(pp, src, m, nd.a, 0 - 1i32);
        if sc != 0 { return sc; }
        let lk: i32 = m.res_kind; let lv: u64 = m.res_val; let ln: i32 = m.res_neg; let lw: i32 = m.res_w;
        let ot: i32 = concretize(lw);
        let sr: i32 = lower_value(pp, src, m, nd.b, ot);
        if sr != 0 { return sr; }
        let rk: i32 = m.res_kind; let rv: u64 = m.res_val; let rn: i32 = m.res_neg; let rw: i32 = m.res_w;
        let id: i32 = new_local(m, W_BOOL, 0, 0, 0);
        set_o1(m, lk, lv, ln, lw);
        set_o2(m, rk, rv, rn, rw);
        st_assign_cmp(m, id, op, m.cur_p0, m.cur_p1);
        set_res_local(m, id, W_BOOL);
        return 0;
    }
    // arithmetic / bitwise / shift
    let mut opty: i32 = 0 - 1i32;
    if exp_w >= 1 && exp_w <= 10 { opty = exp_w; }
    let sc: i32 = lower_value(pp, src, m, nd.a, opty);
    if sc != 0 { return sc; }
    let lk: i32 = m.res_kind; let lv: u64 = m.res_val; let ln: i32 = m.res_neg; let lw: i32 = m.res_w;
    let mut sty: i32 = opty;
    if opty < 0 { sty = concretize(lw); }
    let mut rexp: i32 = sty;
    if op == OP_SHL || op == OP_SHR { rexp = 0 - 1i32; }
    let sr: i32 = lower_value(pp, src, m, nd.b, rexp);
    if sr != 0 { return sr; }
    let rk: i32 = m.res_kind; let rv: u64 = m.res_val; let rn: i32 = m.res_neg; let rw: i32 = m.res_w;
    let mut fallible: i32 = 0;
    if op == OP_ADD || op == OP_SUB || op == OP_MUL || op == OP_DIV || op == OP_REM || op == OP_SHL || op == OP_SHR { fallible = 1; }
    let span0: usize = nd.p0; let span1: usize = nd.p1;
    if fallible != 0 { m.*.cur_p0 = span0; m.*.cur_p1 = span1; }
    let mut hasfault: i32 = 0;
    if fallible != 0 && m.regime == 0 { hasfault = 1; }
    let id: i32 = new_local(m, sty, 0, 0, 0);
    set_o1(m, lk, lv, ln, lw);
    set_o2(m, rk, rv, rn, rw);
    st_assign_bin(m, id, op, m.regime, sty, span0, span1, hasfault, span0, span1);
    set_res_local(m, id, sty);
    return 0;
}

fn lower_short_circuit(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let op: i32 = nd.op;
    let rloc: i32 = new_local(m, W_BOOL, 0, 0, 0);
    let sc: i32 = lower_value(pp, src, m, nd.a, W_BOOL);
    if sc != 0 { return sc; }
    let lk: i32 = m.res_kind; let lv: u64 = m.res_val; let ln: i32 = m.res_neg; let lw: i32 = m.res_w;
    let rhs_bb: i32 = new_block(m);
    let short_bb: i32 = new_block(m);
    let join: i32 = new_block(m);
    let mut then_bb: i32 = rhs_bb;
    let mut else_bb: i32 = short_bb;
    if op == OP_OR { then_bb = short_bb; else_bb = rhs_bb; }
    set_o1(m, lk, lv, ln, lw);
    term_branch(m, then_bb, else_bb);
    switch_to(m, rhs_bb);
    let sr: i32 = lower_value(pp, src, m, nd.b, W_BOOL);
    if sr != 0 { return sr; }
    set_o1(m, m.res_kind, m.res_val, m.res_neg, m.res_w);
    st_assign_use(m, rloc, m.cur_p0, m.cur_p1);
    term_goto(m, join);
    switch_to(m, short_bb);
    let mut shortval: u64 = 0u64;
    if op == OP_OR { shortval = 1u64; }
    set_o1(m, 0, shortval, 0, W_BOOL);
    st_assign_use(m, rloc, m.cur_p0, m.cur_p1);
    term_goto(m, join);
    switch_to(m, join);
    set_res_local(m, rloc, W_BOOL);
    return 0;
}

fn lower_conv(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let sc: i32 = lower_value(pp, src, m, nd.b, 0 - 1i32);
    if sc != 0 { return sc; }
    let vk: i32 = m.res_kind; let vv: u64 = m.res_val; let vn: i32 = m.res_neg; let vw: i32 = m.res_w;
    let tow: i32 = scalar_width(pp, src, nd.a);
    let fp0: usize = m.cur_p0; let fp1: usize = m.cur_p1;
    let mut hasfault: i32 = 0;
    if m.regime == 0 { hasfault = 1; }
    let id: i32 = new_local(m, tow, 0, 0, 0);
    set_o1(m, vk, vv, vn, vw);
    st_assign_conv(m, id, tow, m.regime, hasfault, fp0, fp1, fp0, fp1);
    set_res_local(m, id, tow);
    return 0;
}

fn is_builtin_name(src: [u8], p0: usize, p1: usize) -> bool {
    if span_eq(src, p0, p1, b"addr_of") { return true; }
    if span_eq(src, p0, p1, b"addr_of_mut") { return true; }
    if span_eq(src, p0, p1, b"ptr_read") { return true; }
    if span_eq(src, p0, p1, b"ptr_write") { return true; }
    if span_eq(src, p0, p1, b"ptr_offset") { return true; }
    if span_eq(src, p0, p1, b"is_null") { return true; }
    if span_eq(src, p0, p1, b"ptr_to_addr") { return true; }
    if span_eq(src, p0, p1, b"unbox") { return true; }
    if span_eq(src, p0, p1, b"len") { return true; }
    return false;
}
// The `str` byte-view type: a string literal node (T_STR) or the `str` keyword,
// which the parser records as a T_NAMED/T_SC. build.rs resolves both to Type::Str.
fn tn_is_str_ty(pp: read P, src: [u8], tn: u32) -> bool {
    if tn == 0u32 { return false; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_STR { return true; }
    if nd.tag == T_NAMED || nd.tag == T_SC { return span_eq(src, nd.p0, nd.p1, b"str"); }
    return false;
}
// The collection type node a receiver arg names: peel a read/write prefix and any
// borrow layer (mirrors build.rs collection_ty).
fn coll_recv_tn(pp: read P, src: [u8], m: write M, a0: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize a0];
    if nd.tag == T_PAREN { return coll_recv_tn(pp, src, m, nd.a); }
    let mut inner: u32 = a0;
    if nd.tag == T_PREFIX && (nd.op == PF_READ || nd.op == PF_WRITE) { inner = nd.a; }
    let tn: u32 = resolve_place_tn(pp, src, m, inner);
    if tn == 0u32 { return 0u32; }
    let tnode: Node = pp.nodes[conv usize tn];
    if tnode.tag == T_BORROW || tnode.tag == T_BORROWMUT { return tnode.a; }
    return tn;
}
// Materialize a by-value collection element/value argument (build.rs
// materialize_place): a place expr is used directly (returns -1, the caller renders
// it), else a fresh temp of type `tn` filled by lower_into (returns the temp id).
fn coll_val_mat(pp: read P, src: [u8], m: write M, e: u32, tn: u32) -> i32 {
    if is_place_expr(pp, e) {
        if !is_copy(pp, src, m.head, tn) { mark_moved(pp, src, m, e); }
        place_base_prep(pp, src, m, e);
        m.*.idx_cnt = 0usize;
        prep_place(pp, src, m, e);
        return 0 - 1i32;
    }
    let w: i32 = scalar_width(pp, src, tn);
    let mut tmp: i32 = 0;
    if w != 0 { tmp = new_local(m, w, 0, 0, 0); }
    else { tmp = new_local_tn(m, tn, 0, 0, 0); }
    m.*.dbuf_n = 0usize;
    let sc: i32 = lower_into(pp, src, m, e, tmp, tn);
    if sc != 0 { m.*.err = 1; }
    return tmp;
}
// Materialize a str/[u8] byte-view argument (build.rs coll_view_place): a place is
// used directly (returns -1), else a fresh `str` temp built by lower_into.
fn coll_view_mat(pp: read P, src: [u8], m: write M, e: u32) -> i32 {
    if is_place_expr(pp, e) {
        place_base_prep(pp, src, m, e);
        m.*.idx_cnt = 0usize;
        prep_place(pp, src, m, e);
        return 0 - 1i32;
    }
    let tmp: i32 = new_local_tn(m, m.str_tn, 0, 0, 0);
    m.*.dbuf_n = 0usize;
    let sc: i32 = lower_into(pp, src, m, e, tmp, m.str_tn);
    if sc != 0 { m.*.err = 1; }
    return tmp;
}
// Render a value/key place inside a collop: a temp is `(place tmp (proj))`, a direct
// place goes through render_place_read (prep already done by coll_*_mat).
fn render_coll_place(pp: read P, src: [u8], m: write M, vt: i32, e: u32) -> unit {
    if vt >= 0 {
        pool_lit(m, b"(place ");
        pool_num(m, conv u64 vt);
        pool_lit(m, b" (proj))");
        return;
    }
    render_place_read(pp, src, m, e);
    return;
}
// A collection aggregate constructor: vec_new/map_new/string_new, `pop` on a Vec,
// or `as_str` on a String (build.rs is_collection_agg).
fn is_coll_agg_call(pp: read P, src: [u8], m: write M, cp0: usize, cp1: usize, a0: u32) -> bool {
    if span_eq(src, cp0, cp1, b"vec_new") { return true; }
    if span_eq(src, cp0, cp1, b"map_new") { return true; }
    if span_eq(src, cp0, cp1, b"string_new") { return true; }
    if a0 == 0u32 { return false; }
    let rtn: u32 = coll_recv_tn(pp, src, m, a0);
    if span_eq(src, cp0, cp1, b"pop") { return is_vec_ty(pp, src, rtn); }
    if span_eq(src, cp0, cp1, b"as_str") { return is_string_ty(pp, src, rtn); }
    return false;
}
// Lower an aggregate-producing collection intrinsic into the destination place
// (root + current dbuf prefix), mirroring build.rs lower_collection_agg.
fn lower_coll_agg_into(pp: read P, src: [u8], m: write M, e: u32, root: i32) -> i32 {
    let nd: Node = pp.nodes[conv usize e];
    let callee: Node = pp.nodes[conv usize nd.a];
    let a0: u32 = nd.b;
    let sp0: usize = nd.p0;
    let sp1: usize = nd.p1;
    let mut is_new: bool = false;
    if span_eq(src, callee.p0, callee.p1, b"vec_new") { is_new = true; }
    if span_eq(src, callee.p0, callee.p1, b"map_new") { is_new = true; }
    if span_eq(src, callee.p0, callee.p1, b"string_new") { is_new = true; }
    if is_new {
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return sc; }
        let ak: i32 = m.res_kind; let av: u64 = m.res_val; let an: i32 = m.res_neg; let aw: i32 = m.res_w;
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (collop ");
            place_from_dbuf(m, root);
            pool_lit(m, b" (new ");
            pool_operand(m, ak, av, an, aw);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        return 0;
    }
    if span_eq(src, callee.p0, callee.p1, b"pop") {
        let rtn: u32 = coll_recv_tn(pp, src, m, a0);
        let elem: u32 = coll_elem_ty(pp, rtn);
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return sc; }
        let bk: i32 = m.res_kind; let bv: u64 = m.res_val; let bn: i32 = m.res_neg; let bw: i32 = m.res_w;
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (collop ");
            place_from_dbuf(m, root);
            pool_lit(m, b" (vecpop ");
            pool_operand(m, bk, bv, bn, bw);
            pool_byte(m, 32);
            pool_ty(m, pp, src, elem);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        return 0;
    }
    if span_eq(src, callee.p0, callee.p1, b"as_str") {
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return sc; }
        let bk: i32 = m.res_kind; let bv: u64 = m.res_val; let bn: i32 = m.res_neg; let bw: i32 = m.res_w;
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (collop ");
            place_from_dbuf(m, root);
            pool_lit(m, b" (stringasstr ");
            pool_operand(m, bk, bv, bn, bw);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        return 0;
    }
    m.*.err = 1;
    return 1;
}
// A `get` call on a Vec/Map (its `.*` deref needs the intrinsic lowered as a value).
fn is_coll_get_call(pp: read P, src: [u8], m: write M, call: u32) -> bool {
    let nd: Node = pp.nodes[conv usize call];
    if nd.tag != T_CALL { return false; }
    let callee: Node = pp.nodes[conv usize nd.a];
    if callee.tag != T_ID { return false; }
    if !span_eq(src, callee.p0, callee.p1, b"get") { return false; }
    let a0: u32 = nd.b;
    if a0 == 0u32 { return false; }
    let rtn: u32 = coll_recv_tn(pp, src, m, a0);
    return is_vec_ty(pp, src, rtn) || is_map_ty(pp, src, rtn);
}
// `get(read v/m, k).*`: lower the collection `get` (a borrow value), then read
// through it (build.rs Prefix-Deref over a call result -> deref_place + Load).
fn lower_deref_coll_get(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let call: u32 = nd.a;
    let sc: i32 = lower_value(pp, src, m, call, 0 - 1i32);
    if sc != 0 { return sc; }
    let root: i32 = conv i32 m.res_val;
    let inner: u32 = m.res_pointee;
    let iw: i32 = scalar_width(pp, src, inner);
    let mut id: i32 = 0;
    if iw != 0 { id = new_local(m, iw, 0, 0, 0); }
    else { id = new_local_tn(m, inner, 0, 0, 0); }
    let cn: Node = pp.nodes[conv usize call];
    if m.reachable != 0 {
        let s: usize = m.pool_n;
        pool_lit(m, b"(stmt (assign ");
        pool_num(m, conv u64 id);
        pool_lit(m, b" (load ");
        render_deref_place(m, pp, src, root, inner);
        pool_byte(m, 32);
        pool_ty(m, pp, src, inner);
        pool_lit(m, b")) ");
        pool_num(m, conv u64 cn.p0);
        pool_byte(m, 32);
        pool_num(m, conv u64 cn.p1);
        pool_lit(m, b" false)");
        chunk_end(m, s);
    }
    if iw != 0 { set_res_local(m, id, iw); } else { set_res_local(m, id, 10); }
    set_res_ptr(m, pp, inner);
    return 0;
}
// Lower a word/unit/borrow-producing collection intrinsic (push/set/get/insert/
// contains/append), mirroring build.rs lower_collection_value. Returns 0 handled,
// 1 error, 2 not a collection op (so a same-named user fn wins).
fn lower_coll_value(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let callee: Node = pp.nodes[conv usize nd.a];
    let a0: u32 = nd.b;
    if a0 == 0u32 { return 2; }
    let rtn: u32 = coll_recv_tn(pp, src, m, a0);
    let is_vec: bool = is_vec_ty(pp, src, rtn);
    let is_map: bool = is_map_ty(pp, src, rtn);
    let is_string: bool = is_string_ty(pp, src, rtn);
    if !is_vec && !is_map && !is_string { return 2; }
    let csp0: usize = nd.p0;
    let csp1: usize = nd.p1;
    let a1: u32 = pp.nodes[conv usize a0].nx;
    if is_vec && span_eq(src, callee.p0, callee.p1, b"push") {
        let elem: u32 = coll_elem_ty(pp, rtn);
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return 1; }
        let bk: i32 = m.res_kind; let bv: u64 = m.res_val; let bn: i32 = m.res_neg; let bw: i32 = m.res_w;
        let a1n: Node = pp.nodes[conv usize a1];
        let vt: i32 = coll_val_mat(pp, src, m, a1, elem);
        let dst: i32 = new_local(m, 12, 0, 0, 0);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (collop (place ");
            pool_num(m, conv u64 dst);
            pool_lit(m, b" (proj)) (vecpush ");
            pool_operand(m, bk, bv, bn, bw);
            pool_byte(m, 32);
            pool_ty(m, pp, src, elem);
            pool_byte(m, 32);
            render_coll_place(pp, src, m, vt, a1);
            pool_byte(m, 32);
            pool_num(m, conv u64 a1n.p0);
            pool_byte(m, 32);
            pool_num(m, conv u64 a1n.p1);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 csp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 csp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        set_res_const(m, 0u64, 0, 0);
        return 0;
    }
    if is_string && span_eq(src, callee.p0, callee.p1, b"push") {
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return 1; }
        let bk: i32 = m.res_kind; let bv: u64 = m.res_val; let bn: i32 = m.res_neg; let bw: i32 = m.res_w;
        let sc2: i32 = lower_value(pp, src, m, a1, 8);
        if sc2 != 0 { return 1; }
        let ck: i32 = m.res_kind; let cv: u64 = m.res_val; let cng: i32 = m.res_neg; let cw: i32 = m.res_w;
        let dst: i32 = new_local(m, 12, 0, 0, 0);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (collop (place ");
            pool_num(m, conv u64 dst);
            pool_lit(m, b" (proj)) (stringpush ");
            pool_operand(m, bk, bv, bn, bw);
            pool_byte(m, 32);
            pool_operand(m, ck, cv, cng, cw);
            pool_byte(m, 32);
            pool_num(m, conv u64 csp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 csp1);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 csp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 csp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        set_res_const(m, 0u64, 0, 0);
        return 0;
    }
    if is_vec && span_eq(src, callee.p0, callee.p1, b"get") {
        let elem: u32 = coll_elem_ty(pp, rtn);
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return 1; }
        let bk: i32 = m.res_kind; let bv: u64 = m.res_val; let bn: i32 = m.res_neg; let bw: i32 = m.res_w;
        let a1n: Node = pp.nodes[conv usize a1];
        let sc2: i32 = lower_value(pp, src, m, a1, 10);
        if sc2 != 0 { return 1; }
        let ik: i32 = m.res_kind; let iv: u64 = m.res_val; let ing: i32 = m.res_neg; let iw: i32 = m.res_w;
        let dst: i32 = new_local_borrow_sh(m, elem, 0, 0, 0);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (collop (place ");
            pool_num(m, conv u64 dst);
            pool_lit(m, b" (proj)) (vecget ");
            pool_operand(m, bk, bv, bn, bw);
            pool_byte(m, 32);
            pool_ty(m, pp, src, elem);
            pool_byte(m, 32);
            pool_operand(m, ik, iv, ing, iw);
            pool_byte(m, 32);
            pool_num(m, conv u64 a1n.p0);
            pool_byte(m, 32);
            pool_num(m, conv u64 a1n.p1);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 csp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 csp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        set_res_local(m, dst, 10);
        m.*.res_pointee = elem;
        return 0;
    }
    if is_map && span_eq(src, callee.p0, callee.p1, b"get") {
        let valty: u32 = coll_elem_ty(pp, rtn);
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return 1; }
        let bk: i32 = m.res_kind; let bv: u64 = m.res_val; let bn: i32 = m.res_neg; let bw: i32 = m.res_w;
        let a1n: Node = pp.nodes[conv usize a1];
        let kt: i32 = coll_view_mat(pp, src, m, a1);
        let dst: i32 = new_local_borrow_sh(m, valty, 0, 0, 0);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (collop (place ");
            pool_num(m, conv u64 dst);
            pool_lit(m, b" (proj)) (mapget ");
            pool_operand(m, bk, bv, bn, bw);
            pool_byte(m, 32);
            pool_ty(m, pp, src, valty);
            pool_byte(m, 32);
            render_coll_place(pp, src, m, kt, a1);
            pool_byte(m, 32);
            pool_num(m, conv u64 a1n.p0);
            pool_byte(m, 32);
            pool_num(m, conv u64 a1n.p1);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 csp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 csp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        set_res_local(m, dst, 10);
        m.*.res_pointee = valty;
        return 0;
    }
    if is_map && span_eq(src, callee.p0, callee.p1, b"insert") {
        let valty: u32 = coll_elem_ty(pp, rtn);
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return 1; }
        let bk: i32 = m.res_kind; let bv: u64 = m.res_val; let bn: i32 = m.res_neg; let bw: i32 = m.res_w;
        let a2: u32 = pp.nodes[conv usize a1].nx;
        let a2n: Node = pp.nodes[conv usize a2];
        let kt: i32 = coll_view_mat(pp, src, m, a1);
        let vt: i32 = coll_val_mat(pp, src, m, a2, valty);
        let dst: i32 = new_local(m, 12, 0, 0, 0);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (collop (place ");
            pool_num(m, conv u64 dst);
            pool_lit(m, b" (proj)) (mapinsert ");
            pool_operand(m, bk, bv, bn, bw);
            pool_byte(m, 32);
            pool_ty(m, pp, src, valty);
            pool_byte(m, 32);
            render_coll_place(pp, src, m, kt, a1);
            pool_byte(m, 32);
            render_coll_place(pp, src, m, vt, a2);
            pool_byte(m, 32);
            pool_num(m, conv u64 a2n.p0);
            pool_byte(m, 32);
            pool_num(m, conv u64 a2n.p1);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 csp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 csp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        set_res_const(m, 0u64, 0, 0);
        return 0;
    }
    if is_map && span_eq(src, callee.p0, callee.p1, b"contains") {
        let valty: u32 = coll_elem_ty(pp, rtn);
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return 1; }
        let bk: i32 = m.res_kind; let bv: u64 = m.res_val; let bn: i32 = m.res_neg; let bw: i32 = m.res_w;
        let kt: i32 = coll_view_mat(pp, src, m, a1);
        let dst: i32 = new_local(m, W_BOOL, 0, 0, 0);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (collop (place ");
            pool_num(m, conv u64 dst);
            pool_lit(m, b" (proj)) (mapcontains ");
            pool_operand(m, bk, bv, bn, bw);
            pool_byte(m, 32);
            pool_ty(m, pp, src, valty);
            pool_byte(m, 32);
            render_coll_place(pp, src, m, kt, a1);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 csp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 csp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        set_res_local(m, dst, W_BOOL);
        return 0;
    }
    if is_string && span_eq(src, callee.p0, callee.p1, b"append") {
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return 1; }
        let bk: i32 = m.res_kind; let bv: u64 = m.res_val; let bn: i32 = m.res_neg; let bw: i32 = m.res_w;
        let a1n: Node = pp.nodes[conv usize a1];
        let vt: i32 = coll_view_mat(pp, src, m, a1);
        let dst: i32 = new_local(m, 12, 0, 0, 0);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (collop (place ");
            pool_num(m, conv u64 dst);
            pool_lit(m, b" (proj)) (stringappend ");
            pool_operand(m, bk, bv, bn, bw);
            pool_byte(m, 32);
            render_coll_place(pp, src, m, vt, a1);
            pool_byte(m, 32);
            pool_num(m, conv u64 a1n.p0);
            pool_byte(m, 32);
            pool_num(m, conv u64 a1n.p1);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 csp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 csp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        set_res_const(m, 0u64, 0, 0);
        return 0;
    }
    return 2;
}

// ---- impl-method dispatch (T3) ----------------------------------------------
// Build the dispatch table from every concrete (a == 0) T_IMPL, mirroring
// interp.cnr build_dispatch: key each method by (target struct node, method-name
// span) -> (method fn node, owning T_IMPL node). Generic templates (a != 0) are
// skipped; mono has already instantiated them as concrete T_IMPL nodes.
fn build_dispatch(pp: read P, src: [u8], m: write M) -> unit {
    let mut cur: u32 = m.head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_IMPL && nd.a == 0u32 {
            let sid: u32 = struct_of_ty(pp, src, m.head, nd.c);
            let mut mcur: u32 = nd.d;
            while mcur != 0u32 {
                let mnd: Node = pp.nodes[conv usize mcur];
                let k: usize = m.disp_n;
                m.*.disp_sid[k] = sid;
                m.*.disp_p0[k] = mnd.p0;
                m.*.disp_p1[k] = mnd.p1;
                m.*.disp_fn[k] = mcur;
                m.*.disp_impl[k] = cur;
                m.*.disp_n = k + 1usize;
                mcur = mnd.nx;
            }
        }
        cur = nd.nx;
    }
    return;
}
fn disp_index(m: write M, src: [u8], sid: u32, s: usize, en: usize) -> i32 {
    let mut i: usize = 0usize;
    while i < m.disp_n {
        if m.disp_sid[i] == sid && name_eq(src, m.disp_p0[i], m.disp_p1[i], s, en) {
            return conv i32 i;
        }
        i = i + 1usize;
    }
    return 0 - 1i32;
}
// The mangled free-function name an impl method lowers to (generics.rs
// impl_method_fn_name): `<impl Iface[$args] for Target>::method`. `Target` is the
// concrete nominal (a struct instance's `$`-mangled name for a generic impl).
fn emit_impl_method_name(pp: read P, src: [u8], impl_id: u32, method_id: u32) -> unit {
    let imnd: Node = pp.nodes[conv usize impl_id];
    let mnd: Node = pp.nodes[conv usize method_id];
    emit_byte(34);
    emit_lit(b"<impl ");
    emit_bytes(src, imnd.p0, imnd.p1);
    let mut ac: u32 = imnd.b;
    while ac != 0u32 {
        emit_byte(36);
        emit_mangle_ty(pp, src, ac);
        ac = pp.nodes[conv usize ac].nx;
    }
    emit_lit(b" for ");
    emit_mangle_ty(pp, src, imnd.c);
    emit_lit(b">::");
    emit_bytes(src, mnd.p0, mnd.p1);
    emit_byte(34);
    return;
}
fn pool_impl_method_name(m: write M, pp: read P, src: [u8], impl_id: u32, method_id: u32) -> unit {
    let imnd: Node = pp.nodes[conv usize impl_id];
    let mnd: Node = pp.nodes[conv usize method_id];
    pool_byte(m, 34);
    pool_lit(m, b"<impl ");
    let mut i: usize = imnd.p0;
    while i < imnd.p1 { pool_byte(m, conv i32 src[i]); i = i + 1usize; }
    let mut ac: u32 = imnd.b;
    while ac != 0u32 {
        pool_byte(m, 36);
        pool_mangle_ty(m, pp, src, ac);
        ac = pp.nodes[conv usize ac].nx;
    }
    pool_lit(m, b" for ");
    pool_mangle_ty(m, pp, src, imnd.c);
    pool_lit(m, b">::");
    let mut j: usize = mnd.p0;
    while j < mnd.p1 { pool_byte(m, conv i32 src[j]); j = j + 1usize; }
    pool_byte(m, 34);
    return;
}
fn emit_method_call(m: write M, pp: read P, src: [u8], dst: i32, impl_id: u32, method_id: u32, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (assign ");
    pool_num(m, conv u64 dst);
    pool_lit(m, b" (call ");
    pool_impl_method_name(m, pp, src, impl_id, method_id);
    pool_lit(m, b" (args");
    let mut j: usize = 0usize;
    while j < m.na {
        pool_byte(m, 32);
        pool_operand(m, m.ak[j], m.av[j], m.an[j], m.aw[j]);
        j = j + 1usize;
    }
    pool_lit(m, b"))) ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    chunk_end(m, s);
    return;
}
// A receiver whose value is itself a borrow (build.rs `base_is_borrow`): the
// borrow is forwarded as `self` directly, without taking its address.
fn base_is_borrow(pp: read P, src: [u8], m: write M, base: u32) -> bool {
    let nd: Node = pp.nodes[conv usize base];
    if nd.tag == T_PAREN { return base_is_borrow(pp, src, m, nd.a); }
    if nd.tag == T_ID {
        let id: i32 = lookup(m, src, nd.p0, nd.p1);
        if id >= 0 && m.loc_ptr[conv usize id] >= 2 { return true; }
    }
    return false;
}
// `recv.m(args)` -> a direct MIR Call to the resolved impl method with the receiver
// passed as `self`. Mirrors interp.cnr eval_method_call + build.rs resolve_method:
// type the receiver to its nominal, look up (nominal, method) in the dispatch table,
// then pass the receiver's ADDRESS (a `read`/`write` borrow) as the leading `self`
// operand -- unless the receiver is already a borrow, which is forwarded as-is.
fn lower_method_call(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let callee: Node = pp.nodes[conv usize nd.a];
    let base: u32 = callee.a;
    place_base_prep(pp, src, m, base);
    m.*.idx_cnt = 0usize;
    prep_place(pp, src, m, base);
    let recv_tn: u32 = resolve_place_tn(pp, src, m, base);
    let sid: u32 = struct_of_ty(pp, src, m.head, peel_box_tn(pp, recv_tn));
    let li: i32 = disp_index(m, src, sid, callee.p0, callee.p1);
    if li < 0 { m.*.err = 1; return 1; }
    let lk: usize = conv usize li;
    let fnid: u32 = m.disp_fn[lk];
    let impl_id: u32 = m.disp_impl[lk];
    let fnnd: Node = pp.nodes[conv usize fnid];
    let self_param: u32 = fnnd.c;
    let self_mode: i32 = pp.nodes[conv usize self_param].op;
    let mut retn: u32 = 0u32;
    let cbri: i32 = bret_lookup(m, fnid);
    if cbri >= 0 { retn = m.bret_tn[conv usize cbri]; }
    else if fnnd.e != 0u32 { retn = pp.nodes[conv usize fnnd.e].a; }
    let retw: i32 = scalar_width(pp, src, retn);
    m.*.na = 0usize;
    if base_is_borrow(pp, src, m, base) {
        let sc: i32 = lower_value(pp, src, m, base, 0 - 1i32);
        if sc != 0 { return sc; }
        let k: usize = m.na;
        m.*.ak[k] = m.res_kind; m.*.av[k] = m.res_val; m.*.an[k] = m.res_neg; m.*.aw[k] = m.res_w;
        m.*.na = k + 1usize;
    } else {
        let mut tmp: i32 = 0;
        if self_mode == 2 { tmp = new_local_borrow(m, recv_tn, 0, 0, 0); }
        else { tmp = new_local_borrow_sh(m, recv_tn, 0, 0, 0); }
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (assign ");
            pool_num(m, conv u64 tmp);
            pool_lit(m, b" (ref ");
            render_place_read(pp, src, m, base);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 callee.p0);
            pool_byte(m, 32);
            pool_num(m, conv u64 callee.p1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        let k: usize = m.na;
        m.*.ak[k] = 1; m.*.av[k] = conv u64 tmp; m.*.an[k] = 0; m.*.aw[k] = 0;
        m.*.na = k + 1usize;
    }
    let sc2: i32 = lower_args_core(pp, src, m, pp.nodes[conv usize self_param].nx, nd.b);
    if sc2 != 0 { return sc2; }
    let mut id: i32 = 0;
    if retw != 0 { id = new_local(m, retw, 0, 0, 0); }
    else if is_wordy_tn(pp, src, retn) { id = new_local_tn(m, retn, 0, 0, 0); }
    else { id = new_local(m, 0, 0, 0, 0); }
    emit_method_call(m, pp, src, id, impl_id, fnid, nd.p0, nd.p1);
    if retw != 0 { set_res_local(m, id, retw); } else { set_res_local(m, id, 10); }
    return 0;
}
fn lower_call(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let callee: Node = pp.nodes[conv usize nd.a];
    if callee.tag == T_FIELD { return lower_method_call(pp, src, m, i); }
    if callee.tag != T_ID { m.*.err = 1; return 1; }
    // trace(x): the observable.
    if span_eq(src, callee.p0, callee.p1, b"trace") {
        let sc: i32 = lower_value(pp, src, m, nd.b, 4);
        if sc != 0 { return sc; }
        set_o1(m, m.res_kind, m.res_val, m.res_neg, m.res_w);
        st_trace(m, callee.p0, m.cur_p1);
        set_res_const(m, 0u64, 0, 0);
        return 0;
    }
    if is_builtin_name(src, callee.p0, callee.p1) {
        return lower_builtin_value(pp, src, m, i, callee.p0, callee.p1, nd.p0, nd.p1);
    }
    let cvr: i32 = lower_coll_value(pp, src, m, i);
    if cvr == 0 { return 0; }
    if cvr == 1 { return 1; }
    let mut fnid: u32 = nd.c;
    if fnid == 0u32 { fnid = find_fn(pp, src, m.head, callee.p0, callee.p1); }
    if fnid == 0u32 {
        // An indirect call through a fn-pointer-valued local.
        if lookup(m, src, callee.p0, callee.p1) >= 0 {
            return lower_indirect_call(pp, src, m, i);
        }
        m.*.err = 1;
        return 1;
    }
    let fnnd: Node = pp.nodes[conv usize fnid];
    let mut retn: u32 = 0u32;
    let cbri: i32 = bret_lookup(m, fnid);
    if cbri >= 0 { retn = m.bret_tn[conv usize cbri]; }
    else if fnnd.e != 0u32 { retn = pp.nodes[conv usize fnnd.e].a; }
    let retw: i32 = scalar_width(pp, src, retn);
    let sc: i32 = lower_args(pp, src, m, fnnd, nd.b);
    if sc != 0 { return sc; }
    let mut id: i32 = 0;
    if retw != 0 { id = new_local(m, retw, 0, 0, 0); }
    else if is_wordy_tn(pp, src, retn) { id = new_local_tn(m, retn, 0, 0, 0); }
    else { id = new_local(m, 0, 0, 0, 0); }
    emit_call(m, pp, src, id, fnid, nd.p0, nd.p1);
    if retw != 0 { set_res_local(m, id, retw); } else { set_res_local(m, id, 10); }
    return 0;
}
// An indirect call `fp(args)` (design 0007 §6.2): the callee is a fn-pointer-valued
// operand; the args follow the fn-pointer's declared parameter modes.
fn lower_indirect_call(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let callee: Node = pp.nodes[conv usize nd.a];
    let cid: i32 = lookup(m, src, callee.p0, callee.p1);
    if cid < 0 { m.*.err = 1; return 1; }
    let fptn: u32 = m.luk_tn;
    let fpnode: Node = pp.nodes[conv usize fptn];
    let retn: u32 = fpnode.b;
    let retw: i32 = scalar_width(pp, src, retn);
    let sc: i32 = lower_args_fnptr(pp, src, m, fpnode.a, nd.b);
    if sc != 0 { return sc; }
    let mut id: i32 = 0;
    if retw != 0 { id = new_local(m, retw, 0, 0, 0); }
    else if is_wordy_tn(pp, src, retn) { id = new_local_tn(m, retn, 0, 0, 0); }
    else { id = new_local(m, 0, 0, 0, 0); }
    if m.reachable != 0 {
        let s: usize = m.pool_n;
        pool_lit(m, b"(stmt (assign ");
        pool_num(m, conv u64 id);
        pool_lit(m, b" (callindirect (oplocal ");
        pool_num(m, conv u64 cid);
        pool_lit(m, b") (args");
        let mut j: usize = 0usize;
        while j < m.na {
            pool_byte(m, 32);
            pool_operand(m, m.ak[j], m.av[j], m.an[j], m.aw[j]);
            j = j + 1usize;
        }
        pool_lit(m, b"))) ");
        pool_num(m, conv u64 nd.p0);
        pool_byte(m, 32);
        pool_num(m, conv u64 nd.p1);
        pool_lit(m, b" false)");
        chunk_end(m, s);
    }
    if retw != 0 { set_res_local(m, id, retw); } else { set_res_local(m, id, 10); }
    return 0;
}

fn lower_if(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let sc: i32 = lower_value(pp, src, m, nd.a, W_BOOL);
    if sc != 0 { return sc; }
    let ck: i32 = m.res_kind; let cv: u64 = m.res_val; let cn: i32 = m.res_neg; let cw: i32 = m.res_w;
    let then_bb: i32 = new_block(m);
    let else_bb: i32 = new_block(m);
    let join: i32 = new_block(m);
    set_o1(m, ck, cv, cn, cw);
    term_branch(m, then_bb, else_bb);
    switch_to(m, then_bb);
    let s1: i32 = lower_block(pp, src, m, nd.b);
    if s1 != 0 { return s1; }
    term_goto(m, join);
    switch_to(m, else_bb);
    if nd.c != 0u32 {
        let s2: i32 = lower_value(pp, src, m, nd.c, 0 - 1i32);
        if s2 != 0 { return s2; }
    }
    term_goto(m, join);
    switch_to(m, join);
    return 0;
}

fn lower_while(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let head: i32 = new_block(m);
    let body_bb: i32 = new_block(m);
    let exit: i32 = new_block(m);
    term_goto(m, head);
    switch_to(m, head);
    let sc: i32 = lower_value(pp, src, m, nd.a, W_BOOL);
    if sc != 0 { return sc; }
    set_o1(m, m.res_kind, m.res_val, m.res_neg, m.res_w);
    term_branch(m, body_bb, exit);
    switch_to(m, body_bb);
    m.*.loop_cont[m.loop_n] = head;
    m.*.loop_brk[m.loop_n] = exit;
    m.*.loop_depth[m.loop_n] = m.sco_depth;
    m.*.loop_n = m.loop_n + 1usize;
    let s1: i32 = lower_block(pp, src, m, nd.b);
    m.*.loop_n = m.loop_n - 1usize;
    if s1 != 0 { return s1; }
    term_goto(m, head);
    switch_to(m, exit);
    return 0;
}

fn lower_loop(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let body_bb: i32 = new_block(m);
    let exit: i32 = new_block(m);
    term_goto(m, body_bb);
    switch_to(m, body_bb);
    m.*.loop_cont[m.loop_n] = body_bb;
    m.*.loop_brk[m.loop_n] = exit;
    m.*.loop_depth[m.loop_n] = m.sco_depth;
    m.*.loop_n = m.loop_n + 1usize;
    let s1: i32 = lower_block(pp, src, m, nd.a);
    m.*.loop_n = m.loop_n - 1usize;
    if s1 != 0 { return s1; }
    term_goto(m, body_bb);
    switch_to(m, exit);
    return 0;
}

fn lower_assert(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let sc: i32 = lower_value(pp, src, m, nd.a, W_BOOL);
    if sc != 0 { return sc; }
    let ck: i32 = m.res_kind; let cv: u64 = m.res_val; let cn: i32 = m.res_neg; let cw: i32 = m.res_w;
    let fp0: usize = m.cur_p0; let fp1: usize = m.cur_p1;
    let ok_bb: i32 = new_block(m);
    let fail_bb: i32 = new_block(m);
    set_o1(m, ck, cv, cn, cw);
    term_branch(m, ok_bb, fail_bb);
    switch_to(m, fail_bb);
    term_fault(m, FK_ASSERT, fp0, fp1);
    switch_to(m, ok_bb);
    return 0;
}

// ---- places (lvalues) --------------------------------------------------------
// A top-level `static` decl node with this name, or 0.
fn find_static(pp: read P, src: [u8], head: u32, p0: usize, p1: usize) -> u32 {
    let mut cur: u32 = head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_STATIC && name_eq(src, p0, p1, nd.p0, nd.p1) { return cur; }
        cur = nd.nx;
    }
    return 0u32;
}
// Pre-emit the innermost base of a place: if it is a `static`, emit its
// `(staticaddr "NAME")` temp as its own statement (build.rs models a static place
// as `*(&STATIC)`) and record the temp as the place root; otherwise clear the
// static flag. Must run BEFORE the place-consuming statement is built.
// Hoist every computed array index in place `i` into an operand cache BEFORE the
// place text is built: lowering an index expression (e.g. `conv usize i`) can emit
// its own statement chunk, which must land in the block, not inside the place bytes.
fn prep_place(pp: read P, src: [u8], m: write M, i: u32) -> unit {
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_PAREN { prep_place(pp, src, m, nd.a); return; }
    if nd.tag == T_FIELD { prep_place(pp, src, m, nd.a); return; }
    if nd.tag == T_PREFIX && nd.op == PF_DEREF { prep_place(pp, src, m, nd.a); return; }
    if nd.tag == T_INDEX {
        prep_place(pp, src, m, nd.a);
        let _sc: i32 = lower_value(pp, src, m, nd.b, 10);
        let k: usize = m.idx_cnt;
        m.*.idx_key[k] = i;
        m.*.idx_vk[k] = m.res_kind;
        m.*.idx_vv[k] = m.res_val;
        m.*.idx_vn[k] = m.res_neg;
        m.*.idx_vw[k] = m.res_w;
        m.*.idx_cnt = k + 1usize;
        return;
    }
    return;
}
fn idx_find(m: write M, i: u32) -> i32 {
    let mut k: usize = 0usize;
    while k < m.idx_cnt {
        if m.idx_key[k] == i { return conv i32 k; }
        k = k + 1usize;
    }
    return 0 - 1i32;
}
fn place_base_prep(pp: read P, src: [u8], m: write M, i: u32) -> unit {
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_PAREN { place_base_prep(pp, src, m, nd.a); return; }
    if nd.tag == T_FIELD || nd.tag == T_INDEX { place_base_prep(pp, src, m, nd.a); return; }
    if nd.tag == T_PREFIX && nd.op == PF_DEREF { place_base_prep(pp, src, m, nd.a); return; }
    m.*.plc_base_kind = 0;
    m.*.plc_root_tmp = 0 - 1i32;
    if nd.tag == T_ID {
        let lid: i32 = lookup(m, src, nd.p0, nd.p1);
        if lid >= 0 { return; }
        let sid: u32 = find_static(pp, src, m.head, nd.p0, nd.p1);
        if sid != 0u32 {
            let sty: u32 = pp.nodes[conv usize sid].a;
            let tmp: i32 = new_local_ptr(m, sty, 0, 0, 0);
            if m.reachable != 0 {
                let s: usize = m.pool_n;
                pool_lit(m, b"(stmt (assign ");
                pool_num(m, conv u64 tmp);
                pool_lit(m, b" (staticaddr ");
                pool_qspan(m, src, nd.p0, nd.p1);
                pool_lit(m, b")) ");
                pool_num(m, conv u64 nd.p0);
                pool_byte(m, 32);
                pool_num(m, conv u64 nd.p1);
                pool_lit(m, b" false)");
                chunk_end(m, s);
            }
            m.*.plc_base_kind = 1;
            m.*.plc_root_tmp = tmp;
            m.*.plc_base_tn = sty;
        }
    }
    return;
}
// The root local of a place expression (innermost identifier / static temp).
fn resolve_place_root(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    if m.vscrut_on != 0 && i == m.vscrut_node { return m.vscrut_root; }
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_PAREN { return resolve_place_root(pp, src, m, nd.a); }
    if nd.tag == T_FIELD || nd.tag == T_INDEX { return resolve_place_root(pp, src, m, nd.a); }
    if nd.tag == T_PREFIX && nd.op == PF_DEREF { return resolve_place_root(pp, src, m, nd.a); }
    if nd.tag == T_ID {
        let id: i32 = lookup(m, src, nd.p0, nd.p1);
        if id >= 0 { return id; }
        return m.plc_root_tmp;
    }
    return 0 - 1i32;
}
// The arena type node of a place expression's leaf (no emission). For a Box place
// this is the pointee type node; box-ness is tracked separately (luk_box/plc_box).
fn resolve_place_tn(pp: read P, src: [u8], m: write M, i: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_PAREN { return resolve_place_tn(pp, src, m, nd.a); }
    if nd.tag == T_ID {
        let id: i32 = lookup(m, src, nd.p0, nd.p1);
        if id >= 0 { return m.luk_tn; }
        let sid: u32 = find_static(pp, src, m.head, nd.p0, nd.p1);
        if sid != 0u32 { return pp.nodes[conv usize sid].a; }
        return 0u32;
    }
    if nd.tag == T_PREFIX && nd.op == PF_DEREF {
        let btn: u32 = resolve_place_tn(pp, src, m, nd.a);
        let bnode: Node = pp.nodes[conv usize btn];
        if bnode.tag == T_RAWPTR || bnode.tag == T_BORROW || bnode.tag == T_BORROWMUT { return bnode.a; }
        return btn;
    }
    if nd.tag == T_FIELD {
        let btn: u32 = peel_box_tn(pp, resolve_place_tn(pp, src, m, nd.a));
        let sid: u32 = struct_of_ty(pp, src, m.head, btn);
        return field_ty(pp, src, sid, nd.p0, nd.p1);
    }
    if nd.tag == T_INDEX {
        let btn: u32 = peel_box_tn(pp, resolve_place_tn(pp, src, m, nd.a));
        let an: Node = pp.nodes[conv usize btn];
        if an.tag == T_SLICE || an.tag == T_SLICEMUT { return an.a; }
        return an.b;
    }
    return 0u32;
}
// Append the projection entries of place `i` to the pool (space-prefixed), setting
// plc_local (root), plc_tn (leaf pointee/type) and plc_box (leaf is a Box). A field/
// index on a Box base auto-derefs; a static base derefs its address; `.*` derefs.
fn emit_projs(pp: read P, src: [u8], m: write M, i: u32) -> unit {
    let nd: Node = pp.nodes[conv usize i];
    m.*.cur_p0 = nd.p0;
    m.*.cur_p1 = nd.p1;
    if m.vscrut_on != 0 && i == m.vscrut_node {
        m.*.plc_local = m.vscrut_root;
        m.*.plc_tn = m.vscrut_tn;
        m.*.plc_box = 0;
        m.*.plc_borrow = m.vscrut_borrow;
        return;
    }
    if nd.tag == T_PAREN { emit_projs(pp, src, m, nd.a); return; }
    if nd.tag == T_ID {
        let id: i32 = lookup(m, src, nd.p0, nd.p1);
        if id >= 0 {
            m.*.plc_local = id;
            m.*.plc_tn = m.luk_tn;
            m.*.plc_box = m.luk_box;
            m.*.plc_borrow = 0;
            if m.loc_ptr[conv usize id] >= 2 { m.*.plc_borrow = 1; }
            return;
        }
        // static base: root is the pre-emitted staticaddr temp; deref its address.
        m.*.plc_local = m.plc_root_tmp;
        m.*.plc_tn = m.plc_base_tn;
        m.*.plc_box = 0;
        m.*.plc_borrow = 0;
        pool_lit(m, b" (deref ");
        pool_ty(m, pp, src, m.plc_base_tn);
        pool_byte(m, 41);
        return;
    }
    if nd.tag == T_PREFIX && nd.op == PF_DEREF {
        emit_projs(pp, src, m, nd.a);
        let ptn: u32 = m.plc_tn;
        pool_lit(m, b" (deref ");
        pool_ty(m, pp, src, ptn);
        pool_byte(m, 41);
        // The leaf is now the pointee; box-ness of the pointee is not tracked here
        // (nested-box place projection is out of subset).
        m.*.plc_box = 0;
        m.*.plc_borrow = 0;
        return;
    }
    if nd.tag == T_FIELD {
        emit_projs(pp, src, m, nd.a);
        if m.plc_box != 0 || m.plc_borrow != 0 {
            pool_lit(m, b" (deref ");
            pool_ty(m, pp, src, m.plc_tn);
            pool_byte(m, 41);
            m.*.plc_box = 0;
            m.*.plc_borrow = 0;
        }
        let btn: u32 = m.plc_tn;
        let sid: u32 = struct_of_ty(pp, src, m.head, btn);
        let off: usize = field_off(pp, src, m.head, sid, nd.p0, nd.p1);
        let fty: u32 = field_ty(pp, src, sid, nd.p0, nd.p1);
        pool_lit(m, b" (field ");
        pool_num(m, conv u64 off);
        pool_byte(m, 32);
        pool_ty(m, pp, src, fty);
        pool_byte(m, 41);
        if pp.nodes[conv usize fty].tag == T_BOX {
            m.*.plc_tn = pointee_of(pp, fty);
            m.*.plc_box = 1;
        } else {
            m.*.plc_tn = fty;
            m.*.plc_box = 0;
        }
        return;
    }
    if nd.tag == T_INDEX {
        emit_projs(pp, src, m, nd.a);
        if m.plc_box != 0 || m.plc_borrow != 0 {
            pool_lit(m, b" (deref ");
            pool_ty(m, pp, src, m.plc_tn);
            pool_byte(m, 41);
            m.*.plc_box = 0;
            m.*.plc_borrow = 0;
        }
        let bp0: usize = m.cur_p0;
        let bp1: usize = m.cur_p1;
        let atn: u32 = m.plc_tn;
        let anode: Node = pp.nodes[conv usize atn];
        let mut elem: u32 = anode.b;
        let mut ln: usize = array_len_of(pp, anode.a);
        let mut is_sl: i32 = 0;
        if anode.tag == T_SLICE || anode.tag == T_SLICEMUT {
            elem = anode.a;
            ln = 0usize;
            is_sl = 1;
        }
        let stride: usize = stride_of(pp, src, m.head, elem);
        let ci: i32 = idx_find(m, i);
        let mut ik: i32 = 0;
        let mut iv: u64 = 0u64;
        let mut ing: i32 = 0;
        let mut iw: i32 = 10;
        if ci >= 0 {
            let ck: usize = conv usize ci;
            ik = m.idx_vk[ck]; iv = m.idx_vv[ck]; ing = m.idx_vn[ck]; iw = m.idx_vw[ck];
        } else {
            let _sc: i32 = lower_value(pp, src, m, nd.b, 10);
            ik = m.res_kind; iv = m.res_val; ing = m.res_neg; iw = m.res_w;
        }
        pool_lit(m, b" (index ");
        pool_operand(m, ik, iv, ing, iw);
        pool_byte(m, 32);
        pool_num(m, conv u64 stride);
        pool_byte(m, 32);
        pool_num(m, conv u64 ln);
        pool_byte(m, 32);
        pool_num(m, conv u64 bp0);
        pool_byte(m, 32);
        pool_num(m, conv u64 bp1);
        if is_sl != 0 { pool_lit(m, b" true)"); } else { pool_lit(m, b" false)"); }
        m.*.plc_tn = elem;
        m.*.plc_box = 0;
        return;
    }
    m.*.err = 1;
    return;
}
// Render a READ place `(place root (proj ...))` directly into the pool; sets plc_tn.
// Caller must have run `place_base_prep(i)` first if `i` may be static-rooted.
fn render_place_read(pp: read P, src: [u8], m: write M, i: u32) -> unit {
    let root: i32 = resolve_place_root(pp, src, m, i);
    if root < 0 { m.*.err = 1; }
    pool_lit(m, b"(place ");
    pool_num(m, conv u64 root);
    pool_lit(m, b" (proj");
    emit_projs(pp, src, m, i);
    pool_lit(m, b"))");
    return;
}
// Build the destination place of `i` into dbuf; sets plc_local (root) + plc_tn.
fn build_dbuf_place(pp: read P, src: [u8], m: write M, i: u32) -> unit {
    m.*.dbuf_n = 0usize;
    m.*.idx_cnt = 0usize;
    prep_place(pp, src, m, i);
    let s: usize = m.pool_n;
    emit_projs(pp, src, m, i);
    reloc_to_dbuf(m, s);
    return;
}

// ---- aggregate initialization (lower_into over the current dbuf destination) --
fn find_finit(pp: read P, src: [u8], head_fi: u32, fs: usize, fen: usize) -> u32 {
    let mut cur: u32 = head_fi;
    while cur != 0u32 {
        let fi: Node = pp.nodes[conv usize cur];
        if name_eq(src, fs, fen, fi.p0, fi.p1) { return cur; }
        cur = fi.nx;
    }
    return 0u32;
}
// Emit `(stmt (store <dbuf place> (use <o1>)) ...)` for a scalar leaf.
fn emit_store_dbuf(m: write M, root: i32, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (store ");
    place_from_dbuf(m, root);
    pool_lit(m, b" (use ");
    pool_operand(m, m.o1k, m.o1v, m.o1n, m.o1w);
    pool_lit(m, b")) ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    chunk_end(m, s);
    return;
}
fn lower_struct_lit(pp: read P, src: [u8], m: write M, i: u32, root: i32, tn: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let mut sid: u32 = nd.b;
    if sid == 0u32 { sid = struct_of_ty(pp, src, m.head, tn); }
    if sid == 0u32 { m.*.err = 1; return 1; }
    let snode: Node = pp.nodes[conv usize sid];
    let base_n: usize = m.dbuf_n;
    let mut fc: u32 = snode.b;
    while fc != 0u32 {
        let fd: Node = pp.nodes[conv usize fc];
        let fin: u32 = find_finit(pp, src, nd.a, fd.p0, fd.p1);
        if fin != 0u32 {
            let off: usize = field_off(pp, src, m.head, sid, fd.p0, fd.p1);
            m.*.dbuf_n = base_n;
            dbuf_field(m, pp, src, off, fd.a);
            let sc: i32 = lower_into(pp, src, m, pp.nodes[conv usize fin].a, root, fd.a);
            if sc != 0 { m.*.dbuf_n = base_n; return sc; }
        }
        fc = fd.nx;
    }
    m.*.dbuf_n = base_n;
    return 0;
}
fn lower_array_lit(pp: read P, src: [u8], m: write M, i: u32, root: i32, tn: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let anode: Node = pp.nodes[conv usize tn];
    let elem: u32 = anode.b;
    let stride: usize = stride_of(pp, src, m.head, elem);
    let mut cnt: usize = 0usize;
    let mut c: u32 = nd.a;
    while c != 0u32 { cnt = cnt + 1usize; c = pp.nodes[conv usize c].nx; }
    let base_n: usize = m.dbuf_n;
    let mut idx: usize = 0usize;
    let mut cur: u32 = nd.a;
    while cur != 0u32 {
        let el: Node = pp.nodes[conv usize cur];
        m.*.dbuf_n = base_n;
        dbuf_index_const(m, idx, stride, cnt, el.p0, el.p1);
        let sc: i32 = lower_into(pp, src, m, cur, root, elem);
        if sc != 0 { m.*.dbuf_n = base_n; return sc; }
        idx = idx + 1usize;
        cur = el.nx;
    }
    m.*.dbuf_n = base_n;
    return 0;
}
// A byte-string literal materializes as a `[u8]` slice header: field 0 = the
// static byte address (`straddr`), field 8 = the byte length (build.rs lower_str_into).
fn lower_str_into(pp: read P, src: [u8], m: write M, e: u32, root: i32) -> i32 {
    let nd: Node = pp.nodes[conv usize e];
    let clen: usize = conv usize decoded_len(src, nd.p0, nd.p1);
    let base: usize = m.dbuf_n;
    m.*.dbuf_n = base;
    dbuf_field_scalar(m, 0usize, 9);
    if m.reachable != 0 {
        let s: usize = m.pool_n;
        pool_lit(m, b"(stmt (store ");
        place_from_dbuf(m, root);
        pool_lit(m, b" (straddr ");
        pool_qspan(m, src, nd.p0, nd.p1);
        pool_lit(m, b")) ");
        pool_num(m, conv u64 nd.p0);
        pool_byte(m, 32);
        pool_num(m, conv u64 nd.p1);
        pool_lit(m, b" false)");
        chunk_end(m, s);
    }
    m.*.dbuf_n = base;
    dbuf_field_scalar(m, 8usize, 9);
    set_o1(m, 0, conv u64 clen, 0, 9);
    emit_store_dbuf(m, root, nd.p0, nd.p1);
    m.*.dbuf_n = base;
    return 0;
}
fn lower_array_rep(pp: read P, src: [u8], m: write M, i: u32, root: i32, tn: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let anode: Node = pp.nodes[conv usize tn];
    let elem: u32 = anode.b;
    let stride: usize = stride_of(pp, src, m.head, elem);
    let szn: Node = pp.nodes[conv usize nd.b];
    let n: usize = conv usize szn.ival;
    let ew: i32 = scalar_width(pp, src, elem);
    let mut tmp: i32 = 0;
    if ew != 0 { tmp = new_local(m, ew, 0, 0, 0); }
    else { tmp = new_local_tn(m, elem, 0, 0, 0); }
    // Evaluate the element once into `tmp` (dbuf reset to the temp's empty place).
    let save_n: usize = m.dbuf_n;
    m.*.dbuf_n = 0usize;
    let sc: i32 = lower_into(pp, src, m, nd.a, tmp, elem);
    if sc != 0 { return sc; }
    m.*.dbuf_n = save_n;
    let el: Node = pp.nodes[conv usize nd.a];
    let mut k: usize = 0usize;
    while k < n {
        m.*.dbuf_n = save_n;
        dbuf_index_const(m, k, stride, n, el.p0, el.p1);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (copyval ");
            place_from_dbuf(m, root);
            pool_lit(m, b" (place ");
            pool_num(m, conv u64 tmp);
            pool_lit(m, b" (proj)) ");
            pool_ty(m, pp, src, elem);
            pool_lit(m, b") ");
            pool_num(m, conv u64 el.p0);
            pool_byte(m, 32);
            pool_num(m, conv u64 el.p1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        k = k + 1usize;
    }
    m.*.dbuf_n = save_n;
    return 0;
}
// A call returning an aggregate: the callee writes its _0 return slot, `call`
// yields that slot's ADDRESS into a rawptr temp, then we byte-copy the pointee
// into the destination (the caller-owned return-slot ABI of build.rs).
fn lower_call_agg(pp: read P, src: [u8], m: write M, i: u32, root: i32, tn: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let callee: Node = pp.nodes[conv usize nd.a];
    if callee.tag != T_ID { m.*.err = 1; return 1; }
    let mut fnid: u32 = nd.c;
    if fnid == 0u32 { fnid = find_fn(pp, src, m.head, callee.p0, callee.p1); }
    if fnid == 0u32 { m.*.err = 1; return 1; }
    let fnnd: Node = pp.nodes[conv usize fnid];
    let mut retn: u32 = 0u32;
    if fnnd.e != 0u32 { retn = pp.nodes[conv usize fnnd.e].a; }
    let sc: i32 = lower_args(pp, src, m, fnnd, nd.b);
    if sc != 0 { return sc; }
    let rt: i32 = new_local_ptr(m, retn, 0, 0, 0);
    emit_call(m, pp, src, rt, fnid, nd.p0, nd.p1);
    if m.reachable != 0 {
        let s: usize = m.pool_n;
        pool_lit(m, b"(stmt (copyval ");
        place_from_dbuf(m, root);
        pool_lit(m, b" (place ");
        pool_num(m, conv u64 rt);
        pool_lit(m, b" (proj (deref ");
        pool_ty(m, pp, src, retn);
        pool_lit(m, b"))) ");
        pool_ty(m, pp, src, retn);
        pool_lit(m, b") ");
        pool_num(m, conv u64 nd.p0);
        pool_byte(m, 32);
        pool_num(m, conv u64 nd.p1);
        pool_lit(m, b" false)");
        chunk_end(m, s);
    }
    return 0;
}
// A whole-aggregate value read from a place (`let q = p;`): byte-copy dst <- src.
fn lower_agg_copy(pp: read P, src: [u8], m: write M, i: u32, root: i32, tn: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    if !is_copy(pp, src, m.head, tn) {
        mark_moved(pp, src, m, i);
    }
    // Pre-lower a static base + any index operands (a non-const index like
    // `a[conv usize i]` produces its own statement) BEFORE rendering the source
    // place, so `emit_projs` reads the registered operand instead of re-lowering
    // it into the middle of the place projection (matches lower_place_value).
    place_base_prep(pp, src, m, i);
    m.*.idx_cnt = 0usize;
    prep_place(pp, src, m, i);
    if m.reachable != 0 {
        let s: usize = m.pool_n;
        pool_lit(m, b"(stmt (copyval ");
        place_from_dbuf(m, root);
        pool_byte(m, 32);
        render_place_read(pp, src, m, i);
        pool_byte(m, 32);
        pool_ty(m, pp, src, tn);
        pool_lit(m, b") ");
        pool_num(m, conv u64 nd.p0);
        pool_byte(m, 32);
        pool_num(m, conv u64 nd.p1);
        pool_lit(m, b" false)");
        chunk_end(m, s);
    }
    return 0;
}
// Lower an initializer expression `e` into the destination place (root + current
// dbuf prefix) whose type is `tn`. Scalars store; aggregates recurse per field/
// element; a call materializes through the return-slot ABI (build.rs lower_into).
fn lower_into(pp: read P, src: [u8], m: write M, e: u32, root: i32, tn: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize e];
    m.*.cur_p0 = nd.p0;
    m.*.cur_p1 = nd.p1;
    if nd.tag == T_PAREN { return lower_into(pp, src, m, nd.a, root, tn); }
    if nd.tag == T_STRUCTLIT { return lower_struct_lit(pp, src, m, e, root, tn); }
    if nd.tag == T_ARRAYLIT { return lower_array_lit(pp, src, m, e, root, tn); }
    if nd.tag == T_ARRAYREP { return lower_array_rep(pp, src, m, e, root, tn); }
    if nd.tag == T_ENUMCTOR { return lower_enum_ctor(pp, src, m, e, root, tn); }
    if nd.tag == T_MATCH { return lower_match_dst(pp, src, m, e, root, tn); }
    if nd.tag == T_STR || nd.tag == T_BYTES { return lower_str_into(pp, src, m, e, root); }
    if is_wordy_tn(pp, src, tn) {
        let sp0: usize = nd.p0;
        let sp1: usize = nd.p1;
        let w: i32 = scalar_width(pp, src, tn);
        let mut exp: i32 = 0 - 1i32;
        if w != 0 { exp = w; }
        let sc: i32 = lower_value(pp, src, m, e, exp);
        if sc != 0 { return sc; }
        set_o1(m, m.res_kind, m.res_val, m.res_neg, m.res_w);
        emit_store_dbuf(m, root, sp0, sp1);
        return 0;
    }
    if nd.tag == T_CALL {
        let callee: Node = pp.nodes[conv usize nd.a];
        if callee.tag == T_ID {
            if span_eq(src, callee.p0, callee.p1, b"box") { return lower_builtin_into(pp, src, m, e, root, tn); }
            if is_builtin_name(src, callee.p0, callee.p1) { return lower_builtin_into(pp, src, m, e, root, tn); }
            if is_coll_agg_call(pp, src, m, callee.p0, callee.p1, nd.b) { return lower_coll_agg_into(pp, src, m, e, root); }
        }
        return lower_call_agg(pp, src, m, e, root, tn);
    }
    return lower_agg_copy(pp, src, m, e, root, tn);
}

// ---- calls (arguments + emission) --------------------------------------------
// Lower each argument to an operand in m.ak/av/an/aw (m.na of them): a word-sized
// argument is its value; a by-value aggregate argument is passed as the ADDRESS of
// its place (a `(ref ...)` into a rawptr temp), matching build.rs's call ABI.
// A place-shaped expression (can be addressed directly); else a value that must be
// materialized into a temp before its address is taken (build.rs materialize_place).
fn is_place_expr(pp: read P, i: u32) -> bool {
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_PAREN { return is_place_expr(pp, nd.a); }
    if nd.tag == T_ID || nd.tag == T_FIELD || nd.tag == T_INDEX { return true; }
    if nd.tag == T_PREFIX && nd.op == PF_DEREF { return true; }
    return false;
}
fn lower_args(pp: read P, src: [u8], m: write M, fnnd: Node, arg_head: u32) -> i32 {
    m.*.na = 0usize;
    return lower_args_core(pp, src, m, fnnd.c, arg_head);
}
// The per-argument lowering loop shared by direct and method calls: pairs each
// argument against the parameter chain starting at `parc0`, appending operands
// to `m.na` (the caller seeds any leading `self` operand and does not reset na).
fn lower_args_core(pp: read P, src: [u8], m: write M, parc0: u32, arg_head: u32) -> i32 {
    let mut argc: u32 = arg_head;
    let mut parc: u32 = parc0;
    while argc != 0u32 {
        let pnode: Node = pp.nodes[conv usize parc];
        let ptn: u32 = pnode.a;
        let pmode: i32 = pnode.op;
        let w: i32 = scalar_width(pp, src, ptn);
        if pmode == 1 || pmode == 2 || is_wordy_tn(pp, src, ptn) {
            // Word-sized params (scalar / rawptr / fnptr / borrow) pass by value.
            let sc: i32 = lower_value(pp, src, m, argc, w);
            if sc != 0 { return sc; }
            let k: usize = m.na;
            m.*.ak[k] = m.res_kind;
            m.*.av[k] = m.res_val;
            m.*.an[k] = m.res_neg;
            m.*.aw[k] = m.res_w;
            m.*.na = k + 1usize;
        } else {
            let placeish: bool = is_place_expr(pp, argc);
            let mut tmp: i32 = 0 - 1i32;
            if !placeish {
                tmp = new_local_tn(m, ptn, 0, 0, 0);
                m.*.dbuf_n = 0usize;
                let sc2: i32 = lower_into(pp, src, m, argc, tmp, ptn);
                if sc2 != 0 { return sc2; }
            }
            if !is_copy(pp, src, m.head, ptn) {
                mark_moved(pp, src, m, argc);
            }
            let rt: i32 = new_local_ptr(m, ptn, 0, 0, 0);
            if m.reachable != 0 {
                let an2: Node = pp.nodes[conv usize argc];
                let s: usize = m.pool_n;
                pool_lit(m, b"(stmt (assign ");
                pool_num(m, conv u64 rt);
                pool_lit(m, b" (ref ");
                if placeish {
                    render_place_read(pp, src, m, argc);
                } else {
                    pool_lit(m, b"(place ");
                    pool_num(m, conv u64 tmp);
                    pool_lit(m, b" (proj))");
                }
                pool_lit(m, b")) ");
                pool_num(m, conv u64 an2.p0);
                pool_byte(m, 32);
                pool_num(m, conv u64 an2.p1);
                pool_lit(m, b" false)");
                chunk_end(m, s);
            }
            let k: usize = m.na;
            m.*.ak[k] = 1;
            m.*.av[k] = conv u64 rt;
            m.*.an[k] = 0;
            m.*.aw[k] = 0;
            m.*.na = k + 1usize;
        }
        argc = pp.nodes[conv usize argc].nx;
        parc = pp.nodes[conv usize parc].nx;
    }
    return 0;
}
fn emit_call(m: write M, pp: read P, src: [u8], dst: i32, fnid: u32, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (assign ");
    pool_num(m, conv u64 dst);
    pool_lit(m, b" (call ");
    pool_qname(m, pp, src, fnid);
    pool_lit(m, b" (args");
    let mut j: usize = 0usize;
    while j < m.na {
        pool_byte(m, 32);
        pool_operand(m, m.ak[j], m.av[j], m.an[j], m.aw[j]);
        j = j + 1usize;
    }
    pool_lit(m, b"))) ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    chunk_end(m, s);
    return;
}

// The pointee type node of a pointer-type node (rawptr/box/borrow); for a Box
// LOCAL whose stored type IS already the pointee, resolve_place_tn returns that.
fn pointee_of(pp: read P, ptn: u32) -> u32 {
    if ptn == 0u32 { return 0u32; }
    let nd: Node = pp.nodes[conv usize ptn];
    if nd.tag == T_RAWPTR || nd.tag == T_BOX || nd.tag == T_BORROW || nd.tag == T_BORROWMUT { return nd.a; }
    return ptn;
}
fn peel_box_tn(pp: read P, tn: u32) -> u32 {
    if tn == 0u32 { return tn; }
    if pp.nodes[conv usize tn].tag == T_BOX { return pp.nodes[conv usize tn].a; }
    return tn;
}
fn is_rawptr_tn(pp: read P, ptn: u32) -> bool {
    if ptn == 0u32 { return false; }
    return pp.nodes[conv usize ptn].tag == T_RAWPTR;
}
// INV-OBS-ORDER: flip the last-emitted statement's trailing `false)` to `true)`
// (rawptr `ptr_read`/`ptr_write` are observable MMIO, build.rs mark_last_observable).
fn mark_last_observable(m: write M) -> unit {
    if m.reachable == 0 { return; }
    if m.pn_n == 0usize { return; }
    let k: usize = m.pn_n - 1usize;
    let en: usize = m.pn_start[k] + m.pn_len[k];
    // bytes [en-6, en) are "false)"; rewrite to "true)" and shrink by one.
    m.*.pool[en - 6usize] = 116u8;
    m.*.pool[en - 5usize] = 114u8;
    m.*.pool[en - 4usize] = 117u8;
    m.*.pool[en - 3usize] = 101u8;
    m.*.pool[en - 2usize] = 41u8;
    m.*.pn_len[k] = m.pn_len[k] - 1usize;
    m.*.pool_n = m.pool_n - 1usize;
    return;
}
// fn-pointer-ABI argument lowering (mirrors `lower_args` but over T_FPPARAM types).
fn lower_args_fnptr(pp: read P, src: [u8], m: write M, parc0: u32, arg_head: u32) -> i32 {
    m.*.na = 0usize;
    let mut argc: u32 = arg_head;
    let mut parc: u32 = parc0;
    while argc != 0u32 {
        let ptn: u32 = pp.nodes[conv usize parc].a;
        let w: i32 = scalar_width(pp, src, ptn);
        if w != 0 {
            let sc: i32 = lower_value(pp, src, m, argc, w);
            if sc != 0 { return sc; }
            let k: usize = m.na;
            m.*.ak[k] = m.res_kind; m.*.av[k] = m.res_val; m.*.an[k] = m.res_neg; m.*.aw[k] = m.res_w;
            m.*.na = k + 1usize;
        } else if is_wordy_tn(pp, src, ptn) {
            let sc: i32 = lower_value(pp, src, m, argc, 0 - 1i32);
            if sc != 0 { return sc; }
            let k: usize = m.na;
            m.*.ak[k] = m.res_kind; m.*.av[k] = m.res_val; m.*.an[k] = m.res_neg; m.*.aw[k] = m.res_w;
            m.*.na = k + 1usize;
        } else {
            let placeish: bool = is_place_expr(pp, argc);
            let mut tmp: i32 = 0 - 1i32;
            if !placeish {
                tmp = new_local_tn(m, ptn, 0, 0, 0);
                m.*.dbuf_n = 0usize;
                let sc2: i32 = lower_into(pp, src, m, argc, tmp, ptn);
                if sc2 != 0 { return sc2; }
            }
            if !is_copy(pp, src, m.head, ptn) { mark_moved(pp, src, m, argc); }
            let rt: i32 = new_local_ptr(m, ptn, 0, 0, 0);
            if m.reachable != 0 {
                let an2: Node = pp.nodes[conv usize argc];
                let s: usize = m.pool_n;
                pool_lit(m, b"(stmt (assign ");
                pool_num(m, conv u64 rt);
                pool_lit(m, b" (ref ");
                if placeish { render_place_read(pp, src, m, argc); }
                else { pool_lit(m, b"(place "); pool_num(m, conv u64 tmp); pool_lit(m, b" (proj))"); }
                pool_lit(m, b")) ");
                pool_num(m, conv u64 an2.p0);
                pool_byte(m, 32);
                pool_num(m, conv u64 an2.p1);
                pool_lit(m, b" false)");
                chunk_end(m, s);
            }
            let k: usize = m.na;
            m.*.ak[k] = 1; m.*.av[k] = conv u64 rt; m.*.an[k] = 0; m.*.aw[k] = 0;
            m.*.na = k + 1usize;
        }
        argc = pp.nodes[conv usize argc].nx;
        parc = pp.nodes[conv usize parc].nx;
    }
    return 0;
}
// Emit `(place root (proj (deref <inner>)))` for a through-pointer access.
fn render_deref_place(m: write M, pp: read P, src: [u8], root: i32, inner: u32) -> unit {
    pool_lit(m, b"(place ");
    pool_num(m, conv u64 root);
    pool_lit(m, b" (proj (deref ");
    pool_ty(m, pp, src, inner);
    pool_lit(m, b")))");
    return;
}
// The word/unit-producing pointer + box intrinsics (design 0004 / 0001 §6.2). `i`
// is the T_CALL node; the callee name selects the intrinsic. Aggregate `ptr_read`/
// `unbox`/`box` flow through `lower_builtin_into` instead.
fn lower_builtin_value(pp: read P, src: [u8], m: write M, i: u32, cp0: usize, cp1: usize, sp0: usize, sp1: usize) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let a0: u32 = nd.b;
    if span_eq(src, cp0, cp1, b"addr_of") || span_eq(src, cp0, cp1, b"addr_of_mut") {
        place_base_prep(pp, src, m, a0);
        let ttn: u32 = resolve_place_tn(pp, src, m, a0);
        let tmp: i32 = new_local_ptr(m, ttn, 0, 0, 0);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (assign ");
            pool_num(m, conv u64 tmp);
            pool_lit(m, b" (ref ");
            render_place_read(pp, src, m, a0);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        set_res_local(m, tmp, 10);
        m.*.res_pointee = ttn;
        m.*.res_israw = 1;
        return 0;
    }
    if span_eq(src, cp0, cp1, b"len") {
        let rtn: u32 = coll_recv_tn(pp, src, m, a0);
        if is_vec_ty(pp, src, rtn) || is_map_ty(pp, src, rtn) {
            // `len(read Vec[T]/Map[V])`: the length word lives at offset 8 of the
            // collection the borrow names (build.rs deref + field-8 load).
            let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
            if sc != 0 { return sc; }
            let broot: i32 = conv i32 m.res_val;
            let tmp: i32 = new_local(m, 10, 0, 0, 0);
            if m.reachable != 0 {
                let s: usize = m.pool_n;
                pool_lit(m, b"(stmt (assign ");
                pool_num(m, conv u64 tmp);
                pool_lit(m, b" (load (place ");
                pool_num(m, conv u64 broot);
                pool_lit(m, b" (proj (deref (scalar usize)) (field 8 (scalar usize)))) (scalar usize))) ");
                pool_num(m, conv u64 sp0);
                pool_byte(m, 32);
                pool_num(m, conv u64 sp1);
                pool_lit(m, b" false)");
                chunk_end(m, s);
            }
            set_res_local(m, tmp, 10);
            return 0;
        }
        place_base_prep(pp, src, m, a0);
        m.*.idx_cnt = 0usize;
        prep_place(pp, src, m, a0);
        let ttn: u32 = resolve_place_tn(pp, src, m, a0);
        let tnode: Node = pp.nodes[conv usize ttn];
        if tnode.tag == T_SLICE || tnode.tag == T_SLICEMUT || tn_is_str_ty(pp, src, ttn) {
            let tmp: i32 = new_local(m, 10, 0, 0, 0);
            if m.reachable != 0 {
                let s: usize = m.pool_n;
                pool_lit(m, b"(stmt (assign ");
                pool_num(m, conv u64 tmp);
                pool_lit(m, b" (load ");
                render_place_field(pp, src, m, a0, 8usize, 1, 9, 0u32);
                pool_lit(m, b" (scalar usize))) ");
                pool_num(m, conv u64 sp0);
                pool_byte(m, 32);
                pool_num(m, conv u64 sp1);
                pool_lit(m, b" false)");
                chunk_end(m, s);
            }
            set_res_local(m, tmp, 10);
            return 0;
        }
        let n: usize = array_len_of(pp, tnode.a);
        set_res_const(m, conv u64 n, 0, 10);
        return 0;
    }
    if span_eq(src, cp0, cp1, b"is_null") {
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return sc; }
        let op_k: i32 = m.res_kind; let op_v: u64 = m.res_val; let op_n: i32 = m.res_neg;
        let tmp: i32 = new_local(m, W_BOOL, 0, 0, 0);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (assign ");
            pool_num(m, conv u64 tmp);
            pool_lit(m, b" (isnull ");
            pool_operand(m, op_k, op_v, op_n, 9);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        set_res_local(m, tmp, W_BOOL);
        return 0;
    }
    if span_eq(src, cp0, cp1, b"ptr_to_addr") {
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return sc; }
        set_o1(m, m.res_kind, m.res_val, m.res_neg, 9);
        let tmp: i32 = new_local(m, 10, 0, 0, 0);
        st_assign_use(m, tmp, sp0, sp1);
        set_res_local(m, tmp, 10);
        return 0;
    }
    if span_eq(src, cp0, cp1, b"ptr_offset") {
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return sc; }
        let bk: i32 = m.res_kind; let bv: u64 = m.res_val; let bn: i32 = m.res_neg;
        let inner: u32 = m.res_pointee;
        let stride: usize = ty_size(pp, src, m.head, inner);
        let a1: u32 = pp.nodes[conv usize a0].nx;
        let sc2: i32 = lower_value(pp, src, m, a1, 5);
        if sc2 != 0 { return sc2; }
        let ik: i32 = m.res_kind; let iv: u64 = m.res_val; let in2: i32 = m.res_neg; let iw: i32 = m.res_w;
        let tmp: i32 = new_local_ptr(m, inner, 0, 0, 0);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (assign ");
            pool_num(m, conv u64 tmp);
            pool_lit(m, b" (ptrarith ");
            pool_operand(m, bk, bv, bn, 9);
            pool_byte(m, 32);
            pool_operand(m, ik, iv, in2, iw);
            pool_byte(m, 32);
            pool_num(m, conv u64 stride);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        set_res_local(m, tmp, 10);
        m.*.res_pointee = inner;
        m.*.res_israw = 1;
        return 0;
    }
    if span_eq(src, cp0, cp1, b"ptr_read") {
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return sc; }
        let inner: u32 = m.res_pointee;
        let mut raw: bool = false;
        if m.res_israw != 0 { raw = true; }
        let root: i32 = conv i32 m.res_val;
        let iw: i32 = scalar_width(pp, src, inner);
        let mut id: i32 = 0;
        if iw != 0 { id = new_local(m, iw, 0, 0, 0); } else { id = new_local_tn(m, inner, 0, 0, 0); }
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (assign ");
            pool_num(m, conv u64 id);
            pool_lit(m, b" (load ");
            render_deref_place(m, pp, src, root, inner);
            pool_byte(m, 32);
            pool_ty(m, pp, src, inner);
            pool_lit(m, b")) ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
            if raw { mark_last_observable(m); }
        }
        if iw != 0 { set_res_local(m, id, iw); } else { set_res_local(m, id, 10); }
        return 0;
    }
    if span_eq(src, cp0, cp1, b"ptr_write") {
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return sc; }
        let inner: u32 = m.res_pointee;
        let mut raw: bool = false;
        if m.res_israw != 0 { raw = true; }
        let root: i32 = conv i32 m.res_val;
        let a1: u32 = pp.nodes[conv usize a0].nx;
        m.*.dbuf_n = 0usize;
        let ds: usize = m.pool_n;
        pool_lit(m, b" (deref ");
        pool_ty(m, pp, src, inner);
        pool_byte(m, 41);
        reloc_to_dbuf(m, ds);
        let sc2: i32 = lower_into(pp, src, m, a1, root, inner);
        if sc2 != 0 { return sc2; }
        if raw { mark_last_observable(m); }
        m.*.dbuf_n = 0usize;
        set_res_const(m, 0u64, 0, 0);
        return 0;
    }
    if span_eq(src, cp0, cp1, b"unbox") {
        place_base_prep(pp, src, m, a0);
        let inner: u32 = resolve_place_tn(pp, src, m, a0);
        let iw: i32 = scalar_width(pp, src, inner);
        let id: i32 = new_local(m, iw, 0, 0, 0);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (unboxop (place ");
            pool_num(m, conv u64 id);
            pool_lit(m, b" (proj)) ");
            pool_ty(m, pp, src, inner);
            pool_byte(m, 32);
            render_place_read(pp, src, m, a0);
            pool_lit(m, b") ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        mark_moved(pp, src, m, a0);
        set_res_local(m, id, iw);
        return 0;
    }
    m.*.err = 1;
    return 1;
}
// Aggregate-producing pointer/box builtins into a destination place (root + dbuf):
// `box`, aggregate `unbox`, aggregate `ptr_read`.
fn lower_builtin_into(pp: read P, src: [u8], m: write M, i: u32, root: i32, tn: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let callee: Node = pp.nodes[conv usize nd.a];
    let a0: u32 = nd.b;
    let sp0: usize = nd.p0;
    let sp1: usize = nd.p1;
    if span_eq(src, callee.p0, callee.p1, b"ptr_read") {
        let sc: i32 = lower_value(pp, src, m, a0, 0 - 1i32);
        if sc != 0 { return sc; }
        let mut raw: bool = false;
        if m.res_israw != 0 { raw = true; }
        let root_ptr: i32 = conv i32 m.res_val;
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (copyval ");
            place_from_dbuf(m, root);
            pool_byte(m, 32);
            render_deref_place(m, pp, src, root_ptr, tn);
            pool_byte(m, 32);
            pool_ty(m, pp, src, tn);
            pool_lit(m, b") ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
            if raw { mark_last_observable(m); }
        }
        return 0;
    }
    if span_eq(src, callee.p0, callee.p1, b"unbox") {
        place_base_prep(pp, src, m, a0);
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (unboxop ");
            place_from_dbuf(m, root);
            pool_byte(m, 32);
            pool_ty(m, pp, src, tn);
            pool_byte(m, 32);
            render_place_read(pp, src, m, a0);
            pool_lit(m, b") ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        mark_moved(pp, src, m, a0);
        return 0;
    }
    if span_eq(src, callee.p0, callee.p1, b"box") {
        let inner: u32 = pp.nodes[conv usize tn].a;
        let a1: u32 = pp.nodes[conv usize a0].nx;
        // alloc handle address (build.rs alloc_addr_operand): a `read`/`write` prefix
        // is the borrow value; a borrow-typed variable passes its value directly; an
        // owned `Alloc` place is addressed with `(ref ...)`.
        let a0nd: Node = pp.nodes[conv usize a0];
        let mut alloc_tmp: i32 = 0;
        if a0nd.tag == T_PREFIX && (a0nd.op == PF_READ || a0nd.op == PF_WRITE) {
            let scb: i32 = lower_borrow_val(pp, src, m, a0);
            if scb != 0 { return scb; }
            alloc_tmp = conv i32 m.res_val;
        } else {
            let mut lid: i32 = 0 - 1i32;
            if a0nd.tag == T_ID {
                let idl: i32 = lookup(m, src, a0nd.p0, a0nd.p1);
                if idl >= 0 && m.loc_ptr[conv usize idl] >= 2 { lid = idl; }
            }
            if lid >= 0 {
                alloc_tmp = lid;
            } else {
                place_base_prep(pp, src, m, a0);
                let altn: u32 = resolve_place_tn(pp, src, m, a0);
                alloc_tmp = new_local_ptr(m, altn, 0, 0, 0);
                if m.reachable != 0 {
                    let s: usize = m.pool_n;
                    pool_lit(m, b"(stmt (assign ");
                    pool_num(m, conv u64 alloc_tmp);
                    pool_lit(m, b" (ref ");
                    render_place_read(pp, src, m, a0);
                    pool_lit(m, b")) ");
                    pool_num(m, conv u64 a0nd.p0);
                    pool_byte(m, 32);
                    pool_num(m, conv u64 a0nd.p1);
                    pool_lit(m, b" false)");
                    chunk_end(m, s);
                }
            }
        }
        // value: a place directly, or materialized into a fresh temp.
        let val_place_is: bool = is_place_expr(pp, a1);
        let mut val_tmp: i32 = 0 - 1i32;
        if !val_place_is {
            let vw: i32 = scalar_width(pp, src, inner);
            if vw != 0 { val_tmp = new_local(m, vw, 0, 0, 0); }
            else { val_tmp = new_local_tn(m, inner, 0, 0, 0); }
            m.*.dbuf_n = 0usize;
            let scv: i32 = lower_into(pp, src, m, a1, val_tmp, inner);
            if scv != 0 { return scv; }
        }
        if !is_copy(pp, src, m.head, inner) { mark_moved(pp, src, m, a1); }
        if m.reachable != 0 {
            let s: usize = m.pool_n;
            pool_lit(m, b"(stmt (boxop ");
            place_from_dbuf(m, root);
            pool_byte(m, 32);
            pool_ty(m, pp, src, inner);
            pool_byte(m, 32);
            pool_ty(m, pp, src, tn);
            pool_byte(m, 32);
            pool_lit(m, b"(oplocal ");
            pool_num(m, conv u64 alloc_tmp);
            pool_byte(m, 41);
            pool_byte(m, 32);
            if val_place_is { render_place_read(pp, src, m, a1); }
            else { pool_lit(m, b"(place "); pool_num(m, conv u64 val_tmp); pool_lit(m, b" (proj))"); }
            pool_lit(m, b") ");
            pool_num(m, conv u64 sp0);
            pool_byte(m, 32);
            pool_num(m, conv u64 sp1);
            pool_lit(m, b" false)");
            chunk_end(m, s);
        }
        return 0;
    }
    m.*.err = 1;
    return 1;
}

fn lower_return(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    if nd.a != 0u32 {
        m.*.dbuf_n = 0usize;
        let sc: i32 = lower_into(pp, src, m, nd.a, 0, m.ret_tn);
        if sc != 0 { return sc; }
    }
    emit_return_drops(pp, src, m);
    term_return(m);
    return 0;
}

fn lower_stmt(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_LET {
        if nd.a != 0u32 {
            let tn: u32 = nd.a;
            let w: i32 = scalar_width(pp, src, tn);
            let mut id: i32 = 0;
            if w != 0 { id = new_local(m, w, 1, nd.p0, nd.p1); }
            else { id = new_local_tn(m, tn, 1, nd.p0, nd.p1); }
            if nd.b != 0u32 {
                m.*.dbuf_n = 0usize;
                let sc: i32 = lower_into(pp, src, m, nd.b, id, tn);
                if sc != 0 { return sc; }
            }
            bind(m, nd.p0, nd.p1, id, w, tn);
            return 0;
        }
        // no annotation: infer from the initializer (scalar subset).
        if nd.b == 0u32 { m.*.err = 1; return 1; }
        let sc: i32 = lower_value(pp, src, m, nd.b, 0 - 1i32);
        if sc != 0 { return sc; }
        let w: i32 = m.res_w;
        let ok: i32 = m.res_kind; let ov: u64 = m.res_val; let og: i32 = m.res_neg;
        let id: i32 = new_local(m, w, 1, nd.p0, nd.p1);
        set_o1(m, ok, ov, og, w);
        st_assign_use(m, id, m.cur_p0, m.cur_p1);
        bind(m, nd.p0, nd.p1, id, w, 0u32);
        return 0;
    }
    if nd.tag == T_ASSIGN {
        let ttn: u32 = resolve_place_tn(pp, src, m, nd.a);
        build_dbuf_place(pp, src, m, nd.a);
        let root: i32 = m.plc_local;
        let sc: i32 = lower_into(pp, src, m, nd.b, root, ttn);
        reassign_reown(pp, src, m, nd.a);
        return sc;
    }
    // expression statement (trace, if/while/loop, return, ...)
    return lower_value(pp, src, m, i, 0 - 1i32);
}

fn lower_block(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    scope_push(m);
    let bsave: usize = m.bnd_n;
    let nd: Node = pp.nodes[conv usize i];
    let mut cur: u32 = nd.a;
    while cur != 0u32 {
        if m.reachable == 0 { break; }
        let sc: i32 = lower_stmt(pp, src, m, cur);
        if sc != 0 { scope_pop_drops(pp, src, m); m.*.bnd_n = bsave; return sc; }
        cur = pp.nodes[conv usize cur].nx;
    }
    scope_pop_drops(pp, src, m);
    m.*.bnd_n = bsave;
    return 0;
}

fn reset_fn(m: write M) -> unit {
    m.*.loc_n = 0usize;
    m.*.blk_n = 0usize;
    m.*.pool_n = 0usize;
    m.*.pn_n = 0usize;
    m.*.bnd_n = 0usize;
    m.*.loop_n = 0usize;
    m.*.reachable = 1;
    m.*.regime = 0;
    m.*.cur = 0;
    m.*.ret_w = 4;
    m.*.ret_tn = 0u32;
    m.*.dbuf_n = 0usize;
    m.*.fn_entry = 0;
    m.*.fn_np = 0;
    m.*.sco_n = 0usize;
    m.*.sco_depth = 0usize;
    m.*.mv_n = 0usize;
    m.*.mv_seg_n = 0usize;
    return;
}

fn lower_fn(pp: read P, src: [u8], m: write M, fnid: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize fnid];
    let mut retn: u32 = 0u32;
    let bri: i32 = bret_lookup(m, fnid);
    if bri >= 0 { retn = m.bret_tn[conv usize bri]; }
    else if nd.e != 0u32 { retn = pp.nodes[conv usize nd.e].a; }
    let retw: i32 = scalar_width(pp, src, retn);
    m.*.ret_w = retw;
    m.*.ret_tn = retn;
    // _0 is the return place: a scalar, an aggregate slot, or unit.
    if retw != 0 { let _r: i32 = new_local(m, retw, 0, 0, 0); }
    else if retn != 0u32 { let _r: i32 = new_local_tn(m, retn, 0, 0, 0); }
    else { let _r: i32 = new_local(m, 0, 0, 0, 0); }
    scope_push(m);
    let mut pc: u32 = nd.c;
    let mut np: i32 = 0;
    while pc != 0u32 {
        let pn: Node = pp.nodes[conv usize pc];
        let ptn: u32 = pn.a;
        let mut id: i32 = 0;
        let mut w: i32 = 0;
        if pn.op == 1 {
            id = new_local_borrow_sh(m, ptn, 1, pn.p0, pn.p1);
        } else if pn.op == 2 {
            id = new_local_borrow(m, ptn, 1, pn.p0, pn.p1);
        } else if pn.op == 0 {
            w = scalar_width(pp, src, ptn);
            if w != 0 { id = new_local(m, w, 1, pn.p0, pn.p1); }
            else { id = new_local_tn(m, ptn, 1, pn.p0, pn.p1); }
        } else {
            m.*.err = 1;
            return 1;
        }
        bind(m, pn.p0, pn.p1, id, w, ptn);
        np = np + 1;
        pc = pn.nx;
    }
    m.*.fn_np = np;
    let entry: i32 = new_block(m);
    m.*.fn_entry = entry;
    switch_to(m, entry);
    let sc: i32 = lower_block(pp, src, m, nd.d);
    if sc != 0 { scope_pop_drops(pp, src, m); return sc; }
    if m.reachable != 0 { term_return(m); }
    scope_pop_drops(pp, src, m);
    return 0;
}
// Lower a struct `drop` hook to a MIR fn `<drop Name>(write self)` — `self` is a
// drop-inert borrow, so field reads deref it and the param scope drops nothing.
fn lower_hook(pp: read P, src: [u8], m: write M, sid: u32) -> i32 {
    m.*.ret_w = 0;
    m.*.ret_tn = 0u32;
    let _r: i32 = new_local(m, 0, 0, 0, 0);
    let selfid: i32 = new_local_borrow(m, sid, 1, m.self_p0, m.self_p1);
    m.*.fn_np = 1;
    scope_push(m);
    bind(m, m.self_p0, m.self_p1, selfid, 0, sid);
    let snode: Node = pp.nodes[conv usize sid];
    let entry: i32 = new_block(m);
    m.*.fn_entry = entry;
    switch_to(m, entry);
    let sc: i32 = lower_block(pp, src, m, snode.c);
    if sc != 0 { scope_pop_drops(pp, src, m); return sc; }
    if m.reachable != 0 { term_return(m); }
    scope_pop_drops(pp, src, m);
    return 0;
}
// Lower a `static NAME: T = value;` initializer to `<init NAME>()` returning the
// value into `_0` (build.rs lower_static_init; run once before `main`).
fn lower_static_init(pp: read P, src: [u8], m: write M, stid: u32) -> i32 {
    let st: Node = pp.nodes[conv usize stid];
    let sty: u32 = st.a;
    let w: i32 = scalar_width(pp, src, sty);
    m.*.ret_w = w;
    m.*.ret_tn = sty;
    if w != 0 { let _r: i32 = new_local(m, w, 0, 0, 0); }
    else { let _r: i32 = new_local_tn(m, sty, 0, 0, 0); }
    m.*.fn_np = 0;
    scope_push(m);
    let entry: i32 = new_block(m);
    m.*.fn_entry = entry;
    switch_to(m, entry);
    m.*.dbuf_n = 0usize;
    let sc: i32 = lower_into(pp, src, m, st.b, 0, sty);
    if sc != 0 { scope_pop_drops(pp, src, m); return sc; }
    if m.reachable != 0 { term_return(m); }
    scope_pop_drops(pp, src, m);
    return 0;
}

// ---- emission (trace sink) --------------------------------------------------
fn emit_byte(x: i32) -> unit {
    trace(conv i64 x);
    return;
}
fn emit_scalar(w: i32) -> unit {
    if w == 1 { emit_lit(b"i8"); return; }
    if w == 2 { emit_lit(b"i16"); return; }
    if w == 3 { emit_lit(b"i32"); return; }
    if w == 4 { emit_lit(b"i64"); return; }
    if w == 5 { emit_lit(b"isize"); return; }
    if w == 6 { emit_lit(b"u8"); return; }
    if w == 7 { emit_lit(b"u16"); return; }
    if w == 8 { emit_lit(b"u32"); return; }
    if w == 9 { emit_lit(b"u64"); return; }
    if w == 10 { emit_lit(b"usize"); return; }
    if w == W_BOOL { emit_lit(b"bool"); return; }
    if w == 12 { emit_lit(b"unit"); return; }
    emit_lit(b"unit");
    return;
}
fn emit_qspan(src: [u8], p0: usize, p1: usize) -> unit {
    emit_byte(34);
    emit_bytes(src, p0, p1);
    emit_byte(34);
    return;
}
// Emit a Type s-expression through the trace sink (mirrors pool_ty).
fn emit_ty(pp: read P, src: [u8], tn: u32) -> unit {
    let w: i32 = scalar_width(pp, src, tn);
    if w != 0 {
        emit_lit(b"(scalar ");
        emit_scalar(w);
        emit_byte(41);
        return;
    }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_ARRAY {
        emit_lit(b"(array ");
        emit_ty(pp, src, nd.b);
        emit_lit(b" (litlen ");
        emit_num(conv u64 array_len_of(pp, nd.a));
        emit_lit(b"))");
        return;
    }
    if nd.tag == T_RAWPTR { emit_lit(b"(rawptr "); emit_ty(pp, src, nd.a); emit_byte(41); return; }
    if nd.tag == T_BOX { emit_lit(b"(box "); emit_ty(pp, src, nd.a); emit_byte(41); return; }
    if nd.tag == T_BOXRESULT { emit_lit(b"(boxresult "); emit_ty(pp, src, nd.a); emit_byte(41); return; }
    if nd.tag == T_BORROW { emit_lit(b"(borrow "); emit_ty(pp, src, nd.a); emit_byte(41); return; }
    if nd.tag == T_BORROWMUT { emit_lit(b"(borrowmut "); emit_ty(pp, src, nd.a); emit_byte(41); return; }
    if nd.tag == T_SLICE { emit_lit(b"(slice "); emit_ty(pp, src, nd.a); emit_byte(41); return; }
    if nd.tag == T_SLICEMUT { emit_lit(b"(slicemut "); emit_ty(pp, src, nd.a); emit_byte(41); return; }
    if nd.tag == T_FNPTR { emit_fnptr(pp, src, tn); return; }
    if tn_is_str_ty(pp, src, tn) { emit_lit(b"(str)"); return; }
    if nd.tag == T_APP && nd.b == 0u32 {
        emit_lit(b"(app ");
        emit_qspan(src, nd.p0, nd.p1);
        emit_byte(32);
        emit_ty(pp, src, nd.a);
        emit_byte(41);
        return;
    }
    if nd.tag == T_APP && nd.b != 0u32 {
        emit_lit(b"(named ");
        emit_byte(34);
        emit_inst_name(pp, src, nd.b);
        emit_byte(34);
        emit_byte(41);
        return;
    }
    emit_lit(b"(named ");
    emit_qspan(src, nd.p0, nd.p1);
    emit_byte(41);
    return;
}
fn emit_parammode(mode: i32) -> unit {
    if mode == 1 { emit_lit(b"read"); return; }
    if mode == 2 { emit_lit(b"write"); return; }
    if mode == 3 { emit_lit(b"out"); return; }
    emit_lit(b"take");
    return;
}
fn emit_fnptr(pp: read P, src: [u8], tn: u32) -> unit {
    let nd: Node = pp.nodes[conv usize tn];
    emit_lit(b"(fnptr ");
    if (nd.op / 1) % 2 != 0 { emit_lit(b"true "); } else { emit_lit(b"false "); }
    if (nd.op / 2) % 2 != 0 { emit_lit(b"true "); } else { emit_lit(b"false "); }
    emit_ty(pp, src, nd.b);
    emit_lit(b" (params (");
    let mut fp: u32 = nd.a;
    let mut first: i32 = 1;
    while fp != 0u32 {
        let fpn: Node = pp.nodes[conv usize fp];
        if first == 0 { emit_byte(32); }
        emit_byte(40);
        emit_parammode(fpn.op);
        emit_byte(32);
        emit_ty(pp, src, fpn.a);
        emit_byte(41);
        first = 0;
        fp = fpn.nx;
    }
    emit_lit(b")))");
    return;
}
fn emit_ty_boxwrap(pp: read P, src: [u8], inner: u32) -> unit {
    emit_lit(b"(box ");
    emit_ty(pp, src, inner);
    emit_byte(41);
    return;
}
fn emit_chunk(m: write M, start: usize, ln: usize) -> unit {
    let mut j: usize = start;
    while j < start + ln {
        trace(conv i64 m.pool[j]);
        j = j + 1usize;
    }
    return;
}
fn emit_block(m: write M, b: usize) -> unit {
    emit_lit(b" (block (stmts");
    let mut k: i32 = m.blk_shead[b];
    while k >= 0 {
        emit_byte(32);
        emit_chunk(m, m.pn_start[conv usize k], m.pn_len[conv usize k]);
        k = m.pn_nx[conv usize k];
    }
    emit_lit(b") ");
    emit_chunk(m, m.blk_tstart[b], m.blk_tlen[b]);
    emit_byte(41);
    return;
}
// The synthesized hook name `"<drop Name>"` (name = the struct's name span).
fn emit_inst_name(pp: read P, src: [u8], id: u32) -> unit {
    let nd: Node = pp.nodes[conv usize id];
    emit_bytes(src, nd.p0, nd.p1);
    let mut cur: u32 = conv u32 nd.ival;
    while cur != 0u32 {
        let cell: Node = pp.nodes[conv usize cur];
        emit_byte(36);
        emit_mangle_ty(pp, src, cell.a);
        cur = cell.nx;
    }
    return;
}
fn emit_mangle_ty(pp: read P, src: [u8], tn: u32) -> unit {
    let w: i32 = scalar_width(pp, src, tn);
    if w != 0 { emit_scalar(w); return; }
    let nd: Node = pp.nodes[conv usize tn];
    if nd.tag == T_APP && nd.b != 0u32 { emit_inst_name(pp, src, nd.b); return; }
    emit_bytes(src, nd.p0, nd.p1);
    return;
}
fn emit_qname(pp: read P, src: [u8], id: u32) -> unit {
    emit_byte(34);
    emit_inst_name(pp, src, id);
    emit_byte(34);
    return;
}
fn emit_hook_qname(pp: read P, src: [u8], id: u32) -> unit {
    emit_byte(34);
    emit_lit(b"<drop ");
    emit_inst_name(pp, src, id);
    emit_byte(62);
    emit_byte(34);
    return;
}
fn emit_hook_ref(src: [u8], p0: usize, p1: usize) -> unit {
    emit_byte(34);
    emit_lit(b"<drop ");
    emit_bytes(src, p0, p1);
    emit_byte(62);
    emit_byte(34);
    return;
}
fn emit_init_ref(src: [u8], p0: usize, p1: usize) -> unit {
    emit_byte(34);
    emit_lit(b"<init ");
    emit_bytes(src, p0, p1);
    emit_byte(62);
    emit_byte(34);
    return;
}
// kind: 0 = user fn (quoted name), 1 = drop hook (`<drop N>`), 2 = static init (`<init N>`).
fn emit_fn(m: write M, pp: read P, src: [u8], defid: u32, impl_id: u32, kind: i32) -> unit {
    let dn: Node = pp.nodes[conv usize defid];
    emit_lit(b"(fn ");
    if kind == 1 {
        emit_hook_qname(pp, src, defid);
    } else if kind == 2 {
        emit_init_ref(src, dn.p0, dn.p1);
    } else if kind == 3 {
        emit_impl_method_name(pp, src, impl_id, defid);
    } else {
        emit_qname(pp, src, defid);
    }
    emit_byte(32);
    emit_num(conv u64 m.fn_np);
    emit_lit(b" (none) (locals");
    let mut i: usize = 0usize;
    while i < m.loc_n {
        emit_lit(b" (local ");
        if m.loc_box[i] != 0 {
            emit_ty_boxwrap(pp, src, m.loc_tn[i]);
        } else if m.loc_ptr[i] == 2 {
            emit_lit(b"(borrowmut ");
            emit_ty(pp, src, m.loc_tn[i]);
            emit_byte(41);
        } else if m.loc_ptr[i] == 3 {
            emit_lit(b"(borrow ");
            emit_ty(pp, src, m.loc_tn[i]);
            emit_byte(41);
        } else if m.loc_ptr[i] != 0 {
            emit_lit(b"(rawptr ");
            emit_ty(pp, src, m.loc_tn[i]);
            emit_byte(41);
        } else if m.loc_tn[i] != 0u32 {
            emit_ty(pp, src, m.loc_tn[i]);
        } else {
            emit_lit(b"(scalar ");
            emit_scalar(m.loc_w[i]);
            emit_byte(41);
        }
        emit_byte(32);
        if m.loc_named[i] != 0 {
            emit_lit(b"(some ");
            emit_qspan(src, m.loc_p0[i], m.loc_p1[i]);
            emit_byte(41);
        } else {
            emit_lit(b"(none)");
        }
        let mut dob: i32 = 0;
        if m.loc_box[i] != 0 {
            dob = 1;
        } else if m.loc_ptr[i] == 0 {
            if needs_drop(pp, src, m.head, m.loc_tn[i]) { dob = 1; }
        }
        if dob != 0 { emit_lit(b" true)"); } else { emit_lit(b" false)"); }
        i = i + 1usize;
    }
    emit_lit(b") (blocks");
    let mut b: usize = 0usize;
    while b < m.blk_n {
        emit_block(m, b);
        b = b + 1usize;
    }
    emit_lit(b") ");
    emit_num(conv u64 m.fn_entry);
    emit_lit(b" (requires) (ensures) precise)");
    return;
}

fn collect_fnptrs(pp: read P, src: [u8], m: write M) -> unit {
    let mut cur: u32 = m.head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_FN && nd.a == 0u32 {
            let k: usize = m.fp_n;
            m.*.fp_p0[k] = nd.p0;
            m.*.fp_p1[k] = nd.p1;
            m.*.fp_n = k + 1usize;
        }
        cur = nd.nx;
    }
    return;
}

// ---- enums / match (L4) ------------------------------------------------------
// Append ` (field <off> (scalar w))` to dbuf (the enum tag store's projection).
fn dbuf_field_scalar(m: write M, off: usize, w: i32) -> unit {
    let s: usize = m.pool_n;
    pool_lit(m, b" (field ");
    pool_num(m, conv u64 off);
    pool_byte(m, 32);
    pool_lit(m, b"(scalar ");
    pool_scalar(m, w);
    pool_byte(m, 41);
    pool_byte(m, 41);
    reloc_to_dbuf(m, s);
    return;
}
// Render `(place root (proj <base projs> (field off <leaf ty>)))` into the pool. A
// scalar leaf (the tag) emits `(scalar w)`; else `pool_ty(fty)`. Used for the tag
// read (off 0, u64) and payload-bind reads (payload offset, payload type).
fn render_place_field(pp: read P, src: [u8], m: write M, base: u32, off: usize, is_scalar: i32, w: i32, fty: u32) -> unit {
    let root: i32 = resolve_place_root(pp, src, m, base);
    if root < 0 { m.*.err = 1; }
    pool_lit(m, b"(place ");
    pool_num(m, conv u64 root);
    pool_lit(m, b" (proj");
    emit_projs(pp, src, m, base);
    if m.plc_box != 0 || m.plc_borrow != 0 {
        pool_lit(m, b" (deref ");
        pool_ty(m, pp, src, m.plc_tn);
        pool_byte(m, 41);
        m.*.plc_box = 0;
        m.*.plc_borrow = 0;
    }
    pool_lit(m, b" (field ");
    pool_num(m, conv u64 off);
    pool_byte(m, 32);
    if is_scalar != 0 {
        pool_lit(m, b"(scalar ");
        pool_scalar(m, w);
        pool_byte(m, 41);
    } else {
        pool_ty(m, pp, src, fty);
    }
    pool_lit(m, b")))");
    return;
}
// A copy-bind of a wordy payload: `(stmt (store (place loc (proj)) (load <src> <ty>)) ...)`.
fn emit_payload_load(pp: read P, src: [u8], m: write M, loc: i32, base: u32, off: usize, fty: u32, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (store (place ");
    pool_num(m, conv u64 loc);
    pool_lit(m, b" (proj)) (load ");
    render_place_field(pp, src, m, base, off, 0, 0, fty);
    pool_byte(m, 32);
    pool_ty(m, pp, src, fty);
    pool_lit(m, b")) ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    chunk_end(m, s);
    return;
}
// A move-/copy-bind of a non-wordy payload: byte-copy the payload sub-place into a
// fresh aggregate local: `(stmt (copyval (place loc (proj)) <payload place> <ty>) ...)`.
fn emit_payload_copyval(pp: read P, src: [u8], m: write M, loc: i32, base: u32, off: usize, fty: u32, sp0: usize, sp1: usize) -> unit {
    if m.reachable == 0 { return; }
    let s: usize = m.pool_n;
    pool_lit(m, b"(stmt (copyval (place ");
    pool_num(m, conv u64 loc);
    pool_lit(m, b" (proj)) ");
    render_place_field(pp, src, m, base, off, 0, 0, fty);
    pool_byte(m, 32);
    pool_ty(m, pp, src, fty);
    pool_lit(m, b") ");
    pool_num(m, conv u64 sp0);
    pool_byte(m, 32);
    pool_num(m, conv u64 sp1);
    pool_lit(m, b" false)");
    chunk_end(m, s);
    return;
}
// Mark the scrutinee's payload sub-path `<scrut path>._i` moved (an owned-match
// move-bind), so the scrutinee's tag-directed Drop prunes it (build.rs moves).
fn mark_moved_payload(pp: read P, src: [u8], m: write M, scrut: u32, idx: i32) -> unit {
    let seg_start: usize = m.mv_seg_n;
    let root: i32 = collect_path(pp, src, m, scrut);
    if root < 0 { m.*.mv_seg_n = seg_start; return; }
    let s: usize = m.mv_seg_n;
    m.*.mv_seg_p0[s] = 0usize;
    m.*.mv_seg_p1[s] = 0usize;
    m.*.mv_seg_syn[s] = idx;
    m.*.mv_seg_n = s + 1usize;
    let k: usize = m.mv_n;
    m.*.mv_local[k] = root;
    m.*.mv_seg_start[k] = seg_start;
    m.*.mv_seg_count[k] = m.mv_seg_n - seg_start;
    m.*.mv_n = k + 1usize;
    return;
}
// T_ENUMCTOR into a destination place (root + dbuf prefix): store the variant tag
// (u64 @0), then lower each argument into its payload offset (build.rs lower_enum_ctor).
fn lower_enum_ctor(pp: read P, src: [u8], m: write M, e: u32, root: i32, tn: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize e];
    let tnode: Node = pp.nodes[conv usize tn];
    if tnode.tag == T_BOXRESULT {
        // Synthetic BoxResult ctor: boxed(Box T)=tag 0 (payload@8), oom=tag 1.
        let inner: u32 = tnode.a;
        let vname: Node = pp.nodes[conv usize nd.a];
        let vidx: i32 = br_variant_index(src, vname.p0, vname.p1);
        if vidx < 0 { m.*.err = 1; return 1; }
        let base: usize = m.dbuf_n;
        m.*.dbuf_n = base;
        dbuf_field_scalar(m, 0usize, 9);
        set_o1(m, 0, conv u64 vidx, 0, 9);
        emit_store_dbuf(m, root, nd.p0, nd.p1);
        if vidx == 0 {
            let arg: u32 = nd.b;
            m.*.dbuf_n = base;
            dbuf_field_boxwrap(m, pp, src, 8usize, inner);
            if m.reachable != 0 {
                let s: usize = m.pool_n;
                pool_lit(m, b"(stmt (copyval ");
                place_from_dbuf(m, root);
                pool_byte(m, 32);
                render_place_read(pp, src, m, arg);
                pool_byte(m, 32);
                pool_ty_boxwrap(m, pp, src, inner);
                pool_lit(m, b") ");
                pool_num(m, conv u64 nd.p0);
                pool_byte(m, 32);
                pool_num(m, conv u64 nd.p1);
                pool_lit(m, b" false)");
                chunk_end(m, s);
            }
            mark_moved(pp, src, m, arg);
        }
        m.*.dbuf_n = base;
        return 0;
    }
    let mut eid: u32 = nd.c;
    if eid == 0u32 { eid = enum_of_ty(pp, src, m.head, tn); }
    if eid == 0u32 { m.*.err = 1; return 1; }
    let vname: Node = pp.nodes[conv usize nd.a];
    let idx: i32 = variant_index_by_name(pp, src, eid, vname.p0, vname.p1);
    if idx < 0 { m.*.err = 1; return 1; }
    let vid: u32 = variant_by_index(pp, eid, idx);
    let base_n: usize = m.dbuf_n;
    m.*.dbuf_n = base_n;
    dbuf_field_scalar(m, 0usize, 9);
    set_o1(m, 0, conv u64 idx, 0, 9);
    emit_store_dbuf(m, root, nd.p0, nd.p1);
    let mut argc: u32 = nd.b;
    let mut i: i32 = 0;
    while argc != 0u32 {
        let pty: u32 = variant_payload_ty(pp, vid, i);
        let off: usize = variant_payload_off(pp, src, m.head, vid, i);
        m.*.dbuf_n = base_n;
        dbuf_field(m, pp, src, off, pty);
        let sc: i32 = lower_into(pp, src, m, argc, root, pty);
        if sc != 0 { m.*.dbuf_n = base_n; return sc; }
        i = i + 1i32;
        argc = pp.nodes[conv usize argc].nx;
    }
    m.*.dbuf_n = base_n;
    return 0;
}
// One match arm: bind the variant's payload sub-patterns in a fresh drop-scope, lower
// the arm body, then drop the arm scope (build.rs lower_match_arm). A copy payload
// copies (scalar load / aggregate copyval); a non-copy payload of an owned scrutinee
// moves out (copyval + mark the scrutinee's `_i` path moved). `idx < 0` = default arm.
// The synthetic BoxResult variant index: boxed(Box T) = 0, oom = 1.
fn br_variant_index(src: [u8], p0: usize, p1: usize) -> i32 {
    if span_eq(src, p0, p1, b"boxed") { return 0; }
    if span_eq(src, p0, p1, b"oom") { return 1; }
    return 0 - 1i32;
}
// Render the boxed payload sub-place `(place <scrut> (proj ... (field 8 (box <inner>))))`.
fn render_scrut_boxfield(pp: read P, src: [u8], m: write M, scrut: u32, inner: u32) -> unit {
    let root: i32 = resolve_place_root(pp, src, m, scrut);
    if root < 0 { m.*.err = 1; }
    pool_lit(m, b"(place ");
    pool_num(m, conv u64 root);
    pool_lit(m, b" (proj");
    emit_projs(pp, src, m, scrut);
    pool_lit(m, b" (field 8 ");
    pool_ty_boxwrap(m, pp, src, inner);
    pool_lit(m, b")))");
    return;
}
// Bind the `boxed(bx)` payload: a move-bind of the Box (offset 8) into a fresh Box
// local, marking the scrutinee's `_0` path moved so its BoxResult drop is pruned.
fn bind_boxed_payload(pp: read P, src: [u8], m: write M, scrut: u32, eid: u32, spn: Node) -> unit {
    let inner: u32 = pp.nodes[conv usize eid].a;
    let loc: i32 = new_local_box(m, inner, 1, spn.p0, spn.p1);
    if m.reachable != 0 {
        let s: usize = m.pool_n;
        pool_lit(m, b"(stmt (copyval (place ");
        pool_num(m, conv u64 loc);
        pool_lit(m, b" (proj)) ");
        render_scrut_boxfield(pp, src, m, scrut, inner);
        pool_byte(m, 32);
        pool_ty_boxwrap(m, pp, src, inner);
        pool_lit(m, b") ");
        pool_num(m, conv u64 spn.p0);
        pool_byte(m, 32);
        pool_num(m, conv u64 spn.p1);
        pool_lit(m, b" false)");
        chunk_end(m, s);
    }
    mark_moved_payload(pp, src, m, scrut, 0);
    bind(m, spn.p0, spn.p1, loc, 0, inner);
    return;
}
fn lower_match_arm(pp: read P, src: [u8], m: write M, arm: u32, scrut: u32, eid: u32, idx: i32, is_br: i32, has_dst: i32, dst_root: i32, dst_tn: u32) -> i32 {
    let an: Node = pp.nodes[conv usize arm];
    let pat: Node = pp.nodes[conv usize an.a];
    scope_push(m);
    let bsave: usize = m.bnd_n;
    if idx >= 0 && pat.tag == T_PVARIANT {
        if is_br != 0 {
            // BoxResult::boxed(bx): the only bindable synthetic variant.
            if idx == 0 {
                let sp0: u32 = pat.b;
                if sp0 != 0u32 {
                    let spn: Node = pp.nodes[conv usize sp0];
                    if spn.tag != T_WILD {
                        bind_boxed_payload(pp, src, m, scrut, eid, spn);
                    }
                }
            }
        } else {
            let vid: u32 = variant_by_index(pp, eid, idx);
            let mut sp: u32 = pat.b;
            let mut i: i32 = 0;
            while sp != 0u32 {
                let spn: Node = pp.nodes[conv usize sp];
                if spn.tag == T_PVARIANT {
                    m.*.err = 1;
                    scope_pop_drops(pp, src, m);
                    m.*.bnd_n = bsave;
                    return 1;
                }
                if spn.tag != T_WILD {
                    let pty: u32 = variant_payload_ty(pp, vid, i);
                    let off: usize = variant_payload_off(pp, src, m.head, vid, i);
                    let w: i32 = scalar_width(pp, src, pty);
                    if is_copy(pp, src, m.head, pty) {
                        if w != 0 {
                            let loc: i32 = new_local(m, w, 1, spn.p0, spn.p1);
                            emit_payload_load(pp, src, m, loc, scrut, off, pty, spn.p0, spn.p1);
                            bind(m, spn.p0, spn.p1, loc, w, pty);
                        } else {
                            let loc: i32 = new_local_tn(m, pty, 1, spn.p0, spn.p1);
                            emit_payload_copyval(pp, src, m, loc, scrut, off, pty, spn.p0, spn.p1);
                            bind(m, spn.p0, spn.p1, loc, 0, pty);
                        }
                    } else {
                        let loc: i32 = new_local_tn(m, pty, 1, spn.p0, spn.p1);
                        emit_payload_copyval(pp, src, m, loc, scrut, off, pty, spn.p0, spn.p1);
                        mark_moved_payload(pp, src, m, scrut, i);
                        bind(m, spn.p0, spn.p1, loc, 0, pty);
                    }
                }
                i = i + 1i32;
                sp = spn.nx;
            }
        }
    }
    let mut sc: i32 = 0;
    if has_dst != 0 {
        sc = lower_into(pp, src, m, an.b, dst_root, dst_tn);
    } else {
        sc = lower_value(pp, src, m, an.b, 0 - 1i32);
    }
    scope_pop_drops(pp, src, m);
    m.*.bnd_n = bsave;
    return sc;
}
// T_MATCH in statement position (build.rs lower_match, dst=None). Read the tag once,
// then a per-arm test chain: a variant arm compares the tag and branches into its arm
// block (falling to the next test); a wildcard/binding arm is the unconditional tail.
// Each arm Gotos the shared join; a non-exhaustive tail faults (Panic), mirroring the
// oracle's "no matching arm". Block-creation order (join first, then arm/next per
// variant) and the Cmp/Branch shape match build.rs byte-for-byte.
fn lower_match_core(pp: read P, src: [u8], m: write M, i: u32) -> i32 {
    return lower_match_full(pp, src, m, i, 0, 0, 0u32);
}
fn lower_match_dst(pp: read P, src: [u8], m: write M, i: u32, root: i32, tn: u32) -> i32 {
    return lower_match_full(pp, src, m, i, 1, root, tn);
}
fn lower_match_full(pp: read P, src: [u8], m: write M, i: u32, has_dst: i32, dst_root: i32, dst_tn: u32) -> i32 {
    let nd: Node = pp.nodes[conv usize i];
    let scrut: u32 = nd.a;
    // Save the enclosing materialized-scrutinee context (nested matches).
    let save_on: i32 = m.vscrut_on;
    let save_node: u32 = m.vscrut_node;
    let save_root: i32 = m.vscrut_root;
    let save_tn: u32 = m.vscrut_tn;
    let save_borrow: i32 = m.vscrut_borrow;
    let midx: i32 = mat_lookup(m, scrut);
    let mut stn: u32 = 0u32;
    if midx >= 0 {
        let mk: usize = conv usize midx;
        stn = m.mat_tn[mk];
        let hold: i32 = m.mat_hold[mk];
        if hold != 0 {
            // Borrowed scrutinee (a call returning `read`/`write T`): the value is the
            // borrow address; match through a deref (build.rs Hold::Shared/Excl).
            let scb: i32 = lower_value(pp, src, m, scrut, 0);
            if scb != 0 { return scb; }
            m.*.vscrut_on = 1;
            m.*.vscrut_node = scrut;
            m.*.vscrut_root = conv i32 m.res_val;
            m.*.vscrut_tn = stn;
            m.*.vscrut_borrow = 1;
        } else {
            // Owned value scrutinee (`box(...)` or a call returning an owned aggregate):
            // materialize into a fresh (unscoped, build.rs) temp, match it in place.
            let temp: i32 = new_local_tn(m, stn, 0, 0, 0);
            m.*.dbuf_n = 0usize;
            let scm: i32 = lower_into(pp, src, m, scrut, temp, stn);
            if scm != 0 { return scm; }
            m.*.vscrut_on = 1;
            m.*.vscrut_node = scrut;
            m.*.vscrut_root = temp;
            m.*.vscrut_tn = stn;
            m.*.vscrut_borrow = 0;
        }
    } else {
        stn = resolve_place_tn(pp, src, m, scrut);
    }
    let stnode: Node = pp.nodes[conv usize stn];
    let mut is_br: i32 = 0;
    let mut eid: u32 = 0u32;
    if stnode.tag == T_BOXRESULT {
        is_br = 1;
        eid = stn;
    } else {
        eid = enum_of_ty(pp, src, m.head, stn);
        if eid == 0u32 { m.*.err = 1; return 1; }
    }
    let tagloc: i32 = new_local(m, 9, 0, 0, 0);
    if m.reachable != 0 {
        let s: usize = m.pool_n;
        pool_lit(m, b"(stmt (assign ");
        pool_num(m, conv u64 tagloc);
        pool_lit(m, b" (load ");
        render_place_field(pp, src, m, scrut, 0usize, 1, 9, 0u32);
        pool_byte(m, 32);
        pool_lit(m, b"(scalar u64)");
        pool_lit(m, b")) ");
        pool_num(m, conv u64 nd.p0);
        pool_byte(m, 32);
        pool_num(m, conv u64 nd.p1);
        pool_lit(m, b" false)");
        chunk_end(m, s);
    }
    let join: i32 = new_block(m);
    let mut test_open: i32 = 1;
    let mut arm: u32 = nd.b;
    while arm != 0u32 {
        if test_open == 0 { break; }
        let an: Node = pp.nodes[conv usize arm];
        let pat: Node = pp.nodes[conv usize an.a];
        if pat.tag == T_WILD || pat.tag == T_BIND {
            let sc: i32 = lower_match_arm(pp, src, m, arm, scrut, eid, 0 - 1i32, is_br, has_dst, dst_root, dst_tn);
            if sc != 0 { return sc; }
            if m.reachable != 0 { term_goto(m, join); }
            test_open = 0;
        } else {
            let vname: Node = pp.nodes[conv usize pat.a];
            let mut vidx: i32 = 0;
            if is_br != 0 { vidx = br_variant_index(src, vname.p0, vname.p1); }
            else { vidx = variant_index_by_name(pp, src, eid, vname.p0, vname.p1); }
            if vidx < 0 { m.*.err = 1; return 1; }
            let cmploc: i32 = new_local(m, W_BOOL, 0, 0, 0);
            set_o1(m, 1, conv u64 tagloc, 0, 9);
            set_o2(m, 0, conv u64 vidx, 0, 9);
            st_assign_cmp(m, cmploc, OP_EQ, nd.p0, nd.p1);
            let arm_bb: i32 = new_block(m);
            let next_bb: i32 = new_block(m);
            set_o1(m, 1, conv u64 cmploc, 0, W_BOOL);
            term_branch(m, arm_bb, next_bb);
            switch_to(m, arm_bb);
            let sc2: i32 = lower_match_arm(pp, src, m, arm, scrut, eid, vidx, is_br, has_dst, dst_root, dst_tn);
            if sc2 != 0 { return sc2; }
            if m.reachable != 0 { term_goto(m, join); }
            switch_to(m, next_bb);
        }
        arm = an.nx;
    }
    if test_open != 0 {
        term_fault(m, FK_PANIC, nd.p0, nd.p1);
    }
    switch_to(m, join);
    m.*.vscrut_on = save_on;
    m.*.vscrut_node = save_node;
    m.*.vscrut_root = save_root;
    m.*.vscrut_tn = save_tn;
    m.*.vscrut_borrow = save_borrow;
    return 0;
}

// ---- non-place match scrutinee: synthetic type nodes (build.rs lower_scrutinee) --
// Append a freshly built node to the parse arena and return its index.
fn add_node(pp: write P, nd: Node) -> u32 {
    let idx: u32 = pp.n;
    pp.*.nodes[conv usize idx] = nd;
    pp.*.n = pp.n + 1u32;
    return idx;
}
fn is_ident_char(b: u8) -> bool {
    if b >= 97u8 && b <= 122u8 { return true; }
    if b >= 65u8 && b <= 90u8 { return true; }
    if b >= 48u8 && b <= 57u8 { return true; }
    if b == 95u8 { return true; }
    return false;
}
fn match_at(src: [u8], i: usize, kw: [u8]) -> bool {
    let k: usize = len(kw);
    let mut j: usize = 0usize;
    while j < k {
        if src[i + j] != kw[j] { return false; }
        j = j + 1usize;
    }
    return true;
}
// Find a whole-token occurrence of `kw` in `src`; returns its start or len(src).
fn find_tok(src: [u8], kw: [u8]) -> usize {
    let n: usize = len(src);
    let k: usize = len(kw);
    if k == 0usize { return n; }
    let mut i: usize = 0usize;
    while i + k <= n {
        if match_at(src, i, kw) {
            let mut before_ok: bool = true;
            if i > 0usize { before_ok = !is_ident_char(src[i - 1usize]); }
            let mut after_ok: bool = true;
            if i + k < n { after_ok = !is_ident_char(src[i + k]); }
            if before_ok && after_ok { return i; }
        }
        i = i + 1usize;
    }
    return n;
}
// A synthetic scalar type node (T_SC) for width `w`; spans the keyword in `src`.
fn synth_scalar(pp: write P, src: [u8], m: write M, w: i32) -> u32 {
    let n: usize = len(src);
    let mut s: usize = n;
    let mut e: usize = n;
    if w == 4 { s = find_tok(src, b"i64"); e = s + 3usize; }
    else if w == 3 { s = find_tok(src, b"i32"); e = s + 3usize; }
    else if w == 8 { s = find_tok(src, b"u32"); e = s + 3usize; }
    else if w == 6 { s = find_tok(src, b"u8"); e = s + 2usize; }
    else if w == 9 { s = find_tok(src, b"u64"); e = s + 3usize; }
    else if w == 10 { s = find_tok(src, b"usize"); e = s + 5usize; }
    else { m.*.err = 1; return 0u32; }
    if s >= n { m.*.err = 1; return 0u32; }
    let mut nd: Node = nnew(T_SC);
    nd.p0 = s;
    nd.p1 = e;
    return add_node(pp, nd);
}
fn add_str(pp: write P) -> u32 {
    let nd: Node = nnew(T_STR);
    return add_node(pp, nd);
}
fn add_named(pp: write P, p0: usize, p1: usize) -> u32 {
    let mut nd: Node = nnew(T_NAMED);
    nd.p0 = p0;
    nd.p1 = p1;
    return add_node(pp, nd);
}
fn add_array(pp: write P, size: u32, elem: u32) -> u32 {
    let mut nd: Node = nnew(T_ARRAY);
    nd.a = size;
    nd.b = elem;
    return add_node(pp, nd);
}
fn add_boxresult(pp: write P, inner: u32) -> u32 {
    let mut nd: Node = nnew(T_BOXRESULT);
    nd.a = inner;
    return add_node(pp, nd);
}
// A synthetic borrow type node wrapping `pointee` (build.rs Borrow / BorrowMut).
fn add_borrow(pp: write P, pointee: u32, excl: i32) -> u32 {
    let mut tag: i32 = T_BORROW;
    if excl != 0 { tag = T_BORROWMUT; }
    let mut nd: Node = nnew(tag);
    nd.a = pointee;
    return add_node(pp, nd);
}
fn bret_lookup(m: write M, fnid: u32) -> i32 {
    let mut k: usize = 0usize;
    while k < m.bret_n {
        if m.bret_fn[k] == fnid { return conv i32 k; }
        k = k + 1usize;
    }
    return 0 - 1i32;
}
// The type node of a box(...) value argument (build.rs infer_ty over the subset).
fn synth_ty_for_value(pp: write P, src: [u8], m: write M, e: u32) -> u32 {
    let nd: Node = pp.nodes[conv usize e];
    if nd.tag == T_PAREN { return synth_ty_for_value(pp, src, m, nd.a); }
    if nd.tag == T_INT { return synth_scalar(pp, src, m, lit_width(nd.suf, 4)); }
    if nd.tag == T_NEGINT { return synth_scalar(pp, src, m, lit_width(nd.suf, 4)); }
    if nd.tag == T_ARRAYREP {
        let elem: u32 = synth_ty_for_value(pp, src, m, nd.a);
        return add_array(pp, nd.b, elem);
    }
    if nd.tag == T_ENUMCTOR { return add_named(pp, nd.p0, nd.p1); }
    if nd.tag == T_STRUCTLIT { return add_named(pp, nd.p0, nd.p1); }
    m.*.err = 1;
    return 0u32;
}
// `write P` variants used by the pre-pass (a `write P` cannot reborrow as `read P`).
fn is_place_w(pp: write P, i: u32) -> bool {
    let nd: Node = pp.nodes[conv usize i];
    if nd.tag == T_PAREN { return is_place_w(pp, nd.a); }
    if nd.tag == T_ID || nd.tag == T_FIELD || nd.tag == T_INDEX { return true; }
    if nd.tag == T_PREFIX && nd.op == PF_DEREF { return true; }
    return false;
}
fn find_fn_w(pp: write P, src: [u8], head: u32, p0: usize, p1: usize) -> u32 {
    let mut cur: u32 = head;
    while cur != 0u32 {
        let nd: Node = pp.nodes[conv usize cur];
        if nd.tag == T_FN && name_eq(src, p0, p1, nd.p0, nd.p1) { return cur; }
        cur = nd.nx;
    }
    return 0u32;
}
// Record the materialized-scrutinee type for every non-place `match` scrutinee.
fn prep_synth(pp: write P, src: [u8], m: write M, head: u32) -> unit {
    m.*.str_tn = add_str(pp);
    let orig_n: u32 = pp.n;
    let mut i: u32 = 1u32;
    while i < orig_n {
        let nd: Node = pp.nodes[conv usize i];
        if nd.tag == T_MATCH {
            let scrut: u32 = nd.a;
            if !is_place_w(pp, scrut) {
                let cn: Node = pp.nodes[conv usize scrut];
                if cn.tag == T_CALL {
                    let callee: Node = pp.nodes[conv usize cn.a];
                    let mut stn: u32 = 0u32;
                    let mut hold: i32 = 0;
                    if span_eq(src, callee.p0, callee.p1, b"box") {
                        let a0: u32 = cn.b;
                        let a1: u32 = pp.nodes[conv usize a0].nx;
                        let inner: u32 = synth_ty_for_value(pp, src, m, a1);
                        stn = add_boxresult(pp, inner);
                    } else {
                        let fnid: u32 = find_fn_w(pp, src, head, callee.p0, callee.p1);
                        if fnid != 0u32 {
                            let fnnd: Node = pp.nodes[conv usize fnid];
                            if fnnd.e != 0u32 {
                                let rt: Node = pp.nodes[conv usize fnnd.e];
                                stn = rt.a;
                                hold = rt.op;
                            }
                        }
                    }
                    let k: usize = m.mat_n;
                    m.*.mat_scrut[k] = scrut;
                    m.*.mat_tn[k] = stn;
                    m.*.mat_hold[k] = hold;
                    m.*.mat_n = k + 1usize;
                }
            }
        }
        if nd.tag == T_FN && nd.e != 0u32 {
            let rt: Node = pp.nodes[conv usize nd.e];
            if rt.op == 1 || rt.op == 2 {
                let mut excl: i32 = 0;
                if rt.op == 2 { excl = 1; }
                let bn: u32 = add_borrow(pp, rt.a, excl);
                let bk: usize = m.bret_n;
                m.*.bret_fn[bk] = i;
                m.*.bret_tn[bk] = bn;
                m.*.bret_n = bk + 1usize;
            }
        }
        i = i + 1u32;
    }
    return;
}
// The recorded materialized type for scrut node `scrut`, or 0 if it is a place.
fn mat_lookup(m: write M, scrut: u32) -> i32 {
    let mut k: usize = 0usize;
    while k < m.mat_n {
        if m.mat_scrut[k] == scrut { return conv i32 k; }
        k = k + 1usize;
    }
    return 0 - 1i32;
}

pub fn lower_dump(src: [u8], buf: read Buf) -> unit {
    let mut p: P = P { nodes: [nnew(0); 49152], n: 1u32, pos: 0usize, no_struct: 0, dreg: 0u32, dtp: 0u32, mmode: 0, mreg: 0u32, mty: 0u32, uses: 0u32 };
    let head: u32 = parse_program(write p, src, buf);
    mono_program(write p, src, head);
    let mut m: M = M {
        head: head,
        loc_w: [0; 512],
        loc_named: [0; 512],
        loc_p0: [0usize; 512],
        loc_p1: [0usize; 512],
        loc_n: 0usize,
        blk_shead: [0; 512],
        blk_stail: [0; 512],
        blk_tstart: [0usize; 512],
        blk_tlen: [0usize; 512],
        blk_n: 0usize,
        pool: [0u8; 1048576],
        pool_n: 0usize,
        pn_start: [0usize; 8192],
        pn_len: [0usize; 8192],
        pn_nx: [0; 8192],
        pn_n: 0usize,
        bnd_p0: [0usize; 512],
        bnd_p1: [0usize; 512],
        bnd_local: [0; 512],
        bnd_w: [0; 512],
        bnd_n: 0usize,
        loop_cont: [0; 64],
        loop_brk: [0; 64],
        loop_n: 0usize,
        fp_p0: [0usize; 256],
        fp_p1: [0usize; 256],
        fp_n: 0usize,
        cur: 0,
        reachable: 1,
        regime: 0,
        ret_w: 4,
        fn_entry: 0,
        fn_np: 0,
        cur_p0: 0usize,
        cur_p1: 0usize,
        res_kind: 0,
        res_val: 0u64,
        res_neg: 0,
        res_w: 0,
        res_pointee: 0u32,
        res_israw: 0,
        plc_local: 0,
        plc_borrow: 0,
        plc_w: 0,
        luk_w: 0,
        o1k: 0,
        o1v: 0u64,
        o1n: 0,
        o1w: 0,
        o2k: 0,
        o2v: 0u64,
        o2n: 0,
        o2w: 0,
        loc_tn: [0u32; 512],
        loc_ptr: [0; 512],
        loc_box: [0; 512],
        bnd_tn: [0u32; 512],
        bnd_box: [0; 512],
        dbuf: [0u8; 4096],
        dbuf_n: 0usize,
        ret_tn: 0u32,
        plc_tn: 0u32,
        plc_box: 0,
        plc_base_kind: 0,
        plc_root_tmp: 0i32 - 1i32,
        plc_base_tn: 0u32,
        luk_tn: 0u32,
        luk_box: 0,
        str_tn: 0u32,
        mat_scrut: [0u32; 64],
        mat_tn: [0u32; 64],
        mat_hold: [0; 64],
        mat_n: 0usize,
        vscrut_on: 0,
        vscrut_node: 0u32,
        vscrut_root: 0,
        vscrut_tn: 0u32,
        vscrut_borrow: 0,
        idx_key: [0u32; 32],
        idx_vk: [0; 32],
        idx_vv: [0u64; 32],
        idx_vn: [0; 32],
        idx_vw: [0; 32],
        idx_cnt: 0usize,
        bret_fn: [0u32; 64],
        bret_tn: [0u32; 64],
        bret_n: 0usize,
        ak: [0; 16],
        av: [0u64; 16],
        an: [0; 16],
        aw: [0; 16],
        na: 0usize,
        sco_local: [0; 1024],
        sco_n: 0usize,
        sco_mark: [0usize; 128],
        sco_depth: 0usize,
        loop_depth: [0usize; 64],
        mv_local: [0; 512],
        mv_seg_start: [0usize; 512],
        mv_seg_count: [0usize; 512],
        mv_n: 0usize,
        mv_seg_p0: [0usize; 1024],
        mv_seg_p1: [0usize; 1024],
        mv_seg_syn: [0i32 - 1i32; 1024],
        mv_seg_n: 0usize,
        self_p0: 0usize,
        self_p1: 0usize,
        disp_sid: [0u32; 256],
        disp_p0: [0usize; 256],
        disp_p1: [0usize; 256],
        disp_fn: [0u32; 256],
        disp_impl: [0u32; 256],
        disp_n: 0usize,
        err: 0,
    };
    set_self_span(src, write m);
    prep_synth(write p, src, write m, head);
    build_dispatch(read p, src, write m);
    emit_lit(b"(mir (fns");
    // Drop-hook fns first (item order), then user fns -- matching build.rs.
    let mut ch: u32 = head;
    while ch != 0u32 {
        let cn: Node = p.nodes[conv usize ch];
        if cn.tag == T_STRUCT && cn.c != 0u32 && cn.a == 0u32 {
            reset_fn(write m);
            let _sh: i32 = lower_hook(read p, src, write m, ch);
            emit_byte(32);
            emit_fn(write m, read p, src, ch, 0u32, 1);
        }
        ch = cn.nx;
    }
    // Static-init fns next (item order), then user fns -- matching build.rs.
    let mut si: u32 = head;
    while si != 0u32 {
        let sn: Node = p.nodes[conv usize si];
        if sn.tag == T_STATIC {
            reset_fn(write m);
            let _ss: i32 = lower_static_init(read p, src, write m, si);
            emit_byte(32);
            emit_fn(write m, read p, src, si, 0u32, 2);
        }
        si = sn.nx;
    }
    let mut cur: u32 = head;
    while cur != 0u32 {
        let nd: Node = p.nodes[conv usize cur];
        if nd.tag == T_FN && nd.a == 0u32 {
            reset_fn(write m);
            let _sc: i32 = lower_fn(read p, src, write m, cur);
            emit_byte(32);
            emit_fn(write m, read p, src, cur, 0u32, 0);
        }
        cur = nd.nx;
    }
    // Impl-method fns: each concrete (a == 0) T_IMPL method lowers to a free fn
    // named `<impl Iface for Target>::method`, referenced by method-call Calls.
    let mut ic: u32 = head;
    while ic != 0u32 {
        let icn: Node = p.nodes[conv usize ic];
        if icn.tag == T_IMPL && icn.a == 0u32 {
            let mut mc: u32 = icn.d;
            while mc != 0u32 {
                let mcn: Node = p.nodes[conv usize mc];
                reset_fn(write m);
                let _ms: i32 = lower_fn(read p, src, write m, mc);
                emit_byte(32);
                emit_fn(write m, read p, src, mc, ic, 3);
                mc = mcn.nx;
            }
        }
        ic = icn.nx;
    }
    emit_lit(b") (drop_hooks");
    let mut dh: u32 = head;
    while dh != 0u32 {
        let dn: Node = p.nodes[conv usize dh];
        if dn.tag == T_STRUCT && dn.c != 0u32 && dn.a == 0u32 {
            emit_lit(b" (hook ");
            emit_qname(read p, src, dh);
            emit_byte(32);
            emit_hook_qname(read p, src, dh);
            emit_byte(41);
        }
        dh = dn.nx;
    }
    emit_lit(b") (fn_ptrs");
    let mut fp: u32 = head;
    while fp != 0u32 {
        let f2: Node = p.nodes[conv usize fp];
        if f2.tag == T_STRUCT && f2.c != 0u32 && f2.a == 0u32 {
            emit_byte(32);
            emit_hook_qname(read p, src, fp);
        } else if f2.tag == T_STATIC {
            emit_byte(32);
            emit_init_ref(src, f2.p0, f2.p1);
        } else if f2.tag == T_FN && f2.a == 0u32 {
            emit_byte(32);
            emit_qname(read p, src, fp);
        }
        fp = f2.nx;
    }
    emit_lit(b") (statics");
    let mut sc2: u32 = head;
    while sc2 != 0u32 {
        let scn: Node = p.nodes[conv usize sc2];
        if scn.tag == T_STATIC {
            emit_lit(b" (static ");
            emit_qspan(src, scn.p0, scn.p1);
            emit_byte(32);
            emit_ty(read p, src, scn.a);
            emit_byte(32);
            emit_init_ref(src, scn.p0, scn.p1);
            emit_byte(41);
        }
        sc2 = scn.nx;
    }
    emit_lit(b"))");
    emit_nl();
    return;
}
